msgstr "وحدة حرارية بريطانية أساسية"

#: Other_Calculators/templates/other_calculators/btu_calculator.html:1096
#: Other_Calculators/templates/other_calculators/btu_calculator.html:1115
msgid "Insulation Multiplier"
msgstr "مضاعف العزل"

#: Other_Calculators/templates/other_calculators/btu_calculator.html:1100
#: Other_Calculators/templates/other_calculators/btu_calculator.html:1119
msgid "Climate Multiplier"
msgstr "مضاعف المناخ"

#: Other_Calculators/templates/other_calculators/btu_calculator.html:1134
msgid "Window Load"
msgstr "تحميل النافذة"

#: Other_Calculators/templates/other_calculators/btu_calculator.html:1138
msgid "Occupant Load"
msgstr "تحميل الراكب"

#: Other_Calculators/templates/other_calculators/btu_calculator.html:1142
msgid "Appliance Load"
msgstr "تحميل الجهاز"

