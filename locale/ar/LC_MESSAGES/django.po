#: Financial_Calculators/templates/financial_calculators/401k_calculator.html:402
#, python-format
msgid "Year 1: Withdraw $40,000 (4%%)"
msgstr "السنة الأولى: سحب 40,000 دولار (4%)"

#: Financial_Calculators/templates/financial_calculators/401k_calculator.html:403
#, python-format
msgid "Year 2: Withdraw $40,800 (adjusted for 2%% inflation)"
msgstr ""
"السنة الثانية: سحب 40,800 دولار (تم تعديله ليتناسب مع التضخم بنسبة 2%)"

#: Financial_Calculators/templates/financial_calculators/401k_calculator.html:404
msgid "This strategy is designed to last 30 years"
msgstr "تم تصميم هذه الإستراتيجية لتدوم 30 عامًا"

#: Financial_Calculators/templates/financial_calculators/401k_calculator.html:407
#, python-format
msgid ""
"Note: The 4%% rule is a guideline, not a guarantee. Consult a financial "
"advisor for personalized advice."
msgstr ""
"ملحوظة: قاعدة 4%% هي دليل إرشادي وليست ضمانًا. استشر مستشارًا ماليًا للحصول "
"على مشورة شخصية."

