#: Other_Calculators/templates/other_calculators/btu_calculator.html:1045
msgid "Please enter a valid area greater than zero."
msgstr "الرجاء إدخال منطقة صالحة أكبر من الصفر."

#: Other_Calculators/templates/other_calculators/btu_calculator.html:1051
msgid "Please enter a valid value greater than zero."
msgstr "الرجاء إدخال قيمة صالحة أكبر من الصفر."

#: Other_Calculators/templates/other_calculators/btu_calculator.html:1074
msgid "Required for your room"
msgstr "مطلوب لغرفتك"

#: Other_Calculators/templates/other_calculators/btu_calculator.html:1092
