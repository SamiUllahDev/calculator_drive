#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:173
msgid "Tanaka"
msgstr "Tanaka"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:178
