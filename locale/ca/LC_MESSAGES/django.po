#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:144
msgid ""
"Enter your age and resting heart rate to see your target heart rate zones "
"for different training intensities."
msgstr ""
"Introduïu la vostra edat i la vostra freqüència cardíaca en repòs per veure "
"les vostres zones de freqüència cardíaca objectiu per a diferents "
"intensitats d'entrenament."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:154
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:358
msgid "Maximum Heart Rate"
