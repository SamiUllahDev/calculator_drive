msgstr "Bei Vorschwangerschaft leer lassen"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:169
msgid ""
"Enter your pre-pregnancy weight, height, and current pregnancy status to see"
" recommended weight gain ranges based on your BMI category."
msgstr ""
"Geben Sie Ihr Gewicht vor der Schwangerschaft, Ihre Größe und Ihren "
"aktuellen Schwangerschaftsstatus ein, um die empfohlenen "
"Gewichtszunahmebereiche basierend auf Ihrer BMI-Kategorie anzuzeigen."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:179
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:321
msgid "Weight Gain Status"
msgstr "Gewichtszunahmestatus"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:191
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:218
msgid "Current Gain"
msgstr "Aktueller Gewinn"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:197
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:222
msgid "Expected Gain"
msgstr "Erwarteter Gewinn"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:226
