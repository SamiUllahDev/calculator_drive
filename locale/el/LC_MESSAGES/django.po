msgstr "Μεταβολισμός & Θερμίδες"

#: Fitness_and_Health_Calculators/views/index.py:27
msgid "Calculate your Basal Metabolic Rate"
msgstr "Υπολογίστε τον Βασικό Μεταβολικό Ρυθμό σας"

#: Fitness_and_Health_Calculators/views/index.py:29
msgid "Calculate daily calorie needs for your goals"
msgstr "Υπολογίστε τις ημερήσιες ανάγκες σε θερμίδες για τους στόχους σας"

#: Fitness_and_Health_Calculators/views/index.py:30
msgid "Calculate calories burned during exercise"
msgstr "Υπολογίστε τις θερμίδες που καίγονται κατά τη διάρκεια της άσκησης"

#: Fitness_and_Health_Calculators/views/index.py:31
msgid "Calculate macronutrient distribution"
msgstr "Υπολογίστε την κατανομή μακροθρεπτικών συστατικών"

#: Fitness_and_Health_Calculators/views/index.py:34
#: Fitness_and_Health_Calculators/views/index.py:35
#: Fitness_and_Health_Calculators/views/index.py:36
#: Fitness_and_Health_Calculators/views/index.py:37
