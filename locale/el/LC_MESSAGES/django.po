msgid "Nutrition & Diet"
msgstr "Διατροφή & Διατροφή"

#: Fitness_and_Health_Calculators/views/index.py:34
msgid "Calculate daily carbohydrate intake"
msgstr "Υπολογίστε την ημερήσια πρόσληψη υδατανθράκων"

#: Fitness_and_Health_Calculators/views/index.py:35
msgid "Calculate recommended fat intake"
msgstr "Υπολογίστε τη συνιστώμενη πρόσληψη λίπους"

#: Fitness_and_Health_Calculators/views/index.py:36
msgid "Calculate protein needs based on weight and goals"
msgstr "Υπολογίστε τις ανάγκες σε πρωτεΐνη με βάση το βάρος και τους στόχους"

#: Fitness_and_Health_Calculators/views/index.py:37
msgid "Weight Watcher Points Calculator"
msgstr "Υπολογιστής πόντων παρακολούθησης βάρους"

#: Fitness_and_Health_Calculators/views/index.py:37
msgid "Calculate Weight Watchers points for foods"
msgstr "Υπολογίστε τους βαθμούς Weight Watchers για τα τρόφιμα"

#: Fitness_and_Health_Calculators/views/index.py:40
