#: Fitness_and_Health_Calculators/views/index.py:24
msgid "Determine if you are overweight and by how much"
msgstr "Προσδιορίστε εάν είστε υπέρβαροι και πόσο"

#: Fitness_and_Health_Calculators/views/index.py:27
#: Fitness_and_Health_Calculators/views/index.py:28
#: Fitness_and_Health_Calculators/views/index.py:29
