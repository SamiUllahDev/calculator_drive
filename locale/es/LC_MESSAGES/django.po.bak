#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:208
msgid "MDRD"
msgstr "MDRD"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:214
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:294
msgid "Stage"
msgstr "Escenario"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:222
msgid "eGFR Scale"
msgstr "Escala de TFGe"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:236
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:326
msgid "Stage 5"
msgstr "Etapa 5"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:237
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:321
msgid "Stage 4"
msgstr "Etapa 4"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:238
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:316
msgid "Stage 3b"
msgstr "Etapa 3b"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:239
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:311
msgid "Stage 3a"
msgstr "Etapa 3a"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:240
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:306
