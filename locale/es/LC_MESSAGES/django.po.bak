#: Other_Calculators/views/tire_size_calculator.py:559
#: Other_Calculators/views/tire_size_calculator.py:580
msgid "Tire Dimensions"
msgstr "Dimensiones de los neumáticos"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:213
msgid "Tire width in millimeters or inches"
msgstr "Ancho del neumático en milímetros o pulgadas."

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:214
#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:486
msgid "Aspect Ratio"
msgstr "Relación de aspecto"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:214
msgid "Sidewall height as percentage of width"
msgstr "Altura de la pared lateral como porcentaje del ancho"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:215
#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:490
msgid "Rim Diameter"
msgstr "Diámetro de la llanta"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:215
msgid "Wheel diameter in inches"
msgstr "Diámetro de la rueda en pulgadas"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:216
#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:226
#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:498
msgid "Overall Diameter"
msgstr "Diámetro total"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:216
msgid "Total tire diameter including sidewalls"
msgstr "Diámetro total del neumático, incluidos los flancos"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:217
msgid "Distance around the tire"
msgstr "Distancia alrededor del neumático"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:224
#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:494
msgid "Sidewall Height"
msgstr "Altura de la pared lateral"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:230
msgid "Revolutions per Mile"
msgstr "Revoluciones por milla"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:237
msgid ""
"When you change tire size, the speedometer reading may become inaccurate. "
"Larger tires make the speedometer read slower, while smaller tires make it "
"read faster."
msgstr ""
"Cuando cambia el tamaño de los neumáticos, la lectura del velocímetro puede "
"volverse inexacta. Los neumáticos más grandes hacen que el velocímetro "
"marque más lentamente, mientras que los neumáticos más pequeños hacen que la"
" lectura sea más rápida."

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:247
msgid "Tire size affects speedometer accuracy"
msgstr "El tamaño de los neumáticos afecta la precisión del velocímetro"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:248
msgid "Larger tires increase ground clearance"
msgstr "Los neumáticos más grandes aumentan la distancia al suelo"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:249
msgid "Wider tires improve traction but may rub"
msgstr "Los neumáticos más anchos mejoran la tracción pero pueden rozar"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:250
msgid "Check vehicle manufacturer recommendations"
msgstr "Consulta las recomendaciones del fabricante del vehículo."

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:251
msgid "Consider load rating and speed rating"
msgstr "Considere la clasificación de carga y la clasificación de velocidad"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:252
msgid "Aspect ratio affects ride comfort"
msgstr "La relación de aspecto afecta la comodidad de marcha"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:259
msgid "Tire replacement planning"
msgstr "Planificación de reemplazo de neumáticos"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:260
msgid "Wheel and tire upgrades"
msgstr "Actualizaciones de ruedas y neumáticos"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:261
msgid "Speedometer calibration"
msgstr "Calibración del velocímetro"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:262
msgid "Tire size comparison"
msgstr "Comparación de tamaños de neumáticos"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:263
msgid "Vehicle modification"
msgstr "Modificación del vehículo"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:368
msgid "Invalid format. Use metric (205/55R16) or imperial (31x10.5R15)"
msgstr ""
"Formato no válido. Utilice sistema métrico (205/55R16) o imperial "
"(31x10.5R15)"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:391
#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:406
msgid "Please enter a tire size"
msgstr "Por favor introduce un tamaño de neumático"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:421
#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:438
