#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/overweight_calculator.html:353
msgid "Select your preferred unit system (Metric or Imperial)"
msgstr "Seleccione su sistema de unidades preferido (métrico o imperial)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/anorexic_bmi_calculator.html:366
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:342
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/overweight_calculator.html:354
msgid "Enter your current height accurately"
msgstr "Ingrese su altura actual con precisión"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/anorexic_bmi_calculator.html:367
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:343
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:338
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/overweight_calculator.html:127
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/overweight_calculator.html:355
msgid "Enter your current weight"
msgstr "Introduce tu peso actual"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/anorexic_bmi_calculator.html:368
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:344
msgid "Click 'Calculate BMI' to see your results"
msgstr "Haga clic en 'Calcular IMC' para ver sus resultados"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/anorexic_bmi_calculator.html:369
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:345
msgid "Review the charts and detailed assessment"
msgstr "Revise los gráficos y la evaluación detallada."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/anorexic_bmi_calculator.html:370
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:346
msgid "Read the comprehensive guide below for interpretation"
msgstr "Lea la guía completa a continuación para obtener interpretación."

