#: Other_Calculators/templates/other_calculators/dice_roller.html:12
#: Other_Calculators/templates/other_calculators/dice_roller.html:26
msgid "Dice Roller - Roll Dice Online"
msgstr "Rodillo de dados - Tirar dados en línea"

#: Other_Calculators/templates/other_calculators/dice_roller.html:9
msgid ""
"Roll single or multiple dice online. Support for standard and custom dice "
"with statistics and visualizations."
msgstr ""
"Tira uno o varios dados en línea. Soporte para dados estándar y "
"personalizados con estadísticas y visualizaciones."

#: Other_Calculators/templates/other_calculators/dice_roller.html:13
