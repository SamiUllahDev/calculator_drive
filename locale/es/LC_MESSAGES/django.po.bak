#: Other_Calculators/views/time_duration_calculator.py:433
msgid "Step 3: Calculate duration (crosses midnight)"
msgstr "Paso 3: Calcular la duración (cruza la medianoche)"

#: Other_Calculators/views/time_calculator.py:460
#: Other_Calculators/views/time_duration_calculator.py:434
msgid "Duration = (86400 - Start) + End"
msgstr "Duración = (86400 - Inicio) + Fin"

#: Other_Calculators/views/time_calculator.py:461
#: Other_Calculators/views/time_duration_calculator.py:435
#, python-brace-format
msgid "Duration = (86400 - {start}) + {end} = {duration} seconds"
msgstr "Duración = (86400 - {start}) + {end} = {duration} segundos"

#: Other_Calculators/views/time_calculator.py:463
#: Other_Calculators/views/time_duration_calculator.py:437
