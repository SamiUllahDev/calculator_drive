msgstr "es primo"

#: Math_Calculators/templates/math_calculators/factor_calculator.html:487
#: venv/lib/python3.12/site-packages/django/forms/widgets.py:870
msgid "Yes"
msgstr "Sí"

#: Math_Calculators/templates/math_calculators/factor_calculator.html:488
