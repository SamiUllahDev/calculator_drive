msgstr "Tiempo = {result} horas"

#: Other_Calculators/views/hours_calculator.py:658
msgid "Step 1: Identify all time periods"
msgstr "Paso 1: identificar todos los períodos de tiempo"

#: Other_Calculators/views/hours_calculator.py:660
