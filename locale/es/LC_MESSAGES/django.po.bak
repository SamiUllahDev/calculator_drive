#: Math_Calculators/templates/math_calculators/prime_factorization_calculator.html:301
#: Math_Calculators/templates/math_calculators/prime_factorization_calculator.html:308
msgid "Prime Factorization"
msgstr "Factorización prima"

#: Math_Calculators/templates/math_calculators/factor_calculator.html:476
msgid ""
"Expression of the number as a product of prime numbers raised to their "
"powers"
msgstr ""
"Expresión del número como producto de números primos elevados a sus "
"potencias."

#: Math_Calculators/templates/math_calculators/factor_calculator.html:485
msgid "Example 1: Prime Number"
msgstr "Ejemplo 1: número primo"

#: Math_Calculators/templates/math_calculators/factor_calculator.html:487
#: Math_Calculators/templates/math_calculators/factor_calculator.html:494
#: Math_Calculators/templates/math_calculators/factor_calculator.html:501
