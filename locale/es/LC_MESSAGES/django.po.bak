msgstr "Multiplicador de tono = √(1 + (paso/12)²)"

#: Other_Calculators/views/roofing_calculator.py:524
#, python-brace-format
msgid "Pitch Multiplier = √(1 + ({pitch}/12)²)"
msgstr "Multiplicador de tono = √(1 + ({pitch}/12)²)"

#: Other_Calculators/views/roofing_calculator.py:525
#: Other_Calculators/views/roofing_calculator.py:550
#, python-brace-format
msgid "Pitch Multiplier = {mult}"
msgstr "Multiplicador de tono = {mult}"

#: Other_Calculators/views/roofing_calculator.py:527
