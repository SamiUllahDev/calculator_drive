msgstr "Todos los valores convertidos a miles de millones."

#: Other_Calculators/views/gdp_calculator.py:709
msgid "Step 3: Calculate net exports"
msgstr "Paso 3: Calcular las exportaciones netas"

#: Other_Calculators/views/gdp_calculator.py:710
msgid "Formula: Net Exports = Exports - Imports"
msgstr "Fórmula: Exportaciones Netas = Exportaciones - Importaciones"

#: Other_Calculators/views/gdp_calculator.py:711
#, python-brace-format
msgid "Net Exports = {x} - {m} = {nx} billions"
msgstr "Exportaciones netas = {x} - {m} = {nx} miles de millones"

#: Other_Calculators/views/gdp_calculator.py:713
msgid "Step 4: Apply the expenditure approach formula"
msgstr "Paso 4: Aplicar la fórmula del enfoque del gasto"

#: Other_Calculators/views/gdp_calculator.py:714
msgid "Formula: GDP = C + I + G + (X - M)"
msgstr "Fórmula: PIB = C + I + G + (X - M)"

#: Other_Calculators/views/gdp_calculator.py:715
#, python-brace-format
msgid "GDP = {c} + {i} + {g} + {nx}"
msgstr "PIB = {c} + {i} + {g} + {nx}"

#: Other_Calculators/views/gdp_calculator.py:716
#: Other_Calculators/views/gdp_calculator.py:723
#: Other_Calculators/views/gdp_calculator.py:742
#: Other_Calculators/views/gdp_calculator.py:749
#, python-brace-format
msgid "GDP = {gdp} billions"
msgstr "PIB = {gdp} miles de millones"

#: Other_Calculators/views/gdp_calculator.py:719
#: Other_Calculators/views/gravel_calculator.py:927
#: Other_Calculators/views/gravel_calculator.py:961
#: Other_Calculators/views/molarity_calculator.py:902
#: Other_Calculators/views/mulch_calculator.py:843
#: Other_Calculators/views/mulch_calculator.py:874
#: Other_Calculators/views/mulch_calculator.py:924
#: Other_Calculators/views/resistor_calculator.py:604
#: Other_Calculators/views/roofing_calculator.py:533
#: Other_Calculators/views/tile_calculator.py:448
msgid "Step 5: Convert to desired unit"
msgstr "Paso 5: Convertir a la unidad deseada"

#: Other_Calculators/views/gdp_calculator.py:720
#: Other_Calculators/views/gdp_calculator.py:746
#, python-brace-format
msgid "GDP = {gdp} {unit}"
msgstr "PIB = {gdp} {unit}"

#: Other_Calculators/views/gdp_calculator.py:722
#: Other_Calculators/views/gravel_calculator.py:930
#: Other_Calculators/views/gravel_calculator.py:964
#: Other_Calculators/views/molarity_calculator.py:905
#: Other_Calculators/views/mulch_calculator.py:846
#: Other_Calculators/views/mulch_calculator.py:877
#: Other_Calculators/views/mulch_calculator.py:927
#: Other_Calculators/views/roofing_calculator.py:536
#: Other_Calculators/views/tile_calculator.py:451
#: Other_Calculators/views/time_calculator.py:401
#: Other_Calculators/views/time_calculator.py:430
#: Other_Calculators/views/time_calculator.py:472
#: Other_Calculators/views/time_duration_calculator.py:447
#: Other_Calculators/views/time_duration_calculator.py:476
#: Other_Calculators/views/time_duration_calculator.py:513
msgid "Step 5: Result"
msgstr "Paso 5: Resultado"

#: Other_Calculators/views/gdp_calculator.py:730
#, python-brace-format
msgid "Wages (W): {val} {unit}"
msgstr "Salarios (W): {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:731
#, python-brace-format
msgid "Rent (R): {val} {unit}"
msgstr "Alquiler (R): {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:732
#, python-brace-format
msgid "Interest (I): {val} {unit}"
msgstr "Interés (I): {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:733
#, python-brace-format
msgid "Profit (P): {val} {unit}"
msgstr "Beneficio (P): {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:739
msgid "Step 3: Apply the income approach formula"
msgstr "Paso 3: Aplicar la fórmula del enfoque de ingresos"

#: Other_Calculators/views/gdp_calculator.py:740
msgid "Formula: GDP = W + R + I + P"
msgstr "Fórmula: PIB = W + R + I + P"

#: Other_Calculators/views/gdp_calculator.py:741
#, python-brace-format
msgid "GDP = {w} + {r} + {i} + {p}"
msgstr "PIB = {w} + {r} + {i} + {p}"

#: Other_Calculators/views/gdp_calculator.py:756
#, python-brace-format
msgid "Current GDP: {val} {unit}"
msgstr "PIB actual: {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:757
#, python-brace-format
msgid "Previous GDP: {val} {unit}"
msgstr "PIB anterior: {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:763
msgid "Step 3: Apply the growth rate formula"
msgstr "Paso 3: aplicar la fórmula de la tasa de crecimiento"

#: Other_Calculators/views/gdp_calculator.py:764
msgid "Formula: Growth Rate = ((Current - Previous) / Previous) × 100"
msgstr "Fórmula: Tasa de crecimiento = ((Actual - Anterior) / Anterior) × 100"

#: Other_Calculators/views/gdp_calculator.py:765
#, python-brace-format
msgid "Growth Rate = (({current} - {previous}) / {previous}) × 100"
msgstr "Tasa de crecimiento = (({current} - {previous}) / {previous}) × 100"

#: Other_Calculators/views/gdp_calculator.py:767
#, python-brace-format
msgid "Growth Rate = ({change} / {previous}) × 100"
msgstr "Tasa de crecimiento = ({change} / {previous}) × 100"

#: Other_Calculators/views/gdp_calculator.py:768
#, python-brace-format
msgid "Growth Rate = {rate}%"
msgstr "Tasa de crecimiento = {rate}%"

#: Other_Calculators/views/gdp_calculator.py:775
#, python-brace-format
msgid "GDP: {val} {unit}"
msgstr "PIB: {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:776
#, python-brace-format
msgid "Population: {val} {unit}"
msgstr "Población: {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:780
#, python-brace-format
msgid "GDP in billions: {val} billions"
msgstr "PIB en miles de millones: {val} miles de millones"

#: Other_Calculators/views/gdp_calculator.py:782
#, python-brace-format
msgid "Population in millions: {val} millions"
msgstr "Población en millones: {val} millones"

#: Other_Calculators/views/gdp_calculator.py:784
msgid "Step 3: Apply the per capita formula"
msgstr "Paso 3: aplicar la fórmula per cápita"

#: Other_Calculators/views/gdp_calculator.py:785
msgid "Formula: GDP per capita = (GDP × 1000) / Population"
msgstr "Fórmula: PIB per cápita = (PIB × 1000) / Población"

#: Other_Calculators/views/gdp_calculator.py:786
#, python-brace-format
msgid "GDP per capita = ({gdp} billions × 1000) / {pop} millions"
msgstr "PIB per cápita = ({gdp} miles de millones × 1000) / {pop} millones"

#: Other_Calculators/views/gdp_calculator.py:787
#, python-brace-format
msgid "GDP per capita = {result} (thousands per person)"
msgstr "PIB per cápita = {result} (miles por persona)"

#: Other_Calculators/views/gdp_calculator.py:794
#, python-brace-format
msgid "Nominal GDP: {val} {unit}"
msgstr "PIB nominal: {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:795
#, python-brace-format
msgid "Real GDP: {val} {unit}"
msgstr "PIB real: {val} {unit}"

#: Other_Calculators/views/gdp_calculator.py:801
msgid "Step 3: Apply the deflator formula"
msgstr "Paso 3: aplicar la fórmula del deflactor"

#: Other_Calculators/views/gdp_calculator.py:802
msgid "Formula: GDP Deflator = (Nominal GDP / Real GDP) × 100"
msgstr "Fórmula: Deflactor del PIB = (PIB nominal / PIB real) × 100"

#: Other_Calculators/views/gdp_calculator.py:803
#, python-brace-format
msgid "Deflator = ({nominal} / {real}) × 100"
msgstr "Deflactor = ({nominal} / {real}) × 100"

#: Other_Calculators/views/gdp_calculator.py:804
#, python-brace-format
msgid "GDP Deflator = {deflator}"
msgstr "Deflactor del PIB = {deflator}"

#: Other_Calculators/views/gdp_calculator.py:811
#, python-brace-format
msgid "GDP: {value} {unit}"
msgstr "PIB: {value} {unit}"

#: Other_Calculators/views/gdp_calculator.py:814
msgid "Step 2: Convert to billions"
msgstr "Paso 2: convertir a miles de millones"

#: Other_Calculators/views/gdp_calculator.py:816
msgid "Billions = Millions / 1000"
msgstr "Miles de millones = Millones / 1000"

#: Other_Calculators/views/gdp_calculator.py:817
#, python-brace-format
msgid "Billions = {val} / 1000 = {billions} billions"
msgstr "Billions = {val} / 1000 = {billions} billions"

#: Other_Calculators/views/gdp_calculator.py:819
msgid "Billions = Trillions × 1000"
msgstr "Miles de millones = Billones × 1000"

#: Other_Calculators/views/gdp_calculator.py:820
#, python-brace-format
msgid "Billions = {val} × 1000 = {billions} billions"
msgstr "Billions = {val} × 1000 = {billions} billions"

#: Other_Calculators/views/gdp_calculator.py:823
#, python-brace-format
msgid "Step 3: Convert from billions to {unit}"
msgstr "Paso 3: convertir de miles de millones a {unit}"

#: Other_Calculators/views/gdp_calculator.py:825
msgid "Millions = Billions × 1000"
msgstr "Millones = Miles de millones × 1000"

#: Other_Calculators/views/gdp_calculator.py:826
#, python-brace-format
msgid "Millions = {billions} × 1000 = {result} millions"
msgstr "Millions = {billions} × 1000 = {result} millions"

#: Other_Calculators/views/gdp_calculator.py:828
msgid "Trillions = Billions / 1000"
msgstr "Billones = Miles de millones / 1000"

#: Other_Calculators/views/gdp_calculator.py:829
#, python-brace-format
msgid "Trillions = {billions} / 1000 = {result} trillions"
msgstr "Trillones = {billions} / 1000 = {result} billones"

#: Other_Calculators/views/gdp_calculator.py:832
#, python-brace-format
msgid "GDP = {result} billions"
msgstr "PIB = {result} miles de millones"

