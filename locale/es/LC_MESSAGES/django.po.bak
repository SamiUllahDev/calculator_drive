#: user/management/commands/create_test_notifications.py:28
msgid ""
"Thanks for joining our platform. Explore our tools and boost your SEO "
"strategy."
msgstr ""
"Gracias por unirte a nuestra plataforma. Explora nuestras herramientas e "
"impulsa tu estrategia SEO."

#: user/management/commands/create_test_notifications.py:32
msgid "Profile Updated"
msgstr "Perfil actualizado"

#: user/management/commands/create_test_notifications.py:33
msgid "Your profile information has been successfully updated."
msgstr "La información de su perfil se ha actualizado correctamente."

#: user/management/commands/create_test_notifications.py:37
msgid "Subscription Expiring"
msgstr "Suscripción vencida"

#: user/management/commands/create_test_notifications.py:38
msgid ""
"Your premium subscription will expire in 7 days. Renew now to avoid "
"interruption."
msgstr ""
"Su suscripción premium caducará en 7 días. Renovar ahora para evitar "
"interrupciones."

#: user/management/commands/create_test_notifications.py:42
msgid "Backlink Report Complete"
msgstr "Informe de vínculo de retroceso completo"

#: user/management/commands/create_test_notifications.py:43
msgid "Your backlink analysis report is now ready to view."
msgstr ""
"Su informe de análisis de vínculos de retroceso ya está listo para ser "
"visto."

#: user/management/commands/create_test_notifications.py:48
msgid "Security Alert"
msgstr "Alerta de seguridad"

#: user/management/commands/create_test_notifications.py:49
msgid ""
"We detected an unusual login attempt on your account. Please verify it was "
"you."
msgstr ""
"Detectamos un intento de inicio de sesión inusual en su cuenta. Por favor "
"verifica que fuiste tú."

#: user/management/commands/create_test_notifications.py:53
msgid "New Feature Available"
msgstr "Nueva característica disponible"

#: user/management/commands/create_test_notifications.py:54
msgid "Try our new Keyword Research tool with AI suggestions."
msgstr ""
"Pruebe nuestra nueva herramienta de investigación de palabras clave con "
"sugerencias de IA."

#: user/management/commands/create_test_notifications.py:59
msgid "Saved Report Ready"
msgstr "Informe guardado listo"

#: user/management/commands/create_test_notifications.py:60
msgid "The SEO report you requested for example.com is now available."
msgstr "El informe SEO que solicitaste para ejemplo.com ya está disponible."

#: user/management/commands/create_test_notifications.py:64
msgid "Complete Your Profile"
msgstr "Completa tu perfil"

#: user/management/commands/create_test_notifications.py:65
msgid ""
"Add your social media links to complete your profile and improve networking."
msgstr ""
"Agregue sus enlaces de redes sociales para completar su perfil y mejorar la "
"creación de redes."

#: user/middleware.py:54 user/middleware.py:62 user/middleware.py:82
msgid "Email Verification Required"
msgstr "Se requiere verificación de correo electrónico"

#: user/middleware.py:63
msgid ""
"Please verify your email address to access all features. Check your inbox or"
" spam folder for the verification email."
msgstr ""
"Verifique su dirección de correo electrónico para acceder a todas las "
"funciones. Revise su bandeja de entrada o carpeta de spam para ver el correo"
" electrónico de verificación."

#: user/middleware.py:73 user/views.py:60
msgid ""
"You need to verify your email address before accessing your profile. Please "
"check your inbox or spam folder for the verification email."
msgstr ""
"Debe verificar su dirección de correo electrónico antes de acceder a su "
"perfil. Por favor revise su bandeja de entrada o carpeta de spam para ver el"
" correo electrónico de verificación."

