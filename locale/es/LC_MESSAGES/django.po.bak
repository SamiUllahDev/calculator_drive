msgstr "Somos"

#: Math_Calculators/templates/math_calculators/confidence_interval_calculator.html:693
msgid "confident that the true population"
msgstr "confiado en que la verdadera población"

#: Math_Calculators/templates/math_calculators/confidence_interval_calculator.html:693
msgid "mean"
msgstr "significar"

#: Math_Calculators/templates/math_calculators/confidence_interval_calculator.html:693
msgid "proportion"
msgstr "proporción"

#: Math_Calculators/templates/math_calculators/confidence_interval_calculator.html:693
