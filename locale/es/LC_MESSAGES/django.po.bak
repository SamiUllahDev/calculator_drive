#: Other_Calculators/views/roofing_calculator.py:529
#: Other_Calculators/views/roofing_calculator.py:554
#, python-brace-format
msgid "Area = {length} m × {width} m × {mult}"
msgstr "Área = {length} m × {width} m × {mult}"

