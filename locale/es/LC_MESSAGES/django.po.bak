msgid "mo"
msgstr "mes"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:634
msgid "interest"
msgstr "interés"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:713
