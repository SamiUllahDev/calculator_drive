msgstr "Caracteres especiales"

#: Other_Calculators/templates/other_calculators/password_generator.html:369
#: Other_Calculators/templates/other_calculators/password_generator.html:488
msgid "Feedback"
msgstr "Comentario"

#: Other_Calculators/templates/other_calculators/password_generator.html:386
