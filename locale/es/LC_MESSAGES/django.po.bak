#: Other_Calculators/templates/other_calculators/gpa_calculator.html:350
msgid "Grade improvement tracking"
msgstr "Seguimiento de mejora de calificaciones"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:351
msgid "Honor roll and Dean's List eligibility"
msgstr "Cuadro de honor y elegibilidad para la lista del decano"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:376
msgid "Course Name"
msgstr "Nombre del curso"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:432
msgid "Course"
msgstr "Curso"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:440
msgid "Please add at least one valid course."
msgstr "Por favor agregue al menos un curso válido."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:502
