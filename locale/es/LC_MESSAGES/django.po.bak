msgstr "Conversiones de unidades de tiempo para estándares internacionales"

#: Other_Calculators/templates/other_calculators/hours_calculator.html:519
msgid "Please add at least one time period."
msgstr "Agregue al menos un período de tiempo."

#: Other_Calculators/templates/other_calculators/hours_calculator.html:597
