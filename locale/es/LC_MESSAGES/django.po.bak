#: Other_Calculators/views/shoe_size_conversion.py:50
msgid "Size is required."
msgstr "Se requiere tamaño."

#: Other_Calculators/views/shoe_size_conversion.py:56
msgid "Source size system is required."
msgstr "Se requiere un sistema de tamaño de fuente."

#: Other_Calculators/views/shoe_size_conversion.py:62
