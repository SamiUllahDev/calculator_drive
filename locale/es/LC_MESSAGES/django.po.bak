msgstr "%% de grasa corporal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:108
#, python-format
msgid "Enter your body fat percentage (0-50%%)"
msgstr "Ingrese su porcentaje de grasa corporal (0-50%%)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:152
msgid ""
"Enter your body weight and body fat percentage, then click Calculate to see "
"your lean body mass breakdown with detailed charts and protein "
"recommendations."
msgstr ""
"Ingrese su peso corporal y porcentaje de grasa corporal, luego haga clic en "
"Calcular para ver el desglose de su masa corporal magra con gráficos "
"detallados y recomendaciones de proteínas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:162
msgid "Your Lean Body Mass"
msgstr "Tu masa corporal magra"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:182
#: Other_Calculators/templates/other_calculators/grade_calculator.html:626
