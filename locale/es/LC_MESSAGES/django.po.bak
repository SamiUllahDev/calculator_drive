msgstr "Máximo divisor común de los dos denominadores"

#: Math_Calculators/templates/math_calculators/greatest_common_factor_calculator.html:4
#: Math_Calculators/templates/math_calculators/greatest_common_factor_calculator.html:8
msgid "GCD & LCM Calculator - Greatest Common Factor & Least Common Multiple"
msgstr "Calculadora MCD y MCM: máximo común divisor y mínimo común múltiplo"

#: Math_Calculators/templates/math_calculators/greatest_common_factor_calculator.html:5
msgid ""
"Free GCD and LCM calculator to calculate Greatest Common Factor (GCF) and "
"Least Common Multiple (LCM) of multiple numbers. Find GCD and LCM with step-"
"by-step solutions. Perfect for math homework."
msgstr ""
"Calculadora gratuita de MCD y MCM para calcular el máximo común divisor "
"(MCD) y el mínimo común múltiplo (MCM) de varios números. Encuentre GCD y "
"LCM con soluciones paso a paso. Perfecto para los deberes de matemáticas."

