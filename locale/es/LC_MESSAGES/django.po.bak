#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/weight_watcher_points_calculator.html:5
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/weight_watcher_points_calculator.html:14
msgid "Calculate SmartPoints"
msgstr "Calcular puntos inteligentes"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/weight_watcher_points_calculator.html:7
msgid ""
"Calculate Weight Watchers SmartPoints for foods based on calories, saturated"
" fat, sugar, and protein."
msgstr ""
"Calcule los SmartPoints de Weight Watchers para alimentos en función de "
"calorías, grasas saturadas, azúcar y proteínas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/weight_watcher_points_calculator.html:10
msgid ""
"weight watchers points calculator, smartpoints calculator, WW points, weight"
" watchers calculator"
msgstr ""
"Calculadora de puntos de Weight Watchers, calculadora de puntos "
"inteligentes, puntos WW, calculadora de Weight Watchers"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/weight_watcher_points_calculator.html:15
msgid "Calculate Weight Watchers SmartPoints for foods."
msgstr "Calcule los SmartPoints de Weight Watchers para alimentos."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/weight_watcher_points_calculator.html:24
msgid "Calculate Weight Watchers SmartPoints"
msgstr "Calcular los SmartPoints de Weight Watchers"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/weight_watcher_points_calculator.html:51
msgid ""
"Calculate Weight Watchers SmartPoints for foods based on calories, saturated"
" fat, sugar, and protein content."
msgstr ""
"Calcule los SmartPoints de Weight Watchers para alimentos en función del "
"contenido de calorías, grasas saturadas, azúcar y proteínas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/weight_watcher_points_calculator.html:65
