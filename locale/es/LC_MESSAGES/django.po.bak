msgstr "Período {num}: {start} al {end} = {hours} horas"

#: Other_Calculators/views/hours_calculator.py:664
msgid "Step 2: Calculate total hours"
msgstr "Paso 2: Calcular el total de horas"

#: Other_Calculators/views/hours_calculator.py:666
