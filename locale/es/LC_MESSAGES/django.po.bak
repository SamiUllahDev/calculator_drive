msgstr "y"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:907
#: Other_Calculators/views/dew_point_calculator.py:193
#: Other_Calculators/views/dew_point_calculator.py:452
#: Other_Calculators/views/heat_index_calculator.py:95
#: Other_Calculators/views/heat_index_calculator.py:242
msgid "Relative humidity is required."
msgstr "Se requiere humedad relativa."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:925
