msgstr "Se requiere área."

#: Other_Calculators/views/tile_calculator.py:110
#: Other_Calculators/views/tile_calculator.py:211
#: Other_Calculators/views/tile_calculator.py:297
msgid "Tile length is required."
msgstr "Se requiere la longitud del azulejo."

#: Other_Calculators/views/tile_calculator.py:116
#: Other_Calculators/views/tile_calculator.py:217
#: Other_Calculators/views/tile_calculator.py:303
