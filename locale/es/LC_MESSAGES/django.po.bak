msgstr "Por favor ingrese el costo total y el costo por unidad"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:617
msgid "Please enter a distance value"
msgstr "Por favor ingresa un valor de distancia"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:628
