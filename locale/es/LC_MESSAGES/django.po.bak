msgstr "Duración = Fin - Inicio"

#: Other_Calculators/views/time_calculator.py:465
#: Other_Calculators/views/time_duration_calculator.py:439
#, python-brace-format
msgid "Duration = {end} - {start} = {duration} seconds"
msgstr "Duración = {end} - {start} = {duration} segundos"

#: Other_Calculators/views/time_calculator.py:468
#, python-brace-format
msgid "Hours = {duration} ÷ 3600 = {hours}"
msgstr "Horas = {duration} ÷ 3600 = {hours}"

#: Other_Calculators/views/time_calculator.py:469
#, python-brace-format
msgid "Minutes = ({duration} % 3600) ÷ 60 = {minutes}"
msgstr "Minutos = ({duration} % 3600) ÷ 60 = {minutes}"

#: Other_Calculators/views/time_calculator.py:470
#, python-brace-format
msgid "Seconds = {duration} % 60 = {seconds}"
msgstr "Segundos = {duration} % 60 = {seconds}"

#: Other_Calculators/views/time_calculator.py:473
#, python-brace-format
msgid "Duration = {result}"
msgstr "Duración = {result}"

