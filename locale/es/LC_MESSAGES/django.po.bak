#: Other_Calculators/views/golf_handicap_calculator.py:83
msgid "Score differentials are required as a list."
msgstr "Las diferencias de puntuación se requieren como una lista."

#: Other_Calculators/views/golf_handicap_calculator.py:91
msgid "At least one score differential is required."
msgstr "Se requiere al menos un diferencial de puntuación."

#: Other_Calculators/views/golf_handicap_calculator.py:97
msgid "Maximum 20 score differentials allowed."
msgstr "Se permiten un máximo de 20 diferencias de puntuación."

#: Other_Calculators/views/golf_handicap_calculator.py:113
#, python-brace-format
msgid "Score differential {num} is out of range (0-200)."
msgstr "El diferencial de puntuación {num} está fuera del rango (0-200)."

#: Other_Calculators/views/golf_handicap_calculator.py:181
#, python-brace-format
msgid "Error calculating handicap index: {error}"
msgstr "Error al calcular el índice de handicap: {error}"

#: Other_Calculators/views/golf_handicap_calculator.py:190
