msgstr "Peso Total"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:194
#, python-format
msgid "LBM %%"
msgstr "%%"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:221
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/macro_calculator.html:273
msgid "Percentage Comparison"
msgstr "Comparación porcentual"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:235
