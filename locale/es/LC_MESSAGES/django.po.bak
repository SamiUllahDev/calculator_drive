#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:177
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:570
msgid "Mosteller"
msgstr "Mosteller"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:183
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:571
msgid "Haycock"
msgstr "Montón de heno"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:189
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:572
msgid "Gehan & George"
msgstr "Gehan y George"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:203
msgid "BSA Formulas Comparison"
msgstr "Comparación de fórmulas BSA"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:216
msgid "BSA Range"
msgstr "Gama BSA"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:226
msgid "BSA by Formula"
msgstr "BSA por fórmula"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:231
#: Math_Calculators/templates/math_calculators/number_sequence_calculator.html:303
#: Math_Calculators/templates/math_calculators/number_sequence_calculator.html:309
#: Other_Calculators/templates/other_calculators/stair_calculator.html:225
#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:239
msgid "Formula"
msgstr "Fórmula"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:232
msgid "BSA (m²)"
msgstr "superficie habitable (m²)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:233
#: google_adsense/models.py:142
msgid "Notes"
msgstr "Notas"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:256
msgid "What is Body Surface Area (BSA)?"
msgstr "¿Qué es el área de superficie corporal (BSA)?"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:258
msgid ""
"Body Surface Area (BSA) is the total surface area of the human body. It's "
"measured in square meters (m²) and is used in various medical applications, "
"particularly for calculating drug dosages, determining cardiac index, and "
"assessing metabolic rate."
msgstr ""
"El área de superficie corporal (BSA) es la superficie total del cuerpo "
"humano. Se mide en metros cuadrados (m²) y se utiliza en diversas "
"aplicaciones médicas, particularmente para calcular dosis de medicamentos, "
"determinar el índice cardíaco y evaluar la tasa metabólica."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:261
msgid ""
"BSA provides a more accurate measure than body weight alone for many medical"
" calculations, as it accounts for both height and weight, giving a better "
"representation of body size."
msgstr ""
"BSA proporciona una medida más precisa que el peso corporal solo para muchos"
" cálculos médicos, ya que tiene en cuenta tanto la altura como el peso, lo "
"que proporciona una mejor representación del tamaño corporal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:267
msgid "BSA Calculation Formulas"
msgstr "Fórmulas de cálculo de BSA"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:270
msgid "Du Bois Formula (1916)"
msgstr "Fórmula Du Bois (1916)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:272
msgid ""
"One of the oldest and most widely used formulas. Considered the gold "
"standard."
msgstr ""
"Una de las fórmulas más antiguas y utilizadas. Considerado el patrón oro."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:275
msgid "BSA = 0.007184 × weight^0.425 × height^0.725"
msgstr "BSA = 0,007184 × peso^0,425 × altura^0,725"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:278
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:302
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:314
msgid "Where weight is in kg and height is in cm"
msgstr "Donde el peso está en kg y la altura en cm"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:282
msgid "Mosteller Formula (1987)"
msgstr "Fórmula Mosteller (1987)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:284
msgid ""
"Simplified formula, easy to remember and calculate. Commonly used in "
"clinical practice."
msgstr ""
"Fórmula simplificada, fácil de recordar y calcular. De uso común en la "
"práctica clínica."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:287
msgid "BSA = √((height × weight) / 3600)"
msgstr "BSA = √((altura × peso) / 3600)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:290
msgid "Where height is in cm and weight is in kg"
msgstr "Donde la altura está en cm y el peso en kg"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:294
msgid "Haycock Formula (1978)"
msgstr "Fórmula Haycock (1978)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:296
msgid ""
"Developed specifically for pediatric populations but also accurate for "
"adults."
msgstr ""
"Desarrollado específicamente para poblaciones pediátricas pero también "
"preciso para adultos."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:299
msgid "BSA = 0.024265 × weight^0.5378 × height^0.3964"
msgstr "BSA = 0,024265 × peso^0,5378 × altura^0,3964"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:306
msgid "Gehan & George Formula (1970)"
msgstr "Fórmula de Gehan y George (1970)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:308
msgid ""
"Another commonly used formula, particularly in oncology and chemotherapy "
"dosing."
msgstr ""
"Otra fórmula de uso común, particularmente en oncología y dosificación de "
"quimioterapia."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:311
msgid "BSA = 0.0235 × weight^0.51456 × height^0.42246"
msgstr "BSA = 0,0235 × peso^0,51456 × altura^0,42246"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:322
msgid "Medical Applications of BSA"
msgstr "Aplicaciones médicas de BSA"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:324
msgid "Drug Dosage Calculation:"
msgstr "Cálculo de dosis de medicamento:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:324
msgid ""
"Many medications, especially chemotherapy drugs, are dosed based on BSA "
"rather than body weight to ensure appropriate drug levels."
msgstr ""
"Muchos medicamentos, especialmente los de quimioterapia, se dosifican según "
"el BSA en lugar del peso corporal para garantizar los niveles adecuados del "
"fármaco."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:325
msgid "Cardiac Index:"
msgstr "Índice cardíaco:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:325
msgid ""
"BSA is used to calculate cardiac index (cardiac output divided by BSA), "
"which helps assess heart function."
msgstr ""
"BSA se utiliza para calcular el índice cardíaco (gasto cardíaco dividido por"
" BSA), lo que ayuda a evaluar la función cardíaca."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:326
msgid "Renal Function:"
msgstr "Función renal:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:326
msgid ""
"Glomerular filtration rate (GFR) is often normalized to BSA for more "
"accurate assessment of kidney function."
msgstr ""
"La tasa de filtración glomerular (TFG) a menudo se normaliza con respecto a "
"BSA para una evaluación más precisa de la función renal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:327
msgid "Metabolic Rate:"
msgstr "Tasa metabólica:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:327
msgid ""
"BSA correlates with metabolic rate and is used in some metabolic "
"calculations."
msgstr ""
"BSA se correlaciona con la tasa metabólica y se utiliza en algunos cálculos "
"metabólicos."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:328
msgid "Fluid Requirements:"
msgstr "Requisitos de fluidos:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:328
msgid ""
"Some fluid replacement calculations use BSA to determine appropriate "
"volumes."
msgstr ""
"Algunos cálculos de reemplazo de líquidos utilizan BSA para determinar los "
"volúmenes apropiados."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:337
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:356
msgid "Enter your height accurately"
msgstr "Ingrese su altura con precisión"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:339
msgid "Click 'Calculate BSA' to see your results"
msgstr "Haga clic en 'Calcular BSA' para ver sus resultados"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:340
msgid "Review the BSA values from all four formulas"
msgstr "Revise los valores de BSA de las cuatro fórmulas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:341
msgid "Compare the average BSA with individual formula results"
msgstr "Compare el BSA promedio con los resultados de fórmulas individuales"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:342
msgid "Use the charts to visualize differences between formulas"
msgstr "Utilice los gráficos para visualizar las diferencias entre fórmulas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:351
msgid "Average BSA"
msgstr "BSA promedio"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:353
msgid ""
"The average of all four formulas provides a balanced estimate. This is often"
" used when precision is important."
msgstr ""
"El promedio de las cuatro fórmulas proporciona una estimación equilibrada. "
"Esto se utiliza a menudo cuando la precisión es importante."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:357
msgid "Individual Formula Results"
msgstr "Resultados de fórmulas individuales"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:359
msgid ""
"Each formula may give slightly different results. The Du Bois formula is "
"considered the gold standard, while Mosteller is the simplest to calculate."
msgstr ""
"Cada fórmula puede dar resultados ligeramente diferentes. La fórmula de Du "
"Bois se considera el estándar de oro, mientras que la de Mosteller es la más"
" sencilla de calcular."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:363
msgid "Formula Differences"
msgstr "Diferencias de fórmula"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:365
msgid ""
"Small differences between formulas are normal and expected. The range chart "
"shows the minimum, average, and maximum values."
msgstr ""
"Las pequeñas diferencias entre fórmulas son normales y esperadas. El gráfico"
" de rango muestra los valores mínimo, promedio y máximo."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:373
msgid "Typical BSA Values"
msgstr "Valores típicos de BSA"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:375
msgid "Adults:"
msgstr "Adultos:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:375
msgid "Typically ranges from 1.5 to 2.0 m² for average-sized adults"
msgstr "Normalmente oscila entre 1,5 y 2,0 m² para adultos de tamaño medio"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:376
msgid "Children:"
msgstr "Niños:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:376
msgid ""
"BSA increases with age and size, ranging from approximately 0.2 m² for "
"newborns to adult values"
msgstr ""
"BSA aumenta con la edad y el tamaño, oscilando desde aproximadamente 0,2 m² "
"para recién nacidos hasta valores adultos"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:377
msgid "Men vs Women:"
msgstr "Hombres vs Mujeres:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:377
msgid ""
"Men typically have slightly higher BSA than women of the same height due to "
"generally higher weight"
msgstr ""
"Los hombres suelen tener un BSA ligeramente más alto que las mujeres de la "
"misma altura debido a un peso generalmente mayor."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:378
msgid "Athletes:"
msgstr "Atletas:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:378
msgid "May have higher BSA due to increased muscle mass"
msgstr "Puede tener un BSA más alto debido al aumento de masa muscular."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:390
msgid ""
"BSA calculations are estimates based on mathematical formulas. Actual body "
"surface area may vary slightly."
msgstr ""
"Los cálculos de BSA son estimaciones basadas en fórmulas matemáticas. La "
"superficie corporal real puede variar ligeramente."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:396
msgid ""
"For medical purposes, always consult with healthcare professionals. BSA-"
"based drug dosages should be calculated and verified by qualified medical "
"personnel."
msgstr ""
"Para fines médicos, consulte siempre con profesionales sanitarios. Las dosis"
" de medicamentos basadas en BSA deben ser calculadas y verificadas por "
"personal médico calificado."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:402
msgid ""
"Different formulas may be preferred for specific populations (e.g., "
"pediatric vs adult, oncology vs general medicine)."
msgstr ""
"Es posible que se prefieran diferentes fórmulas para poblaciones específicas"
" (p. ej., pediátrica versus adulta, oncología versus medicina general)."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:408
msgid ""
"This calculator is for educational and informational purposes only. It "
"should not replace professional medical advice or calculations."
msgstr ""
"Esta calculadora tiene fines educativos e informativos únicamente. No debe "
"sustituir los consejos o cálculos médicos profesionales."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:415
msgid "Which Formula to Use?"
msgstr "¿Qué fórmula utilizar?"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:417
msgid "Du Bois:"
msgstr "DuBois:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:417
msgid ""
"Most accurate for general use, considered the gold standard. Recommended for"
" most medical applications."
msgstr ""
"Más preciso para uso general, considerado el estándar de oro. Recomendado "
"para la mayoría de aplicaciones médicas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:418
msgid "Mosteller:"
msgstr "Mosteller:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:418
msgid ""
"Simplest to calculate, commonly used in clinical practice. Good for quick "
"estimates."
msgstr ""
"El más sencillo de calcular y comúnmente utilizado en la práctica clínica. "
"Bueno para estimaciones rápidas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:419
msgid "Haycock:"
msgstr "Montón de heno:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:419
msgid ""
"Particularly accurate for pediatric populations. Also works well for adults."
msgstr ""
"Particularmente preciso para poblaciones pediátricas. También funciona bien "
"para adultos."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:420
msgid "Gehan & George:"
msgstr "Gehan y George:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:420
msgid "Often used in oncology and chemotherapy dosing calculations."
msgstr ""
"A menudo se utiliza en cálculos de dosificación de oncología y "
"quimioterapia."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:421
msgid "Average:"
msgstr "Promedio:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:421
msgid ""
"Using the average of all formulas provides a balanced estimate and reduces "
"the impact of outliers."
msgstr ""
"El uso del promedio de todas las fórmulas proporciona una estimación "
"equilibrada y reduce el impacto de los valores atípicos."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:569
msgid "Gold standard, most accurate"
msgstr "Estándar de oro, el más preciso"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:570
msgid "Simplest, commonly used"
msgstr "El más simple y de uso común."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:571
msgid "Good for pediatric populations"
msgstr "Bueno para poblaciones pediátricas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:572
msgid "Used in oncology"
msgstr "Utilizado en oncología"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:573
msgid "Balanced estimate"
msgstr "Estimación equilibrada"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:4
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:14
