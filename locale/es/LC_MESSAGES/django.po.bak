#: Other_Calculators/views/square_footage_calculator.py:565
#: Other_Calculators/views/square_footage_calculator.py:592
#: Other_Calculators/views/square_footage_calculator.py:616
#, python-brace-format
msgid "Area = {result} {unit}"
msgstr "Área = {result} {unit}"

#: Other_Calculators/views/roofing_calculator.py:537
#: Other_Calculators/views/roofing_calculator.py:562
#: Other_Calculators/views/roofing_calculator.py:586
#: Other_Calculators/views/square_footage_calculator.py:499
#: Other_Calculators/views/square_footage_calculator.py:521
#: Other_Calculators/views/square_footage_calculator.py:544
#: Other_Calculators/views/square_footage_calculator.py:568
#: Other_Calculators/views/square_footage_calculator.py:595
#: Other_Calculators/views/square_footage_calculator.py:619
#, python-brace-format
msgid "Area = {result} m²"
msgstr "Área = {result} m²"

#: Other_Calculators/views/roofing_calculator.py:548
msgid "Step 2: Calculate pitch multiplier"
msgstr "Paso 2: Calcular el multiplicador de tono"

#: Other_Calculators/views/roofing_calculator.py:552
msgid "Step 3: Calculate roof area (hip roof)"
msgstr "Paso 3: Calcular el área del techo (techo a cuatro aguas)"

#: Other_Calculators/views/roofing_calculator.py:576
msgid "Step 3: Calculate roof area"
msgstr "Paso 3: Calcular el área del techo"

#: Other_Calculators/views/roofing_calculator.py:577
#: Other_Calculators/views/square_footage_calculator.py:490
msgid "Area = Length × Width"
msgstr "Área = Largo × Ancho"

#: Other_Calculators/views/roofing_calculator.py:578
#: Other_Calculators/views/square_footage_calculator.py:491
#, python-brace-format
msgid "Area = {length} m × {width} m"
msgstr "Área = {length} m × {width} m"

#: Other_Calculators/views/roofing_calculator.py:593
#: Other_Calculators/views/roofing_calculator.py:642
#, python-brace-format
msgid "Roof Area: {area} {unit}"
msgstr "Área del techo: {area} {unit}"

#: Other_Calculators/views/roofing_calculator.py:594
#, python-brace-format
msgid "Material Type: {type}"
msgstr "Tipo de material: {type}"

#: Other_Calculators/views/roofing_calculator.py:595
#: Other_Calculators/views/roofing_calculator.py:645
#: Other_Calculators/views/tile_calculator.py:400
#: Other_Calculators/views/tile_calculator.py:462
#, python-brace-format
msgid "Waste Factor: {waste}%"
msgstr "Factor de desperdicio: {waste}%"

#: Other_Calculators/views/roofing_calculator.py:597
#: Other_Calculators/views/roofing_calculator.py:647
msgid "Step 2: Convert area to square feet"
msgstr "Paso 2: convertir el área a pies cuadrados"

#: Other_Calculators/views/roofing_calculator.py:598
#: Other_Calculators/views/roofing_calculator.py:648
#, python-brace-format
msgid "Area: {area} ft²"
msgstr "Área: {area} pies²"

#: Other_Calculators/views/roofing_calculator.py:600
#: Other_Calculators/views/roofing_calculator.py:650
msgid "Step 3: Add waste factor"
msgstr "Paso 3: agregar factor de desperdicio"

#: Other_Calculators/views/roofing_calculator.py:601
msgid "Area with Waste = Area × (1 + Waste Factor / 100)"
msgstr "Área con Residuos = Área × (1 + Factor de Residuos / 100)"

#: Other_Calculators/views/roofing_calculator.py:602
#, python-brace-format
msgid "Area with Waste = {area} × (1 + {waste} / 100)"
msgstr "Área con Residuos = {area} × (1 + {waste} / 100)"

#: Other_Calculators/views/roofing_calculator.py:603
#: Other_Calculators/views/roofing_calculator.py:651
#, python-brace-format
msgid "Area with Waste = {area} ft²"
msgstr "Área con residuos = {area} pies²"

#: Other_Calculators/views/roofing_calculator.py:605
msgid "Step 4: Calculate materials needed"
msgstr "Paso 4: Calcular los materiales necesarios"

#: Other_Calculators/views/roofing_calculator.py:606
#, python-brace-format
msgid "Coverage per bundle: {coverage} ft²"
msgstr "Cobertura por paquete: {coverage} pies²"

#: Other_Calculators/views/roofing_calculator.py:607
msgid "Bundles Needed = Area with Waste / Coverage"
msgstr "Paquetes necesarios = Área con residuos / Cobertura"

#: Other_Calculators/views/roofing_calculator.py:608
#, python-brace-format
msgid "Bundles Needed = {area} / {coverage} = {bundles} bundles"
msgstr "Paquetes necesarios = {area} / {coverage} = {bundles} paquetes"

#: Other_Calculators/views/roofing_calculator.py:610
msgid "Step 5: Calculate squares"
msgstr "Paso 5: Calcular cuadrados"

#: Other_Calculators/views/roofing_calculator.py:611
msgid "Squares Needed = Area with Waste / 100"
msgstr "Cuadrados necesarios = Área con residuos / 100"

#: Other_Calculators/views/roofing_calculator.py:612
#, python-brace-format
msgid "Squares Needed = {area} / 100 = {squares} squares"
msgstr "Cuadrados necesarios = {area} / 100 = {squares} cuadrados"

#: Other_Calculators/views/roofing_calculator.py:619
#, python-brace-format
msgid "Rise: {rise} inches"
msgstr "Subida: {rise} pulgadas"

#: Other_Calculators/views/roofing_calculator.py:620
#, python-brace-format
msgid "Run: {run} inches"
msgstr "Ejecutar: {run} pulgadas"

#: Other_Calculators/views/roofing_calculator.py:622
msgid "Step 2: Calculate pitch"
msgstr "Paso 2: Calcular el tono"

#: Other_Calculators/views/roofing_calculator.py:623
msgid "Pitch = (Rise / Run) × 12"
msgstr "Cabeceo = (Levantarse / Correr) × 12"

#: Other_Calculators/views/roofing_calculator.py:624
#, python-brace-format
msgid "Pitch = ({rise} / {run}) × 12"
msgstr "Paso = ({rise} / {run}) × 12"

#: Other_Calculators/views/roofing_calculator.py:625
#, python-brace-format
msgid "Pitch = {pitch} in 12"
msgstr "Paso = {pitch} en 12"

#: Other_Calculators/views/roofing_calculator.py:627
msgid "Step 3: Calculate angle"
msgstr "Paso 3: Calcular el ángulo"

#: Other_Calculators/views/roofing_calculator.py:628
msgid "Angle = arctan(Rise / Run)"
msgstr "Ángulo = arctan(Levantarse / Correr)"

#: Other_Calculators/views/roofing_calculator.py:629
#, python-brace-format
msgid "Angle = arctan({rise} / {run})"
msgstr "Ángulo = arctan({rise} / {run})"

#: Other_Calculators/views/roofing_calculator.py:630
#, python-brace-format
msgid "Angle = {angle}°"
msgstr "Ángulo = {angle}°"

#: Other_Calculators/views/roofing_calculator.py:632
msgid "Step 4: Calculate slope percentage"
msgstr "Paso 4: Calcular el porcentaje de pendiente"

#: Other_Calculators/views/roofing_calculator.py:633
msgid "Slope = (Rise / Run) × 100%"
msgstr "Pendiente = (Subida / Carrera) × 100%"

#: Other_Calculators/views/roofing_calculator.py:634
#, python-brace-format
msgid "Slope = ({rise} / {run}) × 100%"
msgstr "Pendiente = ({rise} / {run}) × 100%"

#: Other_Calculators/views/roofing_calculator.py:635
#, python-brace-format
msgid "Slope = {slope}%"
msgstr "Pendiente = {slope}%"

#: Other_Calculators/views/roofing_calculator.py:643
#, python-brace-format
msgid "Price per Square: {price} {currency}"
msgstr "Precio por cuadrado: {price} {currency}"

#: Other_Calculators/views/roofing_calculator.py:644
#, python-brace-format
msgid "Labor Cost: {cost} {currency}"
msgstr "Costo laboral: {cost} {currency}"

#: Other_Calculators/views/roofing_calculator.py:653
msgid "Step 4: Calculate squares needed"
msgstr "Paso 4: Calcula los cuadrados necesarios"

#: Other_Calculators/views/roofing_calculator.py:654
msgid "Squares = Area with Waste / 100"
msgstr "Cuadrados = Área con Residuos / 100"

#: Other_Calculators/views/roofing_calculator.py:655
#, python-brace-format
msgid "Squares = {area} / 100 = {squares} squares"
msgstr "Cuadrados = {area} / 100 = {squares} cuadrados"

#: Other_Calculators/views/roofing_calculator.py:657
msgid "Step 5: Calculate material cost"
msgstr "Paso 5: Calcular el costo del material"

#: Other_Calculators/views/roofing_calculator.py:658
msgid "Material Cost = Squares × Price per Square"
msgstr "Costo del material = Cuadrados × Precio por cuadrado"

#: Other_Calculators/views/roofing_calculator.py:659
#, python-brace-format
msgid "Material Cost = {squares} × {price} = {cost} {currency}"
msgstr "Costo del material = {squares} × {price} = {cost} {currency}"

#: Other_Calculators/views/roofing_calculator.py:661
msgid "Step 6: Calculate total cost"
msgstr "Paso 6: Calcular el costo total"

#: Other_Calculators/views/roofing_calculator.py:662
msgid "Total Cost = Material Cost + Labor Cost"
msgstr "Costo total = Costo de material + Costo de mano de obra"

#: Other_Calculators/views/roofing_calculator.py:663
#, python-brace-format
msgid "Total Cost = {material} + {labor} = {total} {currency}"
msgstr "Total Cost = {material} + {labor} = {total} {currency}"

