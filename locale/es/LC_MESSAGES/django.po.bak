#: Other_Calculators/templates/other_calculators/resistor_calculator.html:478
msgid "What is a Resistor?"
msgstr "¿Qué es una resistencia?"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:479
msgid ""
"A resistor is an electrical component that limits or regulates the flow of "
"electrical current. Resistance is measured in ohms (Ω) and is indicated by "
"colored bands on the resistor body."
msgstr ""
"Una resistencia es un componente eléctrico que limita o regula el flujo de "
"corriente eléctrica. La resistencia se mide en ohmios (Ω) y se indica "
"mediante bandas de colores en el cuerpo de la resistencia."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:486
msgid "Enter the required values or select colors"
msgstr "Introduzca los valores requeridos o seleccione colores"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:494
msgid "Color Code"
msgstr "Código de colores"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:494
msgid "Decode resistance from color bands"
msgstr "Decodificar la resistencia de las bandas de colores."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:495
msgid "Calculate total resistance in series"
msgstr "Calcular la resistencia total en serie."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:496
msgid "Calculate total resistance in parallel"
msgstr "Calcular la resistencia total en paralelo."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:497
msgid "Calculate power from voltage and resistance"
msgstr "Calcular la potencia a partir del voltaje y la resistencia."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:504
msgid "4-Band"
msgstr "4 bandas"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:504
msgid "2 digits, multiplier, tolerance"
msgstr "2 dígitos, multiplicador, tolerancia"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:505
msgid "5-Band"
msgstr "5 bandas"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:505
msgid "3 digits, multiplier, tolerance"
msgstr "3 dígitos, multiplicador, tolerancia"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:506
msgid "6-Band"
msgstr "6 bandas"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:506
msgid "3 digits, multiplier, tolerance, temp coeff"
msgstr "3 dígitos, multiplicador, tolerancia, coeficiente de temperatura"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:513
msgid "Series"
msgstr "Serie"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:520
msgid "Color Values"
msgstr "Valores de color"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:522
msgid "Black=0, Brown=1, Red=2, Orange=3, Yellow=4"
msgstr "Negro=0, Marrón=1, Rojo=2, Naranja=3, Amarillo=4"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:523
msgid "Green=5, Blue=6, Violet=7, Gray=8, White=9"
msgstr "Verde=5, Azul=6, Violeta=7, Gris=8, Blanco=9"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:524
msgid "Gold=×0.1, Silver=×0.01"
msgstr "Oro=×0,1, Plata=×0,01"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:531
msgid "Resistance values must be greater than zero"
msgstr "Los valores de resistencia deben ser mayores que cero."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:532
msgid "Voltage must be non-negative"
msgstr "El voltaje debe ser no negativo."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:533
msgid "Color bands are read from left to right"
msgstr "Las bandas de colores se leen de izquierda a derecha."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:534
msgid "Tolerance indicates the accuracy range"
msgstr "La tolerancia indica el rango de precisión."

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:542
msgid "Resistor identification"
msgstr "Identificación de resistencia"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:543
msgid "Component selection"
msgstr "Selección de componentes"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:544
msgid "Power rating calculations"
msgstr "Cálculos de potencia"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:675
msgid "Resistor"
msgstr "Resistor"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:786
#: Other_Calculators/templates/other_calculators/resistor_calculator.html:801
msgid "Please enter at least two resistors"
msgstr "Por favor introduzca al menos dos resistencias"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:863
msgid "Resistance Value"
msgstr "Valor de resistencia"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:866
msgid "Tolerance"
msgstr "Tolerancia"

#: Other_Calculators/templates/other_calculators/resistor_calculator.html:872
msgid "Total Resistance"
msgstr "Resistencia total"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:4
#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:8
#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:12
msgid "Roman Numeral Converter - Convert Numbers to Roman Numerals"
msgstr "Convertidor de números romanos - Convertir números a números romanos"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:5
msgid ""
"Free Roman numeral converter to convert numbers to Roman numerals and Roman "
"numerals to numbers. Convert 1-3999 instantly with step-by-step solutions. "
"Perfect for dates, clocks, and learning Roman numerals."
msgstr ""
"Conversor de números romanos gratuito para convertir números a números "
"romanos y números romanos a números. Convierta 1-3999 al instante con "
"soluciones paso a paso. Perfecto para fechas, relojes y aprender números "
"romanos."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:6
msgid ""
"roman numeral converter, roman numerals, convert to roman numerals, roman "
"numeral converter online, decimal to roman, roman to decimal, roman numbers,"
" how to convert to roman numerals, roman numeral calculator, roman numeral "
"translator, I V X L C D M, roman numeral chart, convert roman numerals to "
"numbers"
msgstr ""
"convertidor de números romanos, números romanos, convertir a números "
"romanos, convertidor de números romanos en línea, decimal a romano, romano a"
" decimal, números romanos, cómo convertir a números romanos, calculadora de "
"números romanos, traductor de números romanos, I V X L C D M, tabla de "
"números romanos, convertir números romanos a números"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:9
msgid ""
"Free Roman numeral converter to convert numbers to Roman numerals and Roman "
"numerals to numbers. Convert 1-3999 instantly with step-by-step solutions."
msgstr ""
"Conversor de números romanos gratuito para convertir números a números "
"romanos y números romanos a números. Convierta 1-3999 al instante con "
"soluciones paso a paso."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:13
msgid ""
"Free Roman numeral converter to convert numbers to Roman numerals and vice "
"versa. Convert 1-3999 instantly. Perfect for dates and learning."
msgstr ""
"Conversor de números romanos gratuito para convertir números a números "
"romanos y viceversa. Convierta 1-3999 al instante. Perfecto para citas y "
"aprendizaje."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:24
#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:40
#: Other_Calculators/views/index.py:37
#: Other_Calculators/views/roman_numeral_converter.py:63
msgid "Roman Numeral Converter"
msgstr "Convertidor de números romanos"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:25
msgid ""
"Free online Roman Numeral Converter. Convert decimal numbers to Roman "
"numerals and vice versa with validation and step-by-step solutions."
msgstr ""
"Conversor de números romanos online gratuito. Convierta números decimales a "
"números romanos y viceversa con validación y soluciones paso a paso."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:30
msgid "Decimal to Roman conversion"
msgstr "Conversión de decimal a romano"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:30
msgid "Roman to Decimal conversion"
msgstr "Conversión de romano a decimal"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:30
msgid "Format validation"
msgstr "Validación de formato"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:30
msgid "Visual charts"
msgstr "Gráficos visuales"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:41
msgid "Convert between decimal numbers and Roman numerals"
msgstr "Convertir entre números decimales y números romanos"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:52
msgid "Decimal to Roman Numeral"
msgstr "Decimal a número romano"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:53
msgid "Roman Numeral to Decimal"
msgstr "Número romano a decimal"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:61
#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:394
#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:403
msgid "Decimal Number"
msgstr "Número decimal"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:64
msgid "Enter a number between 1 and 3999"
msgstr "Introduzca un número entre 1 y 3999"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:71
#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:396
#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:401
msgid "Roman Numeral"
msgstr "Número romano"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:74
msgid "Enter a valid Roman numeral (I, V, X, L, C, D, M)"
msgstr "Ingrese un número romano válido (I, V, X, L, C, D, M)"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:108
msgid "What are Roman Numerals?"
msgstr "¿Qué son los números romanos?"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:109
msgid ""
"Roman numerals are a numeral system that originated in ancient Rome. They "
"use combinations of letters from the Latin alphabet to represent numbers."
msgstr ""
"Los números romanos son un sistema de numeración que se originó en la "
"antigua Roma. Usan combinaciones de letras del alfabeto latino para "
"representar números."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:115
msgid "Select conversion direction"
msgstr "Seleccione la dirección de conversión"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:116
msgid "Enter the value to convert"
msgstr "Introduzca el valor a convertir"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:117
#: Other_Calculators/templates/other_calculators/shoe_size_conversion.html:134
msgid "Click 'Convert' to get results"
msgstr "Haga clic en 'Convertir' para obtener resultados"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:122
msgid "Roman Numeral Symbols"
msgstr "Símbolos de números romanos"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:135
msgid "Subtractive Notation"
msgstr "Notación sustractiva"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:147
msgid "Rules"
msgstr "Normas"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:149
msgid "Symbols are written from largest to smallest"
msgstr "Los símbolos se escriben de mayor a menor."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:150
msgid "No more than 3 identical symbols in a row"
msgstr "No más de 3 símbolos idénticos seguidos"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:151
msgid "Only I, X, C can be used for subtraction"
msgstr "Sólo I, X, C se pueden usar para restar."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:152
msgid "Only one smaller value can precede a larger value"
msgstr "Sólo un valor menor puede preceder a un valor mayor"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:153
msgid "V, L, D cannot be subtracted"
msgstr "V, L, D no se pueden restar"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:174
msgid "Decimal numbers must be between 1 and 3999"
msgstr "Los números decimales deben estar entre 1 y 3999."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:175
msgid "Roman numerals are case-insensitive"
msgstr "Los números romanos no distinguen entre mayúsculas y minúsculas."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:176
msgid "Invalid formats will be rejected"
msgstr "Los formatos no válidos serán rechazados."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:177
msgid "Standard Roman numeral rules apply"
msgstr "Se aplican las reglas estándar de números romanos"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:184
msgid "Clock faces and timepieces"
msgstr "Esferas de reloj y relojes"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:185
msgid "Book chapter numbering"
msgstr "Numeración de capítulos de libros"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:186
msgid "Movie and TV series titles"
msgstr "Títulos de películas y series de televisión."

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:187
msgid "Monument inscriptions"
msgstr "Inscripciones de monumentos"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:188
msgid "Educational purposes"
msgstr "Fines educativos"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:285
msgid "Number must be at least 1"
msgstr "El número debe ser al menos 1"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:290
msgid "Number cannot exceed 3999"
msgstr "El número no puede exceder 3999"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:313
msgid "Invalid characters. Only I, V, X, L, C, D, M are allowed"
msgstr "Caracteres no válidos. Sólo se permiten I, V, X, L, C, D, M"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:337
msgid "Please enter a decimal number"
msgstr "Por favor introduce un número decimal"

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:347
msgid "Please enter a Roman numeral"
msgstr "Por favor ingresa un número romano"

#: Other_Calculators/templates/other_calculators/roofing_calculator.html:4
#: Other_Calculators/templates/other_calculators/roofing_calculator.html:8
#: Other_Calculators/templates/other_calculators/roofing_calculator.html:12
msgid "Roofing Calculator - Calculate Roof Area, Materials & Cost"
msgstr ""
