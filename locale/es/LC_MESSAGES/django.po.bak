msgstr "Torsión típica (lb⋅ft)"

#: Other_Calculators/templates/other_calculators/engine_horsepower_calculator.html:409
msgid "Peak RPM"
msgstr "RPM máximas"

#: Other_Calculators/templates/other_calculators/engine_horsepower_calculator.html:413
#: Other_Calculators/templates/other_calculators/fuel_cost_calculator.html:524
msgid "Economy Car"
msgstr "Coche Económico"

#: Other_Calculators/templates/other_calculators/engine_horsepower_calculator.html:414
#: Other_Calculators/templates/other_calculators/fuel_cost_calculator.html:526
msgid "Sports Car"
