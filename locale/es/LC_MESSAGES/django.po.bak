#: Other_Calculators/views/love_calculator.py:419
#: Other_Calculators/views/love_calculator.py:444
#, python-brace-format
msgid "Name 2: {name}"
msgstr "Nombre 2: {name}"

#: Other_Calculators/views/love_calculator.py:384
msgid "Step 2: Combine and normalize names"
msgstr "Paso 2: combinar y normalizar nombres"

#: Other_Calculators/views/love_calculator.py:385
#, python-brace-format
msgid "Combined: {combined}"
msgstr "Combinado: {combined}"

#: Other_Calculators/views/love_calculator.py:387
msgid "Step 3: Count L, O, V, E letters"
msgstr "Paso 3: Cuente las letras L, O, V, E"

#: Other_Calculators/views/love_calculator.py:388
#, python-brace-format
msgid "L count: {count}"
msgstr "Recuento L: {count}"

#: Other_Calculators/views/love_calculator.py:389
#, python-brace-format
msgid "O count: {count}"
msgstr "O cuenta: {count}"

#: Other_Calculators/views/love_calculator.py:390
#, python-brace-format
msgid "V count: {count}"
msgstr "Recuento V: {count}"

#: Other_Calculators/views/love_calculator.py:391
#, python-brace-format
msgid "E count: {count}"
msgstr "Cuenta E: {count}"

#: Other_Calculators/views/love_calculator.py:392
#, python-brace-format
msgid "Total LOVE letters: {total}"
msgstr "Total de cartas de AMOR: {total}"

#: Other_Calculators/views/love_calculator.py:394
msgid "Step 4: Calculate letter percentage"
msgstr "Paso 4: Calcular el porcentaje de letras"

#: Other_Calculators/views/love_calculator.py:395
msgid "Letter Percentage = (LOVE letters / Total letters) × 100"
msgstr "Porcentaje de letras = (letras de AMOR / letras totales) × 100"

#: Other_Calculators/views/love_calculator.py:396
#, python-brace-format
msgid "Letter Percentage = ({love} / {total}) × 100 = {percent}%"
msgstr "Porcentaje de letras = ({love} / {total}) × 100 = {percent}%"

#: Other_Calculators/views/love_calculator.py:400
msgid "Step 5: Calculate common letters percentage"
msgstr "Paso 5: Calcular el porcentaje de letras comunes"

#: Other_Calculators/views/love_calculator.py:401
#: Other_Calculators/views/love_calculator.py:422
#, python-brace-format
msgid "Common Letters: {common}"
msgstr "Letras comunes: {common}"

#: Other_Calculators/views/love_calculator.py:402
#, python-brace-format
msgid "Common Percentage: {percent}%"
msgstr "Porcentaje común: {percent}%"

#: Other_Calculators/views/love_calculator.py:404
msgid "Step 6: Combine percentages"
msgstr "Paso 6: combinar porcentajes"

#: Other_Calculators/views/love_calculator.py:405
msgid "Final Percentage = (Letter % × 0.4) + (Common % × 0.6)"
msgstr "Porcentaje final = (% de letras × 0,4) + (% común × 0,6)"

#: Other_Calculators/views/love_calculator.py:406
#, python-brace-format
msgid "Final Percentage = ({letter} × 0.4) + ({common} × 0.6) = {final}%"
msgstr "Porcentaje final = ({letter} × 0,4) + ({common} × 0,6) = {final}%"

#: Other_Calculators/views/love_calculator.py:410
msgid "Step 7: Final Result"
msgstr "Paso 7: Resultado final"

#: Other_Calculators/views/love_calculator.py:411
#: Other_Calculators/views/love_calculator.py:502
#, python-brace-format
msgid "Love Percentage: {percent}%"
msgstr "Porcentaje de amor: {percent}%"

#: Other_Calculators/views/love_calculator.py:421
msgid "Step 2: Calculate common letters score"
msgstr "Paso 2: Calcular la puntuación de letras comunes"

#: Other_Calculators/views/love_calculator.py:423
#, python-brace-format
msgid "Common Score: {score}%"
msgstr "Puntuación común: {score}%"

#: Other_Calculators/views/love_calculator.py:425
msgid "Step 3: Calculate name length similarity"
msgstr "Paso 3: Calcular la similitud de la longitud del nombre"

#: Other_Calculators/views/love_calculator.py:426
#, python-brace-format
msgid "Length Score: {score}%"
msgstr "Puntuación de duración: {score}%"

#: Other_Calculators/views/love_calculator.py:428
msgid "Step 4: Calculate vowel/consonant ratio similarity"
msgstr "Paso 4: Calcular la similitud de la proporción vocal/consonante"

#: Other_Calculators/views/love_calculator.py:429
#, python-brace-format
msgid "Vowel Score: {score}%"
msgstr "Puntuación de vocales: {score}%"

#: Other_Calculators/views/love_calculator.py:431
msgid "Step 5: Calculate overall compatibility"
msgstr "Paso 5: Calcular la compatibilidad general"

#: Other_Calculators/views/love_calculator.py:432
msgid "Compatibility = (Common Score + Length Score + Vowel Score) / 3"
msgstr ""
"Compatibilidad = (Puntuación común + Puntuación de longitud + Puntuación de "
"vocales) / 3"

#: Other_Calculators/views/love_calculator.py:433
#, python-brace-format
msgid "Compatibility = ({common} + {length} + {vowel}) / 3 = {final}%"
msgstr "Compatibilidad = ({common} + {length} + {vowel}) / 3 = {final}%"

#: Other_Calculators/views/love_calculator.py:446
msgid "Step 2: Analyze name lengths"
msgstr "Paso 2: Analizar la longitud de los nombres"

#: Other_Calculators/views/love_calculator.py:447
