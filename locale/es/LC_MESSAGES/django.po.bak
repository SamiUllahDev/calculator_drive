#: Other_Calculators/views/conversion_calculator.py:350
#: Other_Calculators/views/conversion_calculator.py:360
msgid "Invalid temperature unit"
msgstr "Unidad de temperatura no válida"

#: Other_Calculators/views/conversion_calculator.py:367
#: Other_Calculators/views/conversion_calculator.py:415
msgid "Step 1: Identify the conversion"
msgstr "Paso 1: identificar la conversión"

#: Other_Calculators/views/conversion_calculator.py:368
#, python-brace-format
msgid "Converting from {from_unit} to {to_unit}"
msgstr "Convirtiendo de {from_unit} a {to_unit}"

#: Other_Calculators/views/conversion_calculator.py:372
msgid "Step 2: Convert to Celsius (base unit)"
msgstr "Paso 2: Convertir a Celsius (unidad base)"

#: Other_Calculators/views/conversion_calculator.py:374
#, python-brace-format
msgid "Value is already in Celsius: {value}°C"
msgstr "El valor ya está en Celsius: {value}°C"

#: Other_Calculators/views/conversion_calculator.py:377
msgid "Formula: Celsius = (Fahrenheit - 32) × 5/9"
msgstr "Fórmula: Celsius = (Fahrenheit - 32) × 5/9"

#: Other_Calculators/views/conversion_calculator.py:378
#, python-brace-format
msgid "Celsius = ({value} - 32) × 5/9"
msgstr "Celsius = ({value} - 32) × 5/9"

#: Other_Calculators/views/conversion_calculator.py:380
#: Other_Calculators/views/conversion_calculator.py:385
#, python-brace-format
msgid "Celsius = {result}°C"
msgstr "Celsius = {result}°C"

#: Other_Calculators/views/conversion_calculator.py:382
msgid "Formula: Celsius = Kelvin - 273.15"
msgstr "Fórmula: Celsius = Kelvin - 273,15"

#: Other_Calculators/views/conversion_calculator.py:383
#, python-brace-format
msgid "Celsius = {value} - 273.15"
msgstr "Celsius = {value} - 273,15"

#: Other_Calculators/views/conversion_calculator.py:387
msgid "Step 3: Convert from Celsius to target unit"
msgstr "Paso 3: Convertir de Celsius a unidad objetivo"

#: Other_Calculators/views/conversion_calculator.py:389
#, python-brace-format
msgid "Result: {result}°C"
msgstr "Resultado: {result}°C"

#: Other_Calculators/views/conversion_calculator.py:391
msgid "Formula: Fahrenheit = Celsius × 9/5 + 32"
msgstr "Fórmula: Fahrenheit = Celsius × 9/5 + 32"

#: Other_Calculators/views/conversion_calculator.py:392
#, python-brace-format
msgid "Fahrenheit = {celsius} × 9/5 + 32"
msgstr "Fahrenheit = {celsius} × 9/5 + 32"

#: Other_Calculators/views/conversion_calculator.py:393
#, python-brace-format
msgid "Fahrenheit = {result}°F"
msgstr "Fahrenheit = {result}°F"

#: Other_Calculators/views/conversion_calculator.py:395
msgid "Formula: Kelvin = Celsius + 273.15"
msgstr "Fórmula: Kelvin = Celsius + 273,15"

#: Other_Calculators/views/conversion_calculator.py:396
#, python-brace-format
msgid "Kelvin = {celsius} + 273.15"
msgstr "Kelvin = {celsius} + 273,15"

#: Other_Calculators/views/conversion_calculator.py:397
#, python-brace-format
msgid "Kelvin = {result}K"
msgstr "Kelvin = {result}K"

#: Other_Calculators/views/conversion_calculator.py:400
msgid "meters"
msgstr "metros"

#: Other_Calculators/views/conversion_calculator.py:401
msgid "kilograms"
msgstr "kilogramos"

#: Other_Calculators/views/conversion_calculator.py:403
msgid "square meters"
msgstr "metros cuadrados"

#: Other_Calculators/views/conversion_calculator.py:404
msgid "meters per second"
msgstr "metros por segundo"

#: Other_Calculators/views/conversion_calculator.py:407
msgid "pascals"
msgstr "pascales"

#: Other_Calculators/views/conversion_calculator.py:408
msgid "joules"
msgstr "julios"

#: Other_Calculators/views/conversion_calculator.py:416
#, python-brace-format
msgid "Converting {value} {from_unit} to {to_unit}"
msgstr "Convirtiendo {value} {from_unit} a {to_unit}"

#: Other_Calculators/views/conversion_calculator.py:421
#, python-brace-format
msgid "Step 2: Convert to base unit ({base_unit})"
msgstr "Paso 2: Convertir a unidad base ({base_unit})"

#: Other_Calculators/views/conversion_calculator.py:424
msgid "Formula: Base Value = Value × Conversion Factor"
msgstr "Fórmula: Valor base = Valor × Factor de conversión"

#: Other_Calculators/views/conversion_calculator.py:425
#, python-brace-format
msgid "Base Value = {value} × {factor}"
msgstr "Valor base = {value} × {factor}"

#: Other_Calculators/views/conversion_calculator.py:428
#, python-brace-format
msgid "Base Value = {result} {base_unit}"
msgstr "Valor base = {result} {base_unit}"

#: Other_Calculators/views/conversion_calculator.py:432
msgid "Step 3: Convert from base unit to target unit"
msgstr "Paso 3: Convertir de unidad base a unidad objetivo"

#: Other_Calculators/views/conversion_calculator.py:434
msgid "Formula: Result = Base Value ÷ Conversion Factor"
msgstr "Fórmula: Resultado = Valor base ÷ Factor de conversión"

#: Other_Calculators/views/conversion_calculator.py:435
#, python-brace-format
