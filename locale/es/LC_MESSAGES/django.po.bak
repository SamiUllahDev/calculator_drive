#: user/templates/user/password_change.html:127
#: user/templates/user/password_reset_complete.html:43
#: user/templates/user/security_settings.html:139
msgid "Security Tips"
msgstr "Consejos de seguridad"

#: Other_Calculators/templates/other_calculators/password_generator.html:188
msgid "Use a unique password for each account"
msgstr "Utilice una contraseña única para cada cuenta"

#: Other_Calculators/templates/other_calculators/password_generator.html:189
msgid "Don't share passwords with anyone"
msgstr "No compartas contraseñas con nadie"

#: Other_Calculators/templates/other_calculators/password_generator.html:190
msgid "Use a password manager"
msgstr "Utilice un administrador de contraseñas"

#: Other_Calculators/templates/other_calculators/password_generator.html:191
msgid "Enable two-factor authentication"
msgstr "Habilitar la autenticación de dos factores"

#: Other_Calculators/templates/other_calculators/password_generator.html:192
msgid "Change passwords regularly"
msgstr "Cambie las contraseñas periódicamente"

#: Other_Calculators/templates/other_calculators/password_generator.html:193
msgid "Avoid dictionary words"
msgstr "Evite las palabras del diccionario"

#: Other_Calculators/templates/other_calculators/password_generator.html:200
msgid ""
"Passwords are generated using cryptographically secure random number "
"generator"
msgstr ""
"Las contraseñas se generan mediante un generador de números aleatorios "
"criptográficamente seguro"

#: Other_Calculators/templates/other_calculators/password_generator.html:201
msgid "Generated passwords are not stored or logged"
msgstr "Las contraseñas generadas no se almacenan ni se registran"

#: Other_Calculators/templates/other_calculators/password_generator.html:202
msgid "At least one character type must be selected"
msgstr "Se debe seleccionar al menos un tipo de carácter."

#: Other_Calculators/templates/other_calculators/password_generator.html:203
msgid "Ambiguous characters can be excluded for readability"
msgstr "Los caracteres ambiguos se pueden excluir para facilitar la lectura."

#: Other_Calculators/templates/other_calculators/password_generator.html:235
msgid "Hide"
msgstr "Esconder"

#: Other_Calculators/templates/other_calculators/password_generator.html:268
msgid "Please select at least one character type"
msgstr "Por favor seleccione al menos un tipo de carácter"

#: Other_Calculators/templates/other_calculators/password_generator.html:326
msgid "Password Strength Analysis"
msgstr "Análisis de seguridad de la contraseña"

#: Other_Calculators/templates/other_calculators/password_generator.html:346
#: Other_Calculators/templates/other_calculators/password_generator.html:465
msgid "Strength"
msgstr "Fortaleza"

#: Other_Calculators/templates/other_calculators/password_generator.html:356
#: Other_Calculators/templates/other_calculators/password_generator.html:475
msgid "Entropy"
msgstr "entropía"

#: Other_Calculators/templates/other_calculators/password_generator.html:357
#: Other_Calculators/templates/other_calculators/password_generator.html:476
msgid "Unique Characters"
msgstr "Personajes únicos"

#: Other_Calculators/templates/other_calculators/password_generator.html:358
#: Other_Calculators/templates/other_calculators/password_generator.html:477
msgid "Time to Crack"
msgstr "Es hora de romper"

#: Other_Calculators/templates/other_calculators/password_generator.html:362
#: Other_Calculators/templates/other_calculators/password_generator.html:481
msgid "Lowercase letters"
msgstr "Letras minúsculas"

#: Other_Calculators/templates/other_calculators/password_generator.html:363
#: Other_Calculators/templates/other_calculators/password_generator.html:482
msgid "Uppercase letters"
msgstr "Letras mayúsculas"

