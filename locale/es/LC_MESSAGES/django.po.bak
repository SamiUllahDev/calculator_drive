#: Other_Calculators/views/time_duration_calculator.py:490
#, python-brace-format
msgid "Duration in {unit} = {seconds} ÷ {factor} = {result} {unit}"
msgstr "Duración en {unit} = {seconds} ÷ {factor} = {result} {unit}"

#: Other_Calculators/views/time_duration_calculator.py:498
#, python-brace-format
msgid "Elapsed Duration: {duration} {unit}"
msgstr "Duración transcurrida: {duration} {unit}"

#: Other_Calculators/views/time_duration_calculator.py:502
#, python-brace-format
msgid "Elapsed Duration: {duration} {unit} = {seconds} seconds"
msgstr "Duración transcurrida: {duration} {unit} = {seconds} segundos"

#: Other_Calculators/views/time_duration_calculator.py:504
msgid "Step 3: Calculate end time"
msgstr "Paso 3: Calcular la hora de finalización"

#: Other_Calculators/views/time_duration_calculator.py:505
msgid "End Time = Start Time + Elapsed Duration"
msgstr "Hora de finalización = Hora de inicio + Duración transcurrida"

#: Other_Calculators/views/time_duration_calculator.py:506
#, python-brace-format
msgid "End Time = {start} + {elapsed} = {end} seconds"
msgstr "Hora de finalización = {start} + {elapsed} = {end} segundos"

#: Other_Calculators/views/time_duration_calculator.py:509
#, python-brace-format
msgid "Hours = {end} ÷ 3600 = {hours}"
msgstr "Horas = {end} ÷ 3600 = {hours}"

#: Other_Calculators/views/time_duration_calculator.py:510
#, python-brace-format
msgid "Minutes = ({end} % 3600) ÷ 60 = {minutes}"
msgstr "Minutos = ({end} % 3600) ÷ 60 = {minutes}"

#: Other_Calculators/views/time_duration_calculator.py:511
#, python-brace-format
msgid "Seconds = {end} % 60 = {seconds}"
msgstr "Segundos = {end} % 60 = {seconds}"

#: Other_Calculators/views/time_duration_calculator.py:514
#, python-brace-format
msgid "End Time = {result}"
msgstr "Hora de finalización = {result}"

#: Other_Calculators/views/time_zone_calculator.py:142
msgid "Source timezone is required."
msgstr "Se requiere la zona horaria de origen."

#: Other_Calculators/views/time_zone_calculator.py:148
msgid "Target timezone is required."
msgstr "Se requiere la zona horaria de destino."

#: Other_Calculators/views/time_zone_calculator.py:210
#, python-brace-format
msgid "Error converting timezone: {error}"
msgstr "Error al convertir la zona horaria: {error}"

#: Other_Calculators/views/time_zone_calculator.py:219
msgid "First timezone is required."
msgstr "Se requiere la primera zona horaria."

#: Other_Calculators/views/time_zone_calculator.py:225
msgid "Second timezone is required."
msgstr "Se requiere una segunda zona horaria."

#: Other_Calculators/views/time_zone_calculator.py:263
#, python-brace-format
msgid "Error calculating timezone difference: {error}"
msgstr "Error al calcular la diferencia de zona horaria: {error}"

#: Other_Calculators/views/time_zone_calculator.py:314
#, python-brace-format
msgid "Error getting current time: {error}"
msgstr "Error al obtener la hora actual: {error}"

#: Other_Calculators/views/time_zone_calculator.py:323
#, python-brace-format
msgid "From Timezone: {tz} (UTC{offset:+d})"
msgstr "Desde zona horaria: {tz} (UTC{offset:+d})"

#: Other_Calculators/views/time_zone_calculator.py:324
#, python-brace-format
msgid "To Timezone: {tz} (UTC{offset:+d})"
msgstr "A la zona horaria: {tz} (UTC{offset:+d})"

#: Other_Calculators/views/time_zone_calculator.py:329
msgid "Step 3: Convert to UTC"
msgstr "Paso 3: convertir a UTC"

#: Other_Calculators/views/time_zone_calculator.py:330
msgid "UTC Time = Source Time - Source Offset"
msgstr "Hora UTC = Hora de origen - Desplazamiento de origen"

#: Other_Calculators/views/time_zone_calculator.py:331
#, python-brace-format
msgid "UTC Time = {time} - ({offset} × 3600)"
msgstr "Hora UTC = {time} - ({offset} × 3600)"

#: Other_Calculators/views/time_zone_calculator.py:332
#, python-brace-format
msgid "UTC Time = {utc} seconds = {utc_formatted}"
msgstr "Hora UTC = {utc} segundos = {utc_formatted}"

#: Other_Calculators/views/time_zone_calculator.py:334
msgid "Step 4: Convert from UTC to target timezone"
msgstr "Paso 4: convertir de UTC a la zona horaria de destino"

#: Other_Calculators/views/time_zone_calculator.py:335
msgid "Target Time = UTC Time + Target Offset"
msgstr "Hora objetivo = Hora UTC + Desplazamiento objetivo"

#: Other_Calculators/views/time_zone_calculator.py:336
#, python-brace-format
msgid "Target Time = {utc} + ({offset} × 3600)"
msgstr "Hora objetivo = {utc} + ({offset} × 3600)"

#: Other_Calculators/views/time_zone_calculator.py:337
#, python-brace-format
msgid "Target Time = {result} seconds = {result_formatted}"
msgstr "Tiempo objetivo = {result} segundos = {result_formatted}"

#: Other_Calculators/views/time_zone_calculator.py:339
msgid "Step 5: Time difference"
msgstr "Paso 5: diferencia horaria"

#: Other_Calculators/views/time_zone_calculator.py:340
#, python-brace-format
msgid "Time Difference = {diff} hours"
msgstr "Diferencia horaria = {diff} horas"

#: Other_Calculators/views/time_zone_calculator.py:346
msgid "Step 1: Identify the given timezones"
msgstr "Paso 1: identificar las zonas horarias dadas"

#: Other_Calculators/views/time_zone_calculator.py:347
#, python-brace-format
msgid "Timezone 1: {tz1} (UTC{offset1:+d})"
msgstr "Zona horaria 1: {tz1} (UTC{offset1:+d})"

#: Other_Calculators/views/time_zone_calculator.py:348
#, python-brace-format
msgid "Timezone 2: {tz2} (UTC{offset2:+d})"
msgstr "Zona horaria 2: {tz2} (UTC{offset2:+d})"

#: Other_Calculators/views/time_zone_calculator.py:351
msgid "Difference = Offset 2 - Offset 1"
msgstr "Diferencia = Desplazamiento 2 - Desplazamiento 1"

#: Other_Calculators/views/time_zone_calculator.py:352
#, python-brace-format
msgid "Difference = {offset2} - {offset1} = {diff} hours"
msgstr "Diferencia = {offset2} - {offset1} = {diff} horas"

#: Other_Calculators/views/time_zone_calculator.py:354
msgid "Step 3: Convert to different units"
msgstr "Paso 3: convertir a diferentes unidades"

#: Other_Calculators/views/time_zone_calculator.py:355
#, python-brace-format
msgid "Difference = {hours} hours"
msgstr "Diferencia = {hours} horas"

#: Other_Calculators/views/time_zone_calculator.py:356
#, python-brace-format
msgid "Difference = {minutes} minutes"
msgstr "Diferencia = {minutes} minutos"

#: Other_Calculators/views/time_zone_calculator.py:357
#, python-brace-format
msgid "Difference = {seconds} seconds"
msgstr "Diferencia = {seconds} segundos"

#: Other_Calculators/views/time_zone_calculator.py:363
msgid "Step 1: Current time in different timezones"
msgstr "Paso 1: hora actual en diferentes zonas horarias"

#: Other_Calculators/views/time_zone_calculator.py:365
#, python-brace-format
msgid "{tz}: {time} (UTC{offset:+d})"
msgstr "{tz}: {time} (UTC{desplazamiento:+d})"

#: Other_Calculators/views/time_zone_calculator.py:403
msgid "Time Zone Conversion"
msgstr "Conversión de zona horaria"

#: Other_Calculators/views/time_zone_calculator.py:448
msgid "Current Time in Different Time Zones"
msgstr "Hora actual en diferentes zonas horarias"

#: Other_Calculators/views/tip_calculator.py:72
#: Other_Calculators/views/tip_calculator.py:174
msgid "Bill amount is required."
msgstr "Se requiere el monto de la factura."

#: Other_Calculators/views/tip_calculator.py:92
#: Other_Calculators/views/tip_calculator.py:192
msgid "Bill amount must be greater than zero."
msgstr "El monto de la factura debe ser mayor que cero."

#: Other_Calculators/views/tip_calculator.py:98
msgid "Tip percentage must be between 0 and 100."
msgstr "El porcentaje de propina debe estar entre 0 y 100."

#: Other_Calculators/views/tip_calculator.py:104
msgid "Number of people must be at least 1."
msgstr "El número de personas debe ser al menos 1."

#: Other_Calculators/views/tip_calculator.py:159
#, python-brace-format
msgid "Error calculating tip: {error}"
msgstr "Consejo de cálculo de error: {error}"

#: Other_Calculators/views/tip_calculator.py:168
msgid "Total amount is required."
msgstr "Se requiere el monto total."

#: Other_Calculators/views/tip_calculator.py:198
msgid "Total amount must be greater than or equal to bill amount."
msgstr "El monto total debe ser mayor o igual al monto de la factura."

#: Other_Calculators/views/tip_calculator.py:223
#, python-brace-format
msgid "Error calculating from total: {error}"
msgstr "Error al calcular del total: {error}"

#: Other_Calculators/views/tip_calculator.py:231
#: Other_Calculators/views/tip_calculator.py:262
#, python-brace-format
msgid "Bill Amount: {amount} {currency}"
msgstr "Monto de la factura: {amount} {currency}"

#: Other_Calculators/views/tip_calculator.py:232
#, python-brace-format
msgid "Tip Percentage: {percent}%"
msgstr "Porcentaje de propina: {percent}%"

#: Other_Calculators/views/tip_calculator.py:233
#, python-brace-format
msgid "Number of People: {num}"
msgstr "Número de personas: {num}"

#: Other_Calculators/views/tip_calculator.py:235
msgid "Round Up: Yes"
msgstr "Redondeo: Sí"

#: Other_Calculators/views/tip_calculator.py:237
#: Other_Calculators/views/tip_calculator.py:265
msgid "Step 2: Calculate tip amount"
msgstr "Paso 2: Calcular el monto de la propina"

#: Other_Calculators/views/tip_calculator.py:238
msgid "Tip Amount = Bill Amount × (Tip Percentage / 100)"
msgstr ""
"Monto de propina = Monto de la factura × (Porcentaje de propina / 100)"

#: Other_Calculators/views/tip_calculator.py:239
#, python-brace-format
msgid "Tip Amount = {bill} × ({percent} / 100)"
msgstr "Monto de propina = {bill} × ({percent} / 100)"

#: Other_Calculators/views/tip_calculator.py:240
#, python-brace-format
msgid "Tip Amount = {tip} {currency}"
msgstr "Monto de propina = {tip} {currency}"

#: Other_Calculators/views/tip_calculator.py:243
msgid "Total = Bill Amount + Tip Amount"
msgstr "Total = Monto de la factura + Monto de la propina"

#: Other_Calculators/views/tip_calculator.py:244
#, python-brace-format
msgid "Total = {bill} + {tip} = {total} {currency}"
msgstr "Total = {bill} + {tip} = {total} {currency}"

#: Other_Calculators/views/tip_calculator.py:246
#, python-brace-format
msgid "Rounded Up Total = {total} {currency}"
msgstr "Total redondeado hacia arriba = {total} {currency}"

#: Other_Calculators/views/tip_calculator.py:249
msgid "Step 4: Calculate per person amounts"
msgstr "Paso 4: Calcular cantidades por persona"

#: Other_Calculators/views/tip_calculator.py:250
msgid "Per Person Bill = Bill Amount / Number of People"
msgstr "Factura por persona = Monto de la factura / Número de personas"

#: Other_Calculators/views/tip_calculator.py:251
#, python-brace-format
msgid "Per Person Bill = {bill} / {num} = {per_bill} {currency}"
msgstr "Factura por persona = {bill} / {num} = {per_bill} {currency}"

#: Other_Calculators/views/tip_calculator.py:252
msgid "Per Person Tip = Tip Amount / Number of People"
msgstr "Propina por persona = Monto de la propina / Número de personas"

#: Other_Calculators/views/tip_calculator.py:253
#, python-brace-format
msgid "Per Person Tip = {tip} / {num} = {per_tip} {currency}"
msgstr "Propina por persona = {tip} / {num} = {per_tip} {currency}"

#: Other_Calculators/views/tip_calculator.py:254
msgid "Per Person Total = Total / Number of People"
msgstr "Total por persona = Total / Número de personas"

#: Other_Calculators/views/tip_calculator.py:255
#, python-brace-format
msgid "Per Person Total = {total} / {num} = {per_total} {currency}"
msgstr "Total por persona = {total} / {num} = {per_total} {currency}"

#: Other_Calculators/views/tip_calculator.py:263
#, python-brace-format
msgid "Total Amount: {amount} {currency}"
msgstr "Importe total: {amount} {currency}"

#: Other_Calculators/views/tip_calculator.py:266
msgid "Tip Amount = Total Amount - Bill Amount"
msgstr "Monto de propina = Monto total - Monto de factura"

#: Other_Calculators/views/tip_calculator.py:267
#, python-brace-format
msgid "Tip Amount = {total} - {bill} = {tip} {currency}"
msgstr "Monto de propina = {total} - {bill} = {tip} {currency}"

#: Other_Calculators/views/tip_calculator.py:269
msgid "Step 3: Calculate tip percentage"
msgstr "Paso 3: Calcular el porcentaje de propina"

#: Other_Calculators/views/tip_calculator.py:270
msgid "Tip Percentage = (Tip Amount / Bill Amount) × 100"
msgstr "Porcentaje de propina = (Monto de propina / Monto de factura) × 100"

#: Other_Calculators/views/tip_calculator.py:271
#, python-brace-format
msgid "Tip Percentage = ({tip} / {bill}) × 100"
msgstr "Porcentaje de propina = ({tip} / {bill}) × 100"

#: Other_Calculators/views/tip_calculator.py:272
#, python-brace-format
msgid "Tip Percentage = {percent}%"
msgstr "Porcentaje de propina = {percent}%"

#: Other_Calculators/views/tip_calculator.py:306
#, python-brace-format
msgid "Bill Breakdown (Total: {total})"
msgstr "Desglose de facturas (Total: {total})"

#: Other_Calculators/views/tire_size_calculator.py:199
#: Other_Calculators/views/tire_size_calculator.py:254
msgid "Tire size is required."
msgstr "Se requiere el tamaño de los neumáticos."

#: Other_Calculators/views/tire_size_calculator.py:214
msgid ""
"Invalid tire size format. Use metric (e.g., 205/55R16) or imperial (e.g., "
"31x10.5R15) format."
msgstr ""
"Formato de tamaño de neumático no válido. Utilice formato métrico (p. ej., "
"205/55R16) o imperial (p. ej., 31x10.5R15)."

#: Other_Calculators/views/tire_size_calculator.py:245
#, python-brace-format
msgid "Error calculating dimensions: {error}"
msgstr "Error al calcular las dimensiones: {error}"

#: Other_Calculators/views/tire_size_calculator.py:268
#: Other_Calculators/views/tire_size_calculator.py:337
#: Other_Calculators/views/tire_size_calculator.py:418
msgid "Invalid tire size format."
msgstr "Formato de tamaño de neumático no válido."

#: Other_Calculators/views/tire_size_calculator.py:304
#, python-brace-format
msgid "Error converting size: {error}"
msgstr "Error al convertir el tamaño: {error}"

#: Other_Calculators/views/tire_size_calculator.py:313
msgid "First tire size is required."
msgstr "Se requiere el primer tamaño de neumático."

#: Other_Calculators/views/tire_size_calculator.py:319
msgid "Second tire size is required."
msgstr "Se requiere un segundo tamaño de neumático."

#: Other_Calculators/views/tire_size_calculator.py:384
#, python-brace-format
msgid "Error comparing tires: {error}"
msgstr "Error al comparar neumáticos: {error}"

#: Other_Calculators/views/tire_size_calculator.py:393
msgid "Original tire size is required."
msgstr "Se requiere el tamaño de neumático original."

#: Other_Calculators/views/tire_size_calculator.py:399
msgid "New tire size is required."
msgstr "Se requiere un tamaño de neumático nuevo."

#: Other_Calculators/views/tire_size_calculator.py:448
#, python-brace-format
msgid "Error calculating speedometer: {error}"
msgstr "Error al calcular el velocímetro: {error}"

#: Other_Calculators/views/tire_size_calculator.py:455
msgid "Step 1: Identify tire specifications"
msgstr "Paso 1: identificar las especificaciones de los neumáticos"

#: Other_Calculators/views/tire_size_calculator.py:457
#, python-brace-format
msgid "Width: {width} mm"
msgstr "Ancho: {width} mm"

#: Other_Calculators/views/tire_size_calculator.py:458
#, python-brace-format
msgid "Aspect Ratio: {ratio}%"
msgstr "Relación de aspecto: {ratio}%"

#: Other_Calculators/views/tire_size_calculator.py:459
#: Other_Calculators/views/tire_size_calculator.py:463
#, python-brace-format
msgid "Rim Diameter: {diameter}\""
msgstr "Diámetro de la llanta: {diameter}\""

#: Other_Calculators/views/tire_size_calculator.py:461
#: Other_Calculators/views/tire_size_calculator.py:497
#, python-brace-format
msgid "Overall Diameter: {diameter}\""
msgstr "Diámetro total: {diameter}\""

#: Other_Calculators/views/tire_size_calculator.py:462
#, python-brace-format
msgid "Width: {width}\""
msgstr "Ancho: {width}\""

#: Other_Calculators/views/tire_size_calculator.py:465
msgid "Step 2: Calculate sidewall height"
msgstr "Paso 2: Calcular la altura de la pared lateral"

#: Other_Calculators/views/tire_size_calculator.py:467
msgid "Sidewall Height = (Width × Aspect Ratio / 100) / 25.4"
msgstr ""
"Altura de la pared lateral = (Ancho × Relación de aspecto / 100) / 25,4"

#: Other_Calculators/views/tire_size_calculator.py:468
#, python-brace-format
msgid "Sidewall Height = ({width} × {ratio} / 100) / 25.4"
msgstr "Altura de la pared lateral = ({width} × {ratio} / 100) / 25,4"

#: Other_Calculators/views/tire_size_calculator.py:470
msgid "Sidewall Height = (Overall Diameter - Rim Diameter) / 2"
msgstr ""
"Altura de la pared lateral = (Diámetro total - Diámetro de la llanta) / 2"

#: Other_Calculators/views/tire_size_calculator.py:471
#, python-brace-format
msgid "Sidewall Height = ({diameter} - {rim}) / 2"
msgstr "Altura de la pared lateral = ({diameter} - {rim}) / 2"

#: Other_Calculators/views/tire_size_calculator.py:472
#, python-brace-format
msgid "Sidewall Height = {height}\""
msgstr "Altura de la pared lateral = {height}\""

#: Other_Calculators/views/tire_size_calculator.py:474
msgid "Step 3: Calculate overall diameter"
msgstr "Paso 3: Calcular el diámetro total"

#: Other_Calculators/views/tire_size_calculator.py:476
msgid "Overall Diameter = Rim Diameter + (2 × Sidewall Height)"
msgstr ""
"Diámetro total = Diámetro de la llanta + (2 × Altura de la pared lateral)"

#: Other_Calculators/views/tire_size_calculator.py:477
#, python-brace-format
msgid "Overall Diameter = {rim} + (2 × {sidewall})"
msgstr "Overall Diameter = {rim} + (2 × {sidewall})"

#: Other_Calculators/views/tire_size_calculator.py:478
#, python-brace-format
msgid "Overall Diameter = {diameter}\""
msgstr "Diámetro total = {diameter}\""

#: Other_Calculators/views/tire_size_calculator.py:480
msgid "Step 4: Calculate circumference"
msgstr "Paso 4: Calcular la circunferencia"

#: Other_Calculators/views/tire_size_calculator.py:481
msgid "Circumference = π × Overall Diameter"
msgstr "Circunferencia = π × Diámetro total"

#: Other_Calculators/views/tire_size_calculator.py:482
#, python-brace-format
msgid "Circumference = π × {diameter}"
msgstr "Circunferencia = π × {diameter}"

#: Other_Calculators/views/tire_size_calculator.py:483
#, python-brace-format
msgid "Circumference = {circ}\""
msgstr "Circunferencia = {circ}\""

#: Other_Calculators/views/tire_size_calculator.py:485
msgid "Step 5: Calculate revolutions"
msgstr "Paso 5: Calcular revoluciones"

#: Other_Calculators/views/tire_size_calculator.py:486
msgid "Revolutions per Mile = 63360 / Circumference"
msgstr "Revoluciones por Milla = 63360 / Circunferencia"

#: Other_Calculators/views/tire_size_calculator.py:487
#, python-brace-format
msgid "Revolutions per Mile = 63360 / {circ} = {rev}"
msgstr "Revoluciones por milla = 63360 / {circ} = {rev}"

#: Other_Calculators/views/tire_size_calculator.py:493
msgid "Step 1: Parse original tire size"
msgstr "Paso 1: analizar el tamaño original del neumático"

#: Other_Calculators/views/tire_size_calculator.py:494
#, python-brace-format
msgid "Original Size: {size} ({format})"
msgstr "Tamaño original: {size} ({format})"

#: Other_Calculators/views/tire_size_calculator.py:496
#: Other_Calculators/views/tire_size_calculator.py:511
msgid "Step 2: Calculate dimensions"
msgstr "Paso 2: Calcular las dimensiones"

#: Other_Calculators/views/tire_size_calculator.py:498
#, python-brace-format
msgid "Width: {width}\" ({width_mm} mm)"
msgstr "Ancho: {width}\" ({width_mm} mm)"

#: Other_Calculators/views/tire_size_calculator.py:500
#, python-brace-format
msgid "Step 3: Convert to {format} format"
msgstr "Paso 3: convertir al formato {format}"

#: Other_Calculators/views/tire_size_calculator.py:501
#, python-brace-format
msgid "Converted Size: {size}"
msgstr "Tamaño convertido: {size}"

#: Other_Calculators/views/tire_size_calculator.py:507
#: Other_Calculators/views/tire_size_calculator.py:528
msgid "Step 1: Identify tire sizes"
msgstr "Paso 1: identificar los tamaños de neumáticos"

#: Other_Calculators/views/tire_size_calculator.py:508
#, python-brace-format
msgid "Tire 1: {size}"
msgstr "Neumático 1: {size}"

#: Other_Calculators/views/tire_size_calculator.py:509
#, python-brace-format
msgid "Tire 2: {size}"
msgstr "Neumático 2: {size}"

#: Other_Calculators/views/tire_size_calculator.py:512
#, python-brace-format
msgid "Tire 1 Diameter: {diameter}\""
msgstr "Diámetro del neumático 1: {diameter}\""

#: Other_Calculators/views/tire_size_calculator.py:513
#, python-brace-format
msgid "Tire 2 Diameter: {diameter}\""
msgstr "Diámetro del neumático 2: {diameter}\""

#: Other_Calculators/views/tire_size_calculator.py:515
msgid "Step 3: Calculate differences"
msgstr "Paso 3: Calcular las diferencias"

#: Other_Calculators/views/tire_size_calculator.py:516
msgid "Diameter Difference = Tire 2 - Tire 1"
msgstr "Diferencia de diámetro = Neumático 2 - Neumático 1"

#: Other_Calculators/views/tire_size_calculator.py:517
#, python-brace-format
msgid "Diameter Difference = {d2} - {d1} = {diff}\""
msgstr "Diferencia de diámetro = {d2} - {d1} = {diff}\""

#: Other_Calculators/views/tire_size_calculator.py:518
#, python-brace-format
msgid "Diameter Difference % = ({diff} / {d1}) × 100 = {percent}%"
msgstr "% de diferencia de diámetro = ({diff} / {d1}) × 100 = {percent}%"

#: Other_Calculators/views/tire_size_calculator.py:520
msgid "Step 4: Speed difference"
msgstr "Paso 4: diferencia de velocidad"

#: Other_Calculators/views/tire_size_calculator.py:521
#, python-brace-format
msgid "Speed Difference = {diff}%"
msgstr "Diferencia de velocidad = {diff}%"

#: Other_Calculators/views/tire_size_calculator.py:522
#, python-brace-format
msgid "When speedometer shows 60 mph, actual speed is {actual} mph"
msgstr ""
"Cuando el velocímetro muestra 60 mph, la velocidad real es {actual} mph"

#: Other_Calculators/views/tire_size_calculator.py:529
#, python-brace-format
msgid "Original Tire: {size}"
msgstr "Neumático original: {size}"

#: Other_Calculators/views/tire_size_calculator.py:530
#, python-brace-format
msgid "New Tire: {size}"
msgstr "Neumático nuevo: {size}"

#: Other_Calculators/views/tire_size_calculator.py:532
msgid "Step 2: Calculate diameters"
msgstr "Paso 2: Calcular diámetros"

#: Other_Calculators/views/tire_size_calculator.py:533
#, python-brace-format
msgid "Original Diameter: {diameter}\""
msgstr "Diámetro original: {diameter}\""

#: Other_Calculators/views/tire_size_calculator.py:534
#, python-brace-format
msgid "New Diameter: {diameter}\""
msgstr "Nuevo diámetro: {diameter}\""

#: Other_Calculators/views/tire_size_calculator.py:536
msgid "Step 3: Calculate diameter ratio"
msgstr "Paso 3: Calcular la relación de diámetros"

#: Other_Calculators/views/tire_size_calculator.py:537
msgid "Diameter Ratio = New Diameter / Original Diameter"
msgstr "Relación de diámetro = Diámetro nuevo / Diámetro original"

#: Other_Calculators/views/tire_size_calculator.py:538
#, python-brace-format
msgid "Diameter Ratio = {new} / {original} = {ratio}"
msgstr "Relación de diámetro = {new} / {original} = {ratio}"

#: Other_Calculators/views/tire_size_calculator.py:540
msgid "Step 4: Calculate actual speed"
msgstr "Paso 4: Calcular la velocidad real"

#: Other_Calculators/views/tire_size_calculator.py:541
msgid "Actual Speed = Indicated Speed × Diameter Ratio"
msgstr "Velocidad real = Velocidad indicada × Relación de diámetro"

#: Other_Calculators/views/tire_size_calculator.py:542
#, python-brace-format
msgid "Actual Speed = {speed} × {ratio} = {actual}"
msgstr "Velocidad real = {speed} × {ratio} = {actual}"

#: Other_Calculators/views/tire_size_calculator.py:544
msgid "Step 5: Calculate speed difference"
msgstr "Paso 5: Calcular la diferencia de velocidad"

#: Other_Calculators/views/tire_size_calculator.py:545
msgid "Speed Difference = Actual Speed - Indicated Speed"
msgstr "Diferencia de velocidad = Velocidad real - Velocidad indicada"

#: Other_Calculators/views/tire_size_calculator.py:546
#, python-brace-format
msgid "Speed Difference = {actual} - {speed} = {diff}"
msgstr "Diferencia de velocidad = {actual} - {speed} = {diff}"

#: Other_Calculators/views/tire_size_calculator.py:547
#, python-brace-format
msgid "Speed Difference % = {percent}%"
msgstr "% de diferencia de velocidad = {percent}%"

#: Other_Calculators/views/tire_size_calculator.py:557
msgid "Width (in)"
msgstr "Ancho (pulg.)"

#: Other_Calculators/views/tire_size_calculator.py:557
msgid "Sidewall (in)"
msgstr "Pared lateral (pulg.)"

#: Other_Calculators/views/tire_size_calculator.py:557
msgid "Diameter (in)"
msgstr "Diámetro (pulg.)"

#: Other_Calculators/views/tire_size_calculator.py:557
msgid "Circumference (in)"
msgstr "Circunferencia (pulg)"

#: Other_Calculators/views/tire_size_calculator.py:637
msgid "Tire Comparison"
msgstr "Comparación de neumáticos"

#: Other_Calculators/views/voltage_drop_calculator.py:132
msgid "Length must be greater than zero."
msgstr "La longitud debe ser mayor que cero."

#: Other_Calculators/views/voltage_drop_calculator.py:138
msgid "Invalid wire material."
msgstr "Material de alambre no válido."

#: Other_Calculators/views/voltage_drop_calculator.py:144
msgid "Invalid wire size."
msgstr "Tamaño de cable no válido."

#: Other_Calculators/views/voltage_drop_calculator.py:195
#, python-brace-format
msgid "Error calculating voltage drop: {error}"
msgstr "Error al calcular la caída de tensión: {error}"

#: Other_Calculators/views/voltage_drop_calculator.py:210
msgid "Maximum voltage drop is required."
msgstr "Se requiere una caída de voltaje máxima."

#: Other_Calculators/views/voltage_drop_calculator.py:278
#, python-brace-format
msgid "Error calculating wire size: {error}"
msgstr "Error al calcular el tamaño del cable: {error}"

#: Other_Calculators/views/voltage_drop_calculator.py:287
#: Other_Calculators/views/voltage_drop_calculator.py:350
msgid "Voltage drop is required."
msgstr "Se requiere caída de voltaje."

#: Other_Calculators/views/voltage_drop_calculator.py:341
#, python-brace-format
msgid "Error calculating max current: {error}"
msgstr "Error al calcular la corriente máxima: {error}"

#: Other_Calculators/views/voltage_drop_calculator.py:401
#, python-brace-format
msgid "Error calculating max length: {error}"
msgstr "Error al calcular la longitud máxima: {error}"

#: Other_Calculators/views/voltage_drop_calculator.py:411
#: Other_Calculators/views/voltage_drop_calculator.py:456
#: Other_Calculators/views/voltage_drop_calculator.py:490
#, python-brace-format
msgid "Length: {length} ft"
msgstr "Longitud: {length} pies"

#: Other_Calculators/views/voltage_drop_calculator.py:412
#: Other_Calculators/views/voltage_drop_calculator.py:491
#: Other_Calculators/views/voltage_drop_calculator.py:518
#, python-brace-format
msgid "Wire Size: {size} AWG"
msgstr "Tamaño del cable: {size} AWG"

#: Other_Calculators/views/voltage_drop_calculator.py:413
#, python-brace-format
msgid "Wire Material: {material}"
msgstr "Material del alambre: {material}"

#: Other_Calculators/views/voltage_drop_calculator.py:414
#, python-brace-format
msgid "Circuit Type: {type}"
msgstr "Tipo de circuito: {type}"

#: Other_Calculators/views/voltage_drop_calculator.py:416
#, python-brace-format
msgid "Power Factor: {pf}"
msgstr "Factor de potencia: {pf}"

#: Other_Calculators/views/voltage_drop_calculator.py:418
#: Other_Calculators/views/voltage_drop_calculator.py:493
msgid "Step 2: Calculate wire resistance"
msgstr "Paso 2: Calcular la resistencia del cable"

#: Other_Calculators/views/voltage_drop_calculator.py:419
#, python-brace-format
msgid "Resistivity: {resistivity} Ω-cmil/ft"
msgstr "Resistividad: {resistivity} Ω-cmil/pie"

#: Other_Calculators/views/voltage_drop_calculator.py:420
#, python-brace-format
msgid "Circular Mils: {cmils} cmil"
msgstr "Mils circulares: {cmils} cmil"

#: Other_Calculators/views/voltage_drop_calculator.py:421
msgid "Resistance = (Resistivity × Length) / Circular Mils"
msgstr "Resistencia = (Resistividad × Longitud) / Mils circulares"

#: Other_Calculators/views/voltage_drop_calculator.py:422
#, python-brace-format
msgid "Resistance = ({resistivity} × {length}) / {cmils}"
msgstr "Resistencia = ({resistivity} × {length}) / {cmils}"

#: Other_Calculators/views/voltage_drop_calculator.py:425
msgid "Step 3: Calculate voltage drop"
msgstr "Paso 3: Calcular la caída de voltaje"

#: Other_Calculators/views/voltage_drop_calculator.py:427
msgid "Voltage Drop = Current × Resistance × 2"
msgstr "Caída de voltaje = Corriente × Resistencia × 2"

#: Other_Calculators/views/voltage_drop_calculator.py:428
#, python-brace-format
msgid "Voltage Drop = {current} × {resistance} × 2"
msgstr "Caída de voltaje = {current} × {resistance} × 2"

#: Other_Calculators/views/voltage_drop_calculator.py:430
msgid "Voltage Drop = Current × Resistance × 2 × Power Factor"
msgstr "Caída de voltaje = Corriente × Resistencia × 2 × Factor de potencia"

#: Other_Calculators/views/voltage_drop_calculator.py:431
#, python-brace-format
msgid "Voltage Drop = {current} × {resistance} × 2 × {pf}"
msgstr "Caída de voltaje = {current} × {resistance} × 2 × {pf}"

#: Other_Calculators/views/voltage_drop_calculator.py:433
msgid "Voltage Drop = Current × Resistance × √3 × Power Factor"
msgstr "Caída de voltaje = Corriente × Resistencia × √3 × Factor de potencia"

#: Other_Calculators/views/voltage_drop_calculator.py:434
#, python-brace-format
msgid "Voltage Drop = {current} × {resistance} × 1.732 × {pf}"
msgstr "Caída de voltaje = {current} × {resistance} × 1,732 × {pf}"

#: Other_Calculators/views/voltage_drop_calculator.py:435
#, python-brace-format
msgid "Voltage Drop = {drop} V"
msgstr "Caída de voltaje = {drop} V"

#: Other_Calculators/views/voltage_drop_calculator.py:437
#: Other_Calculators/views/voltage_drop_calculator.py:507
msgid "Step 4: Calculate percentage drop"
msgstr "Paso 4: Calcular la caída porcentual"

#: Other_Calculators/views/voltage_drop_calculator.py:438
msgid "Voltage Drop % = (Voltage Drop / Voltage) × 100"
msgstr "Caída de voltaje % = (Caída de voltaje / Voltaje) × 100"

#: Other_Calculators/views/voltage_drop_calculator.py:439
#: Other_Calculators/views/voltage_drop_calculator.py:508
#: Other_Calculators/views/voltage_drop_calculator.py:533
#, python-brace-format
msgid "Voltage Drop % = ({drop} / {voltage}) × 100 = {percent}%"
msgstr "% de caída de voltaje = ({drop} / {voltage}) × 100 = {percent}%"

#: Other_Calculators/views/voltage_drop_calculator.py:441
msgid "Step 5: Calculate voltage at load"
msgstr "Paso 5: Calcular el voltaje en carga"

#: Other_Calculators/views/voltage_drop_calculator.py:442
msgid "Voltage at Load = Source Voltage - Voltage Drop"
msgstr "Voltaje en carga = Voltaje de fuente - Caída de voltaje"

#: Other_Calculators/views/voltage_drop_calculator.py:443
#, python-brace-format
msgid "Voltage at Load = {voltage} - {drop} = {load} V"
msgstr "Voltaje en carga = {voltage} - {drop} = {load} V"

#: Other_Calculators/views/voltage_drop_calculator.py:445
msgid "Step 6: Calculate power loss"
msgstr "Paso 6: Calcular la pérdida de energía"

#: Other_Calculators/views/voltage_drop_calculator.py:446
msgid "Power Loss = Current × Voltage Drop"
msgstr "Pérdida de energía = Corriente × Caída de voltaje"

#: Other_Calculators/views/voltage_drop_calculator.py:447
#, python-brace-format
msgid "Power Loss = {current} × {drop} = {loss} W"
msgstr "Pérdida de energía = {current} × {drop} = {loss} W"

#: Other_Calculators/views/voltage_drop_calculator.py:457
#, python-brace-format
msgid "Max Voltage Drop: {drop} {type}"
msgstr "Caída de voltaje máxima: {drop} {type}"

#: Other_Calculators/views/voltage_drop_calculator.py:459
msgid "Step 2: Convert max voltage drop to volts"
msgstr "Paso 2: convierta la caída de voltaje máxima a voltios"

#: Other_Calculators/views/voltage_drop_calculator.py:461
#, python-brace-format
msgid "Max Voltage Drop = ({drop}% / 100) × {voltage} = {volts} V"
msgstr "Caída de voltaje máxima = ({drop}% / 100) × {voltage} = {volts} V"

#: Other_Calculators/views/voltage_drop_calculator.py:463
#, python-brace-format
msgid "Max Voltage Drop = {volts} V"
msgstr "Caída de voltaje máxima = {volts} V"

#: Other_Calculators/views/voltage_drop_calculator.py:465
msgid "Step 3: Calculate maximum resistance"
msgstr "Paso 3: Calcular la resistencia máxima"

#: Other_Calculators/views/voltage_drop_calculator.py:467
msgid "Max Resistance = Max Voltage Drop / (Current × 2)"
msgstr "Resistencia máxima = Caída de voltaje máxima / (Corriente × 2)"

#: Other_Calculators/views/voltage_drop_calculator.py:468
#, python-brace-format
msgid "Max Resistance = {drop} / ({current} × 2) = {resistance} Ω"
msgstr "Resistencia máxima = {drop} / ({current} × 2) = {resistance} Ω"

#: Other_Calculators/views/voltage_drop_calculator.py:470
msgid "Max Resistance = Max Voltage Drop / (Current × 2 × Power Factor)"
msgstr ""
"Resistencia máxima = Caída de voltaje máxima / (Corriente × 2 × Factor de "
"potencia)"

#: Other_Calculators/views/voltage_drop_calculator.py:471
#, python-brace-format
msgid "Max Resistance = {drop} / ({current} × 2 × {pf}) = {resistance} Ω"
msgstr "Resistencia máxima = {drop} / ({current} × 2 × {pf}) = {resistance} Ω"

#: Other_Calculators/views/voltage_drop_calculator.py:473
msgid "Max Resistance = Max Voltage Drop / (Current × √3 × Power Factor)"
msgstr ""
"Resistencia máxima = Caída de voltaje máxima / (Corriente × √3 × Factor de "
"potencia)"

#: Other_Calculators/views/voltage_drop_calculator.py:474
#, python-brace-format
msgid "Max Resistance = {drop} / ({current} × 1.732 × {pf}) = {resistance} Ω"
msgstr ""
"Resistencia máxima = {drop} / ({current} × 1,732 × {pf}) = {resistance} Ω"

#: Other_Calculators/views/voltage_drop_calculator.py:476
msgid "Step 4: Calculate required circular mils"
msgstr "Paso 4: Calcule las mils circulares requeridas"

#: Other_Calculators/views/voltage_drop_calculator.py:477
msgid "Required CM = (Resistivity × Length) / Max Resistance"
msgstr "CM requerido = (Resistividad × Longitud) / Resistencia máxima"

#: Other_Calculators/views/voltage_drop_calculator.py:478
#, python-brace-format
msgid "Required CM = ({resistivity} × {length}) / {resistance} = {cmils} cmil"
msgstr ""
"CM requerido = ({resistivity} × {length}) / {resistance} = {cmils} cmil"

#: Other_Calculators/views/voltage_drop_calculator.py:480
msgid "Step 5: Select appropriate wire size"
msgstr "Paso 5: seleccione el tamaño de cable apropiado"

#: Other_Calculators/views/voltage_drop_calculator.py:481
#, python-brace-format
msgid "Recommended Wire Size: {size} AWG"
msgstr "Tamaño de cable recomendado: {size} AWG"

#: Other_Calculators/views/voltage_drop_calculator.py:488
#: Other_Calculators/views/voltage_drop_calculator.py:515
#, python-brace-format
msgid "Voltage Drop: {drop} V"
msgstr "Caída de voltaje: {drop} V"

#: Other_Calculators/views/voltage_drop_calculator.py:494
#, python-brace-format
msgid "Resistance = ({resistivity} × {length}) / {cmils} = {resistance} Ω"
msgstr "Resistencia = ({resistivity} × {length}) / {cmils} = {resistance} Ω"

#: Other_Calculators/views/voltage_drop_calculator.py:496
msgid "Step 3: Calculate maximum current"
msgstr "Paso 3: Calcular la corriente máxima"

#: Other_Calculators/views/voltage_drop_calculator.py:498
msgid "Max Current = Voltage Drop / (Resistance × 2)"
msgstr "Corriente máxima = Caída de voltaje / (Resistencia × 2)"

#: Other_Calculators/views/voltage_drop_calculator.py:499
#, python-brace-format
msgid "Max Current = {drop} / ({resistance} × 2) = {current} A"
msgstr "Corriente máxima = {drop} / ({resistance} × 2) = {current} A"

#: Other_Calculators/views/voltage_drop_calculator.py:501
msgid "Max Current = Voltage Drop / (Resistance × 2 × Power Factor)"
msgstr ""
"Corriente máxima = Caída de voltaje / (Resistencia × 2 × Factor de potencia)"

#: Other_Calculators/views/voltage_drop_calculator.py:502
#, python-brace-format
msgid "Max Current = {drop} / ({resistance} × 2 × {pf}) = {current} A"
msgstr "Corriente máxima = {drop} / ({resistance} × 2 × {pf}) = {current} A"

#: Other_Calculators/views/voltage_drop_calculator.py:504
msgid "Max Current = Voltage Drop / (Resistance × √3 × Power Factor)"
msgstr ""
"Corriente máxima = Caída de voltaje / (Resistencia × √3 × Factor de "
"potencia)"

#: Other_Calculators/views/voltage_drop_calculator.py:505
#, python-brace-format
msgid "Max Current = {drop} / ({resistance} × 1.732 × {pf}) = {current} A"
msgstr ""
"Corriente máxima = {drop} / ({resistance} × 1,732 × {pf}) = {current} A"

#: Other_Calculators/views/voltage_drop_calculator.py:520
msgid "Step 2: Calculate maximum length"
msgstr "Paso 2: Calcular la longitud máxima"

#: Other_Calculators/views/voltage_drop_calculator.py:522
msgid ""
"Max Length = (Voltage Drop × Circular Mils) / (Current × Resistivity × 2)"
msgstr ""
"Longitud máxima = (Caída de voltaje × Mils circulares) / (Corriente × "
"Resistividad × 2)"

#: Other_Calculators/views/voltage_drop_calculator.py:523
#, python-brace-format
msgid "Max Length = ({drop} × {cmils}) / ({current} × {resistivity} × 2)"
msgstr ""
"Longitud máxima = ({drop} × {cmils}) / ({current} × {resistivity} × 2)"

#: Other_Calculators/views/voltage_drop_calculator.py:525
msgid ""
"Max Length = (Voltage Drop × Circular Mils) / (Current × Resistivity × 2 × "
"Power Factor)"
msgstr ""
"Longitud máxima = (Caída de voltaje × Mils circulares) / (Corriente × "
"Resistividad × 2 × Factor de potencia)"

#: Other_Calculators/views/voltage_drop_calculator.py:526
#, python-brace-format
msgid ""
"Max Length = ({drop} × {cmils}) / ({current} × {resistivity} × 2 × {pf})"
msgstr ""
"Longitud máxima = ({drop} × {cmils}) / ({current} × {resistivity} × 2 × "
"{pf})"

#: Other_Calculators/views/voltage_drop_calculator.py:528
msgid ""
"Max Length = (Voltage Drop × Circular Mils) / (Current × Resistivity × √3 × "
"Power Factor)"
msgstr ""
"Longitud máxima = (Caída de voltaje × Mils circulares) / (Corriente × "
"Resistividad × √3 × Factor de potencia)"

#: Other_Calculators/views/voltage_drop_calculator.py:529
#, python-brace-format
msgid ""
"Max Length = ({drop} × {cmils}) / ({current} × {resistivity} × 1.732 × {pf})"
msgstr ""
"Longitud máxima = ({drop} × {cmils}) / ({current} × {resistivity} × 1,732 × "
"{pf})"

#: Other_Calculators/views/voltage_drop_calculator.py:530
#, python-brace-format
msgid "Max Length = {length} ft"
msgstr "Longitud máxima = {length} pies"

#: Other_Calculators/views/voltage_drop_calculator.py:532
msgid "Step 3: Calculate percentage drop"
msgstr "Paso 3: Calcular la caída porcentual"

