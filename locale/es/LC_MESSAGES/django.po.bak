#: Fitness_and_Health_Calculators/views/index.py:17
msgid "Body Fat Calculator"
msgstr "Calculadora de grasa corporal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:4
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:14
msgid "Calculate Your Body Fat Percentage"
msgstr "Calcule su porcentaje de grasa corporal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:5
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:15
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:59
msgid ""
"Calculate your body fat percentage using the US Navy method. Get insights on"
" lean mass, fat mass, and body composition."
msgstr ""
"Calcule su porcentaje de grasa corporal utilizando el método de la Marina de"
" los EE. UU. Obtenga información sobre masa magra, masa grasa y composición "
"corporal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:10
msgid ""
"body fat calculator, body fat percentage, US Navy method, body composition, "
"fat mass"
msgstr ""
"calculadora de grasa corporal, porcentaje de grasa corporal, método de la "
"Marina de EE. UU., composición corporal, masa grasa"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:24
msgid "Calculate your body fat percentage using the US Navy method."
msgstr ""
"Calcule su porcentaje de grasa corporal utilizando el método de la Marina de"
" los EE. UU."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:156
msgid "Measure just below the larynx"
msgstr "Mida justo debajo de la laringe."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:164
msgid "Measure at navel level"
msgstr "Medir a la altura del ombligo"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:172
msgid "Measure at widest point (required for females)"
msgstr "Mida en el punto más ancho (obligatorio para las mujeres)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:210
msgid ""
"Enter your measurements and click Calculate to see your body fat percentage "
"with detailed charts and body composition analysis."
msgstr ""
"Ingrese sus medidas y haga clic en Calcular para ver su porcentaje de grasa "
"corporal con gráficos detallados y análisis de composición corporal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:232
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:489
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:176
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:349
msgid "Fat Mass"
msgstr "masa grasa"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:238
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:495
msgid "Lean Mass"
msgstr "Masa magra"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:244
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:501
msgid "Ideal Weight"
msgstr "Peso Ideal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:250
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:203
msgid "BMI"
msgstr "IMC"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:278
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:208
msgid "Body Composition"
msgstr "Composición corporal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:292
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:383
msgid "Body Fat Categories"
msgstr "Categorías de grasa corporal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:305
msgid "Your Body Fat vs Ideal Range"
msgstr "Su grasa corporal frente a su rango ideal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:317
#: core/templates/core/cookie_policy.html:313
msgid "Essential"
msgstr "Básico"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:318
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:395
msgid "Athletes"
msgstr "Atletas"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:319
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:404
msgid "Fitness"
msgstr "Aptitud física"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:320
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:413
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:573
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:577
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:578
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:579
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:580
#: Other_Calculators/templates/other_calculators/btu_calculator.html:259
#: Other_Calculators/templates/other_calculators/btu_calculator.html:317
#: Other_Calculators/templates/other_calculators/btu_calculator.html:409
#: Other_Calculators/templates/other_calculators/btu_calculator.html:691
#: Other_Calculators/templates/other_calculators/dice_roller.html:535
msgid "Average"
msgstr "Promedio"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:355
msgid "What is Body Fat Percentage?"
msgstr "¿Qué es el porcentaje de grasa corporal?"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:357
msgid ""
"Body fat percentage is the proportion of fat mass to total body weight. "
"Unlike BMI, which only considers weight and height, body fat percentage "
"provides a more accurate assessment of body composition by distinguishing "
"between fat mass and lean mass (muscle, bone, organs, water)."
msgstr ""
"El porcentaje de grasa corporal es la proporción de masa grasa con respecto "
"al peso corporal total. A diferencia del IMC, que sólo considera el peso y "
"la altura, el porcentaje de grasa corporal proporciona una evaluación más "
"precisa de la composición corporal al distinguir entre masa grasa y masa "
"magra (músculo, hueso, órganos, agua)."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:360
msgid ""
"Knowing your body fat percentage helps you understand your health status "
"better than weight alone, as it accounts for muscle mass and overall body "
"composition."
msgstr ""
"Conocer su porcentaje de grasa corporal le ayuda a comprender su estado de "
"salud mejor que el peso solo, ya que tiene en cuenta la masa muscular y la "
"composición corporal general."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:366
msgid "US Navy Body Fat Method"
msgstr "Método de grasa corporal de la Marina de EE. UU."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:368
msgid ""
"This calculator uses the US Navy body fat estimation method, which is one of"
" the most accurate measurement-based formulas available. It uses body "
"circumference measurements (neck, waist, and hip for women) along with "
"height to estimate body fat percentage."
msgstr ""
"Esta calculadora utiliza el método de estimación de grasa corporal de la "
"Marina de los EE. UU., que es una de las fórmulas basadas en mediciones más "
"precisas disponibles. Utiliza medidas de circunferencia corporal (cuello, "
"cintura y cadera para mujeres) junto con la altura para estimar el "
"porcentaje de grasa corporal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:371
msgid "For Men:"
msgstr "Para hombres:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:372
#, python-format
msgid ""
"Body Fat %% = 495 / (1.0324 - 0.19077 × log10(waist - neck) + 0.15456 × "
"log10(height)) - 450"
msgstr ""
"Grasa corporal %% = 495 / (1,0324 - 0,19077 × log10(cintura - cuello) + "
"0,15456 × log10(altura)) - 450"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:373
msgid "For Women:"
msgstr "Para mujeres:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:374
#, python-format
msgid ""
"Body Fat %% = 495 / (1.29579 - 0.35004 × log10(waist + hip - neck) + 0.22100"
" × log10(height)) - 450"
msgstr ""
"Grasa corporal %% = 495 / (1,29579 - 0,35004 × log10 (cintura + cadera - "
"cuello) + 0,22100 × log10 (altura)) - 450"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:377
msgid ""
"All measurements are in centimeters. The formula uses logarithmic "
"calculations to provide accurate estimates based on body circumference "
"measurements."
msgstr ""
"Todas las medidas están en centímetros. La fórmula utiliza cálculos "
"logarítmicos para proporcionar estimaciones precisas basadas en medidas de "
"circunferencia corporal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:386
msgid "Essential Fat"
msgstr "Grasa esencial"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:388
#, python-format
msgid "Men: 2-5%% | Women: 10-13%%"
msgstr "Hombres: 2-5%% | Mujeres: 10-13%%"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:391
msgid ""
"The minimum amount of body fat necessary for basic physiological functions. "
"Below this level can be dangerous."
msgstr ""
"La cantidad mínima de grasa corporal necesaria para las funciones "
"fisiológicas básicas. Por debajo de este nivel puede ser peligroso."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:397
#, python-format
msgid "Men: 6-13%% | Women: 14-20%%"
msgstr "Hombres: 6-13%% | Mujeres: 14-20%%"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:400
msgid ""
"Very lean body fat levels typical of competitive athletes. Excellent muscle "
"definition."
msgstr ""
"Niveles de grasa corporal muy magros típicos de los atletas competitivos. "
"Excelente definición muscular."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:406
#, python-format
msgid "Men: 14-17%% | Women: 21-24%%"
msgstr "Hombres: 14-17%% | Mujeres: 21-24%%"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:409
msgid ""
"Good body fat level for active individuals. Visible muscle definition, "
"healthy appearance."
msgstr ""
"Buen nivel de grasa corporal para personas activas. Definición muscular "
"visible, apariencia saludable."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:415
#, python-format
msgid "Men: 18-24%% | Women: 25-31%%"
msgstr "Hombres: 18-24%% | Mujeres: 25-31%%"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:418
msgid ""
"Average body fat level for the general population. May have some excess fat "
"but generally healthy."
msgstr ""
"Nivel medio de grasa corporal para la población general. Puede tener algo de"
" exceso de grasa pero en general es saludable."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:424
#, python-format
msgid "Men: >25%% | Women: >32%%"
msgstr "Hombres: >25%% | Mujeres: >32%%"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:427
msgid ""
"Excess body fat that may increase health risks. Consider consulting with a "
"healthcare provider."
msgstr ""
"Exceso de grasa corporal que puede aumentar los riesgos para la salud. "
"Considere consultar con un proveedor de atención médica."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:438
msgid "Select your gender (affects the formula used)"
msgstr "Seleccione su género (afecta la fórmula utilizada)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:439
msgid "Enter your age, height, and weight"
msgstr "Ingrese su edad, altura y peso"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:444
msgid "Review charts and body composition analysis"
msgstr "Revisar gráficos y análisis de composición corporal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:455
msgid ""
"Measure just below the larynx (Adam's apple) with the tape sloping slightly "
"downward at the front. Keep the tape horizontal and snug but not tight."
msgstr ""
"Mida justo debajo de la laringe (nuez de Adán) con la cinta ligeramente "
"inclinada hacia abajo en la parte delantera. Mantenga la cinta horizontal y "
"ajustada pero no apretada."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:461
msgid ""
"Measure at your navel level (belly button), not at the narrowest point. "
"Stand straight, breathe normally, and measure at the end of a normal breath."
" Keep the tape level and parallel to the floor."
msgstr ""
"Mida a la altura del ombligo (ombligo), no en el punto más estrecho. Párese "
"derecho, respire normalmente y mida al final de una respiración normal. "
"Mantenga la cinta nivelada y paralela al suelo."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:467
msgid ""
"Measure around the hips at the widest point. This is typically around the "
"buttocks area. Keep the tape measure horizontal and parallel to the floor."
msgstr ""
"Mide alrededor de las caderas en el punto más ancho. Suele ocurrir alrededor"
" del área de las nalgas. Mantenga la cinta métrica horizontal y paralela al "
"suelo."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:473
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:388
msgid "Tip:"
msgstr "Consejo:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:473
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:388
msgid ""
"For best accuracy, take measurements in the morning before eating, and "
"measure multiple times to ensure consistency."
msgstr ""
"Para obtener la mayor precisión, tome medidas por la mañana antes de comer y"
" mida varias veces para garantizar la coherencia."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:485
msgid ""
"Your estimated body fat percentage based on the US Navy formula. This is an "
"estimate and may vary from other measurement methods like DEXA scan or "
"hydrostatic weighing."
msgstr ""
"Su porcentaje de grasa corporal estimado según la fórmula de la Marina de "
"los EE. UU. Esta es una estimación y puede variar de otros métodos de "
"medición como el escaneo DEXA o el pesaje hidrostático."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:491
msgid ""
"The total weight of fat in your body, calculated as a percentage of your "
"total body weight."
msgstr ""
"El peso total de grasa en su cuerpo, calculado como porcentaje de su peso "
"corporal total."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:497
msgid ""
"The total weight of everything except fat: muscle, bone, organs, and water. "
"Higher lean mass generally indicates better fitness and health."
msgstr ""
"El peso total de todo excepto la grasa: músculos, huesos, órganos y agua. "
"Una mayor masa magra generalmente indica una mejor condición física y salud."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:503
#, python-format
msgid ""
"An estimated weight at which you would have an ideal body fat percentage "
"(10-20%% for men, 18-28%% for women) while maintaining your current lean "
"mass."
msgstr ""
"Un peso estimado en el que tendrías un porcentaje de grasa corporal ideal "
"(10-20%% para hombres, 18-28%% para mujeres) manteniendo tu masa magra "
"actual."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:509
msgid ""
"Your body fat classification based on gender-specific ranges. This helps you"
" understand where you stand relative to health and fitness standards."
msgstr ""
"Su clasificación de grasa corporal basada en rangos específicos de género. "
"Esto le ayudará a comprender su situación en relación con los estándares de "
"salud y estado físico."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:523
msgid ""
"This calculator provides ESTIMATES based on body measurements. Actual body "
"fat percentage may vary when measured with more precise methods like DEXA "
"scan, hydrostatic weighing, or BodPod."
msgstr ""
"Esta calculadora proporciona ESTIMACIONES basadas en medidas corporales. El "
"porcentaje de grasa corporal real puede variar cuando se mide con métodos "
"más precisos como el escaneo DEXA, el pesaje hidrostático o BodPod."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:529
msgid ""
"Accurate measurements are crucial. Measure at the same time of day, "
"preferably in the morning before eating, and ensure the tape measure is "
"level and snug but not tight."
msgstr ""
"Las mediciones precisas son cruciales. Mida a la misma hora del día, "
"preferiblemente por la mañana antes de comer, y asegúrese de que la cinta "
"métrica esté nivelada y ajustada, pero no apretada."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:535
msgid ""
"Body fat percentage is just one indicator of health. Consider other factors "
"like blood pressure, cholesterol, blood sugar, and overall fitness level."
msgstr ""
"El porcentaje de grasa corporal es sólo un indicador de salud. Considere "
"otros factores como la presión arterial, el colesterol, el azúcar en sangre "
"y el nivel general de condición física."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:541
msgid ""
"This calculator is for educational and informational purposes only. Always "
"consult with a healthcare provider or registered dietitian for personalized "
"health advice."
msgstr ""
"Esta calculadora tiene fines educativos e informativos únicamente. Consulte "
"siempre con un proveedor de atención médica o un dietista registrado para "
"obtener asesoramiento de salud personalizado."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:548
msgid "Tips for Healthy Body Fat Levels"
msgstr "Consejos para niveles saludables de grasa corporal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:550
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/healthy_weight_calculator.html:374
msgid "Regular Exercise:"
msgstr "Ejercicio regular:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:550
msgid ""
"Combine cardiovascular exercise with strength training to build lean muscle "
"and reduce body fat."
msgstr ""
"Combine ejercicio cardiovascular con entrenamiento de fuerza para "
"desarrollar músculo magro y reducir la grasa corporal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:551
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/healthy_weight_calculator.html:373
msgid "Balanced Diet:"
msgstr "Alimentación equilibrada:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:551
msgid ""
"Focus on whole foods, adequate protein, and appropriate calorie intake for "
"your goals."
msgstr ""
"Concéntrese en alimentos integrales, proteínas adecuadas y una ingesta "
"calórica adecuada para sus objetivos."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:552
msgid "Consistency:"
msgstr "Consistencia:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:552
msgid ""
"Sustainable changes over time are more effective than quick fixes. Aim for "
"gradual progress."
msgstr ""
"Los cambios sostenibles en el tiempo son más efectivos que las soluciones "
"rápidas. Apunte a un progreso gradual."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:553
msgid "Sleep:"
msgstr "Dormir:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:553
msgid "Adequate sleep (7-9 hours) supports metabolism and hormone regulation."
msgstr ""
"Dormir lo suficiente (7-9 horas) favorece el metabolismo y la regulación "
"hormonal."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:554
msgid "Stress Management:"
msgstr "Manejo del estrés:"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:554
msgid ""
"Chronic stress can affect body composition. Practice stress-reduction "
"techniques."
msgstr ""
"El estrés crónico puede afectar la composición corporal. Practique técnicas "
"de reducción del estrés."

