#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:249
msgid "What is a Time Zone?"
msgstr "¿Qué es una zona horaria?"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:250
msgid ""
"A time zone is a region that observes a uniform standard time for legal, "
"commercial, and social purposes."
msgstr ""
"Una zona horaria es una región que observa una hora estándar uniforme para "
"fines legales, comerciales y sociales."

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:257
msgid "Enter time and select timezones"
msgstr "Ingrese la hora y seleccione zonas horarias"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:272
msgid "Common Time Zones"
msgstr "Zonas horarias comunes"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:274
msgid "Coordinated Universal Time"
msgstr "Hora universal coordinada"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:275
msgid "Eastern Time (US)"
msgstr "Hora del este (EE. UU.)"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:276
msgid "Central Time (US)"
msgstr "Hora central (EE. UU.)"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:277
msgid "Mountain Time (US)"
msgstr "Hora de la montaña (EE. UU.)"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:278
msgid "Pacific Time (US)"
msgstr "Hora del Pacífico (EE. UU.)"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:279
msgid "Greenwich Mean Time"
msgstr "Hora media de Greenwich"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:280
msgid "Central European Time"
msgstr "Hora de Europa Central"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:281
msgid "Japan Standard Time"
msgstr "Hora estándar de Japón"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:282
msgid "India Standard Time"
msgstr "Hora estándar de la India"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:287
msgid "Daylight Saving Time"
msgstr "Horario de verano"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:288
msgid ""
"Some time zones observe Daylight Saving Time (DST), which shifts clocks "
"forward by one hour during summer months. Examples: EDT, CDT, MDT, PDT, "
"CEST, EEST, AEDT, NZDT."
msgstr ""
"Algunas zonas horarias observan el horario de verano (DST), que adelanta los"
" relojes una hora durante los meses de verano. Ejemplos: EDT, CDT, MDT, PDT,"
" CEST, EEST, AEDT, NZDT."

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:292
msgid "UTC Offsets"
msgstr "Compensaciones UTC"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:294
msgid "UTC offsets are expressed as hours ahead (+) or behind (-) UTC"
msgstr ""
"Las compensaciones UTC se expresan como horas adelantadas (+) o retrasadas "
"(-) UTC"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:295
msgid "Example: EST is UTC-5, meaning 5 hours behind UTC"
msgstr "Ejemplo: EST es UTC-5, lo que significa 5 horas detrás de UTC"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:296
msgid "Example: JST is UTC+9, meaning 9 hours ahead of UTC"
msgstr "Ejemplo: JST es UTC+9, lo que significa 9 horas por delante de UTC"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:304
msgid "DST dates vary by location and year"
msgstr "Las fechas de horario de verano varían según la ubicación y el año."

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:305
msgid "Some regions don't observe DST"
msgstr "Algunas regiones no observan el horario de verano"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:306
msgid "UTC is the standard reference"
msgstr "UTC es la referencia estándar"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:307
msgid "Time differences account for day changes"
msgstr "Las diferencias horarias tienen en cuenta los cambios de día."

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:314
msgid "International meetings"
msgstr "Reuniones internacionales"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:316
msgid "Remote work coordination"
msgstr "Coordinación de trabajo remoto"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:317
msgid "Event scheduling"
msgstr "Programación de eventos"

#: Other_Calculators/templates/other_calculators/time_zone_calculator.html:318
msgid "Business communications"
msgstr "Comunicaciones empresariales"

