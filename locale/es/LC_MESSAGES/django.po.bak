msgstr "Saldo del préstamo"

#: Financial_Calculators/templates/financial_calculators/budget_calculator.html:4
msgid "Budget Calculator - Plan Your Monthly Budget"
msgstr "Calculadora de presupuesto: planifique su presupuesto mensual"

#: Financial_Calculators/templates/financial_calculators/budget_calculator.html:5
msgid ""
"Create a personal budget with our free calculator. Track income and "
"expenses, see spending breakdowns, and get budget recommendations."
msgstr ""
"Crea un presupuesto personal con nuestra calculadora gratuita. Realice un "
"seguimiento de los ingresos y gastos, vea los desgloses de gastos y obtenga "
"recomendaciones presupuestarias."

#: Financial_Calculators/templates/financial_calculators/budget_calculator.html:6
msgid ""
"budget calculator, personal budget, monthly budget planner, expense tracker,"
" budget planning tool"
msgstr ""
