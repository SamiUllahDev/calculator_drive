msgstr "Fórmula: MPG = Distancia / Combustible"

#: Other_Calculators/views/fuel_cost_calculator.py:928
#: Other_Calculators/views/gas_mileage_calculator.py:780
#, python-brace-format
msgid "MPG = {dist} miles / {fuel} gallons"
msgstr "MPG = {dist} millas / {fuel} galones"

#: Other_Calculators/views/fuel_cost_calculator.py:929
#: Other_Calculators/views/gas_mileage_calculator.py:781
#, python-brace-format
msgid "MPG = {mpg}"
msgstr "MPG = {mpg}"

#: Other_Calculators/views/fuel_cost_calculator.py:933
msgid "Formula: L/100km = 235.214 / MPG"
msgstr "Fórmula: L/100 km = 235,214 / MPG"

#: Other_Calculators/views/fuel_cost_calculator.py:934
#, python-brace-format
msgid "L/100km = 235.214 / {mpg}"
msgstr "L/100 km = 235,214 / {mpg}"

#: Other_Calculators/views/fuel_cost_calculator.py:935
