msgstr "Tiempo en {unit} = {seconds} ÷ {factor} = {result} {unit}"

#: Other_Calculators/views/time_calculator.py:451
#, python-brace-format
msgid "Start Time: {start}"
msgstr "Hora de inicio: {start}"

#: Other_Calculators/views/time_calculator.py:452
