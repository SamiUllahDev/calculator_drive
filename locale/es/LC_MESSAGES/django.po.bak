msgstr "Masa = Peso / Gravedad"

#: Other_Calculators/views/weight_calculator.py:445
#: Other_Calculators/views/weight_calculator.py:459
#, python-brace-format
msgid "Mass = {weight} / {gravity} = {mass} kg"
msgstr "Masa = {weight} / {gravity} = {mass} kg"

