msgstr ""
"Ingrese su altura y peso para calcular su área de superficie corporal (BSA) "
"utilizando múltiples fórmulas comprobadas."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:161
msgid "Average Body Surface Area"
msgstr "Área de superficie corporal promedio"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:163
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/ideal_weight_calculator.html:184
