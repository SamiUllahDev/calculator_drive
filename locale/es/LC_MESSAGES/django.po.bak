msgstr "Máximo"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:4
msgid "Health & Fitness Calculators Online"
msgstr "Calculadoras de salud y fitness en línea"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:4
msgid "Free Health Tools"
msgstr "Herramientas de salud gratuitas"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:8
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:142
msgid "free health and fitness calculators across"
msgstr "calculadoras gratuitas de salud y fitness en"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:8
msgid ""
"categories. Professional tools for fitness tracking, nutrition planning, "
"pregnancy monitoring, and health assessment. Calculate BMI, calorie needs, "
"body fat, and more instantly."
msgstr ""
"categorías. Herramientas profesionales para seguimiento del estado físico, "
"planificación nutricional, seguimiento del embarazo y evaluación de la "
"salud. Calcule el IMC, las necesidades calóricas, la grasa corporal y más al"
" instante."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:12
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:17
msgid "Health & Fitness Calculators - Wellness Tools"
msgstr "Calculadoras de salud y fitness - Herramientas de bienestar"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:13
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:18
msgid "health and fitness calculators across"
msgstr "calculadoras de salud y fitness en todo"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/index.html:13
msgid ""
