msgstr "Pago de horas extras = Horas extras × Tarifa de horas extras"

#: Other_Calculators/views/time_card_calculator.py:409
#, python-brace-format
msgid "Overtime Pay = {hours} × {rate} = {pay} {currency}"
msgstr "Pago de horas extras = {hours} × {rate} = {pay} {currency}"

#: Other_Calculators/views/time_card_calculator.py:411
msgid "Step 5: Calculate total pay"
msgstr "Paso 5: Calcular el pago total"

#: Other_Calculators/views/time_card_calculator.py:412
msgid "Total Pay = Regular Pay + Overtime Pay"
msgstr "Pago Total = Pago Regular + Pago de Horas Extras"

#: Other_Calculators/views/time_card_calculator.py:413
#, python-brace-format
msgid "Total Pay = {regular} + {overtime} = {total} {currency}"
msgstr "Total Pay = {regular} + {overtime} = {total} {currency}"

