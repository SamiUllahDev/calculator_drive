msgstr "Por favor introduzca ambos tamaños de neumáticos"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:506
msgid "Rev/Mile"
msgstr "Rev/Milla"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:510
msgid "Rev/Km"
msgstr "revoluciones/km"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:536
msgid "Differences"
msgstr "Diferencias"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:539
