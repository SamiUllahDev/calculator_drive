#: Math_Calculators/templates/math_calculators/matrix_calculator.html:263
msgid "What is a Matrix?"
msgstr "¿Qué es una matriz?"

#: Math_Calculators/templates/math_calculators/matrix_calculator.html:265
msgid ""
"A matrix is a rectangular array of numbers arranged in rows and columns. "
"Matrices are used in mathematics, physics, computer science, and many other "
"fields."
msgstr ""
"Una matriz es una matriz rectangular de números dispuestos en filas y "
"columnas. Las matrices se utilizan en matemáticas, física, informática y "
"muchos otros campos."

#: Math_Calculators/templates/math_calculators/matrix_calculator.html:268
msgid "Example: A 2×2 matrix has 2 rows and 2 columns: [[a, b], [c, d]]"
msgstr ""
"Ejemplo: Una matriz de 2×2 tiene 2 filas y 2 columnas: [[a, b], [c, d]]"

#: Math_Calculators/templates/math_calculators/matrix_calculator.html:273
msgid "Matrix Operations"
msgstr "Operaciones matriciales"

#: Math_Calculators/templates/math_calculators/matrix_calculator.html:275
msgid "Add corresponding elements (matrices must have same dimensions)"
msgstr ""
"Agregue los elementos correspondientes (las matrices deben tener las mismas "
"dimensiones)"

#: Math_Calculators/templates/math_calculators/matrix_calculator.html:276
msgid "Subtract corresponding elements (matrices must have same dimensions)"
msgstr ""
"Restar los elementos correspondientes (las matrices deben tener las mismas "
"dimensiones)"

#: Math_Calculators/templates/math_calculators/matrix_calculator.html:277
msgid "Multiply matrices (columns of first must equal rows of second)"
msgstr ""
"Multiplicar matrices (las columnas de la primera deben ser iguales a las "
"filas de la segunda)"

