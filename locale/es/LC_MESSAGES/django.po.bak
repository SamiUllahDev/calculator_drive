#: Other_Calculators/views/gpa_calculator.py:305
msgid "Step 1: Identify all courses and grades"
msgstr "Paso 1: Identificar todos los cursos y grados"

#: Other_Calculators/views/gpa_calculator.py:307
#, python-brace-format
msgid "Course {num}: {name} - Grade: {grade}, Credits: {credits}"
msgstr "Curso {num}: {name} - Calificación: {grade}, Créditos: {credits}"

#: Other_Calculators/views/gpa_calculator.py:311
msgid "Step 2: Calculate quality points for each course"
msgstr "Paso 2: Calcula los puntos de calidad para cada curso"

#: Other_Calculators/views/gpa_calculator.py:312
msgid "Formula: Quality Points = Grade Points × Credits"
msgstr "Fórmula: Puntos de calidad = Puntos de calificación × Créditos"

#: Other_Calculators/views/gpa_calculator.py:314
#, python-brace-format
msgid "{name}: {points} × {credits} = {qp} quality points"
msgstr "{name}: {points} × {credits} = {qp} puntos de calidad"

#: Other_Calculators/views/gpa_calculator.py:318
msgid "Step 3: Calculate total quality points"
msgstr "Paso 3: Calcular los puntos de calidad totales"

#: Other_Calculators/views/gpa_calculator.py:320
#, python-brace-format
msgid "Total Quality Points = {points}"
msgstr "Puntos de calidad totales = {points}"

#: Other_Calculators/views/gpa_calculator.py:321
#, python-brace-format
msgid "Total Quality Points = {total}"
msgstr "Puntos de calidad totales = {total}"

#: Other_Calculators/views/gpa_calculator.py:323
msgid "Step 4: Calculate total credits"
msgstr "Paso 4: Calcular los créditos totales"

#: Other_Calculators/views/gpa_calculator.py:325
#, python-brace-format
msgid "Total Credits = {credits}"
msgstr "Créditos totales = {credits}"

#: Other_Calculators/views/gpa_calculator.py:326
#, python-brace-format
msgid "Total Credits = {total}"
msgstr "Créditos totales = {total}"

#: Other_Calculators/views/gpa_calculator.py:328
msgid "Step 5: Calculate Semester GPA"
msgstr "Paso 5: Calcular el GPA semestral"

#: Other_Calculators/views/gpa_calculator.py:329
msgid "Formula: GPA = Total Quality Points / Total Credits"
msgstr "Fórmula: GPA = Puntos totales de calidad / Créditos totales"

#: Other_Calculators/views/gpa_calculator.py:330
#, python-brace-format
msgid "GPA = {points} / {credits}"
msgstr "GPA = {points} / {credits}"

#: Other_Calculators/views/gpa_calculator.py:331
#, python-brace-format
msgid "Semester GPA = {gpa} (on {scale} scale)"
msgstr "GPA semestral = {gpa} (en escala {scale})"

#: Other_Calculators/views/gpa_calculator.py:335
msgid "Step 6: Calculate Cumulative GPA"
msgstr "Paso 6: Calcular el GPA acumulativo"

#: Other_Calculators/views/gpa_calculator.py:337
#, python-brace-format
msgid "Previous Quality Points = {gpa} × {credits} = {points}"
msgstr "Puntos de calidad anteriores = {gpa} × {credits} = {points}"

#: Other_Calculators/views/gpa_calculator.py:341
#, python-brace-format
msgid "Cumulative Quality Points = {prev} + {new} = {total}"
msgstr "Puntos de calidad acumulados = {prev} + {new} = {total}"

#: Other_Calculators/views/gpa_calculator.py:344
#, python-brace-format
msgid "Cumulative Credits = {prev} + {new} = {total}"
msgstr "Créditos acumulativos = {prev} + {new} = {total}"

#: Other_Calculators/views/gpa_calculator.py:347
#, python-brace-format
msgid "Cumulative GPA = {points} / {credits} = {gpa}"
msgstr "GPA acumulado = {points} / {credits} = {gpa}"

