#: user/templates/user/password_change.html:6
msgid "Update your account password"
msgstr "Actualiza la contraseña de tu cuenta"

#: user/templates/user/password_change.html:18
msgid "Update your password to keep your account secure"
msgstr "Actualice su contraseña para mantener su cuenta segura"

#: user/templates/user/password_change.html:73
#: user/templates/user/password_reset_confirm.html:59
msgid ""
"Your password must contain at least 8 characters and cannot be entirely "
"numeric."
msgstr ""
"Su contraseña debe contener al menos 8 caracteres y no puede ser "
"completamente numérica."

#: user/templates/user/password_change.html:102
msgid "Back"
msgstr "Atrás"

#: user/templates/user/password_change.html:115
msgid "Forgot your password?"
msgstr "¿Olvidaste tu contraseña?"

#: user/templates/user/password_change.html:132
msgid "Use a unique password you don't use elsewhere"
msgstr "Utilice una contraseña única que no utilice en ningún otro lugar"

#: user/templates/user/password_change.html:136
msgid "Include uppercase letters, numbers, and symbols"
msgstr "Incluir letras mayúsculas, números y símbolos."

#: user/templates/user/password_change.html:140
msgid "Avoid using personal information or common words"
msgstr "Evite el uso de información personal o palabras comunes."

#: user/templates/user/password_change.html:144
msgid "Consider using a password manager"
msgstr "Considere usar un administrador de contraseñas"

#: user/templates/user/password_change_done.html:17
msgid "Password Changed Successfully"
msgstr "Contraseña cambiada exitosamente"

#: user/templates/user/password_change_done.html:18
msgid "Your account is now protected with your new password"
msgstr "Su cuenta ahora está protegida con su nueva contraseña"

#: user/templates/user/password_change_done.html:26
msgid ""
"Your password was changed successfully. You can now use your new password to"
" log in."
msgstr ""
"Su contraseña fue cambiada exitosamente. Ahora puede utilizar su nueva "
"contraseña para iniciar sesión."

#: user/templates/user/password_change_done.html:34
msgid "Go to Your Profile"
msgstr "Ir a tu perfil"

#: user/templates/user/password_change_done.html:38
msgid "Back to Account Settings"
msgstr "Volver a la configuración de la cuenta"

#: user/templates/user/password_reset.html:7
#: user/templates/user/password_reset_email.html:6
msgid "Reset your account password"
msgstr "Restablecer la contraseña de tu cuenta"

#: user/templates/user/password_reset.html:20
msgid ""
"Enter your email address and we'll send you a link to reset your password"
msgstr ""
"Ingresa tu dirección de correo electrónico y te enviaremos un enlace para "
"restablecer tu contraseña"

#: user/templates/user/password_reset.html:63
msgid "Send Reset Link"
msgstr "Enviar enlace de reinicio"

#: user/templates/user/password_reset.html:79
#: user/templates/user/password_reset_confirm.html:132
msgid "Back to Login"
msgstr "Volver a iniciar sesión"

#: user/templates/user/password_reset_complete.html:5
#: user/templates/user/password_reset_complete.html:17
msgid "Password Reset Complete"
msgstr "Restablecimiento de contraseña completo"

#: user/templates/user/password_reset_complete.html:6
msgid "Your password has been successfully reset"
msgstr "Su contraseña ha sido restablecida exitosamente"

#: user/templates/user/password_reset_complete.html:26
msgid "Your password has been set. You may now log in with your new password."
msgstr ""
"Su contraseña ha sido establecida. Ahora puede iniciar sesión con su nueva "
"contraseña."

#: user/templates/user/password_reset_complete.html:34
msgid "Log In Now"
msgstr "Iniciar sesión ahora"

#: user/templates/user/password_reset_complete.html:48
msgid "Keep your password confidential and never share it with others"
msgstr "Mantenga su contraseña confidencial y nunca la comparta con otros"

#: user/templates/user/password_reset_complete.html:52
msgid "Always log out when using shared computers"
msgstr "Cerrar sesión siempre cuando utilices ordenadores compartidos"

#: user/templates/user/password_reset_complete.html:56
msgid "Consider enabling two-factor authentication for added security"
msgstr ""
"Considere habilitar la autenticación de dos factores para mayor seguridad"

#: user/templates/user/password_reset_confirm.html:5
#: user/templates/user/password_reset_confirm.html:18
msgid "Set New Password"
msgstr "Establecer nueva contraseña"

#: user/templates/user/password_reset_confirm.html:6
msgid "Set a new password for your account"
msgstr "Establece una nueva contraseña para tu cuenta"

#: user/templates/user/password_reset_confirm.html:19
msgid "Choose a new password for your account"
msgstr "Elija una nueva contraseña para su cuenta"

#: user/templates/user/password_reset_confirm.html:21
msgid "Invalid Password Reset Link"
msgstr "Enlace de restablecimiento de contraseña no válido"

#: user/templates/user/password_reset_confirm.html:22
msgid ""
"The password reset link was invalid, possibly because it has already been "
"used."
msgstr ""
"El enlace para restablecer la contraseña no era válido, posiblemente porque "
"ya se había utilizado."

#: user/templates/user/password_reset_confirm.html:86
msgid "Set Password"
msgstr "Establecer contraseña"

#: user/templates/user/password_reset_confirm.html:94
msgid "Password Security Tips:"
msgstr "Consejos de seguridad de contraseña:"

#: user/templates/user/password_reset_confirm.html:99
msgid "Use a mix of letters, numbers, and symbols"
msgstr "Utilice una combinación de letras, números y símbolos."

#: user/templates/user/password_reset_confirm.html:103
msgid "Don't reuse passwords from other sites"
msgstr "No reutilices contraseñas de otros sitios"

#: user/templates/user/password_reset_confirm.html:107
msgid "Avoid using personal information"
msgstr "Evite el uso de información personal"

#: user/templates/user/password_reset_confirm.html:116
msgid ""
"This password reset link is invalid or has expired. Please request a new "
"password reset."
msgstr ""
"Este enlace para restablecer contraseña no es válido o ha caducado. Solicite"
" un nuevo restablecimiento de contraseña."

#: user/templates/user/password_reset_confirm.html:124
msgid "Request New Reset Link"
msgstr "Solicitar nuevo enlace de reinicio"

#: user/templates/user/password_reset_done.html:17
msgid "Email Sent"
msgstr "Correo electrónico enviado"

#: user/templates/user/password_reset_done.html:18
msgid "Check your inbox for password reset instructions"
msgstr ""
"Revise su bandeja de entrada para obtener instrucciones para restablecer su "
"contraseña."

#: user/templates/user/password_reset_done.html:26
msgid ""
"We've emailed you instructions for setting your password. If they haven't "
"arrived in a few minutes, check your spam folder."
msgstr ""
"Le hemos enviado por correo electrónico instrucciones para configurar su "
"contraseña. Si no han llegado en unos minutos, revisa tu carpeta de spam."

#: user/templates/user/password_reset_done.html:34
msgid "What to do next:"
msgstr "Qué hacer a continuación:"

#: user/templates/user/password_reset_done.html:39
msgid "Check your email inbox for the reset link"
msgstr ""
"Revise su bandeja de entrada de correo electrónico para ver el enlace de "
"reinicio"

#: user/templates/user/password_reset_done.html:43
msgid "Click the link in the email to reset your password"
msgstr ""
"Haga clic en el enlace del correo electrónico para restablecer su contraseña"

#: user/templates/user/password_reset_done.html:47
msgid "Create a new, secure password"
msgstr "Crea una contraseña nueva y segura"

#: user/templates/user/password_reset_done.html:51
msgid "Log in with your new password"
msgstr "Inicia sesión con tu nueva contraseña"

#: user/templates/user/password_reset_done.html:59
msgid "Return to Login"
msgstr "Volver a iniciar sesión"

#: user/templates/user/password_reset_email.html:22
