msgid "Determinant"
msgstr "Determinante"

#: Math_Calculators/templates/math_calculators/matrix_calculator.html:279
msgid "Calculate determinant (matrix must be square)"
msgstr "Calcular determinante (la matriz debe ser cuadrada)"

#: Math_Calculators/templates/math_calculators/matrix_calculator.html:280
msgid "Calculate inverse matrix (matrix must be square and non-singular)"
msgstr ""
"Calcular la matriz inversa (la matriz debe ser cuadrada y no singular)"

