#: Other_Calculators/views/grade_calculator.py:611
#, python-brace-format
msgid "Current Grade: {grade}%"
msgstr "Calificación actual: {grade}%"

#: Other_Calculators/views/grade_calculator.py:612
#, python-brace-format
msgid "Target Grade: {grade}%"
msgstr "Calificación objetivo: {grade}%"

#: Other_Calculators/views/grade_calculator.py:613
#, python-brace-format
msgid "Final Weight: {weight}%"
msgstr "Peso final: {weight}%"

#: Other_Calculators/views/grade_calculator.py:615
msgid "Step 2: Calculate current weight"
msgstr "Paso 2: Calcular el peso actual"

#: Other_Calculators/views/grade_calculator.py:616
msgid "Current Weight = 100% - Final Weight"
msgstr "Peso Actual = 100% - Peso Final"

#: Other_Calculators/views/grade_calculator.py:617
#, python-brace-format
msgid "Current Weight = 100% - {final}% = {current}%"
msgstr "Peso actual = 100% - {final}% = {current}%"

#: Other_Calculators/views/grade_calculator.py:619
msgid "Step 3: Calculate points from current grade"
msgstr "Paso 3: Calcular los puntos de la calificación actual"

#: Other_Calculators/views/grade_calculator.py:620
msgid "Current Points = Current Grade × (Current Weight / 100)"
msgstr "Puntos actuales = Calificación actual × (Peso actual / 100)"

#: Other_Calculators/views/grade_calculator.py:621
#, python-brace-format
msgid "Current Points = {grade}% × ({weight}% / 100)"
msgstr "Puntos actuales = {grade}% × ({weight}% / 100)"

#: Other_Calculators/views/grade_calculator.py:622
#, python-brace-format
msgid "Current Points = {points}"
msgstr "Puntos actuales = {points}"

#: Other_Calculators/views/grade_calculator.py:624
msgid "Step 4: Calculate points needed for target grade"
msgstr "Paso 4: Calcule los puntos necesarios para la calificación objetivo"

#: Other_Calculators/views/grade_calculator.py:625
#, python-brace-format
msgid "Target Points = Target Grade = {grade}"
msgstr "Puntos objetivo = Calificación objetivo = {grade}"

#: Other_Calculators/views/grade_calculator.py:627
msgid "Step 5: Calculate points needed from final"
msgstr "Paso 5: Calcule los puntos necesarios para la final"

#: Other_Calculators/views/grade_calculator.py:628
msgid "Points Needed = Target Points - Current Points"
msgstr "Puntos necesarios = Puntos objetivo - Puntos actuales"

#: Other_Calculators/views/grade_calculator.py:629
#, python-brace-format
msgid "Points Needed = {target} - {current} = {needed}"
msgstr "Puntos necesarios = {target} - {current} = {needed}"

#: Other_Calculators/views/grade_calculator.py:633
msgid "Step 6: Calculate final grade needed"
msgstr "Paso 6: Calcular la calificación final necesaria"

#: Other_Calculators/views/grade_calculator.py:634
msgid "Final Grade Needed = Points Needed / (Final Weight / 100)"
msgstr "Calificación final necesaria = Puntos necesarios / (Peso final / 100)"

#: Other_Calculators/views/grade_calculator.py:635
#, python-brace-format
msgid "Final Grade Needed = {needed} / ({weight}% / 100)"
msgstr "Calificación final necesaria = {needed} / ({weight}% / 100)"

#: Other_Calculators/views/grade_calculator.py:638
#, python-brace-format
msgid "Final Grade Needed = {grade}%"
msgstr "Calificación final necesaria = {grade}%"

#: Other_Calculators/views/grade_calculator.py:641
#, python-brace-format
msgid "Note: This grade is not achievable. Maximum possible grade: {max}%"
msgstr ""
"Nota: Esta calificación no se puede lograr. Nota máxima posible: {max}%"

#: Other_Calculators/views/grade_calculator.py:643
#, python-format, python-brace-format
msgid ""
"Final Result: You need {grade}% on the final to achieve {target}% overall"
msgstr ""
"Resultado final: necesitas un {grade}% en la final para lograr un {target}% "
"en general"

#: Other_Calculators/views/grade_calculator.py:651
msgid "Step 1: Identify all assignments"
msgstr "Paso 1: identificar todas las asignaciones"

#: Other_Calculators/views/grade_calculator.py:654
#, python-brace-format
msgid ""
"Assignment {num}: {name} - {earned}/{possible} points ({weight}% weight)"
msgstr "Tarea {num}: {name} - {earned}/{possible} puntos ({weight}% del peso)"

#: Other_Calculators/views/grade_calculator.py:659
#, python-brace-format
msgid "Assignment {num}: {name} - {earned}/{possible} points"
msgstr "Tarea {num}: {name} - {earned}/{possible} puntos"

#: Other_Calculators/views/grade_calculator.py:665
msgid "Step 2: Calculate percentage for each assignment"
msgstr "Paso 2: Calcular el porcentaje para cada tarea"

#: Other_Calculators/views/grade_calculator.py:668
#, python-brace-format
msgid "{name}: ({earned} / {possible}) × 100 = {percent}%"
msgstr "{name}: ({earned} / {possible}) × 100 = {percent}%"

#: Other_Calculators/views/grade_calculator.py:673
msgid "Step 3: Calculate weighted contribution for each assignment"
msgstr "Paso 3: Calcular la contribución ponderada para cada tarea"

#: Other_Calculators/views/grade_calculator.py:677
#, python-brace-format
msgid "{name}: {percent}% × {weight}% = {contribution}"
msgstr "{name}: {percent}% × {weight}% = {contribution}"

#: Other_Calculators/views/grade_calculator.py:682
msgid "Step 4: Calculate weighted average"
msgstr "Paso 4: Calcular el promedio ponderado"

#: Other_Calculators/views/grade_calculator.py:685
msgid "Weighted Average = Sum of Contributions / Total Weight"
msgstr "Promedio Ponderado = Suma de Aportaciones / Peso Total"

#: Other_Calculators/views/grade_calculator.py:686
#, python-brace-format
msgid "Weighted Average = {sum} / {weight} = {grade}%"
msgstr "Promedio ponderado = {sum} / {weight} = {grade}%"

#: Other_Calculators/views/grade_calculator.py:690
msgid "Step 2: Calculate total points earned"
msgstr "Paso 2: Calcular el total de puntos obtenidos"

#: Other_Calculators/views/grade_calculator.py:692
#, python-brace-format
msgid "Total Points Earned = {points}"
msgstr "Puntos totales obtenidos = {points}"

#: Other_Calculators/views/grade_calculator.py:693
#, python-brace-format
msgid "Total Points Earned = {total}"
msgstr "Puntos totales obtenidos = {total}"

#: Other_Calculators/views/grade_calculator.py:695
msgid "Step 3: Calculate total points possible"
msgstr "Paso 3: Calcular el total de puntos posibles"

#: Other_Calculators/views/grade_calculator.py:697
#, python-brace-format
msgid "Total Points Possible = {points}"
msgstr "Total de puntos posibles = {points}"

#: Other_Calculators/views/grade_calculator.py:698
#, python-brace-format
msgid "Total Points Possible = {total}"
msgstr "Total de puntos posibles = {total}"

#: Other_Calculators/views/grade_calculator.py:700
msgid "Step 4: Calculate current grade"
msgstr "Paso 4: Calcular la calificación actual"

#: Other_Calculators/views/grade_calculator.py:701
msgid "Current Grade = (Total Points Earned / Total Points Possible) × 100"
msgstr ""
"Calificación actual = (Total de puntos obtenidos / Total de puntos posibles)"
" × 100"

#: Other_Calculators/views/grade_calculator.py:702
#, python-brace-format
msgid "Current Grade = ({earned} / {possible}) × 100"
msgstr "Calificación actual = ({earned} / {possible}) × 100"

#: Other_Calculators/views/grade_calculator.py:705
#, python-brace-format
msgid "Current Grade = {grade}%"
msgstr "Calificación actual = {grade}%"

#: Other_Calculators/views/grade_calculator.py:712
#, python-brace-format
msgid "Points Earned: {earned}"
msgstr "Puntos ganados: {earned}"

#: Other_Calculators/views/grade_calculator.py:713
#, python-brace-format
msgid "Points Possible: {possible}"
msgstr "Puntos posibles: {possible}"

#: Other_Calculators/views/grade_calculator.py:715
msgid "Step 2: Apply the percentage formula"
msgstr "Paso 2: aplica la fórmula del porcentaje"

#: Other_Calculators/views/grade_calculator.py:716
msgid "Formula: Percentage = (Points Earned / Points Possible) × 100"
msgstr "Fórmula: Porcentaje = (Puntos obtenidos / Puntos posibles) × 100"

#: Other_Calculators/views/grade_calculator.py:717
#, python-brace-format
msgid "Percentage = ({earned} / {possible}) × 100"
msgstr "Porcentaje = ({earned} / {possible}) × 100"

#: Other_Calculators/views/grade_calculator.py:718
#, python-brace-format
msgid "Percentage = {percent}%"
msgstr "Porcentaje = {percent}%"

#: Other_Calculators/views/grade_calculator.py:724
msgid "Step 1: Identify all assignments and their weights"
msgstr "Paso 1: identificar todas las asignaciones y sus pesos"

#: Other_Calculators/views/grade_calculator.py:726
#, python-brace-format
msgid "Assignment {num}: {name} - Grade: {grade}%, Weight: {weight}%"
msgstr "Tarea {num}: {name} - Calificación: {grade}%, Peso: {weight}%"

#: Other_Calculators/views/grade_calculator.py:730
msgid "Step 2: Calculate weighted contribution for each assignment"
msgstr "Paso 2: Calcular la contribución ponderada para cada tarea"

#: Other_Calculators/views/grade_calculator.py:731
msgid "Formula: Weighted Contribution = Grade × (Weight / 100)"
msgstr "Fórmula: Contribución ponderada = Calificación × (Peso / 100)"

#: Other_Calculators/views/grade_calculator.py:733
#, python-brace-format
msgid "{name}: {grade}% × ({weight}% / 100) = {contribution}"
msgstr "{name}: {grade}% × ({weight}% / 100) = {contribution}"

#: Other_Calculators/views/grade_calculator.py:738
msgid "Step 3: Calculate sum of weighted contributions"
msgstr "Paso 3: Calcular la suma de las contribuciones ponderadas"

#: Other_Calculators/views/grade_calculator.py:740
#, python-brace-format
msgid "Sum = {contributions}"
msgstr "Suma = {contributions}"

#: Other_Calculators/views/grade_calculator.py:741
#, python-brace-format
msgid "Sum = {total}"
msgstr "Suma = {total}"

#: Other_Calculators/views/grade_calculator.py:743
msgid "Step 4: Calculate weighted grade"
msgstr "Paso 4: Calcular la calificación ponderada"

#: Other_Calculators/views/grade_calculator.py:744
msgid "Weighted Grade = Sum / (Total Weight / 100)"
msgstr "Calificación ponderada = Suma / (Peso total / 100)"

#: Other_Calculators/views/grade_calculator.py:745
#, python-brace-format
msgid "Weighted Grade = {sum} / ({weight}% / 100)"
msgstr "Calificación ponderada = {sum} / ({weight}% / 100)"

#: Other_Calculators/views/grade_calculator.py:746
#, python-brace-format
msgid "Weighted Grade = {grade}%"
msgstr "Calificación ponderada = {grade}%"

#: Other_Calculators/views/grade_calculator.py:752
msgid "Step 1: Identify the percentage"
msgstr "Paso 1: Identificar el porcentaje"

#: Other_Calculators/views/grade_calculator.py:753
