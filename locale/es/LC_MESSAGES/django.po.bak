#: Other_Calculators/templates/other_calculators/time_calculator.html:229
#: Other_Calculators/templates/other_calculators/time_duration_calculator.html:242
msgid "Convert Units"
msgstr "Convertir unidades"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:206
msgid ""
"Enter a value and select units to see the conversion result with detailed "
"step-by-step solution."
msgstr ""
"Ingrese un valor y seleccione unidades para ver el resultado de la "
"conversión con una solución detallada paso a paso."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:222
msgid "What is Unit Conversion?"
msgstr "¿Qué es la conversión de unidades?"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:224
msgid ""
"Unit conversion is the process of converting a measurement from one unit to "
"another while maintaining the same quantity. This calculator supports "
"conversions across 10 major categories with hundreds of units, using "
"internationally recognized conversion factors for accuracy."
msgstr ""
"La conversión de unidades es el proceso de convertir una medida de una "
"unidad a otra manteniendo la misma cantidad. Esta calculadora admite "
"conversiones en 10 categorías principales con cientos de unidades y utiliza "
"factores de conversión reconocidos internacionalmente para mayor precisión."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:231
msgid ""
"Select the conversion type from the dropdown (Length, Weight, Volume, "
"Temperature, Area, Speed, Time, Data, Pressure, or Energy)."
msgstr ""
"Seleccione el tipo de conversión en el menú desplegable (Longitud, Peso, "
"Volumen, Temperatura, Área, Velocidad, Tiempo, Datos, Presión o Energía)."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:232
msgid "Enter the value you want to convert."
msgstr "Ingrese el valor que desea convertir."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:233
msgid "Select the unit you are converting from."
msgstr "Seleccione la unidad desde la que está convirtiendo."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:234
msgid "Select the unit you want to convert to."
msgstr "Seleccione la unidad a la que desea convertir."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:235
msgid "Click 'Convert' to see the result with step-by-step solution."
msgstr ""
"Haga clic en 'Convertir' para ver el resultado con la solución paso a paso."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:240
msgid "Conversion Categories"
msgstr "Categorías de conversión"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:244
msgid "Meters, kilometers, miles, yards, feet, inches, nautical miles"
msgstr "Metros, kilómetros, millas, yardas, pies, pulgadas, millas náuticas"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:247
msgid "Weight/Mass"
msgstr "Peso/Masa"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:248
msgid "Kilograms, grams, pounds, ounces, tons, stones"
msgstr "Kilogramos, gramos, libras, onzas, toneladas, piedras"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:252
msgid "Liters, gallons, cubic meters, cubic feet, cubic yards"
msgstr "Litros, galones, metros cúbicos, pies cúbicos, yardas cúbicas"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:256
msgid "Celsius, Fahrenheit, Kelvin"
msgstr "Celsius, Fahrenheit, Kelvin"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:260
msgid "Square meters, square feet, acres, hectares"
msgstr "Metros cuadrados, pies cuadrados, acres, hectáreas"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:264
msgid "km/h, mph, m/s, knots, Mach"
msgstr "km/h, mph, m/s, nudos, Mach"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:268
msgid "Seconds, minutes, hours, days, weeks, months, years"
msgstr "Segundos, minutos, horas, días, semanas, meses, años."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:272
msgid "Bytes, KB, MB, GB, TB, PB, bits"
msgstr "Bytes, KB, MB, GB, TB, PB, bits"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:276
msgid "Pascals, PSI, bar, atmosphere, torr"
msgstr "Pascal, PSI, bar, atmósfera, torr"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:280
msgid "Joules, BTU, kWh, calories, foot-pounds"
msgstr "Julios, BTU, kWh, calorías, libras-pie"

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:288
msgid ""
"All conversions use internationally recognized conversion factors and are "
"accurate to 10 decimal places."
msgstr ""
"Todas las conversiones utilizan factores de conversión reconocidos "
"internacionalmente y tienen una precisión de 10 decimales."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:289
msgid ""
"Temperature conversions use precise formulas: Celsius to Fahrenheit: F = C ×"
" 9/5 + 32."
msgstr ""
"Las conversiones de temperatura utilizan fórmulas precisas: Celsius a "
"Fahrenheit: F = C × 9/5 + 32."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:290
msgid ""
"Data conversions use binary (1024) base for bytes, kilobytes, megabytes, "
"etc."
msgstr ""
"Las conversiones de datos utilizan una base binaria (1024) para bytes, "
"kilobytes, megabytes, etc."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:291
msgid "Negative values are only allowed for temperature conversions."
msgstr ""
"Los valores negativos solo se permiten para conversiones de temperatura."

