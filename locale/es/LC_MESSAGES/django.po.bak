msgstr "Restablece tu contraseña"

#: core/templates/account/password_reset.html:21
msgid ""
"Forgotten your password? Enter your email address below, and we'll send you "
"an email allowing you to reset it."
msgstr ""
"¿Olvidaste tu contraseña? Ingrese su dirección de correo electrónico a "
"continuación y le enviaremos un correo electrónico que le permitirá "
"restablecerla."

