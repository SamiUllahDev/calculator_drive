msgid "Power Visualization"
msgstr "Visualización de poder"

#: Math_Calculators/templates/math_calculators/root_calculator.html:267
msgid "What is a Root?"
msgstr "¿Qué es una raíz?"

#: Math_Calculators/templates/math_calculators/root_calculator.html:269
msgid ""
"A root is the inverse operation of exponentiation. The nth root of a number "
"x is a number y such that y^n = x."
msgstr ""
"Una raíz es la operación inversa de la exponenciación. La raíz enésima de un"
" número x es un número y tal que y^n = x."

#: Math_Calculators/templates/math_calculators/root_calculator.html:272
msgid "The 2nd root (e.g., √16 = 4)"
msgstr "La segunda raíz (por ejemplo, √16 = 4)"

#: Math_Calculators/templates/math_calculators/root_calculator.html:273
msgid "The 3rd root (e.g., ∛27 = 3)"
msgstr "La tercera raíz (por ejemplo, ∛27 = 3)"

#: Math_Calculators/templates/math_calculators/root_calculator.html:274
msgid "Nth Root"
msgstr "Enésima raíz"

#: Math_Calculators/templates/math_calculators/root_calculator.html:274
msgid "The nth root (e.g., 4th root of 16 = 2)"
msgstr "La raíz enésima (por ejemplo, cuarta raíz de 16 = 2)"

#: Math_Calculators/templates/math_calculators/root_calculator.html:279
msgid "Perfect Roots"
msgstr "Raíces perfectas"

#: Math_Calculators/templates/math_calculators/root_calculator.html:281
msgid "A perfect root is when the result is a whole number:"
msgstr "Una raíz perfecta es cuando el resultado es un número entero:"

#: Math_Calculators/templates/math_calculators/root_calculator.html:284
msgid "Perfect squares: 1, 4, 9, 16, 25, 36, 49, 64, 81, 100..."
msgstr "Cuadrados perfectos: 1, 4, 9, 16, 25, 36, 49, 64, 81, 100..."

#: Math_Calculators/templates/math_calculators/root_calculator.html:285
msgid "Perfect cubes: 1, 8, 27, 64, 125, 216..."
msgstr "Cubos perfectos: 1, 8, 27, 64, 125, 216..."

#: Math_Calculators/templates/math_calculators/root_calculator.html:293
msgid "Example 1: Square Root"
msgstr "Ejemplo 1: raíz cuadrada"

#: Math_Calculators/templates/math_calculators/root_calculator.html:298
msgid "Example 2: Cube Root"
msgstr "Ejemplo 2: raíz cúbica"

#: Math_Calculators/templates/math_calculators/root_calculator.html:303
msgid "Example 3: Decimal Root"
msgstr "Ejemplo 3: raíz decimal"

