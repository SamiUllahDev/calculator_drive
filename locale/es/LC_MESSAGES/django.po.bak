#: Financial_Calculators/templates/financial_calculators/rent_vs_buy_calculator.html:139
#: Financial_Calculators/templates/financial_calculators/rent_vs_buy_calculator.html:386
msgid "Compare Rent vs Buy"
msgstr "Comparar alquiler versus comprar"

#: Financial_Calculators/templates/financial_calculators/rent_vs_buy_calculator.html:151
