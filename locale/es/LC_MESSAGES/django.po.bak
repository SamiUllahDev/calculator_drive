msgstr "Pruebas y verificación del banco de pruebas del motor."

#: Other_Calculators/templates/other_calculators/engine_horsepower_calculator.html:441
msgid "Comparing engine specifications"
msgstr "Comparación de especificaciones del motor"

#: Other_Calculators/templates/other_calculators/engine_horsepower_calculator.html:442
