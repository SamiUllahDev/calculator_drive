#: Other_Calculators/views/love_calculator.py:380
#: Other_Calculators/views/love_calculator.py:417
#: Other_Calculators/views/love_calculator.py:442
msgid "Step 1: Identify the given names"
msgstr "Paso 1: Identificar los nombres de pila"

#: Other_Calculators/views/love_calculator.py:381
#: Other_Calculators/views/love_calculator.py:418
#: Other_Calculators/views/love_calculator.py:443
#, python-brace-format
msgid "Name 1: {name}"
msgstr "Nombre 1: {name}"

