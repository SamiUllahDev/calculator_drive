#: Other_Calculators/views/age_calculator.py:253
msgid "Step 1: Identify the Dates"
msgstr "Paso 1: identificar las fechas"

#: Other_Calculators/views/age_calculator.py:254
#, python-brace-format
msgid "  Birth Date: {date}"
msgstr "Fecha de nacimiento: {date}"

#: Other_Calculators/views/age_calculator.py:255
#, python-brace-format
msgid "  Target Date: {date}"
msgstr "Fecha objetivo: {date}"

#: Other_Calculators/views/age_calculator.py:258
msgid "Step 2: Calculate the Difference"
msgstr "Paso 2: Calcula la diferencia"

#: Other_Calculators/views/age_calculator.py:259
msgid "  Total Days = Target Date - Birth Date"
msgstr "Días totales = Fecha objetivo - Fecha de nacimiento"

#: Other_Calculators/views/age_calculator.py:260
msgid "  Total Days = {days:,} days"
msgstr "Días totales = {days:,} días"

#: Other_Calculators/views/age_calculator.py:263
msgid "Step 3: Break Down into Time Units"
msgstr "Paso 3: dividir en unidades de tiempo"

#: Other_Calculators/views/age_calculator.py:264
#, python-brace-format
msgid "  Years: {years} years"
msgstr "Años: {years} años"

#: Other_Calculators/views/age_calculator.py:265
#, python-brace-format
msgid "  Months: {months} months (in addition to {years} years)"
msgstr "Meses: {months} meses (además de {years} años)"

#: Other_Calculators/views/age_calculator.py:266
#, python-brace-format
msgid "  Days: {days} days (in addition to {years} years and {months} months)"
msgstr "Días: {days} días (además de {years} años y {months} meses)"

#: Other_Calculators/views/age_calculator.py:271
msgid "Step 4: Calculate Total Time Units"
msgstr "Paso 4: Calcular las unidades de tiempo totales"

#: Other_Calculators/views/age_calculator.py:272
msgid ""
"  Total Months = (Years × 12) + Months = ({years} × 12) + {months} = "
"{total:,} months"
msgstr ""
"Meses totales = (Años × 12) + Meses = ({years} × 12) + {months} = {total:,} "
"meses"

#: Other_Calculators/views/age_calculator.py:275
msgid "  Total Weeks = Total Days ÷ 7 = {days:,} ÷ 7 = {weeks:,} weeks"
msgstr "Semanas totales = Días totales ÷ 7 = {days:,} ÷ 7 = {weeks:,} semanas"

#: Other_Calculators/views/age_calculator.py:278
msgid "  Total Hours = Total Days × 24 = {days:,} × 24 = {hours:,} hours"
msgstr "Horas totales = Días totales × 24 = {days:,} × 24 = {hours:,} horas"

#: Other_Calculators/views/age_calculator.py:281
msgid ""
"  Total Minutes = Total Hours × 60 = {hours:,} × 60 = {minutes:,} minutes"
msgstr ""
"Minutos totales = Horas totales × 60 = {hours:,} × 60 = {minutes:,} minutos"

#: Other_Calculators/views/age_calculator.py:284
msgid ""
"  Total Seconds = Total Minutes × 60 = {minutes:,} × 60 = {seconds:,} "
"seconds"
msgstr ""
"Segundos totales = Minutos totales × 60 = {minutes:,} × 60 = {seconds:,} "
"segundos"

#: Other_Calculators/views/age_calculator.py:289
#: Other_Calculators/views/bandwidth_calculator.py:367
#: Other_Calculators/views/bandwidth_calculator.py:408
#: Other_Calculators/views/bandwidth_calculator.py:450
#: Other_Calculators/views/bra_size_calculator.py:420
#: Other_Calculators/views/bra_size_calculator.py:579
msgid "Step 5: Final Result"
msgstr "Paso 5: Resultado final"

#: Other_Calculators/views/age_calculator.py:290
#, python-brace-format
msgid "  Age: {years} years, {months} months, {days} days"
msgstr "Edad: {years} años, {months} meses, {days} días"

#: Other_Calculators/views/age_calculator.py:307
msgid "Total Units"
msgstr "Unidades totales"

