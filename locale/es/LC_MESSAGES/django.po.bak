#, python-brace-format
msgid "Weight = {mass} × {gravity} = {weight} N"
msgstr "Peso = {mass} × {gravity} = {weight} N"

#: Other_Calculators/views/weight_calculator.py:427
#: Other_Calculators/views/weight_calculator.py:447
#, python-brace-format
