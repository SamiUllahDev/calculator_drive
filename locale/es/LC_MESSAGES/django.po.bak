msgstr "Área = (1/2) × (Base 1 + Base 2) × Altura"

#: Other_Calculators/views/square_footage_calculator.py:586
#, python-brace-format
msgid "Area = (1/2) × ({base1} + {base2}) × {height}"
msgstr "Área = (1/2) × ({base1} + {base2}) × {height}"

#: Other_Calculators/views/square_footage_calculator.py:587
#, python-brace-format
msgid "Area = (1/2) × {sum} × {height}"
msgstr "Área = (1/2) × {sum} × {height}"

#: Other_Calculators/views/square_footage_calculator.py:602
#, python-brace-format
msgid "Radius A: {radius_a} {unit}"
msgstr "Radio A: {radius_a} {unit}"

#: Other_Calculators/views/square_footage_calculator.py:603
#, python-brace-format
msgid "Radius B: {radius_b} {unit}"
msgstr "Radio B: {radius_b} {unit}"

#: Other_Calculators/views/square_footage_calculator.py:606
#, python-brace-format
msgid "Radius A: {radius_a} m"
msgstr "Radio A: {radius_a} m"

#: Other_Calculators/views/square_footage_calculator.py:607
#, python-brace-format
msgid "Radius B: {radius_b} m"
msgstr "Radio B: {radius_b} m"

#: Other_Calculators/views/square_footage_calculator.py:610
msgid "Area = π × a × b"
msgstr "Área = π × a × b"

#: Other_Calculators/views/square_footage_calculator.py:611
#, python-brace-format
msgid "Area = π × {radius_a} × {radius_b}"
msgstr "Área = π × {radius_a} × {radius_b}"

#: Other_Calculators/views/square_footage_calculator.py:633
#: Other_Calculators/views/square_footage_calculator.py:657
#: Other_Calculators/views/tile_calculator.py:539
#: Other_Calculators/views/tile_calculator.py:563
#, python-brace-format
msgid "Area ({unit})"
msgstr "Área ({unit})"

#: Other_Calculators/views/square_footage_calculator.py:649
#, python-brace-format
msgid "{shape} Area Calculation"
msgstr "{shape} Cálculo del área"

#: Other_Calculators/views/stair_calculator.py:100
#: Other_Calculators/views/stair_calculator.py:268
msgid "Total rise is required."
msgstr "Se requiere un aumento total."

#: Other_Calculators/views/stair_calculator.py:118
msgid "Total rise must be greater than zero."
msgstr "El aumento total debe ser mayor que cero."

#: Other_Calculators/views/stair_calculator.py:174
#, python-brace-format
msgid "Error calculating stair design: {error}"
msgstr "Error al calcular el diseño de la escalera: {error}"

#: Other_Calculators/views/stair_calculator.py:183
msgid "Riser height is required."
msgstr "Se requiere altura de contrahuella."

#: Other_Calculators/views/stair_calculator.py:189
msgid "Tread depth is required."
msgstr "Se requiere profundidad de la banda de rodadura."

#: Other_Calculators/views/stair_calculator.py:195
msgid "Number of steps is required."
msgstr "Se requiere número de pasos."

#: Other_Calculators/views/stair_calculator.py:214
msgid "All values must be greater than zero."
msgstr "Todos los valores deben ser mayores que cero."

#: Other_Calculators/views/stair_calculator.py:259
#, python-brace-format
msgid "Error calculating riser/tread: {error}"
msgstr "Error al calcular contrahuella/banda de rodadura: {error}"

#: Other_Calculators/views/stair_calculator.py:274
msgid "Total run is required."
msgstr "Se requiere ejecución total."

#: Other_Calculators/views/stair_calculator.py:292
msgid "Total rise and run must be greater than zero."
msgstr "La subida y la carrera totales deben ser mayores que cero."

#: Other_Calculators/views/stair_calculator.py:322
#, python-brace-format
msgid "Error calculating stringer: {error}"
msgstr "Error al calcular el larguero: {error}"

#: Other_Calculators/views/stair_calculator.py:348
#: Other_Calculators/views/stair_calculator.py:423
#, python-brace-format
msgid "Total Rise: {rise} {unit}"
msgstr "Aumento total: {rise} {unit}"

#: Other_Calculators/views/stair_calculator.py:349
#, python-brace-format
msgid "Preferred Riser Height: {riser} in"
msgstr "Altura de contrahuella preferida: {riser} en"

#: Other_Calculators/views/stair_calculator.py:351
#: Other_Calculators/views/stair_calculator.py:393
#: Other_Calculators/views/stair_calculator.py:426
msgid "Step 2: Convert to inches"
msgstr "Paso 2: convertir a pulgadas"

#: Other_Calculators/views/stair_calculator.py:352
#: Other_Calculators/views/stair_calculator.py:427
#, python-brace-format
msgid "Total Rise: {rise} in"
msgstr "Aumento total: {rise} en"

#: Other_Calculators/views/stair_calculator.py:354
msgid "Step 3: Calculate number of risers"
msgstr "Paso 3: Calcular el número de contrahuellas"

#: Other_Calculators/views/stair_calculator.py:355
msgid "Number of Risers = Total Rise / Preferred Riser"
msgstr "Número de contrahuellas = Subida total / Contrahuella preferida"

#: Other_Calculators/views/stair_calculator.py:356
#, python-brace-format
msgid "Number of Risers = {rise} / {pref} = {num} risers"
msgstr "Número de contrahuellas = {rise} / {pref} = {num} contrahuellas"

#: Other_Calculators/views/stair_calculator.py:358
msgid "Step 4: Calculate actual riser height"
msgstr "Paso 4: Calcule la altura real de la contrahuella"

#: Other_Calculators/views/stair_calculator.py:359
msgid "Riser Height = Total Rise / Number of Risers"
msgstr "Altura de contrahuella = Subida total / Número de contrahuellas"

#: Other_Calculators/views/stair_calculator.py:360
#, python-brace-format
msgid "Riser Height = {rise} / {num} = {riser} in"
msgstr "Altura del contrahuella = {rise} / {num} = {riser} en"

#: Other_Calculators/views/stair_calculator.py:362
msgid "Step 5: Calculate tread depth"
msgstr "Paso 5: Calcular la profundidad de la banda de rodadura"

#: Other_Calculators/views/stair_calculator.py:363
msgid "Using formula: 2R + T = 24.5"
msgstr "Usando la fórmula: 2R + T = 24,5"

#: Other_Calculators/views/stair_calculator.py:364
msgid "Tread Depth = 24.5 - 2 × Riser Height"
msgstr ""
"Profundidad de la banda de rodadura = 24,5 - 2 × Altura de la contrahuella"

#: Other_Calculators/views/stair_calculator.py:365
#, python-brace-format
msgid "Tread Depth = 24.5 - 2 × {riser} = {tread} in"
msgstr "Tread Depth = 24.5 - 2 × {riser} = {tread} in"

#: Other_Calculators/views/stair_calculator.py:367
msgid "Step 6: Calculate total run"
msgstr "Paso 6: Calcular la ejecución total"

#: Other_Calculators/views/stair_calculator.py:368
msgid "Total Run = Tread Depth × (Number of Risers - 1)"
msgstr ""
"Carrera total = Profundidad de la banda de rodadura × (Número de "
"contrahuellas - 1)"

#: Other_Calculators/views/stair_calculator.py:369
#: Other_Calculators/views/stair_calculator.py:403
#, python-brace-format
msgid "Total Run = {tread} × ({num} - 1) = {run} in"
msgstr "Total Run = {tread} × ({num} - 1) = {run} in"

#: Other_Calculators/views/stair_calculator.py:371
msgid "Step 7: Calculate stringer length"
msgstr "Paso 7: Calcular la longitud del larguero"

#: Other_Calculators/views/stair_calculator.py:372
#: Other_Calculators/views/stair_calculator.py:406
#: Other_Calculators/views/stair_calculator.py:431
msgid "Stringer Length = √(Total Rise² + Total Run²)"
msgstr "Longitud del larguero = √(Elevación total² + Carrera total²)"

#: Other_Calculators/views/stair_calculator.py:373
#: Other_Calculators/views/stair_calculator.py:407
#, python-brace-format
msgid "Stringer Length = √({rise}² + {run}²) = {stringer} in"
msgstr "Longitud del larguero = √({rise}² + {run}²) = {stringer} en"

#: Other_Calculators/views/stair_calculator.py:375
msgid "Step 8: Calculate angle"
msgstr "Paso 8: Calcular el ángulo"

#: Other_Calculators/views/stair_calculator.py:376
#: Other_Calculators/views/stair_calculator.py:410
#: Other_Calculators/views/stair_calculator.py:436
msgid "Angle = arctan(Total Rise / Total Run)"
msgstr "Ángulo = arctan(Ascenso total / Carrera total)"

#: Other_Calculators/views/stair_calculator.py:377
#: Other_Calculators/views/stair_calculator.py:411
#: Other_Calculators/views/stair_calculator.py:437
#, python-brace-format
msgid "Angle = arctan({rise} / {run}) = {angle}°"
msgstr "Ángulo = arctan({rise} / {run}) = {angle}°"

#: Other_Calculators/views/stair_calculator.py:379
msgid "Step 9: Check building code compliance"
msgstr "Paso 9: Verifique el cumplimiento del código de construcción"

#: Other_Calculators/views/stair_calculator.py:380
#: Other_Calculators/views/stair_calculator.py:414
#, python-brace-format
msgid "Riser Height: {riser} in ({status})"
msgstr "Altura de la contrahuella: {riser} en ({status})"

#: Other_Calculators/views/stair_calculator.py:380
#: Other_Calculators/views/stair_calculator.py:381
#: Other_Calculators/views/stair_calculator.py:382
#: Other_Calculators/views/stair_calculator.py:414
#: Other_Calculators/views/stair_calculator.py:415
#: Other_Calculators/views/stair_calculator.py:416
msgid "OK"
msgstr "DE ACUERDO"

#: Other_Calculators/views/stair_calculator.py:380
#: Other_Calculators/views/stair_calculator.py:381
#: Other_Calculators/views/stair_calculator.py:382
#: Other_Calculators/views/stair_calculator.py:414
#: Other_Calculators/views/stair_calculator.py:415
#: Other_Calculators/views/stair_calculator.py:416
msgid "Not OK"
msgstr "No está bien"

#: Other_Calculators/views/stair_calculator.py:381
#: Other_Calculators/views/stair_calculator.py:415
#, python-brace-format
msgid "Tread Depth: {tread} in ({status})"
msgstr "Tread Depth: {tread} in ({status})"

#: Other_Calculators/views/stair_calculator.py:382
#: Other_Calculators/views/stair_calculator.py:416
#, python-brace-format
msgid "2R + T = {sum} ({status})"
msgstr "2R + T = {sum} ({status})"

#: Other_Calculators/views/stair_calculator.py:389
#, python-brace-format
msgid "Riser Height: {riser} {unit}"
msgstr "Altura del contrahuella: {riser} {unit}"

#: Other_Calculators/views/stair_calculator.py:390
#, python-brace-format
msgid "Tread Depth: {tread} {unit}"
msgstr "Tread Depth: {tread} {unit}"

#: Other_Calculators/views/stair_calculator.py:391
#, python-brace-format
msgid "Number of Steps: {num}"
msgstr "Número de pasos: {num}"

#: Other_Calculators/views/stair_calculator.py:394
#, python-brace-format
msgid "Riser Height: {riser} in"
msgstr "Altura del contrahuella: {riser} en"

#: Other_Calculators/views/stair_calculator.py:395
#, python-brace-format
msgid "Tread Depth: {tread} in"
msgstr "Tread Depth: {tread} in"

#: Other_Calculators/views/stair_calculator.py:397
msgid "Step 3: Calculate total rise"
msgstr "Paso 3: Calcular el aumento total"

#: Other_Calculators/views/stair_calculator.py:398
msgid "Total Rise = Riser Height × Number of Steps"
msgstr "Elevación total = Altura de la contrahuella × Número de escalones"

#: Other_Calculators/views/stair_calculator.py:399
#, python-brace-format
msgid "Total Rise = {riser} × {num} = {rise} in"
msgstr "Subida total = {riser} × {num} = {rise} en"

#: Other_Calculators/views/stair_calculator.py:401
msgid "Step 4: Calculate total run"
msgstr "Paso 4: Calcular la ejecución total"

#: Other_Calculators/views/stair_calculator.py:402
msgid "Total Run = Tread Depth × (Number of Steps - 1)"
msgstr ""
"Carrera total = Profundidad de la banda de rodadura × (Número de pasos - 1)"

#: Other_Calculators/views/stair_calculator.py:405
msgid "Step 5: Calculate stringer length"
msgstr "Paso 5: Calcular la longitud del larguero"

#: Other_Calculators/views/stair_calculator.py:409
msgid "Step 6: Calculate angle"
msgstr "Paso 6: Calcular el ángulo"

#: Other_Calculators/views/stair_calculator.py:413
msgid "Step 7: Check building code compliance"
msgstr "Paso 7: Verifique el cumplimiento del código de construcción"

#: Other_Calculators/views/stair_calculator.py:424
#, python-brace-format
msgid "Total Run: {run} {unit}"
msgstr "Ejecución total: {run} {unit}"

#: Other_Calculators/views/stair_calculator.py:428
#, python-brace-format
msgid "Total Run: {run} in"
msgstr "Ejecución total: {run} en"

#: Other_Calculators/views/stair_calculator.py:430
msgid "Step 3: Calculate stringer length"
msgstr "Paso 3: Calcular la longitud del larguero"

#: Other_Calculators/views/stair_calculator.py:432
#, python-brace-format
msgid "Stringer Length = √({rise}² + {run}²)"
msgstr "Longitud del larguero = √({rise}² + {run}²)"

#: Other_Calculators/views/stair_calculator.py:433
#, python-brace-format
msgid "Stringer Length = {stringer} in"
msgstr "Longitud del larguero = {stringer} pulgadas"

#: Other_Calculators/views/stair_calculator.py:435
msgid "Step 4: Calculate angle"
msgstr "Paso 4: Calcular el ángulo"

