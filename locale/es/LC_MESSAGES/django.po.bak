#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pace_calculator.html:138
msgid "Pace per km"
msgstr "ritmo por km"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pace_calculator.html:197
msgid ""
"Enter your distance and time (or pace), then click Calculate to see your "
"pace, speed, and race time predictions for common distances."
msgstr ""
"Ingresa tu distancia y tiempo (o ritmo), luego haz clic en Calcular para ver"
" tus predicciones de ritmo, velocidad y tiempo de carrera para distancias "
"comunes."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pace_calculator.html:207
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pace_calculator.html:608
msgid "Pace per Kilometer"
msgstr "Paso por kilómetro"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pace_calculator.html:220
msgid "Pace per Mile"
msgstr "Paz por milla"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pace_calculator.html:226
#: Other_Calculators/templates/other_calculators/conversion_calculator.html:85
#: Other_Calculators/templates/other_calculators/conversion_calculator.html:263
#: Other_Calculators/templates/other_calculators/speed_calculator.html:112
#: Other_Calculators/templates/other_calculators/speed_calculator.html:161
#: Other_Calculators/templates/other_calculators/speed_calculator.html:210
