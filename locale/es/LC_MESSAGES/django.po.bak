msgstr "Busque en nuestra colección completa de calculadoras profesionales"

#: core/templates/core/index.html:88
#: core/templates/core/search_results.html:42
msgid "Search calculators (e.g., BMI calculator, mortgage calculator)"
msgstr ""
"Calculadoras de búsqueda (por ejemplo, calculadora de IMC, calculadora de "
