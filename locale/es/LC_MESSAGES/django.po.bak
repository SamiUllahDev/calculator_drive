msgstr "Peso en diferentes planetas"

#: Other_Calculators/views/wind_chill_calculator.py:113
msgid "Little Danger"
msgstr "Pequeño peligro"

#: Other_Calculators/views/wind_chill_calculator.py:113
msgid "Little danger from freezing for properly clothed person"
msgstr "Poco peligro de congelación para una persona debidamente vestida"

#: Other_Calculators/views/wind_chill_calculator.py:115
#: Other_Calculators/views/wind_chill_calculator.py:117
msgid "Uncomfortable. Risk of hypothermia if outside for long periods"
msgstr ""
"Incómodo. Riesgo de hipotermia si está afuera por períodos prolongados."

#: Other_Calculators/views/wind_chill_calculator.py:119
msgid "Dangerous. Exposed skin can freeze in 10 minutes"
msgstr "Peligroso. La piel expuesta puede congelarse en 10 minutos."

#: Other_Calculators/views/wind_chill_calculator.py:121
msgid "Extremely dangerous. Exposed skin can freeze in 5 minutes"
msgstr ""
"Extremadamente peligroso. La piel expuesta puede congelarse en 5 minutos."

#: Other_Calculators/views/wind_chill_calculator.py:135
#: Other_Calculators/views/wind_chill_calculator.py:227
msgid "Wind speed is required."
msgstr "Se requiere velocidad del viento."

#: Other_Calculators/views/wind_chill_calculator.py:166
msgid "Wind speed must be non-negative."
msgstr "La velocidad del viento no debe ser negativa."

#: Other_Calculators/views/wind_chill_calculator.py:212
#, python-brace-format
msgid "Error calculating wind chill: {error}"
msgstr "Error al calcular la sensación térmica: {error}"

#: Other_Calculators/views/wind_chill_calculator.py:221
#: Other_Calculators/views/wind_chill_calculator.py:300
msgid "Wind chill is required."
msgstr "Se requiere sensación térmica."

#: Other_Calculators/views/wind_chill_calculator.py:258
msgid "Wind speed must be at least 3 mph for wind chill calculation."
msgstr ""
"La velocidad del viento debe ser de al menos 3 mph para calcular la "
"sensación térmica."

#: Other_Calculators/views/wind_chill_calculator.py:291
#, python-brace-format
msgid "Error calculating from wind chill: {error}"
msgstr "Error al calcular a partir de la sensación térmica: {error}"

#: Other_Calculators/views/wind_chill_calculator.py:332
msgid "Wind chill only applies when temperature is 50°F (10°C) or below."
msgstr ""
"La sensación térmica solo se aplica cuando la temperatura es de 50 °F (10 "
"°C) o menos."

#: Other_Calculators/views/wind_chill_calculator.py:383
#, python-brace-format
msgid "Error calculating wind speed: {error}"
msgstr "Error al calcular la velocidad del viento: {error}"

#: Other_Calculators/views/wind_chill_calculator.py:392
#: Other_Calculators/views/wind_chill_calculator.py:424
#, python-brace-format
msgid "Wind Speed: {speed} {unit}"
msgstr "Velocidad del viento: {speed} {unit}"

#: Other_Calculators/views/wind_chill_calculator.py:394
#: Other_Calculators/views/wind_chill_calculator.py:426
#: Other_Calculators/views/wind_chill_calculator.py:454
msgid "Step 2: Convert to standard units"
msgstr "Paso 2: convertir a unidades estándar"

#: Other_Calculators/views/wind_chill_calculator.py:396
#, python-brace-format
msgid "Temperature in Fahrenheit = ({temp} × 9/5) + 32 = {f}°F"
msgstr "Temperatura en Fahrenheit = ({temp} × 9/5) + 32 = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:398
#: Other_Calculators/views/wind_chill_calculator.py:457
#, python-brace-format
msgid "Temperature in Fahrenheit = {f}°F"
msgstr "Temperatura en Fahrenheit = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:400
#: Other_Calculators/views/wind_chill_calculator.py:430
#, python-brace-format
msgid "Wind Speed in mph = {speed} {unit} = {mph} mph"
msgstr "Velocidad del viento en mph = {speed} {unit} = {mph} mph"

#: Other_Calculators/views/wind_chill_calculator.py:402
#, python-brace-format
msgid "Wind Speed in mph = {mph} mph"
msgstr "Velocidad del viento en mph = {mph} mph"

#: Other_Calculators/views/wind_chill_calculator.py:404
msgid "Step 3: Apply Wind Chill Index formula"
msgstr "Paso 3: Aplicar la fórmula del índice de sensación térmica"

#: Other_Calculators/views/wind_chill_calculator.py:405
msgid "Wind Chill = 35.74 + 0.6215×T - 35.75×V^0.16 + 0.4275×T×V^0.16"
msgstr "Sensación térmica = 35,74 + 0,6215×T - 35,75×V^0,16 + 0,4275×T×V^0,16"

#: Other_Calculators/views/wind_chill_calculator.py:406
msgid "Where T = temperature in °F, V = wind speed in mph"
msgstr "Donde T = temperatura en °F, V = velocidad del viento en mph"

#: Other_Calculators/views/wind_chill_calculator.py:408
#: Other_Calculators/views/wind_chill_calculator.py:436
#, python-brace-format
msgid "V^0.16 = {v_power}"
msgstr "V^0,16 = {v_power}"

#: Other_Calculators/views/wind_chill_calculator.py:409
#, python-brace-format
msgid ""
"Wind Chill = 35.74 + 0.6215×{temp} - 35.75×{v_power} + "
"0.4275×{temp}×{v_power}"
msgstr ""
"Sensación térmica = 35,74 + 0,6215×{temp} - 35,75×{v_power} + "
"0,4275×{temp}×{v_power}"

#: Other_Calculators/views/wind_chill_calculator.py:410
#, python-brace-format
msgid "Wind Chill = {wc}°F"
msgstr "Sensación térmica = {wc}°F"

#: Other_Calculators/views/wind_chill_calculator.py:412
#: Other_Calculators/views/wind_chill_calculator.py:440
#: Other_Calculators/views/wind_chill_calculator.py:464
msgid "Step 4: Convert to requested unit"
msgstr "Paso 4: Convertir a la unidad solicitada"

#: Other_Calculators/views/wind_chill_calculator.py:414
#, python-brace-format
msgid "Wind Chill in Celsius = ({f} - 32) × 5/9 = {c}°C"
msgstr "Sensación térmica en grados Celsius = ({f} - 32) × 5/9 = {c}°C"

#: Other_Calculators/views/wind_chill_calculator.py:416
#, python-brace-format
msgid "Wind Chill = {result}°F"
msgstr "Sensación térmica = {result}°F"

#: Other_Calculators/views/wind_chill_calculator.py:423
#: Other_Calculators/views/wind_chill_calculator.py:451
#, python-brace-format
msgid "Wind Chill: {wc}°{unit}"
msgstr "Sensación térmica: {wc}°{unit}"

#: Other_Calculators/views/wind_chill_calculator.py:428
#, python-brace-format
msgid "Wind Chill in Fahrenheit = ({wc} × 9/5) + 32 = {f}°F"
msgstr "Sensación térmica en grados Fahrenheit = ({wc} × 9/5) + 32 = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:432
msgid "Step 3: Solve for temperature"
msgstr "Paso 3: Resuelva la temperatura"

#: Other_Calculators/views/wind_chill_calculator.py:433
#: Other_Calculators/views/wind_chill_calculator.py:460
msgid "From: WC = 35.74 + 0.6215×T - 35.75×V^0.16 + 0.4275×T×V^0.16"
msgstr "De: CC = 35,74 + 0,6215×T - 35,75×V^0,16 + 0,4275×T×V^0,16"

#: Other_Calculators/views/wind_chill_calculator.py:434
msgid "Solving for T:"
msgstr "Resolviendo para T:"

#: Other_Calculators/views/wind_chill_calculator.py:435
msgid "T = (WC - 35.74 + 35.75×V^0.16) / (0.6215 + 0.4275×V^0.16)"
msgstr "T = (CA - 35,74 + 35,75×V^0,16) / (0,6215 + 0,4275×V^0,16)"

#: Other_Calculators/views/wind_chill_calculator.py:437
#, python-brace-format
msgid "T = ({wc} - 35.74 + 35.75×{v_power}) / (0.6215 + 0.4275×{v_power})"
msgstr "T = ({wc} - 35,74 + 35,75×{v_power}) / (0,6215 + 0,4275×{v_power})"

#: Other_Calculators/views/wind_chill_calculator.py:438
#, python-brace-format
msgid "T = {temp}°F"
msgstr "T = {temp}°F"

#: Other_Calculators/views/wind_chill_calculator.py:442
#, python-brace-format
msgid "Temperature in Celsius = ({f} - 32) × 5/9 = {c}°C"
msgstr "Temperatura en Celsius = ({f} - 32) × 5/9 = {c}°C"

#: Other_Calculators/views/wind_chill_calculator.py:444
#, python-brace-format
msgid "Temperature = {result}°F"
msgstr "Temperatura = {result}°F"

#: Other_Calculators/views/wind_chill_calculator.py:456
#, python-brace-format
msgid "Wind Chill in Fahrenheit = {f}°F"
msgstr "Sensación térmica en grados Fahrenheit = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:459
msgid "Step 3: Solve for wind speed"
msgstr "Paso 3: Resuelva la velocidad del viento"

#: Other_Calculators/views/wind_chill_calculator.py:461
msgid "Using iterative method to solve for V"
msgstr "Usando el método iterativo para resolver V"

#: Other_Calculators/views/wind_chill_calculator.py:462
#, python-brace-format
msgid "Wind Speed = {speed} mph"
msgstr "Velocidad del viento = {speed} mph"

#: Other_Calculators/views/wind_chill_calculator.py:466
#, python-brace-format
msgid "Wind Speed = {result} {unit}"
msgstr "Velocidad del viento = {result} {unit}"

#: Other_Calculators/views/wind_chill_calculator.py:468
#, python-brace-format
msgid "Wind Speed = {result} mph"
msgstr "Velocidad del viento = {result} mph"

#: Other_Calculators/views/wind_chill_calculator.py:480
#: Other_Calculators/views/wind_chill_calculator.py:512
#, python-brace-format
msgid "Wind Chill (°{unit})"
msgstr "Sensación térmica (°{unit})"

#: Other_Calculators/views/wind_chill_calculator.py:499
msgid "Wind Chill vs Wind Speed"
msgstr "Sensación térmica vs velocidad del viento"

#: Other_Calculators/views/wind_chill_calculator.py:506
msgid "Wind Speed (mph)"
msgstr "Velocidad del viento (mph)"

