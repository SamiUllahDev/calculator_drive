msgstr "Valores factoriales"

#: Math_Calculators/templates/math_calculators/permutation_and_combination_calculator.html:242
msgid "What are Permutations and Combinations?"
msgstr "¿Qué son las permutaciones y combinaciones?"

#: Math_Calculators/templates/math_calculators/permutation_and_combination_calculator.html:244
msgid ""
"Permutations and combinations are ways to count arrangements and selections "
"of items from a set."
msgstr ""
"Las permutaciones y combinaciones son formas de contar arreglos y "
"selecciones de elementos de un conjunto."

#: Math_Calculators/templates/math_calculators/permutation_and_combination_calculator.html:247
msgid "Number of ways to arrange r items from n items where order matters"
msgstr ""
"Número de formas de organizar r artículos a partir de n artículos donde el "
"orden importa"

#: Math_Calculators/templates/math_calculators/permutation_and_combination_calculator.html:248
msgid ""
"Number of ways to select r items from n items where order does not matter"
msgstr ""
"Número de formas de seleccionar r artículos de n artículos donde el orden no"
" importa"

