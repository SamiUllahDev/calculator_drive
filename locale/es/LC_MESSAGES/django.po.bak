#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:4
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:24
#: Fitness_and_Health_Calculators/views/index.py:18
msgid "Army Body Fat Calculator"
msgstr "Calculadora de grasa corporal del ejército"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:4
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:280
msgid "US Army Body Fat Standards"
msgstr "Estándares de grasa corporal del ejército de EE. UU."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:5
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:27
msgid ""
"Calculate body fat percentage using US Army measurement standards. Check if "
"you meet Army body fat requirements."
msgstr ""
"Calcule el porcentaje de grasa corporal utilizando los estándares de "
"medición del ejército de EE. UU. Compruebe si cumple con los requisitos de "
"grasa corporal del ejército."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:41
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:73
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:73
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:73
msgid "Your Measurements"
msgstr "Tus medidas"

