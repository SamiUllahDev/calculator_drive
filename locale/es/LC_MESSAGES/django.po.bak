#: Other_Calculators/views/time_card_calculator.py:353
msgid "Step 3: Calculate total time"
msgstr "Paso 3: Calcular el tiempo total"

#: Other_Calculators/views/time_card_calculator.py:354
msgid "Total Time = Clock Out - Clock In"
msgstr "Tiempo total = marcar la salida - marcar la entrada"

#: Other_Calculators/views/time_card_calculator.py:355
#, python-brace-format
msgid "Total Time = {out} - {clock_in} = {total} seconds"
msgstr "Tiempo total = {out} - {clock_in} = {total} segundos"

#: Other_Calculators/views/time_card_calculator.py:356
#, python-brace-format
msgid "Total Time = {hours} hours"
msgstr "Tiempo total = {hours} horas"

#: Other_Calculators/views/time_card_calculator.py:358
msgid "Step 4: Subtract break time"
msgstr "Paso 4: Resta el tiempo de descanso"

#: Other_Calculators/views/time_card_calculator.py:359
#, python-brace-format
msgid "Break Time = {break_time} minutes = {seconds} seconds = {hours} hours"
msgstr ""
"Tiempo de descanso = {break_time} minutos = {seconds} segundos = {hours} "
"horas"

#: Other_Calculators/views/time_card_calculator.py:360
msgid "Worked Time = Total Time - Break Time"
msgstr "Tiempo trabajado = Tiempo total - Tiempo de descanso"

#: Other_Calculators/views/time_card_calculator.py:361
#, python-brace-format
msgid "Worked Time = {total} - {break_time} = {worked} hours"
msgstr "Tiempo trabajado = {total} - {break_time} = {worked} horas"

#: Other_Calculators/views/time_card_calculator.py:363
msgid "Step 5: Calculate regular and overtime"
msgstr "Paso 5: Calcular las horas regulares y extras"

#: Other_Calculators/views/time_card_calculator.py:364
#, python-brace-format
msgid "Regular Hours = min(Worked Hours, {threshold}) = {regular} hours"
msgstr ""
"Horas regulares = min(Horas trabajadas, {threshold}) = horas {regular}"

#: Other_Calculators/views/time_card_calculator.py:365
#, python-brace-format
msgid "Overtime Hours = max(0, Worked Hours - {threshold}) = {overtime} hours"
msgstr ""
"Overtime Hours = max(0, Worked Hours - {threshold}) = {overtime} hours"

#: Other_Calculators/views/time_card_calculator.py:371
msgid "Step 1: Calculate hours for each day"
msgstr "Paso 1: Calcula las horas de cada día."

#: Other_Calculators/views/time_card_calculator.py:373
#, python-brace-format
msgid "{day}: {hours} hours ({regular} regular, {overtime} overtime)"
msgstr "{day}: {hours} horas ({regular} regular, {overtime} horas extra)"

#: Other_Calculators/views/time_card_calculator.py:380
msgid "Step 2: Sum daily hours"
msgstr "Paso 2: Sumar horas diarias"

#: Other_Calculators/views/time_card_calculator.py:381
#, python-brace-format
msgid "Total Worked Hours = {total} hours"
msgstr "Total de horas trabajadas = {total} horas"

#: Other_Calculators/views/time_card_calculator.py:382
#, python-brace-format
msgid "Total Regular Hours = {regular} hours"
msgstr "Total de horas regulares = {regular} horas"

#: Other_Calculators/views/time_card_calculator.py:383
#, python-brace-format
msgid "Total Overtime Hours = {overtime} hours"
msgstr "Total Overtime Hours = {overtime} hours"

#: Other_Calculators/views/time_card_calculator.py:385
msgid "Step 3: Calculate weekly overtime"
msgstr "Paso 3: Calcular las horas extras semanales"

#: Other_Calculators/views/time_card_calculator.py:386
#, python-brace-format
msgid "Weekly Regular = min(Total Hours, {threshold}) = {regular} hours"
msgstr "Semanal regular = min(Total de horas, {threshold}) = {regular} horas"

#: Other_Calculators/views/time_card_calculator.py:387
#, python-brace-format
msgid "Weekly Overtime = max(0, Total Hours - {threshold}) = {overtime} hours"
msgstr ""
"Weekly Overtime = max(0, Total Hours - {threshold}) = {overtime} hours"

#: Other_Calculators/views/time_card_calculator.py:394
#, python-brace-format
msgid "Regular Hours: {hours}"
msgstr "Horario habitual: {hours}"

#: Other_Calculators/views/time_card_calculator.py:395
#, python-brace-format
msgid "Overtime Hours: {hours}"
msgstr "Horas extras: {hours}"

#: Other_Calculators/views/time_card_calculator.py:396
#, python-brace-format
msgid "Hourly Rate: {rate} {currency}"
msgstr "Tarifa por hora: {rate} {currency}"

#: Other_Calculators/views/time_card_calculator.py:397
#, python-brace-format
msgid "Overtime Multiplier: {mult}"
msgstr "Multiplicador de horas extras: {mult}"

#: Other_Calculators/views/time_card_calculator.py:399
msgid "Step 2: Calculate regular pay"
msgstr "Paso 2: Calcular el salario regular"

#: Other_Calculators/views/time_card_calculator.py:400
