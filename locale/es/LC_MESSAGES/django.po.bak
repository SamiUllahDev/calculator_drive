#: Other_Calculators/templates/other_calculators/molecular_weight_calculator.html:53
msgid "Examples: H2O, CO2, NaCl, Ca(OH)2, Al2(SO4)3, CuSO4·5H2O"
msgstr "Ejemplos: H2O, CO2, NaCl, Ca(OH)2, Al2(SO4)3, CuSO4·5H2O"

#: Other_Calculators/templates/other_calculators/molecular_weight_calculator.html:58
msgid "Calculate Molecular Weight"
msgstr "Calcular el peso molecular"

#: Other_Calculators/templates/other_calculators/molecular_weight_calculator.html:92
msgid "What is Molecular Weight?"
msgstr "¿Qué es el peso molecular?"

#: Other_Calculators/templates/other_calculators/molecular_weight_calculator.html:93
msgid ""
"Molecular weight (also called molar mass) is the sum of the atomic weights "
"of all atoms in a molecule. It is expressed in grams per mole (g/mol) and is"
" used to convert between mass and moles in chemical calculations."
msgstr ""
"El peso molecular (también llamado masa molar) es la suma de los pesos "
"atómicos de todos los átomos de una molécula. Se expresa en gramos por mol "
"(g/mol) y se utiliza para convertir entre masa y moles en cálculos químicos."

#: Other_Calculators/templates/other_calculators/molecular_weight_calculator.html:99
msgid "Enter the chemical formula in the input field"
msgstr "Ingrese la fórmula química en el campo de entrada"

#: Other_Calculators/templates/other_calculators/molecular_weight_calculator.html:100
msgid "Use proper capitalization (e.g., H2O, not h2o)"
msgstr "Utilice mayúsculas adecuadas (por ejemplo, H2O, no h2o)"

#: Other_Calculators/templates/other_calculators/molecular_weight_calculator.html:102
msgid "View element breakdown and mass percentages"
msgstr "Ver desglose de elementos y porcentajes de masa"

#: Other_Calculators/templates/other_calculators/molecular_weight_calculator.html:107
msgid "Formula Format"
msgstr "Formato de fórmula"

