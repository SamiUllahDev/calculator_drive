msgstr "El índice de handicap debe estar entre 0 y 54."

#: Other_Calculators/views/golf_handicap_calculator.py:221
#: Other_Calculators/views/golf_handicap_calculator.py:327
msgid "Slope Rating must be between 55 and 155."
msgstr "La clasificación de pendiente debe estar entre 55 y 155."

#: Other_Calculators/views/golf_handicap_calculator.py:227
#: Other_Calculators/views/golf_handicap_calculator.py:321
msgid "Course Rating must be between 60 and 80."
msgstr "La calificación del curso debe estar entre 60 y 80."

#: Other_Calculators/views/golf_handicap_calculator.py:233
msgid "Par must be between 60 and 80."
msgstr "El par debe estar entre 60 y 80."

#: Other_Calculators/views/golf_handicap_calculator.py:277
#, python-brace-format
msgid "Error calculating course handicap: {error}"
msgstr "Error al calcular el hándicap del recorrido: {error}"

#: Other_Calculators/views/golf_handicap_calculator.py:286
msgid "Adjusted Gross Score is required."
msgstr "Se requiere puntaje bruto ajustado."

#: Other_Calculators/views/golf_handicap_calculator.py:292
msgid "Course Rating is required."
msgstr "Se requiere calificación del curso."

#: Other_Calculators/views/golf_handicap_calculator.py:315
msgid "Adjusted Gross Score must be between 50 and 200."
msgstr "La puntuación bruta ajustada debe estar entre 50 y 200."

#: Other_Calculators/views/golf_handicap_calculator.py:369
#, python-brace-format
msgid "Error calculating score differential: {error}"
msgstr "Error al calcular el diferencial de puntuación: {error}"

#: Other_Calculators/views/golf_handicap_calculator.py:378
msgid "Gross Score is required."
msgstr "Se requiere puntuación bruta."

#: Other_Calculators/views/golf_handicap_calculator.py:384
#: Other_Calculators/views/golf_handicap_calculator.py:453
msgid "Course Handicap is required."
msgstr "Se requiere Handicap del curso."

#: Other_Calculators/views/golf_handicap_calculator.py:400
msgid "Gross Score must be between 50 and 200."
msgstr "La puntuación bruta debe estar entre 50 y 200."

#: Other_Calculators/views/golf_handicap_calculator.py:406
#: Other_Calculators/views/golf_handicap_calculator.py:470
msgid "Course Handicap must be between -10 and 54."
msgstr "El hándicap del campo debe estar entre -10 y 54."

#: Other_Calculators/views/golf_handicap_calculator.py:444
#, python-brace-format
msgid "Error calculating net score: {error}"
msgstr "Error al calcular la puntuación neta: {error}"

#: Other_Calculators/views/golf_handicap_calculator.py:476
msgid "Handicap Allowance must be between 0% and 200%."
msgstr "El subsidio para discapacitados debe estar entre 0% y 200%."

#: Other_Calculators/views/golf_handicap_calculator.py:517
#, python-brace-format
msgid "Error calculating playing handicap: {error}"
msgstr "Error al calcular el hándicap de juego: {error}"

#: Other_Calculators/views/golf_handicap_calculator.py:524
msgid "Step 1: Identify the score differentials"
msgstr "Paso 1: Identificar las diferencias de puntuación"

#: Other_Calculators/views/golf_handicap_calculator.py:525
#, python-brace-format
msgid "Number of differentials: {num}"
msgstr "Número de diferenciales: {num}"

#: Other_Calculators/views/golf_handicap_calculator.py:526
#, python-brace-format
msgid "Differentials: {diffs}"
msgstr "Diferenciales: {diffs}"

#: Other_Calculators/views/golf_handicap_calculator.py:528
msgid "Step 2: Sort differentials in ascending order (best scores first)"
msgstr ""
"Paso 2: Ordenar los diferenciales en orden ascendente (las mejores "
"puntuaciones primero)"

#: Other_Calculators/views/golf_handicap_calculator.py:529
#, python-brace-format
msgid "Sorted: {sorted_diffs}"
msgstr "Ordenado: {sorted_diffs}"

#: Other_Calculators/views/golf_handicap_calculator.py:531
msgid "Step 3: Select best differentials based on count"
msgstr "Paso 3: seleccione los mejores diferenciales según el recuento"

#: Other_Calculators/views/golf_handicap_calculator.py:533
msgid "Using best 8 of 20 differentials (WHS standard)"
msgstr "Usando los mejores 8 de 20 diferenciales (estándar WHS)"

#: Other_Calculators/views/golf_handicap_calculator.py:535
#, python-brace-format
msgid "Using best 6 of {num} differentials"
msgstr "Usando los 6 mejores diferenciales de {num}"

#: Other_Calculators/views/golf_handicap_calculator.py:537
#, python-brace-format
msgid "Using best 3 of {num} differentials"
msgstr "Usando los 3 mejores diferenciales de {num}"

#: Other_Calculators/views/golf_handicap_calculator.py:539
#, python-brace-format
msgid "Using best 2 of {num} differentials"
msgstr "Usando los 2 mejores diferenciales de {num}"

#: Other_Calculators/views/golf_handicap_calculator.py:541
#, python-brace-format
msgid "Using best 1 of {num} differentials"
msgstr "Usando el mejor 1 de {num} diferenciales"

#: Other_Calculators/views/golf_handicap_calculator.py:542
#, python-brace-format
msgid "Best differentials: {best}"
msgstr "Mejores diferenciales: {best}"

#: Other_Calculators/views/golf_handicap_calculator.py:544
msgid "Step 4: Calculate average of best differentials"
msgstr "Paso 4: Calcular el promedio de los mejores diferenciales"

#: Other_Calculators/views/golf_handicap_calculator.py:545
#, python-brace-format
msgid "Average = ({diffs}) / {count}"
msgstr "Promedio = ({diffs}) / {count}"

#: Other_Calculators/views/golf_handicap_calculator.py:549
#, python-brace-format
msgid "Average = {avg}"
msgstr "Promedio = {avg}"

#: Other_Calculators/views/golf_handicap_calculator.py:551
msgid "Step 5: Apply adjustment factor (0.96 for WHS)"
msgstr "Paso 5: Aplicar factor de ajuste (0,96 para WHS)"

#: Other_Calculators/views/golf_handicap_calculator.py:552
#, python-brace-format
msgid "Handicap Index = {avg} × 0.96"
msgstr "Índice de desventaja = {avg} × 0,96"

#: Other_Calculators/views/golf_handicap_calculator.py:553
#, python-brace-format
msgid "Handicap Index = {hi}"
msgstr "Índice de desventaja = {hi}"

#: Other_Calculators/views/golf_handicap_calculator.py:560
#: Other_Calculators/views/golf_handicap_calculator.py:659
#, python-brace-format
msgid "Handicap Index: {hi}"
msgstr "Índice de handicap: {hi}"

#: Other_Calculators/views/golf_handicap_calculator.py:561
#: Other_Calculators/views/golf_handicap_calculator.py:583
#, python-brace-format
msgid "Slope Rating: {sr}"
msgstr "Clasificación de pendiente: {sr}"

#: Other_Calculators/views/golf_handicap_calculator.py:562
#: Other_Calculators/views/golf_handicap_calculator.py:582
#, python-brace-format
msgid "Course Rating: {cr}"
msgstr "Calificación del curso: {cr}"

#: Other_Calculators/views/golf_handicap_calculator.py:563
#, python-brace-format
msgid "Par: {par}"
msgstr "Por: {par}"

#: Other_Calculators/views/golf_handicap_calculator.py:565
msgid "Step 2: Calculate slope factor"
msgstr "Paso 2: Calcular el factor de pendiente"

#: Other_Calculators/views/golf_handicap_calculator.py:566
msgid "Slope Factor = Slope Rating / 113"
msgstr "Factor de pendiente = Clasificación de pendiente / 113"

#: Other_Calculators/views/golf_handicap_calculator.py:567
#, python-brace-format
msgid "Slope Factor = {sr} / 113 = {factor}"
msgstr "Factor de pendiente = {sr} / 113 = {factor}"

#: Other_Calculators/views/golf_handicap_calculator.py:569
msgid "Step 3: Apply the course handicap formula"
msgstr "Paso 3: Aplicar la fórmula de handicap del curso"

#: Other_Calculators/views/golf_handicap_calculator.py:570
msgid ""
"Formula: Course Handicap = (Handicap Index × Slope Factor) + (Course Rating "
"- Par)"
msgstr ""
"Fórmula: Handicap del campo = (Índice de handicap × Factor de pendiente) + "
"(Calificación del campo - Par)"

#: Other_Calculators/views/golf_handicap_calculator.py:571
#, python-brace-format
msgid "Course Handicap = ({hi} × {factor}) + ({cr} - {par})"
msgstr "Hándicap del campo = ({hi} × {factor}) + ({cr} - {par})"

#: Other_Calculators/views/golf_handicap_calculator.py:574
#, python-brace-format
msgid "Course Handicap = {ch}"
msgstr "Hándicap del recorrido = {ch}"

#: Other_Calculators/views/golf_handicap_calculator.py:581
#, python-brace-format
msgid "Adjusted Gross Score: {ags}"
msgstr "Puntaje bruto ajustado: {ags}"

#: Other_Calculators/views/golf_handicap_calculator.py:585
msgid "Step 2: Apply the score differential formula"
msgstr "Paso 2: Aplicar la fórmula diferencial de puntuación"

#: Other_Calculators/views/golf_handicap_calculator.py:586
msgid ""
"Formula: Score Differential = (Adjusted Gross Score - Course Rating) × (113 "
"/ Slope Rating)"
msgstr ""
"Fórmula: Diferencial de puntuación = (Puntuación bruta ajustada - "
"Clasificación del campo) × (113 / Clasificación de pendiente)"

#: Other_Calculators/views/golf_handicap_calculator.py:587
#, python-brace-format
msgid "Score Differential = ({ags} - {cr}) × (113 / {sr})"
msgstr "Diferencial de puntuación = ({ags} - {cr}) × (113 / {sr})"

#: Other_Calculators/views/golf_handicap_calculator.py:592
#, python-brace-format
msgid "Score Differential = {diff} × {slope}"
msgstr "Diferencial de puntuación = {diff} × {slope}"

#: Other_Calculators/views/golf_handicap_calculator.py:593
#, python-brace-format
msgid "Score Differential = {sd}"
msgstr "Diferencial de puntuación = {sd}"

#: Other_Calculators/views/golf_handicap_calculator.py:600
#, python-brace-format
msgid "Gross Score: {gross}"
msgstr "Puntuación bruta: {gross}"

#: Other_Calculators/views/golf_handicap_calculator.py:601
#: Other_Calculators/views/golf_handicap_calculator.py:613
#, python-brace-format
msgid "Course Handicap: {ch}"
msgstr "Hándicap del campo: {ch}"

#: Other_Calculators/views/golf_handicap_calculator.py:603
msgid "Step 2: Apply the net score formula"
