msgstr "Paso 2: convertir el peso a Newtons"

#: Other_Calculators/views/weight_calculator.py:439
#, python-brace-format
msgid "Weight in N = {weight} × {factor} = {newtons} N"
msgstr "Peso en N = {weight} × {factor} = {newtons} N"

#: Other_Calculators/views/weight_calculator.py:441
#, python-brace-format
msgid "Weight in N = {newtons} N"
msgstr "Peso en N = {newtons} N"

#: Other_Calculators/views/weight_calculator.py:443
msgid "Step 3: Calculate mass"
msgstr "Paso 3: Calcular la masa"

#: Other_Calculators/views/weight_calculator.py:444
