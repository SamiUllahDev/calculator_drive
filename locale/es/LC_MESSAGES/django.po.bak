#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:5
msgid ""
"Calculate your daily carbohydrate needs based on total calories and macro "
"percentages. Get personalized carb recommendations for your diet."
msgstr ""
"Calcule sus necesidades diarias de carbohidratos en función de las calorías "
"totales y los macroporcentajes. Obtenga recomendaciones personalizadas de "
"carbohidratos para su dieta."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:10
msgid ""
"carbohydrate calculator, carb calculator, daily carbs, carb intake, macro "
"calculator"
msgstr ""
