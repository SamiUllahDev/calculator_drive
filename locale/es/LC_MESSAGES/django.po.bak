msgstr "Masa: {value} {unit}"

#: Other_Calculators/views/mass_calculator.py:528
msgid "Step 2: Convert to kilograms (base unit)"
msgstr "Paso 2: Convertir a kilogramos (unidad base)"

#: Other_Calculators/views/mass_calculator.py:530
msgid "Kilograms = Grams / 1000"
msgstr "Kilogramos = Gramos / 1000"

#: Other_Calculators/views/mass_calculator.py:531
