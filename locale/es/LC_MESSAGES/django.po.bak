#: Other_Calculators/templates/other_calculators/day_counter.html:224
#: Other_Calculators/templates/other_calculators/day_of_the_week_calculator.html:296
#: Other_Calculators/templates/other_calculators/day_of_week_calculator.html:296
msgid "Use the copy or print buttons to save your results."
msgstr "Utilice los botones copiar o imprimir para guardar sus resultados."

#: Other_Calculators/templates/other_calculators/date_calculator.html:269
msgid ""
"Calculate the exact difference between two dates in years, months, days, "
"weeks, hours, minutes, seconds, and business days (excluding weekends)."
msgstr ""
"Calcule la diferencia exacta entre dos fechas en años, meses, días, semanas,"
" horas, minutos, segundos y días hábiles (excluidos los fines de semana)."

#: Other_Calculators/templates/other_calculators/date_calculator.html:273
msgid ""
"Add or subtract years, months, weeks, or days from any date to find the "
"resulting date and day of the week."
msgstr ""
"Sume o reste años, meses, semanas o días de cualquier fecha para encontrar "
"la fecha y el día de la semana resultantes."

#: Other_Calculators/templates/other_calculators/date_calculator.html:277
msgid ""
"Calculate how many days have passed since a past date. Useful for tracking "
"time elapsed since events."
msgstr ""
"Calcula cuántos días han pasado desde una fecha pasada. Útil para realizar "
"un seguimiento del tiempo transcurrido desde los eventos."

#: Other_Calculators/templates/other_calculators/date_calculator.html:281
msgid ""
"Calculate how many days remain until a future date. Perfect for countdowns "
"and planning."
msgstr ""
"Calcula cuántos días quedan hasta una fecha futura. Perfecto para cuentas "
"atrás y planificación."

#: Other_Calculators/templates/other_calculators/date_calculator.html:285
msgid ""
"Find what day of the week any date falls on. Useful for planning events and "
"scheduling."
msgstr ""
"Encuentra en qué día de la semana cae cualquier fecha. Útil para planificar "
"eventos y programar."

#: Other_Calculators/templates/other_calculators/date_calculator.html:291
#: Other_Calculators/templates/other_calculators/day_counter.html:251
msgid "Understanding Business Days"
msgstr "Comprensión de los días hábiles"

#: Other_Calculators/templates/other_calculators/date_calculator.html:293
msgid ""
"Business days are weekdays (Monday through Friday) excluding weekends. This "
"calculator automatically excludes Saturdays and Sundays when calculating "
"business days. Business days are commonly used in:"
msgstr ""
"Los días hábiles son días laborables (de lunes a viernes), excluyendo los "
"fines de semana. Esta calculadora excluye automáticamente los sábados y "
"domingos al calcular los días hábiles. Los días hábiles se utilizan "
"comúnmente en:"

#: Other_Calculators/templates/other_calculators/date_calculator.html:296
#: Other_Calculators/templates/other_calculators/day_counter.html:256
msgid "Project planning and deadlines"
msgstr "Planificación del proyecto y plazos."

#: Other_Calculators/templates/other_calculators/date_calculator.html:297
#: Other_Calculators/templates/other_calculators/day_counter.html:257
msgid "Shipping and delivery estimates"
msgstr "Estimaciones de envío y entrega."

#: Other_Calculators/templates/other_calculators/date_calculator.html:298
#: Other_Calculators/templates/other_calculators/day_counter.html:258
msgid "Work schedules and payroll"
msgstr "Horarios de trabajo y nómina"

#: Other_Calculators/templates/other_calculators/date_calculator.html:299
#: Other_Calculators/templates/other_calculators/day_counter.html:259
msgid "Legal and contract terms"
msgstr "Términos legales y contractuales"

#: Other_Calculators/templates/other_calculators/date_calculator.html:304
msgid "Date Calculation Methods"
msgstr "Métodos de cálculo de fecha"

#: Other_Calculators/templates/other_calculators/date_calculator.html:306
#: Other_Calculators/templates/other_calculators/day_counter.html:267
msgid "Relativedelta:"
msgstr "Delta relativa:"

#: Other_Calculators/templates/other_calculators/date_calculator.html:306
msgid ""
"Used for precise year, month, and day differences. Accounts for varying "
"month lengths and leap years."
msgstr ""
"Se utiliza para diferencias precisas de año, mes y día. Tiene en cuenta "
"diferentes duraciones de meses y años bisiestos."

#: Other_Calculators/templates/other_calculators/date_calculator.html:307
msgid "Timedelta:"
msgstr "Desde cronometrado:"

#: Other_Calculators/templates/other_calculators/date_calculator.html:307
msgid "Used for total days calculation. Simple subtraction of date objects."
msgstr ""
"Se utiliza para el cálculo del total de días. Resta simple de objetos de "
"fecha."

#: Other_Calculators/templates/other_calculators/date_calculator.html:308
#: Other_Calculators/templates/other_calculators/day_counter.html:268
msgid "Business Days:"
msgstr "Días hábiles:"

#: Other_Calculators/templates/other_calculators/date_calculator.html:308
#: Other_Calculators/templates/other_calculators/day_counter.html:268
msgid ""
"Calculated by counting weekdays (Monday-Friday) between dates, excluding "
"weekends."
msgstr ""
"Calculado contando los días laborables (de lunes a viernes) entre fechas, "
"excluyendo los fines de semana."

#: Other_Calculators/templates/other_calculators/date_calculator.html:315
#: Other_Calculators/templates/other_calculators/day_counter.html:275
#: Other_Calculators/templates/other_calculators/day_of_the_week_calculator.html:350
#: Other_Calculators/templates/other_calculators/day_of_week_calculator.html:350
msgid "All calculations account for leap years, including February 29th."
msgstr ""
"Todos los cálculos tienen en cuenta los años bisiestos, incluido el 29 de "
"febrero."

#: Other_Calculators/templates/other_calculators/date_calculator.html:316
#: Other_Calculators/templates/other_calculators/day_counter.html:276
#: Other_Calculators/templates/other_calculators/day_of_the_week_calculator.html:351
#: Other_Calculators/templates/other_calculators/day_of_week_calculator.html:351
msgid "Month lengths vary (28, 29, 30, or 31 days) and are handled correctly."
msgstr ""
"La duración de los meses varía (28, 29, 30 o 31 días) y se manejan "
"correctamente."

#: Other_Calculators/templates/other_calculators/date_calculator.html:317
#: Other_Calculators/templates/other_calculators/day_counter.html:277
#: Other_Calculators/templates/other_calculators/day_of_the_week_calculator.html:352
#: Other_Calculators/templates/other_calculators/day_of_week_calculator.html:352
msgid "Year boundaries and month boundaries are calculated precisely."
msgstr "Los límites de año y mes se calculan con precisión."

#: Other_Calculators/templates/other_calculators/date_calculator.html:318
#: Other_Calculators/templates/other_calculators/day_counter.html:278
msgid ""
"Business days exclude weekends (Saturday and Sunday) only. Holidays are not "
"excluded."
msgstr ""
"Los días hábiles excluyen únicamente los fines de semana (sábado y domingo)."
" No se excluyen los días festivos."

#: Other_Calculators/templates/other_calculators/date_calculator.html:319
#: Other_Calculators/templates/other_calculators/day_counter.html:279
#: Other_Calculators/templates/other_calculators/day_of_the_week_calculator.html:354
#: Other_Calculators/templates/other_calculators/day_of_week_calculator.html:354
msgid "Dates must be between year 1 and year 9999 AD."
msgstr "Las fechas deben estar entre el año 1 y el año 9999 d.C."

#: Other_Calculators/templates/other_calculators/date_calculator.html:433
msgid "total days"
msgstr "días totales"

#: Other_Calculators/templates/other_calculators/date_calculator.html:451
#: Other_Calculators/templates/other_calculators/day_counter.html:406
#: Other_Calculators/views/date_calculator.py:496
#: Other_Calculators/views/day_counter.py:380
msgid "Business Days"
msgstr "Días hábiles"

#: Other_Calculators/templates/other_calculators/date_calculator.html:474
msgid "days from now"
msgstr "días a partir de ahora"

#: Other_Calculators/templates/other_calculators/day_counter.html:4
msgid "Day Counter - Count Days Between Dates | Free Online Tool"
msgstr ""
"Contador de días: cuente los días entre fechas | Herramienta en línea "
"gratuita"

#: Other_Calculators/templates/other_calculators/day_counter.html:5
msgid ""
"Free day counter to count days between dates, days since a date, days until "
"a date, and countdown to events. Calculate with step-by-step solutions. "
"Perfect for planning and tracking important dates."
msgstr ""
"Contador de días gratuito para contar días entre fechas, días desde una "
"fecha, días hasta una fecha y cuenta regresiva para eventos. Calcula con "
"soluciones paso a paso. Perfecto para planificar y realizar un seguimiento "
"de fechas importantes."

#: Other_Calculators/templates/other_calculators/day_counter.html:6
