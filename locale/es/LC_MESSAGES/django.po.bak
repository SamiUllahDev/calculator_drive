#, python-brace-format
msgid "Step 3: Convert from kilograms to {unit}"
msgstr "Paso 3: Convertir de kilogramos a {unit}"

#: Other_Calculators/views/mass_calculator.py:550
msgid "Grams = Kilograms × 1000"
msgstr "Gramos = Kilogramos × 1000"

#: Other_Calculators/views/mass_calculator.py:551
#, python-brace-format
msgid "Grams = {kg} kg × 1000 = {result} g"
msgstr "Gramos = {kg} kg × 1000 = {result} g"

#: Other_Calculators/views/mass_calculator.py:553
msgid "Pounds = Kilograms / 0.453592"
msgstr "Libras = Kilogramos / 0,453592"

#: Other_Calculators/views/mass_calculator.py:554
#, python-brace-format
msgid "Pounds = {kg} kg / 0.453592 = {result} lbs"
msgstr "Libras = {kg} kg / 0,453592 = {result} lbs"

#: Other_Calculators/views/mass_calculator.py:556
msgid "Ounces = Kilograms / 0.0283495"
msgstr "Onzas = Kilogramos / 0,0283495"

#: Other_Calculators/views/mass_calculator.py:557
#, python-brace-format
msgid "Ounces = {kg} kg / 0.0283495 = {result} oz"
msgstr "Onzas = {kg} kg / 0,0283495 = {result} oz"

#: Other_Calculators/views/mass_calculator.py:559
msgid "Tons = Kilograms / 1000"
msgstr "Toneladas = Kilogramos / 1000"

#: Other_Calculators/views/mass_calculator.py:560
#, python-brace-format
msgid "Tons = {kg} kg / 1000 = {result} tons"
msgstr "Toneladas = {kg} kg / 1000 = {result} toneladas"

#: Other_Calculators/views/mass_calculator.py:562
msgid "Stone = Kilograms / 6.35029"
msgstr "Piedra = Kilogramos / 6,35029"

#: Other_Calculators/views/mass_calculator.py:563
#, python-brace-format
msgid "Stone = {kg} kg / 6.35029 = {result} stone"
msgstr "Piedra = {kg} kg / 6.35029 = {result} piedra"

#: Other_Calculators/views/mass_calculator.py:565
#, python-brace-format
msgid "Result = {kg} kg / conversion factor = {result} {unit}"
msgstr "Resultado = {kg} kg / factor de conversión = {result} {unit}"

#: Other_Calculators/views/mass_calculator.py:568
#: Other_Calculators/views/mass_calculator.py:594
#, python-brace-format
