#: user/templates/user/account_delete.html:5
#: user/templates/user/account_delete.html:87
#: user/templates/user/account_settings.html:89
#: user/templates/user/account_settings.html:96
msgid "Delete Account"
msgstr "Eliminar cuenta"

#: user/templates/user/account_delete.html:6
msgid "Permanently delete your account and all associated data"
msgstr "Eliminar permanentemente su cuenta y todos los datos asociados"

#: user/templates/user/account_delete.html:19
msgid "Delete Your Account"
msgstr "Eliminar tu cuenta"

#: user/templates/user/account_delete.html:20
msgid "This action cannot be undone"
msgstr "Esta acción no se puede deshacer."

#: user/templates/user/account_delete.html:30
msgid ""
"Warning: Once you delete your account, there is no going back. All of your "
"data will be permanently removed."
msgstr ""
"Advertencia: Una vez que elimines tu cuenta, no hay vuelta atrás. Todos sus "
"datos serán eliminados permanentemente."

#: user/templates/user/account_delete.html:39
msgid "What happens when you delete your account:"
msgstr "Qué sucede cuando eliminas tu cuenta:"

#: user/templates/user/account_delete.html:44
msgid "Your profile and personal information will be permanently deleted"
msgstr "Su perfil e información personal se eliminarán permanentemente."

#: user/templates/user/account_delete.html:48
msgid "You'll lose access to all your saved data and settings"
msgstr "Perderás el acceso a todos tus datos y configuraciones guardados."

#: user/templates/user/account_delete.html:52
msgid "Your username will be available for others to use"
msgstr "Su nombre de usuario estará disponible para que otros lo utilicen"

#: user/templates/user/account_delete.html:74
msgid ""
"I understand that this action cannot be undone and all my data will be "
"permanently deleted."
msgstr ""
"Entiendo que esta acción no se puede deshacer y todos mis datos se "
"eliminarán permanentemente."

#: user/templates/user/account_delete.html:96
msgid "Having issues with your account? Consider"
msgstr "¿Tiene problemas con su cuenta? Considerar"

#: user/templates/user/account_delete.html:97
msgid "updating your profile"
msgstr "actualizando tu perfil"

#: user/templates/user/account_delete.html:99
msgid "contacting support"
msgstr "contactando al soporte"

#: user/templates/user/account_delete.html:100
msgid "instead."
msgstr "en cambio."

