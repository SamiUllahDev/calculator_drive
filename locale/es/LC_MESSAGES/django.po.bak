msgid "Error calculating tiles needed: {error}"
msgstr "Error al calcular los mosaicos necesarios: {error}"

#: Other_Calculators/views/tile_calculator.py:205
msgid "Number of tiles is required."
msgstr "Se requiere la cantidad de mosaicos."

#: Other_Calculators/views/tile_calculator.py:237
msgid "Number of tiles must be greater than zero."
msgstr "El número de mosaicos debe ser mayor que cero."

#: Other_Calculators/views/tile_calculator.py:309
