msgstr "Justo"

#: Other_Calculators/templates/other_calculators/password_generator.html:178
msgid "28-40 bits entropy"
msgstr "Entropía de 28-40 bits"

#: Other_Calculators/templates/other_calculators/password_generator.html:179
msgid "40-60 bits entropy"
msgstr "Entropía de 40-60 bits"

#: Other_Calculators/templates/other_calculators/password_generator.html:180
#: Other_Calculators/templates/other_calculators/password_generator.html:340
#: Other_Calculators/templates/other_calculators/password_generator.html:456
msgid "Strong"
msgstr "Fuerte"

#: Other_Calculators/templates/other_calculators/password_generator.html:180
