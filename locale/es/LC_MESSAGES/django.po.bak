#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:175
msgid ""
"Enter your total calories and carbohydrate percentage to see your daily "
"carbohydrate breakdown with meal distribution and food sources."
msgstr ""
"Ingrese sus calorías totales y su porcentaje de carbohidratos para ver su "
"desglose diario de carbohidratos con la distribución de comidas y las "
"fuentes de alimentos."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:185
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:376
