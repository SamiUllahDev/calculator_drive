msgstr "Nombre 1 Longitud: {len} caracteres"

#: Other_Calculators/views/love_calculator.py:448
#, python-brace-format
msgid "Name 2 Length: {len} characters"
msgstr "Nombre 2 Longitud: {len} caracteres"

#: Other_Calculators/views/love_calculator.py:450
msgid "Step 3: Count vowels and consonants"
msgstr "Paso 3: cuenta vocales y consonantes"

#: Other_Calculators/views/love_calculator.py:451
#, python-brace-format
msgid "Name 1: {vowels} vowels, {consonants} consonants"
msgstr "Nombre 1: {vowels} vocales, {consonants} consonantes"

#: Other_Calculators/views/love_calculator.py:454
#, python-brace-format
msgid "Name 2: {vowels} vowels, {consonants} consonants"
msgstr "Nombre 2: {vowels} vocales, {consonants} consonantes"

