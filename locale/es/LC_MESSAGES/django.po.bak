msgstr "creatinina"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:141
msgid "Range: 0.1-10 mg/dL"
msgstr "Rango: 0,1-10 mg/dL"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:149
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:594
msgid "Calculate eGFR"
msgstr "Calcular eGFR"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:179
msgid ""
"Enter your information to calculate your estimated glomerular filtration "
"rate (eGFR) with detailed analysis and charts."
msgstr ""
"Ingrese su información para calcular su tasa de filtración glomerular "
"estimada (eGFR) con análisis y gráficos detallados."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:189
msgid "Estimated GFR (eGFR)"
msgstr "TFG estimada (TFGe)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:202
