msgstr "Tarifa de horas extras = Tarifa por hora × Multiplicador"

#: Other_Calculators/views/time_card_calculator.py:405
#, python-brace-format
msgid "Overtime Rate = {rate} × {mult} = {overtime_rate} {currency}"
msgstr "Overtime Rate = {rate} × {mult} = {overtime_rate} {currency}"

#: Other_Calculators/views/time_card_calculator.py:407
msgid "Step 4: Calculate overtime pay"
msgstr "Paso 4: Calcular el pago de horas extras"

#: Other_Calculators/views/time_card_calculator.py:408
