#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:177
msgid "What is Tire Size?"
msgstr "¿Qué es el tamaño de los neumáticos?"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:178
msgid ""
"Tire size is a standardized way of describing tire dimensions, including "
"width, aspect ratio, and rim diameter. It affects vehicle performance, "
"speedometer accuracy, and handling."
msgstr ""
"El tamaño de los neumáticos es una forma estandarizada de describir las "
"dimensiones de los neumáticos, incluido el ancho, la relación de aspecto y "
"el diámetro de la llanta. Afecta el rendimiento del vehículo, la precisión "
"del velocímetro y el manejo."

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:185
msgid "Enter tire size(s)"
msgstr "Ingrese el tamaño de los neumáticos"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:191
msgid "Tire Size Formats"
msgstr "Formatos de tamaño de neumáticos"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:196
msgid "205 = Width (mm)"
msgstr "205 = Ancho (mm)"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:197
#, python-format
msgid "55 = Aspect Ratio (%%)"
msgstr "55 = Relación de aspecto (%%)"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:198
msgid "16 = Rim Diameter (inches)"
msgstr "16 = Diámetro de la llanta (pulgadas)"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:203
msgid "31 = Overall Diameter (inches)"
msgstr "31 = Diámetro total (pulgadas)"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:204
msgid "10.5 = Width (inches)"
msgstr "10,5 = Ancho (pulgadas)"

#: Other_Calculators/templates/other_calculators/tire_size_calculator.html:205
msgid "15 = Rim Diameter (inches)"
msgstr "15 = Diámetro de la llanta (pulgadas)"

