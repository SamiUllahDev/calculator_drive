msgstr "Paso 2: Convertir a unidad base (kilogramos)"

#: Other_Calculators/views/weight_calculator.py:402
#, python-brace-format
msgid "Conversion factor: 1 {from_unit} = {factor} kg"
msgstr "Factor de conversión: 1 {from_unit} = {factor} kg"

#: Other_Calculators/views/weight_calculator.py:403
#, python-brace-format
msgid "Weight in kg = {weight} × {factor} = {kg} kg"
msgstr "Peso en kg = {weight} × {factor} = {kg} kg"

#: Other_Calculators/views/weight_calculator.py:406
#, python-brace-format
msgid "Conversion factor: 1 {to_unit} = {factor} kg"
msgstr "Factor de conversión: 1 {to_unit} = {factor} kg"

#: Other_Calculators/views/weight_calculator.py:407
#, python-brace-format
msgid "Result = {kg} / {factor} = {result} {unit}"
msgstr "Resultado = {kg} / {factor} = {result} {unit}"

#: Other_Calculators/views/weight_calculator.py:415
#: Other_Calculators/views/weight_calculator.py:435
#, python-brace-format
