msgid "Step 2: Convert mass to kilograms"
msgstr "Paso 2: convertir masa a kilogramos"

#: Other_Calculators/views/weight_calculator.py:419
#, python-brace-format
msgid "Mass in kg = {mass} × {factor} = {kg} kg"
msgstr "Masa en kg = {mass} × {factor} = {kg} kg"

#: Other_Calculators/views/weight_calculator.py:421
#, python-brace-format
msgid "Mass in kg = {kg} kg"
msgstr "Masa en kg = {kg} kg"

