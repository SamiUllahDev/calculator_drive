msgstr "Lea nuestra política de privacidad"

#: core/templates/core/cookie_policy.html:421
#: core/templates/core/privacy_policy.html:410
msgid "Read our terms and conditions"
msgstr "Lea nuestros términos y condiciones"

#: core/templates/core/cookie_policy.html:428
