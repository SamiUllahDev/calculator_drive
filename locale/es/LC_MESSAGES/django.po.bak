msgstr "Pago regular = Horas regulares × Tarifa por hora"

#: Other_Calculators/views/time_card_calculator.py:401
#, python-brace-format
msgid "Regular Pay = {hours} × {rate} = {pay} {currency}"
msgstr "Pago regular = {hours} × {rate} = {pay} {currency}"

#: Other_Calculators/views/time_card_calculator.py:403
msgid "Step 3: Calculate overtime rate"
msgstr "Paso 3: Calcular la tarifa de horas extras"

#: Other_Calculators/views/time_card_calculator.py:404
