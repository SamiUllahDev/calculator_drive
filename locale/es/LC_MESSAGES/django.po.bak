msgstr "Hora de inicio: {start} = {seconds} segundos"

#: Other_Calculators/views/time_calculator.py:456
#, python-brace-format
msgid "End Time: {end} = {seconds} seconds"
msgstr "Hora de finalización: {end} = {seconds} segundos"

