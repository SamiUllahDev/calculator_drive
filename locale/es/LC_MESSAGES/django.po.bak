#: Other_Calculators/views/btu_calculator.py:365
msgid "Appliance heat cannot be negative."
msgstr "El calor del aparato no puede ser negativo."

#: Other_Calculators/views/btu_calculator.py:446
msgid "Step 1: Enter Room Dimensions"
msgstr "Paso 1: Ingrese las dimensiones de la habitación"

#: Other_Calculators/views/btu_calculator.py:447
#: Other_Calculators/views/concrete_calculator.py:543
#: Other_Calculators/views/concrete_calculator.py:686
#: Other_Calculators/views/concrete_calculator.py:729
#, python-brace-format
msgid "  Length: {length} {unit}"
msgstr "Longitud: {length} {unit}"

#: Other_Calculators/views/btu_calculator.py:448
#: Other_Calculators/views/concrete_calculator.py:544
#: Other_Calculators/views/concrete_calculator.py:687
#, python-brace-format
msgid "  Width: {width} {unit}"
msgstr "Ancho: {width} {unit}"

#: Other_Calculators/views/btu_calculator.py:449
#: Other_Calculators/views/concrete_calculator.py:637
#: Other_Calculators/views/concrete_calculator.py:730
#, python-brace-format
msgid "  Height: {height} {unit}"
msgstr "Altura: {height} {unit}"

#: Other_Calculators/views/btu_calculator.py:453
#: Other_Calculators/views/concrete_calculator.py:549
#: Other_Calculators/views/concrete_calculator.py:591
#: Other_Calculators/views/concrete_calculator.py:641
#: Other_Calculators/views/concrete_calculator.py:692
#: Other_Calculators/views/concrete_calculator.py:735
msgid "Step 2: Convert to Feet"
msgstr "Paso 2: convertir a pies"

#: Other_Calculators/views/btu_calculator.py:454
#: Other_Calculators/views/concrete_calculator.py:550
#: Other_Calculators/views/concrete_calculator.py:693
#: Other_Calculators/views/concrete_calculator.py:736
#, python-brace-format
msgid "  Length: {m} m × 3.28084 = {ft:.2f} ft"
msgstr "Longitud: {m} m × 3,28084 = {ft:.2f} pies"

#: Other_Calculators/views/btu_calculator.py:455
#: Other_Calculators/views/concrete_calculator.py:551
#: Other_Calculators/views/concrete_calculator.py:694
#, python-brace-format
msgid "  Width: {m} m × 3.28084 = {ft:.2f} ft"
msgstr "Ancho: {m} m × 3,28084 = {ft:.2f} pies"

#: Other_Calculators/views/btu_calculator.py:456
#: Other_Calculators/views/concrete_calculator.py:643
#: Other_Calculators/views/concrete_calculator.py:737
#, python-brace-format
msgid "  Height: {m} m × 3.28084 = {ft:.2f} ft"
msgstr "Altura: {m} m × 3,28084 = {ft:.2f} pies"

#: Other_Calculators/views/btu_calculator.py:459
msgid "Step 3: Calculate Area"
msgstr "Paso 3: calcular el área"

#: Other_Calculators/views/btu_calculator.py:460
msgid "  Area = Length × Width"
msgstr "Área = Largo × Ancho"

#: Other_Calculators/views/btu_calculator.py:461
#, python-brace-format
msgid "  Area = {length:.2f} × {width:.2f} = {area:.2f} sq ft"
msgstr "Área = {largo:.2f} × {ancho:.2f} = {área:.2f} pies cuadrados"

#: Other_Calculators/views/btu_calculator.py:466
#: Other_Calculators/views/concrete_calculator.py:605
#: Other_Calculators/views/concrete_calculator.py:655
msgid "Step 4: Calculate Volume"
msgstr "Paso 4: calcular el volumen"

#: Other_Calculators/views/btu_calculator.py:467
msgid "  Volume = Length × Width × Height"
msgstr "Volumen = Largo × Ancho × Alto"

#: Other_Calculators/views/btu_calculator.py:468
#, python-brace-format
msgid ""
"  Volume = {length:.2f} × {width:.2f} × {height:.2f} = {volume:.2f} cu ft"
msgstr ""
"Volumen = {largo:.2f} × {ancho:.2f} × {alto:.2f} = {volumen:.2f} pies "
"cúbicos"

#: Other_Calculators/views/btu_calculator.py:473
msgid "Step 5: Determine Base BTU"
msgstr "Paso 5: Determinar los BTU base"

#: Other_Calculators/views/btu_calculator.py:474
#: Other_Calculators/views/btu_calculator.py:515
#, python-brace-format
msgid "  Room Type: {room_type} ({btu_per_sqft} BTU per sq ft)"
msgstr "Tipo de habitación: {room_type} ({btu_per_sqft} BTU por pie cuadrado)"

#: Other_Calculators/views/btu_calculator.py:477
#: Other_Calculators/views/btu_calculator.py:518
#: Other_Calculators/views/btu_calculator.py:616
msgid "  Base BTU = Area × BTU per sq ft"
msgstr "BTU base = Área × BTU por pie cuadrado"

#: Other_Calculators/views/btu_calculator.py:478
#: Other_Calculators/views/btu_calculator.py:519
#: Other_Calculators/views/btu_calculator.py:617
#, python-brace-format
msgid "  Base BTU = {area:.2f} × {btu_per_sqft} = {base_btu:.2f} BTU"
msgstr "BTU base = {área:.2f} × {btu_per_sqft} = {base_btu:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:483
msgid "Step 6: Apply Multipliers"
msgstr "Paso 6: aplicar multiplicadores"

#: Other_Calculators/views/btu_calculator.py:484
#: Other_Calculators/views/btu_calculator.py:525
#, python-brace-format
msgid "  Insulation Quality: {insulation} (multiplier: {mult})"
msgstr "Calidad de aislamiento: {insulation} (multiplicador: {mult})"

#: Other_Calculators/views/btu_calculator.py:487
#: Other_Calculators/views/btu_calculator.py:528
#, python-brace-format
msgid "  Climate Zone: {climate} (multiplier: {mult})"
msgstr "Zona climática: {climate} (multiplicador: {mult})"

#: Other_Calculators/views/btu_calculator.py:492
msgid "Step 7: Calculate Total BTU"
msgstr "Paso 7: Calcular el BTU total"

#: Other_Calculators/views/btu_calculator.py:493
#: Other_Calculators/views/btu_calculator.py:534
msgid "  Total BTU = Base BTU × Insulation Multiplier × Climate Multiplier"
msgstr ""
"BTU total = BTU base × Multiplicador de aislamiento × Multiplicador "
"climático"

#: Other_Calculators/views/btu_calculator.py:494
#: Other_Calculators/views/btu_calculator.py:535
#, python-brace-format
msgid "  Total BTU = {base:.2f} × {ins_mult} × {clim_mult} = {total:.2f} BTU"
msgstr "BTU totales = {base:.2f} × {ins_mult} × {clim_mult} = {total:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:505
msgid "Step 1: Enter Area"
msgstr "Paso 1: ingresar al área"

#: Other_Calculators/views/btu_calculator.py:506
#: Other_Calculators/views/btu_calculator.py:601
#, python-brace-format
msgid "  Area: {area} {unit}"
msgstr "Área: {area} {unit}"

#: Other_Calculators/views/btu_calculator.py:510
msgid "Step 2: Convert to Square Feet"
msgstr "Paso 2: convertir a pies cuadrados"

#: Other_Calculators/views/btu_calculator.py:511
#: Other_Calculators/views/btu_calculator.py:609
#, python-brace-format
msgid "  Area = {sqm} m² × 10.764 = {sqft:.2f} sq ft"
msgstr "Área = {sqm} m² × 10,764 = {sqft:.2f} pies cuadrados"

#: Other_Calculators/views/btu_calculator.py:514
msgid "Step 3: Determine Base BTU"
msgstr "Paso 3: Determinar los BTU base"

#: Other_Calculators/views/btu_calculator.py:524
#: Other_Calculators/views/btu_calculator.py:622
msgid "Step 4: Apply Multipliers"
msgstr "Paso 4: aplicar multiplicadores"

#: Other_Calculators/views/btu_calculator.py:533
msgid "Step 5: Calculate Total BTU"
msgstr "Paso 5: Calcular el BTU total"

#: Other_Calculators/views/btu_calculator.py:545
#: Other_Calculators/views/concrete_calculator.py:770
msgid "Step 1: Original Value"
msgstr "Paso 1: valor original"

#: Other_Calculators/views/btu_calculator.py:546
#: Other_Calculators/views/concrete_calculator.py:771
#, python-brace-format
msgid "  Value: {value} {unit}"
msgstr "Valor: {value} {unit}"

#: Other_Calculators/views/btu_calculator.py:550
msgid "Step 2: Convert to BTU"
msgstr "Paso 2: convertir a BTU"

#: Other_Calculators/views/btu_calculator.py:552
#, python-brace-format
msgid "  BTU = {kwh} kWh ÷ {factor} = {btu:.2f} BTU"
msgstr "BTU = {kwh} kWh ÷ {factor} = {btu:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:556
#, python-brace-format
msgid "  BTU = {j} J ÷ {factor} = {btu:.2f} BTU"
msgstr "PERO = {j} Ji Ñ {factor} = {btu: {btu:2f} PERO."

#: Other_Calculators/views/btu_calculator.py:560
#, python-brace-format
msgid "  BTU = {cal} cal ÷ {factor} = {btu:.2f} BTU"
msgstr "BTU = {cal} cal ÷ {factor} = {btu:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:564
#, python-brace-format
msgid "  BTU = {fp} ft-lb ÷ {factor} = {btu:.2f} BTU"
msgstr "BTU = {fp} pies-libra ÷ {factor} = {btu:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:570
#: Other_Calculators/views/concrete_calculator.py:787
#, python-brace-format
msgid "Step 3: Convert to {unit}"
msgstr "Paso 3: convertir a {unit}"

#: Other_Calculators/views/btu_calculator.py:572
#, python-brace-format
msgid "  {unit} = {btu} BTU × {factor} = {converted:.6f} {unit}"
msgstr "{unit} = {btu} BTU × {factor} = {convertido:.6f} {unit}"

#: Other_Calculators/views/btu_calculator.py:576
#: Other_Calculators/views/btu_calculator.py:580
#: Other_Calculators/views/btu_calculator.py:584
#, python-brace-format
msgid "  {unit} = {btu} BTU × {factor} = {converted:.2f} {unit}"
msgstr "{unit} = {btu} BTU × {factor} = {convertido:.2f} {unit}"

#: Other_Calculators/views/btu_calculator.py:588
#: Other_Calculators/views/concrete_calculator.py:799
#: Other_Calculators/views/day_of_the_week_calculator.py:431
#: Other_Calculators/views/day_of_the_week_calculator.py:447
#: Other_Calculators/views/day_of_week_calculator.py:431
#: Other_Calculators/views/day_of_week_calculator.py:447
