msgid "1%% - 5%%"
msgstr "1%% - 5%%"

#: Math_Calculators/templates/math_calculators/percent_error_calculator.html:288
#: Math_Calculators/templates/math_calculators/percent_error_calculator.html:313
msgid "Good accuracy"
msgstr "Buena precisión"

#: Math_Calculators/templates/math_calculators/percent_error_calculator.html:289
#, python-format
msgid "5%% - 10%%"
msgstr "5%% - 10%%"

#: Math_Calculators/templates/math_calculators/percent_error_calculator.html:289
msgid "Acceptable accuracy"
msgstr "Precisión aceptable"

#: Math_Calculators/templates/math_calculators/percent_error_calculator.html:290
#, python-format
msgid "&gt; 10%%"
msgstr "> 10%%"

#: Math_Calculators/templates/math_calculators/percent_error_calculator.html:290
msgid "Poor accuracy - review measurements and procedures"
msgstr "Poca precisión: revise las mediciones y los procedimientos"

