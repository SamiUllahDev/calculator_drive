msgstr "az (26 caracteres)"

#: Other_Calculators/templates/other_calculators/password_generator.html:168
msgid "Uppercase"
msgstr "Mayúsculas"

#: Other_Calculators/templates/other_calculators/password_generator.html:168
msgid "A-Z (26 characters)"
msgstr "AZ (26 caracteres)"

#: Other_Calculators/templates/other_calculators/password_generator.html:169
msgid "0-9 (10 characters)"
msgstr "0-9 (10 caracteres)"

#: Other_Calculators/templates/other_calculators/password_generator.html:170
msgid "Special"
msgstr "Especial"

