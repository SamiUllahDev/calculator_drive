#: core/templates/core/index.html:99
msgid "Popular:"
msgstr "Popular:"

#: core/templates/core/index.html:121
msgid "Unit Converter"
msgstr "Convertidor de unidades"

#: core/templates/core/index.html:143
msgid "Featured Calculators"
msgstr "Calculadoras destacadas"

#: core/templates/core/index.html:144
msgid ""
"Discover our most popular and useful calculators across different categories"
msgstr ""
"Descubra nuestras calculadoras más populares y útiles en diferentes "
"categorías"

#: core/templates/core/index.html:160
msgid ""
"Essential math tools for algebra, geometry, statistics, trigonometry, and "
"number theory."
msgstr ""
"Herramientas matemáticas esenciales para álgebra, geometría, estadística, "
"trigonometría y teoría de números."

#: core/templates/core/index.html:168
msgid "Geometry & Trigonometry"
msgstr "Geometría y trigonometría"

#: core/templates/core/index.html:176
msgid "Explore Math"
msgstr "Explora las matemáticas"

#: core/templates/core/index.html:194
msgid ""
"Financial tools for mortgages, loans, investments, taxes, retirement "
"planning, and business calculations."
msgstr ""
"Herramientas financieras para hipotecas, préstamos, inversiones, impuestos, "
"planificación de jubilación y cálculos comerciales."

#: core/templates/core/index.html:198
msgid "Loans & Mortgages"
msgstr "Préstamos e Hipotecas"

#: core/templates/core/index.html:202
msgid "Investments & Retirement"
msgstr "Inversiones y jubilación"

#: core/templates/core/index.html:206
msgid "Taxes & Business"
