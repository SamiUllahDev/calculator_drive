msgstr "Fórmula de permutación"

#: Math_Calculators/templates/math_calculators/permutation_and_combination_calculator.html:258
msgid "Example: P(5, 3) = 5! / (5-3)! = 120 / 2 = 60"
msgstr "Ejemplo: ¡P(5, 3) = 5! / (5-3)! = 120 / 2 = 60"

#: Math_Calculators/templates/math_calculators/permutation_and_combination_calculator.html:261
msgid "Combination Formula"
msgstr "Fórmula combinada"

#: Math_Calculators/templates/math_calculators/permutation_and_combination_calculator.html:263
