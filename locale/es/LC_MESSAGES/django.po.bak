msgid "Area (ft²)"
msgstr "Área (pies²)"

#: Other_Calculators/views/tile_calculator.py:511
msgid "Tiles Needed Calculation"
msgstr "Cálculo de los mosaicos necesarios"

#: Other_Calculators/views/tile_calculator.py:555
msgid "Tile Coverage"
msgstr "Cobertura de azulejos"

#: Other_Calculators/views/tile_calculator.py:605
#, python-brace-format
msgid "Cost Breakdown (Total: {total})"
msgstr "Desglose de costos (Total: {total})"

#: Other_Calculators/views/time_calculator.py:121
msgid "First time is required."
msgstr "Se requiere la primera vez."

#: Other_Calculators/views/time_calculator.py:127
msgid "Second time is required."
msgstr "Se requiere segunda vez."

#: Other_Calculators/views/time_calculator.py:140
#: Other_Calculators/views/time_calculator.py:210
#: Other_Calculators/views/time_calculator.py:339
#: Other_Calculators/views/time_card_calculator.py:133
#: Other_Calculators/views/time_duration_calculator.py:164
