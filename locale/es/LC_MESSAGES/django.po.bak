msgid "Temperature cannot be below absolute zero (-459.67°F)."
msgstr ""
"La temperatura no puede estar por debajo del cero absoluto (-459,67°F)."

#: Other_Calculators/views/dew_point_calculator.py:630
msgid "Temperature cannot be below absolute zero (0K)."
msgstr "La temperatura no puede estar por debajo del cero absoluto (0K)."

#: Other_Calculators/views/dew_point_calculator.py:637
msgid "Temperature is too high. Please enter a value below 1000°C."
msgstr ""
"La temperatura es demasiado alta. Introduzca un valor inferior a 1000 °C."

#: Other_Calculators/views/dew_point_calculator.py:642
msgid "Temperature is too high. Please enter a value below 1832°F."
msgstr ""
"La temperatura es demasiado alta. Ingrese un valor inferior a 1832 °F."

#: Other_Calculators/views/dew_point_calculator.py:647
msgid "Temperature is too high. Please enter a value below 1273.15K."
msgstr ""
"La temperatura es demasiado alta. Introduzca un valor inferior a 1273,15 K."

#: Other_Calculators/views/dew_point_calculator.py:682
#: Other_Calculators/views/dew_point_calculator.py:715
#, python-brace-format
msgid "Temperature: {temp} {unit}"
msgstr "Temperatura: {temp} {unit}"

#: Other_Calculators/views/dew_point_calculator.py:683
#: Other_Calculators/views/dew_point_calculator.py:747
#, python-brace-format
msgid "Relative Humidity: {rh}%"
msgstr "Humedad relativa: {rh}%"

#: Other_Calculators/views/dew_point_calculator.py:685
msgid "Step 2: Convert temperature to Celsius"
msgstr "Paso 2: convertir la temperatura a Celsius"

#: Other_Calculators/views/dew_point_calculator.py:686
#: Other_Calculators/views/dew_point_calculator.py:719
#, python-brace-format
msgid "Temperature in Celsius: {temp}°C"
msgstr "Temperatura en grados Celsius: {temp}°C"

#: Other_Calculators/views/dew_point_calculator.py:688
#: Other_Calculators/views/dew_point_calculator.py:722
msgid "Step 3: Apply the Magnus formula"
msgstr "Paso 3: aplica la fórmula Magnus"

#: Other_Calculators/views/dew_point_calculator.py:692
#: Other_Calculators/views/dew_point_calculator.py:696
msgid "Formula: Td = (B × α) / (A - α)"
msgstr "Fórmula: Td = (B × α) / (A - α)"

#: Other_Calculators/views/dew_point_calculator.py:693
msgid "Where: α = (A × T) / (B + T) + ln(RH/100)"
msgstr "Donde: α = (A × T) / (B + T) + ln(RH/100)"

#: Other_Calculators/views/dew_point_calculator.py:694
#: Other_Calculators/views/dew_point_calculator.py:726
msgid "A = 17.27, B = 237.7°C"
msgstr "A = 17,27, B = 237,7°C"

#: Other_Calculators/views/dew_point_calculator.py:697
#, python-brace-format
msgid "α = ({a} × {temp}) / ({b} + {temp}) + ln({rh}/100)"
msgstr "α = ({a} × {temp}) / ({b} + {temp}) + ln({rh}/100)"

#: Other_Calculators/views/dew_point_calculator.py:701
#: Other_Calculators/views/dew_point_calculator.py:763
#, python-brace-format
msgid "α = {alpha}"
msgstr "α = {alpha}"

#: Other_Calculators/views/dew_point_calculator.py:702
#, python-brace-format
msgid "Dew Point = ({b} × {alpha}) / ({a} - {alpha})"
msgstr "Punto de rocío = ({b} × {alpha}) / ({a} - {alpha})"

#: Other_Calculators/views/dew_point_calculator.py:705
#, python-brace-format
msgid "Dew Point = {dp}°C"
msgstr "Punto de rocío = {dp}°C"

#: Other_Calculators/views/dew_point_calculator.py:708
#, python-brace-format
msgid "Dew Point = {dp} {unit}"
msgstr "Punto de rocío = {dp} {unit}"

#: Other_Calculators/views/dew_point_calculator.py:716
#: Other_Calculators/views/dew_point_calculator.py:746
#, python-brace-format
msgid "Dew Point: {dp} {unit}"
msgstr "Punto de rocío: {dp} {unit}"

#: Other_Calculators/views/dew_point_calculator.py:718
#: Other_Calculators/views/dew_point_calculator.py:781
msgid "Step 2: Convert to Celsius"
msgstr "Paso 2: convertir a Celsius"

#: Other_Calculators/views/dew_point_calculator.py:720
#: Other_Calculators/views/dew_point_calculator.py:750
#, python-brace-format
msgid "Dew Point in Celsius: {dp}°C"
msgstr "Punto de rocío en grados Celsius: {dp}°C"

#: Other_Calculators/views/dew_point_calculator.py:725
#: Other_Calculators/views/dew_point_calculator.py:728
msgid "Formula: RH = 100 × exp((A×Td)/(B+Td) - (A×T)/(B+T))"
msgstr "Fórmula: RH = 100 × exp((A×Td)/(B+Td) - (A×T)/(B+T))"

#: Other_Calculators/views/dew_point_calculator.py:731
#, python-brace-format
msgid "Term 1: (A×Td)/(B+Td) = ({a}×{td})/({b}+{td}) = {term1}"
msgstr "Término 1: (A×Td)/(B+Td) = ({a}×{td})/({b}+{td}) = {term1}"

#: Other_Calculators/views/dew_point_calculator.py:734
#, python-brace-format
msgid "Term 2: (A×T)/(B+T) = ({a}×{t})/({b}+{t}) = {term2}"
msgstr "Término 2: (A×T)/(B+T) = ({a}×{t})/({b}+{t}) = {term2}"

#: Other_Calculators/views/dew_point_calculator.py:738
#, python-brace-format
msgid "Difference: {term1} - {term2} = {diff}"
msgstr "Diferencia: {term1} - {term2} = {diff}"

#: Other_Calculators/views/dew_point_calculator.py:739
#, python-brace-format
msgid "RH = 100 × exp({diff}) = {rh}%"
msgstr "HR = 100 × exp({diff}) = {rh}%"

#: Other_Calculators/views/dew_point_calculator.py:749
msgid "Step 2: Convert dew point to Celsius"
msgstr "Paso 2: convertir el punto de rocío a Celsius"

#: Other_Calculators/views/dew_point_calculator.py:752
msgid "Step 3: Apply the Magnus formula (rearranged)"
msgstr "Paso 3: Aplicar la fórmula Magnus (reorganizada)"

#: Other_Calculators/views/dew_point_calculator.py:755
#: Other_Calculators/views/dew_point_calculator.py:758
msgid "Formula: T = (B × α) / (A - α)"
msgstr "Fórmula: T = (B × α) / (A - α)"

#: Other_Calculators/views/dew_point_calculator.py:756
msgid "Where: α = (A×Td)/(B+Td) - ln(RH/100)"
msgstr "Donde: α = (A×Td)/(B+Td) - ln(RH/100)"

#: Other_Calculators/views/dew_point_calculator.py:760
#, python-brace-format
msgid "α = ({a}×{td})/({b}+{td}) - ln({rh}/100)"
msgstr "α = ({a}×{td})/({b}+{td}) - ln({rh}/100)"

#: Other_Calculators/views/dew_point_calculator.py:764
#, python-brace-format
msgid "Temperature = ({b} × {alpha}) / ({a} - {alpha})"
msgstr "Temperatura = ({b} × {alpha}) / ({a} - {alpha})"

#: Other_Calculators/views/dew_point_calculator.py:767
#: Other_Calculators/views/heat_index_calculator.py:762
#, python-brace-format
msgid "Temperature = {temp}°C"
msgstr "Temperatura = {temp}°C"

#: Other_Calculators/views/dew_point_calculator.py:770
#, python-brace-format
msgid "Temperature = {temp} {unit}"
msgstr "Temperatura = {temp} {unit}"

#: Other_Calculators/views/dew_point_calculator.py:777
#, python-brace-format
msgid "Temperature: {value} {unit}"
msgstr "Temperatura: {value} {unit}"

#: Other_Calculators/views/dew_point_calculator.py:783
msgid "Celsius = (Fahrenheit - 32) × 5/9"
msgstr "Celsius = (Fahrenheit - 32) × 5/9"

#: Other_Calculators/views/dew_point_calculator.py:784
#, python-brace-format
msgid "Celsius = ({val} - 32) × 5/9 = {celsius}°C"
msgstr "Celsius = ({val} - 32) × 5/9 = {celsius}°C"

#: Other_Calculators/views/dew_point_calculator.py:788
msgid "Celsius = Kelvin - 273.15"
msgstr "Celsius = Kelvin - 273,15"

#: Other_Calculators/views/dew_point_calculator.py:789
#, python-brace-format
msgid "Celsius = {val} - 273.15 = {celsius}°C"
msgstr "Celsius = {val} - 273,15 = {celsius}°C"

#: Other_Calculators/views/dew_point_calculator.py:796
#, python-brace-format
msgid "Step 3: Convert from Celsius to {unit}"
msgstr "Paso 3: Convertir de Celsius a {unit}"

#: Other_Calculators/views/dew_point_calculator.py:798
msgid "Fahrenheit = Celsius × 9/5 + 32"
msgstr "Fahrenheit = Celsius × 9/5 + 32"

#: Other_Calculators/views/dew_point_calculator.py:799
#, python-brace-format
msgid "Fahrenheit = {celsius} × 9/5 + 32 = {result}°F"
msgstr "Fahrenheit = {celsius} × 9/5 + 32 = {result}°F"

#: Other_Calculators/views/dew_point_calculator.py:803
msgid "Kelvin = Celsius + 273.15"
msgstr "Kelvin = Celsius + 273,15"

#: Other_Calculators/views/dew_point_calculator.py:804
#, python-brace-format
msgid "Kelvin = {celsius} + 273.15 = {result}K"
msgstr "Kelvin = {celsius} + 273,15 = {result}K"

