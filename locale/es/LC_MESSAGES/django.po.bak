msgstr "Tu código de verificación único"

#: core/templates/account/email/password_reset_code_message.html:49
#: core/templates/account/email/password_reset_code_message.txt:7
#, python-format
msgid ""
"You requested a password reset for your account at %(site_name)s. Use the "
"code below to complete the process:"
msgstr ""
"Solicitó un restablecimiento de contraseña para su cuenta en %(site_name)s. "
"Utilice el siguiente código para completar el proceso:"

#: core/templates/account/email/password_reset_code_message.html:76
#: core/templates/account/email/password_reset_code_message.txt:16
msgid "⚠️ Important:"
msgstr "⚠️ Importante:"

#: core/templates/account/email/password_reset_code_message.html:76
#: core/templates/account/email/password_reset_code_message.txt:16
msgid ""
"If you didn't request this code, please ignore this email and ensure your "
"account is secure."
msgstr ""
"Si no solicitó este código, ignore este correo electrónico y asegúrese de "
"que su cuenta esté segura."

