#: Other_Calculators/views/gravel_calculator.py:1358
msgid "Volume (ft³)"
msgstr "Volumen (pies³)"

#: Other_Calculators/templates/other_calculators/gravel_calculator.html:766
#: Other_Calculators/templates/other_calculators/mulch_calculator.html:301
