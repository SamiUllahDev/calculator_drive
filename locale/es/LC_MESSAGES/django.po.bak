msgstr "Convertir entre todas las bases"

#: Math_Calculators/templates/math_calculators/binary_calculator.html:559
msgid "Binary numbers can include spaces for readability (e.g., '1010 1010')"
msgstr ""
"Los números binarios pueden incluir espacios para facilitar la lectura (por "
"ejemplo, '1010 1010')"

#: Math_Calculators/templates/math_calculators/binary_calculator.html:560
msgid "Prefixes are optional: 0b for binary, 0x for hex, 0o for octal"
msgstr ""
"Los prefijos son opcionales: 0b para binario, 0x para hexadecimal, 0o para "
"octal"

#: Math_Calculators/templates/math_calculators/binary_calculator.html:561
msgid "Bitwise operations work on 32-bit integers"
msgstr "Las operaciones bit a bit funcionan con enteros de 32 bits"

#: Math_Calculators/templates/math_calculators/binary_calculator.html:562
msgid "Negative numbers use two's complement representation"
msgstr ""
"Los números negativos utilizan la representación en complemento a dos."

#: Math_Calculators/templates/math_calculators/binary_calculator.html:564
msgid "Shift operations require non-negative shift amounts"
msgstr "Las operaciones de turnos requieren cantidades de turnos no negativas"

#: Math_Calculators/templates/math_calculators/binary_calculator.html:623
