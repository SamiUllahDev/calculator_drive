#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:136
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:153
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:335
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:530
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:572
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:669
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:684
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:699
#: Other_Calculators/views/dew_point_calculator.py:905
#: Other_Calculators/views/dew_point_calculator.py:954
msgid "Dew Point"
msgstr "Punto de rocío"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:284
msgid "What is Dew Point?"
msgstr "¿Qué es el punto de rocío?"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:286
#, python-format
msgid ""
"Dew point is the temperature at which air becomes saturated with water vapor"
" and condensation begins to form. It is a measure of atmospheric moisture. "
"When the air temperature drops to the dew point, relative humidity reaches "
"100%%, and water vapor condenses into liquid water (dew). The dew point is "
"always less than or equal to the air temperature."
msgstr ""
"El punto de rocío es la temperatura a la que el aire se satura con vapor de "
"agua y comienza a formarse condensación. Es una medida de la humedad "
"atmosférica. Cuando la temperatura del aire desciende hasta el punto de "
"rocío, la humedad relativa alcanza el 100% y el vapor de agua se condensa en"
" agua líquida (rocío). El punto de rocío es siempre menor o igual a la "
"temperatura del aire."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:293
msgid ""
"Select a calculation type from the dropdown (Calculate Dew Point, Calculate "
"Relative Humidity, Calculate Temperature, or Convert Units)."
msgstr ""
"Seleccione un tipo de cálculo en el menú desplegable (Calcular punto de "
"rocío, Calcular humedad relativa, Calcular temperatura o Convertir "
"unidades)."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:295
msgid "Select appropriate temperature units (Celsius, Fahrenheit, or Kelvin)."
msgstr ""
"Seleccione las unidades de temperatura adecuadas (Celsius, Fahrenheit o "
"Kelvin)."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:306
msgid ""
"Enter temperature and relative humidity to calculate dew point. Uses the "
"Magnus formula for accurate calculations."
msgstr ""
"Ingrese la temperatura y la humedad relativa para calcular el punto de "
"rocío. Utiliza la fórmula de Magnus para cálculos precisos."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:310
msgid ""
"Enter temperature and dew point to calculate relative humidity. Formula: RH "
"= 100 × exp((A×Td)/(B+Td) - (A×T)/(B+T))."
msgstr ""
"Ingrese la temperatura y el punto de rocío para calcular la humedad "
"relativa. Fórmula: RH = 100 × exp((A×Td)/(B+Td) - (A×T)/(B+T))."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:314
msgid ""
"Enter dew point and relative humidity to calculate temperature. Uses the "
"Magnus formula rearranged."
msgstr ""
"Ingrese el punto de rocío y la humedad relativa para calcular la "
"temperatura. Utiliza la fórmula de Magnus reordenada."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:318
msgid "Convert temperature values between Celsius, Fahrenheit, and Kelvin."
msgstr "Convierta valores de temperatura entre Celsius, Fahrenheit y Kelvin."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:324
msgid "Magnus Formula"
msgstr "Fórmula Magnus"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:326
msgid "Dew Point Formula:"
msgstr "Fórmula del punto de rocío:"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:334
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:483
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:578
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:665
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:703
#: Other_Calculators/templates/other_calculators/heat_index_calculator.html:519
#: Other_Calculators/templates/other_calculators/heat_index_calculator.html:535
msgid "Relative Humidity"
msgstr "Humedad relativa"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:339
msgid ""
"The Magnus formula is an empirical relationship that accurately calculates "
"dew point from temperature and relative humidity. It is widely used in "
"meteorology and HVAC applications."
msgstr ""
"La fórmula de Magnus es una relación empírica que calcula con precisión el "
"punto de rocío a partir de la temperatura y la humedad relativa. Es "
"ampliamente utilizado en meteorología y aplicaciones HVAC."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:344
msgid "Dew Point Comfort Levels"
msgstr "Niveles de comodidad del punto de rocío"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:349
#: Other_Calculators/views/dew_point_calculator.py:849
msgid "Dew Point (°C)"
msgstr "Punto de rocío (°C)"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:350
msgid "Comfort Level"
msgstr "Nivel de comodidad"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:355
msgid "Dry"
msgstr "Seco"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:355
msgid "Very comfortable, dry air"
msgstr "Aire muy confortable y seco."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:356
msgid "Comfortable"
msgstr "Cómodo"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:356
msgid "Pleasant, comfortable conditions"
msgstr "Condiciones agradables y confortables."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:357
msgid "Slightly Humid"
msgstr "Ligeramente húmedo"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:357
msgid "Most people feel comfortable"
msgstr "La mayoría de la gente se siente cómoda"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:358
msgid "Humid"
msgstr "Húmedo"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:358
msgid "Some discomfort, sticky feeling"
msgstr "Algo de malestar, sensación pegajosa."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:359
msgid "Very Humid"
msgstr "muy humedo"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:359
msgid "Uncomfortable, oppressive"
msgstr "Incómodo, opresivo"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:360
msgid "Extremely Humid"
msgstr "Extremadamente húmedo"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:360
msgid "Dangerous, heat exhaustion risk"
msgstr "Peligroso, riesgo de agotamiento por calor"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:369
msgid "Dew point cannot be greater than air temperature."
msgstr "El punto de rocío no puede ser mayor que la temperatura del aire."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:370
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:912
#, python-format
msgid "Relative humidity must be between 0%% and 100%%."
msgstr "La humedad relativa debe estar entre 0%% y 100%%."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:371
msgid ""
"The calculator uses the Magnus formula, which is accurate for temperatures "
"between -45°C and 60°C."
msgstr ""
"La calculadora utiliza la fórmula de Magnus, que es precisa para "
"temperaturas entre -45°C y 60°C."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:372
msgid ""
"Temperature conversions use standard formulas: F = C × 9/5 + 32, K = C + "
"273.15."
msgstr ""
"Las conversiones de temperatura utilizan fórmulas estándar: F = C × 9/5 + "
"32, K = C + 273,15."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:373
msgid ""
"Dew point is a better indicator of comfort than relative humidity alone."
msgstr ""
"El punto de rocío es un mejor indicador del confort que la humedad relativa "
"por sí sola."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:542
#: Other_Calculators/views/dew_point_calculator.py:404
msgid "Dew point cannot be greater than temperature."
msgstr "El punto de rocío no puede ser mayor que la temperatura."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:688
msgid "Temperature Difference"
msgstr "Diferencia de temperatura"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:881
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:952
#: Other_Calculators/views/dew_point_calculator.py:187
#: Other_Calculators/views/dew_point_calculator.py:306
#: Other_Calculators/views/heat_index_calculator.py:89
#: Other_Calculators/views/heat_index_calculator.py:453
#: Other_Calculators/views/wind_chill_calculator.py:129
#: Other_Calculators/views/wind_chill_calculator.py:306
msgid "Temperature is required."
msgstr "Se requiere temperatura."

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:896
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:967
msgid "Temperature must be between"
msgstr "La temperatura debe estar entre"

#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:896
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:940
#: Other_Calculators/templates/other_calculators/dew_point_calculator.html:967
#: user/templates/user/register.html:182
#: venv/lib/python3.12/site-packages/django/db/models/base.py:1631
