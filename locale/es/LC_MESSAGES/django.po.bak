msgstr "Fines educativos para estudiantes de ingeniería automotriz."

#: Other_Calculators/templates/other_calculators/engine_horsepower_calculator.html:443
msgid "Racing and performance optimization"
msgstr "Optimización de carreras y rendimiento."

#: Other_Calculators/templates/other_calculators/engine_horsepower_calculator.html:444
msgid "Vehicle modification planning"
msgstr "Planificación de modificaciones de vehículos"

#: Other_Calculators/templates/other_calculators/engine_horsepower_calculator.html:445
msgid "Understanding engine power curves"
msgstr "Comprender las curvas de potencia del motor"

#: Other_Calculators/templates/other_calculators/fuel_cost_calculator.html:4
msgid ""
"Fuel Cost Calculator - Calculate Trip Cost, MPG, Fuel Efficiency | Free "
"Online Tool"
msgstr ""
"Calculadora de costo de combustible: calcule el costo del viaje, MPG y "
"eficiencia del combustible | Herramienta en línea gratuita"

