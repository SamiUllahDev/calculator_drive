#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_conception_calculator.html:233
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_conception_calculator.html:358
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_conception_calculator.html:402
msgid "Fertile Window"
msgstr "ventana fértil"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/ovulation_calculator.html:163
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/period_calculator.html:155
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/period_calculator.html:190
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/period_calculator.html:354
