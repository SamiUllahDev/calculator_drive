#: Other_Calculators/views/time_card_calculator.py:345
#, python-brace-format
msgid "Clock In: {time}"
msgstr "Entrada: {time}"

#: Other_Calculators/views/time_card_calculator.py:346
#, python-brace-format
msgid "Clock Out: {time}"
msgstr "Reloj de salida: {time}"

#: Other_Calculators/views/time_card_calculator.py:347
#, python-brace-format
msgid "Break Time: {break_time} minutes"
msgstr "Tiempo de descanso: {break_time} minutos"

#: Other_Calculators/views/time_card_calculator.py:350
#, python-brace-format
