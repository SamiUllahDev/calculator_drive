#: Other_Calculators/templates/other_calculators/mileage_calculator.html:366
msgid "What is Mileage?"
msgstr "¿Qué es el kilometraje?"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:367
msgid ""
"Mileage refers to the distance traveled, typically measured in miles or "
"kilometers. Mileage calculators help determine reimbursement amounts, trip "
"costs, and cost efficiency for business travel."
msgstr ""
"El kilometraje se refiere a la distancia recorrida, generalmente medida en "
"millas o kilómetros. Las calculadoras de kilometraje ayudan a determinar los"
" montos de reembolso, los costos de viaje y la rentabilidad de los viajes de"
" negocios."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:375
msgid "Select appropriate units and currency"
msgstr "Seleccione unidades y moneda apropiadas"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:383
msgid "Calculate reimbursement based on distance and rate"
msgstr "Calcular el reembolso en función de la distancia y la tarifa."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:384
msgid "Calculate total trip cost including fuel and other expenses"
msgstr ""
"Calcule el costo total del viaje, incluido el combustible y otros gastos."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:385
msgid "Calculate the cost per unit distance"
msgstr "Calcular el costo por unidad de distancia."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:386
msgid "Calculate how far you can travel with a given budget"
msgstr "Calcula hasta dónde puedes viajar con un presupuesto determinado"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:387
msgid "Convert between different distance units"
msgstr "Convertir entre diferentes unidades de distancia"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:388
msgid "Compare two different mileage rates"
msgstr "Compare dos tarifas de kilometraje diferentes"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:395
#: Other_Calculators/views/mileage_calculator.py:888
msgid "Reimbursement"
msgstr "Reembolso"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:395
msgid "Reimbursement = Distance × Rate"
msgstr "Reembolso = Distancia × Tarifa"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:396
#: Other_Calculators/views/mileage_calculator.py:768
msgid "Total Cost = Fuel Cost + Other Costs"
msgstr "Costo total = Costo de combustible + Otros costos"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:397
msgid "Cost per Mile"
msgstr "Costo por milla"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:397
msgid "Cost per Mile = Total Cost / Distance"
msgstr "Costo por milla = Costo total / Distancia"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:398
msgid "Distance = Total Cost / Cost per Mile"
msgstr "Distancia = Costo total / Costo por milla"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:405
msgid "miles, km, m, ft, yd, nautical miles"
msgstr "millas, km, m, pies, yd, millas náuticas"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:406
msgid "MPG, L/100km, km/L"
msgstr "MPG, L/100km, km/L"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:407
msgid "USD, EUR, GBP, CAD, AUD"
msgstr "USD, EUR, GBP, CAD, AUD"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:414
msgid "Distance values must be non-negative"
msgstr "Los valores de distancia no deben ser negativos."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:415
msgid "Rates and costs must be non-negative"
msgstr "Las tarifas y los costos no deben ser negativos."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:416
msgid "Fuel efficiency must be greater than zero"
msgstr "La eficiencia del combustible debe ser mayor que cero."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:417
msgid "Results are rounded to 2-6 decimal places"
msgstr "Los resultados se redondean a 2-6 decimales."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:424
msgid "Business travel expense reimbursement"
msgstr "Reembolso de gastos de viaje de negocios"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:425
msgid "Trip planning and budgeting"
msgstr "Planificación y presupuesto de viajes."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:426
msgid "Fleet management and cost analysis"
msgstr "Gestión de flotas y análisis de costes."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:427
msgid "Tax deduction calculations"
msgstr "Cálculos de deducción de impuestos."

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:428
msgid "Fuel efficiency comparisons"
msgstr "Comparaciones de eficiencia de combustible"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:566
msgid "Please enter both distance and rate"
msgstr "Por favor ingrese la distancia y la tarifa"

#: Other_Calculators/templates/other_calculators/mileage_calculator.html:579
