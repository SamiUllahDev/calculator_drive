msgstr "Calculadora de pagos: calcular pagos mensuales de préstamos"

#: Financial_Calculators/templates/financial_calculators/payment_calculator.html:5
msgid ""
"Calculate your monthly loan payment. See payment breakdowns, compare terms, "
"and plan your budget with our free payment calculator."
msgstr ""
"Calcule el pago mensual de su préstamo. Vea desgloses de pagos, compare "
"términos y planifique su presupuesto con nuestra calculadora de pagos "
"gratuita."

#: Financial_Calculators/templates/financial_calculators/payment_calculator.html:6
msgid ""
"payment calculator, loan payment, monthly payment calculator, installment "
"calculator, loan calculator"
msgstr ""
"calculadora de pagos, pago de préstamos, calculadora de pagos mensuales, "
"calculadora de cuotas, calculadora de préstamos"

