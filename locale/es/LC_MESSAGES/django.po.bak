msgstr "Analizar"

#: Other_Calculators/templates/other_calculators/password_generator.html:140
msgid "What is a Strong Password?"
msgstr "¿Qué es una contraseña segura?"

#: Other_Calculators/templates/other_calculators/password_generator.html:141
msgid ""
"A strong password is long, random, and includes a mix of uppercase, "
"lowercase, numbers, and special characters. It should be unique for each "
"account and not contain personal information."
msgstr ""
"Una contraseña segura es larga, aleatoria e incluye una combinación de "
"mayúsculas, minúsculas, números y caracteres especiales. Debe ser único para"
" cada cuenta y no contener información personal."

#: Other_Calculators/templates/other_calculators/password_generator.html:147
msgid "Set your desired password length"
msgstr "Establezca la longitud de contraseña deseada"

#: Other_Calculators/templates/other_calculators/password_generator.html:148
msgid "Choose which character types to include"
msgstr "Elige qué tipos de personajes incluir"

#: Other_Calculators/templates/other_calculators/password_generator.html:149
msgid "Click 'Generate Passwords'"
msgstr "Haga clic en 'Generar contraseñas'"

#: Other_Calculators/templates/other_calculators/password_generator.html:150
msgid "Copy the password(s) you want to use"
msgstr "Copie las contraseñas que desea utilizar"

#: Other_Calculators/templates/other_calculators/password_generator.html:157
msgid "Minimum: 8 characters (recommended)"
msgstr "Mínimo: 8 caracteres (recomendado)"

#: Other_Calculators/templates/other_calculators/password_generator.html:158
msgid "Good: 12-16 characters"
msgstr "Bueno: 12-16 caracteres"

#: Other_Calculators/templates/other_calculators/password_generator.html:159
msgid "Strong: 20+ characters"
msgstr "Fuerte: más de 20 personajes"

#: Other_Calculators/templates/other_calculators/password_generator.html:160
msgid "Longer passwords are more secure"
msgstr "Las contraseñas más largas son más seguras"

#: Other_Calculators/templates/other_calculators/password_generator.html:165
#: Other_Calculators/templates/other_calculators/password_generator.html:361
#: Other_Calculators/templates/other_calculators/password_generator.html:480
msgid "Character Types"
msgstr "Tipos de personajes"

