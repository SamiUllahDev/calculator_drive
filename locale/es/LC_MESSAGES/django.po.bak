#: Other_Calculators/templates/other_calculators/horsepower_calculator.html:50
#: Other_Calculators/views/horsepower_calculator.py:48
#: Other_Calculators/views/index.py:45
msgid "Horsepower Calculator"
msgstr "Calculadora de caballos de fuerza"

#: Other_Calculators/templates/other_calculators/horsepower_calculator.html:53
msgid ""
"Calculate horsepower from torque and RPM, calculate torque from HP and RPM, "
"convert between HP, kW, and watts with step-by-step solutions."
msgstr ""
