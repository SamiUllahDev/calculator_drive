#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:140
msgid ""
"Enter your measurements and click Calculate to see your body fat percentage "
"and Army standards assessment."
msgstr ""
"Ingrese sus medidas y haga clic en Calcular para ver su porcentaje de grasa "
"corporal y la evaluación de los estándares del Ejército."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:150
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:341
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:220
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:483
msgid "Body Fat Percentage"
msgstr "Porcentaje de grasa corporal"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:168
msgid "Max Allowed"
msgstr "Máximo permitido"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:194
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:264
msgid "Body Fat Gauge"
