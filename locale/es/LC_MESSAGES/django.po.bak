#: Other_Calculators/templates/other_calculators/age_calculator.html:184
msgid "Month"
msgstr "Mes"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:302
#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:265
msgid "Principal Paid"
msgstr "Principal pagado"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:303
#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:266
msgid "Interest Paid"
msgstr "Intereses pagados"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:304
#: Financial_Calculators/templates/financial_calculators/compound_interest_calculator.html:254
#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:267
#: Financial_Calculators/templates/financial_calculators/mortgage_amortization_calculator.html:321
msgid "End Balance"
msgstr "Saldo final"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:320
msgid "Calculate Your Car Payment"
msgstr "Calcule el pago de su automóvil"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:321
msgid ""
"Enter vehicle details to see your monthly payment and total cost of "
"financing."
msgstr ""
"Ingrese los detalles del vehículo para ver su pago mensual y el costo total "
"de financiamiento."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:335
msgid "Enter the purchase price of the vehicle you're considering."
msgstr "Ingrese el precio de compra del vehículo que está considerando."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:341
msgid "Down & Trade-In"
msgstr "Baja y canje"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:342
msgid "Add your down payment and trade-in value to reduce the loan."
msgstr ""
"Agregue su pago inicial y el valor de intercambio para reducir el préstamo."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:348
msgid "Rate & Term"
msgstr "Tarifa y Plazo"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:349
msgid "Enter your interest rate and choose a loan term length."
msgstr ""
"Ingrese su tasa de interés y elija la duración del plazo del préstamo."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:355
#: Financial_Calculators/templates/financial_calculators/cd_calculator.html:204
msgid "Compare Options"
msgstr "Comparar opciones"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:356
msgid "Review different terms to find your best financing option."
msgstr ""
"Revise diferentes términos para encontrar su mejor opción de financiamiento."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:364
msgid "Understanding Auto Loans"
msgstr "Comprensión de los préstamos para automóviles"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:367
msgid "Shorter vs Longer Terms"
msgstr "Plazos más cortos frente a plazos más largos"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:368
msgid ""
"Shorter terms (36-48 months) have higher payments but less total interest. "
"Longer terms (72-84 months) have lower payments but cost more overall and "
"risk negative equity."
msgstr ""
"Los plazos más cortos (36-48 meses) tienen pagos más altos pero menos "
"intereses totales. Los plazos más largos (72-84 meses) tienen pagos más "
"bajos pero cuestan más en general y corren el riesgo de tener un capital "
"negativo."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:370
msgid "Down Payment Benefits"
msgstr "Beneficios del pago inicial"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:371
#, python-format
msgid ""
"A larger down payment (20%%+) reduces your loan amount, lowers monthly "
"payments, and may qualify you for better rates. It also reduces the risk of "
"being 'underwater' on your loan."
msgstr ""
"Un pago inicial mayor (20%%+) reduce el monto de su préstamo, reduce los "
"pagos mensuales y puede calificarlo para obtener mejores tasas. También "
"reduce el riesgo de quedar \"bajo el agua\" en su préstamo."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:374
msgid "New vs Used Rates"
msgstr "Tarifas nuevas vs usadas"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:375
msgid ""
"New car loans typically have lower interest rates than used car loans. "
"However, new cars depreciate faster, so consider the total cost of "
"ownership."
msgstr ""
"Los préstamos para automóviles nuevos suelen tener tasas de interés más "
"bajas que los préstamos para automóviles usados. Sin embargo, los autos "
"nuevos se deprecian más rápido, así que considere el costo total de "
"propiedad."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:377
msgid "Pre-Approval Advantage"
msgstr "Ventaja de aprobación previa"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:378
msgid ""
"Get pre-approved before shopping to know your rate and budget. This gives "
"you negotiating power and protects against dealer markup on financing."
msgstr ""
"Obtenga una aprobación previa antes de comprar para conocer su tarifa y "
"presupuesto. Esto le brinda poder de negociación y lo protege contra el "
"margen de beneficio del concesionario en el financiamiento."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:389
msgid "What interest rate can I expect?"
msgstr "¿Qué tasa de interés puedo esperar?"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:395
#, python-format
msgid ""
"Interest rates vary by credit score: Excellent (750+): 3-5%%, Good "
"(700-749): 5-7%%, Fair (650-699): 7-10%%, Poor (below 650): 10-15%%+. Rates "
"also depend on loan term, new vs used, and lender."
msgstr ""
"Las tasas de interés varían según el puntaje crediticio: Excelente (750+): "
"3-5%%, Buena (700-749): 5-7%%, Regular (650-699): 7-10%%, Mala (por debajo "
"de 650): 10-15%%+. Las tasas también dependen del plazo del préstamo, de si "
"son nuevos o usados ​​y del prestamista."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:401
msgid "How much should I put down?"
msgstr "¿Cuanto debo depositar?"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:407
#, python-format
msgid ""
"Experts recommend 20%% down for new cars and 10%% for used cars. This helps "
"avoid negative equity and may get you better loan terms. At minimum, aim to "
"cover taxes and fees upfront."
msgstr ""
"Los expertos recomiendan un 20%% de descuento para autos nuevos y un 10%% "
"para autos usados. Esto ayuda a evitar el capital negativo y puede ofrecerle"
" mejores condiciones de préstamo. Como mínimo, trate de cubrir los impuestos"
" y tarifas por adelantado."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:413
msgid "What loan term should I choose?"
msgstr "¿Qué plazo de préstamo debo elegir?"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:419
msgid ""
"Choose the shortest term you can afford. 48-60 months is ideal for new cars,"
" 36-48 months for used. Avoid 72+ month loans if possible - they cost more "
"and you risk owing more than the car is worth."
msgstr ""
"Elija el plazo más corto que pueda permitirse. 48-60 meses es ideal para "
"autos nuevos, 36-48 meses para autos usados. Evite los préstamos a más de 72"
" meses si es posible: cuestan más y corre el riesgo de deber más de lo que "
"vale el automóvil."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:425
msgid "Should I finance through the dealer or a bank?"
msgstr "¿Debo financiar a través del concesionario o de un banco?"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:431
#, python-format
msgid ""
"Get pre-approved from your bank or credit union first, then compare with "
"dealer offers. Dealers sometimes offer promotional rates (like 0%%) that "
"beat bank rates, but watch for higher prices or added fees."
msgstr ""
"Primero obtenga la aprobación previa de su banco o cooperativa de crédito y "
"luego compárela con las ofertas de los distribuidores. Los distribuidores a "
"veces ofrecen tasas promocionales (como 0%%) que superan las tasas "
"bancarias, pero estén atentos a precios más altos o tarifas adicionales."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:439
#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:395
#: Financial_Calculators/templates/financial_calculators/mortgage_calculator.html:505
#: Financial_Calculators/templates/financial_calculators/savings_calculator.html:429
msgid "Money-Saving Tips"
msgstr "Consejos para ahorrar dinero"

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:445
msgid "Check your credit score and fix errors before applying for a loan."
msgstr ""
"Verifique su puntaje crediticio y corrija errores antes de solicitar un "
"préstamo."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:451
msgid "Negotiate the vehicle price separately from the financing terms."
msgstr ""
"Negociar el precio del vehículo por separado de las condiciones de "
"financiación."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:457
msgid "Make extra payments when possible to reduce total interest paid."
msgstr ""
"Realice pagos adicionales cuando sea posible para reducir el interés total "
"pagado."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:463
msgid ""
"Consider slightly used cars (1-2 years old) to avoid steep depreciation."
msgstr ""
"Considere automóviles ligeramente usados ​​(de 1 a 2 años de antigüedad) "
"para evitar una fuerte depreciación."

#: Financial_Calculators/templates/financial_calculators/auto_loan_calculator.html:571
#: Financial_Calculators/templates/financial_calculators/compound_interest_calculator.html:502
#: Financial_Calculators/templates/financial_calculators/credit_card_calculator.html:478
#: Financial_Calculators/templates/financial_calculators/investment_calculator.html:506
#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:526
#: Financial_Calculators/templates/financial_calculators/retirement_calculator.html:566
#: Financial_Calculators/templates/financial_calculators/savings_calculator.html:563
msgid "An error occurred. Please check your inputs."
msgstr "Se produjo un error. Por favor revise sus entradas."

