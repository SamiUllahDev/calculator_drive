#: Other_Calculators/templates/other_calculators/gpa_calculator.html:201
msgid ""
"Add courses and click Calculate to see your GPA with detailed step-by-step "
"solutions."
msgstr ""
"Agregue cursos y haga clic en Calcular para ver su GPA con soluciones "
"detalladas paso a paso."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:217
msgid "What is GPA?"
msgstr "¿Qué es el GPA?"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:219
msgid ""
"Grade Point Average (GPA) is a numerical representation of a student's "
"academic performance. It is calculated by dividing the total quality points "
"earned by the total credit hours attempted. GPA is used by educational "
"institutions to evaluate student performance, determine academic standing, "
"and make decisions about scholarships, honors, and graduation eligibility."
msgstr ""
"El promedio de calificaciones (GPA) es una representación numérica del "
"desempeño académico de un estudiante. Se calcula dividiendo el total de "
"puntos de calidad obtenidos por el total de horas de crédito intentadas. Las"
" instituciones educativas utilizan el GPA para evaluar el desempeño de los "
"estudiantes, determinar la situación académica y tomar decisiones sobre "
"becas, honores y elegibilidad para graduación."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:226
msgid "Select your GPA scale (4.0, 4.3, or 5.0) from the dropdown."
msgstr "Seleccione su escala de GPA (4.0, 4.3 o 5.0) en el menú desplegable."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:227
msgid "Add courses by clicking the 'Add Course' button."
msgstr "Agregue cursos haciendo clic en el botón 'Agregar curso'."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:228
msgid ""
"Enter the course name, select the grade, and enter the number of credits for"
" each course."
msgstr ""
"Ingrese el nombre del curso, seleccione la calificación e ingrese la "
"cantidad de créditos para cada curso."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:229
msgid ""
"Optionally, enter your current GPA and credits earned to calculate "
"cumulative GPA."
msgstr ""
"Opcionalmente, ingrese su GPA actual y los créditos obtenidos para calcular "
"el GPA acumulativo."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:230
msgid "Click 'Calculate GPA' to see your results."
msgstr "Haga clic en 'Calcular GPA' para ver sus resultados."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:236
msgid "GPA Scales"
msgstr "Escalas de GPA"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:240
msgid "Most common scale in the United States. A+ and A both equal 4.0."
msgstr ""
"Escala más común en los Estados Unidos. A+ y A son ambos iguales a 4,0."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:244
msgid ""
"Used by some institutions. A+ equals 4.3, allowing for higher distinction."
msgstr ""
"Utilizado por algunas instituciones. A+ equivale a 4,3, lo que permite una "
"mayor distinción."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:248
msgid "Used for weighted GPAs, often for honors or AP courses."
msgstr "Se utiliza para GPA ponderados, a menudo para cursos de honores o AP."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:254
msgid "GPA Formula"
msgstr "Fórmula GPA"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:256
msgid "Semester GPA:"
msgstr "GPA del semestre:"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:258
msgid "Quality Points:"
msgstr "Puntos de calidad:"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:260
msgid "Cumulative GPA:"
msgstr "Promedio acumulado:"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:264
msgid "Grade Points = Points assigned to letter grade (A=4.0, B=3.0, etc.)"
msgstr ""
"Puntos de calificación = Puntos asignados a la calificación con letras "
"(A=4.0, B=3.0, etc.)"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:265
msgid "Credits = Credit hours for the course"
msgstr "Créditos = Horas de crédito para el curso."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:266
msgid "Quality Points = Grade Points × Credits"
msgstr "Puntos de calidad = Puntos de calificación × Créditos"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:272
msgid "Grade Scale Reference"
msgstr "Referencia de escala de calificaciones"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:277
msgid "Grade"
msgstr "Calificación"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:306
msgid "Credits must be greater than zero for each course."
msgstr "Los créditos deben ser mayores que cero para cada curso."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:307
msgid ""
"Credits typically range from 1 to 6 per course, but can vary by institution."
msgstr ""
"Los créditos suelen oscilar entre 1 y 6 por curso, pero pueden variar según "
"la institución."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:308
msgid "Current GPA must be between 0 and the maximum for the selected scale."
msgstr ""
"El GPA actual debe estar entre 0 y el máximo de la escala seleccionada."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:309
msgid ""
"Cumulative GPA is calculated only when both current GPA and credits are "
"provided."
msgstr ""
"El GPA acumulativo se calcula solo cuando se proporcionan tanto el GPA "
"actual como los créditos."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:310
msgid ""
"Academic standing is determined by the ratio of GPA to maximum scale value."
msgstr ""
"La situación académica está determinada por la relación entre el GPA y el "
"valor máximo de la escala."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:311
msgid "Letter grade conversion may vary slightly between institutions."
msgstr ""
"La conversión de calificaciones con letras puede variar ligeramente entre "
"instituciones."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:320
#: Other_Calculators/views/gpa_calculator.py:292
msgid "Dean's List"
msgstr "Lista del decano"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:321
#, python-format
msgid "GPA ≥ 90%% of maximum (e.g., ≥ 3.6 on 4.0 scale)"
msgstr "GPA ≥ 90%% del máximo (p. ej., ≥ 3,6 en una escala de 4,0)"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:325
#, python-format
msgid "GPA ≥ 75%% of maximum (e.g., ≥ 3.0 on 4.0 scale)"
msgstr "GPA ≥ 75%% del máximo (p. ej., ≥ 3,0 en una escala de 4,0)"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:328
#: Other_Calculators/views/gpa_calculator.py:296
msgid "Satisfactory"
msgstr "Satisfactorio"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:329
#, python-format
msgid "GPA ≥ 50%% of maximum (e.g., ≥ 2.0 on 4.0 scale)"
msgstr "GPA ≥ 50%% del máximo (p. ej., ≥ 2,0 en una escala de 4,0)"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:332
#: Other_Calculators/views/gpa_calculator.py:298
msgid "Academic Warning"
msgstr "Advertencia Académica"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:333
#, python-format
msgid "GPA ≥ 25%% of maximum (e.g., ≥ 1.0 on 4.0 scale)"
msgstr "GPA ≥ 25%% del máximo (p. ej., ≥ 1,0 en una escala de 4,0)"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:336
#: Other_Calculators/views/gpa_calculator.py:300
msgid "Probation"
msgstr "Libertad condicional"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:337
#, python-format
msgid "GPA < 25%% of maximum (e.g., < 1.0 on 4.0 scale)"
msgstr "GPA <25%% del máximo (p. ej., <1,0 en una escala de 4,0)"

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:345
msgid "Academic planning and goal setting"
msgstr "Planificación académica y establecimiento de objetivos."

#: Other_Calculators/templates/other_calculators/gpa_calculator.html:346
