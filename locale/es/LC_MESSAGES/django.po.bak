#: Math_Calculators/templates/math_calculators/statistics_calculator.html:278
#: Math_Calculators/templates/math_calculators/statistics_calculator.html:295
msgid "Median"
msgstr "Mediana"

#: Math_Calculators/templates/math_calculators/average_calculator.html:345
msgid "Middle value when numbers are sorted. Less affected by outliers."
msgstr ""
"Valor medio cuando se ordenan los números. Menos afectado por valores "
"atípicos."

#: Math_Calculators/templates/math_calculators/average_calculator.html:348
#: Math_Calculators/templates/math_calculators/hex_calculator.html:75
#: Math_Calculators/templates/math_calculators/mean_median_mode_range_calculator.html:185
#: Math_Calculators/templates/math_calculators/mean_median_mode_range_calculator.html:314
#: Math_Calculators/templates/math_calculators/mean_median_mode_range_calculator.html:342
#: Math_Calculators/templates/math_calculators/mean_median_mode_range_calculator.html:350
#: Math_Calculators/templates/math_calculators/statistics_calculator.html:187
#: Math_Calculators/templates/math_calculators/statistics_calculator.html:279
msgid "Mode"
msgstr "Modo"

#: Math_Calculators/templates/math_calculators/average_calculator.html:349
msgid "Most frequently occurring value(s). May have multiple modes or none."
msgstr ""
"Valores que aparecen con mayor frecuencia. Puede tener múltiples modos o "
"ninguno."

#: Math_Calculators/templates/math_calculators/average_calculator.html:352
msgid "Geometric Mean"
msgstr "Media geométrica"

#: Math_Calculators/templates/math_calculators/average_calculator.html:353
msgid "nth root of the product of all numbers. Useful for rates and ratios."
msgstr ""
"raíz enésima del producto de todos los números. Útil para tasas y ratios."

#: Math_Calculators/templates/math_calculators/average_calculator.html:357
msgid "Harmonic Mean"
msgstr "Media armónica"

#: Math_Calculators/templates/math_calculators/average_calculator.html:358
msgid "Reciprocal of the arithmetic mean of reciprocals. Used for rates."
msgstr ""
"Recíproco de la media aritmética de recíprocos. Utilizado para tarifas."

#: Math_Calculators/templates/math_calculators/average_calculator.html:362
msgid "Quadratic Mean (RMS)"
msgstr "Media cuadrática (RMS)"

#: Math_Calculators/templates/math_calculators/average_calculator.html:363
msgid "Square root of the mean of squares. Used in physics and engineering."
msgstr ""
"Raíz cuadrada de la media de cuadrados. Utilizado en física e ingeniería."

#: Math_Calculators/templates/math_calculators/average_calculator.html:373
msgid "Geometric mean requires all numbers to be positive"
msgstr "La media geométrica requiere que todos los números sean positivos."

#: Math_Calculators/templates/math_calculators/average_calculator.html:374
msgid "Harmonic mean requires all numbers to be non-zero"
msgstr ""
"La media armónica requiere que todos los números sean distintos de cero"

#: Math_Calculators/templates/math_calculators/average_calculator.html:375
msgid "Mode may not exist if all values are unique"
msgstr "Es posible que el modo no exista si todos los valores son únicos"

#: Math_Calculators/templates/math_calculators/average_calculator.html:376
msgid "Median is more robust to outliers than mean"
msgstr "La mediana es más robusta frente a los valores atípicos que la media"

#: Math_Calculators/templates/math_calculators/average_calculator.html:377
msgid "You can add or remove input fields as needed"
msgstr "Puede agregar o eliminar campos de entrada según sea necesario"

