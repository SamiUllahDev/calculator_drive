msgstr "Banda 4 (multiplicador): {color} = ×{mult}"

#: Other_Calculators/views/resistor_calculator.py:534
#: Other_Calculators/views/resistor_calculator.py:550
#, python-brace-format
msgid "Band 5 (tolerance): {color} = ±{tol}%"
msgstr "Banda 5 (tolerancia): {color} = ±{tol}%"

#: Other_Calculators/views/resistor_calculator.py:537
#: Other_Calculators/views/resistor_calculator.py:554
msgid "Resistance = (Digit1 × 100 + Digit2 × 10 + Digit3) × Multiplier"
msgstr ""
"Resistencia = (Dígito1 × 100 + Dígito2 × 10 + Dígito3) × Multiplicador"

#: Other_Calculators/views/resistor_calculator.py:538
#: Other_Calculators/views/resistor_calculator.py:555
#, python-brace-format
msgid "Resistance = ({d1} × 100 + {d2} × 10 + {d3}) × {mult}"
msgstr "Resistencia = ({d1} × 100 + {d2} × 10 + {d3}) × {mult}"

#: Other_Calculators/views/resistor_calculator.py:551
#, python-brace-format
msgid "Band 6 (temp coeff): {color} = {temp} ppm/°C"
msgstr "Banda 6 (coeficiente de temperatura): {color} = {temp} ppm/°C"

#: Other_Calculators/views/resistor_calculator.py:562
#: Other_Calculators/views/resistor_calculator.py:584
msgid "Step 1: Identify the resistor values"
msgstr "Paso 1: identificar los valores de resistencia"

#: Other_Calculators/views/resistor_calculator.py:564
#: Other_Calculators/views/resistor_calculator.py:586
#, python-brace-format
msgid "R{index}: {value} {unit}"
msgstr "R{index}: {value} {unit}"

#: Other_Calculators/views/resistor_calculator.py:566
#: Other_Calculators/views/resistor_calculator.py:588
msgid "Step 2: Convert all to ohms"
msgstr "Paso 2: convertir todo a ohmios"

#: Other_Calculators/views/resistor_calculator.py:568
#: Other_Calculators/views/resistor_calculator.py:590
#, python-brace-format
msgid "R{index}: {value} Ω"
msgstr "R{index}: {value} Ω"

#: Other_Calculators/views/resistor_calculator.py:570
msgid "Step 3: Calculate total resistance"
msgstr "Paso 3: Calcular la resistencia total"

#: Other_Calculators/views/resistor_calculator.py:571
msgid "Formula: R_total = R1 + R2 + R3 + ..."
msgstr "Fórmula: R_total = R1 + R2 + R3 + ..."

#: Other_Calculators/views/resistor_calculator.py:572
#: Other_Calculators/views/resistor_calculator.py:598
#: Other_Calculators/views/roman_numeral_converter.py:269
#, python-brace-format
msgid "{value}"
msgstr "{value}"

#: Other_Calculators/views/resistor_calculator.py:573
#, python-brace-format
msgid "R_total = {sum}"
msgstr "R_total = {sum}"

#: Other_Calculators/views/resistor_calculator.py:574
#, python-brace-format
msgid "R_total = {total} Ω"
msgstr "R_total = {total} Ω"

#: Other_Calculators/views/resistor_calculator.py:578
#: Other_Calculators/views/resistor_calculator.py:605
#, python-brace-format
msgid "R_total = {result} {unit}"
msgstr "R_total = {result} {unit}"

#: Other_Calculators/views/resistor_calculator.py:592
msgid "Step 3: Calculate reciprocals"
msgstr "Paso 3: Calcular los recíprocos"

#: Other_Calculators/views/resistor_calculator.py:594
#, python-brace-format
msgid "1/R{index} = 1 / {r} = {rec}"
msgstr "1/R{index} = 1 / {r} = {rec}"

#: Other_Calculators/views/resistor_calculator.py:596
msgid "Step 4: Calculate total resistance"
msgstr "Paso 4: Calcular la resistencia total"

#: Other_Calculators/views/resistor_calculator.py:597
msgid "Formula: 1/R_total = 1/R1 + 1/R2 + 1/R3 + ..."
msgstr "Fórmula: 1/R_total = 1/R1 + 1/R2 + 1/R3 + ..."

#: Other_Calculators/views/resistor_calculator.py:599
#, python-brace-format
msgid "1/R_total = {sum}"
msgstr "1/R_total = {sum}"

#: Other_Calculators/views/resistor_calculator.py:600
#, python-brace-format
msgid "1/R_total = {total}"
msgstr "1/R_total = {total}"

#: Other_Calculators/views/resistor_calculator.py:601
#, python-brace-format
msgid "R_total = 1 / {total} = {resistance} Ω"
msgstr "R_total = 1 / {total} = {resistance} Ω"

#: Other_Calculators/views/resistor_calculator.py:615
msgid "Step 2: Convert resistance to ohms"
msgstr "Paso 2: convertir la resistencia a ohmios"

#: Other_Calculators/views/resistor_calculator.py:618
msgid "Step 3: Calculate current"
msgstr "Paso 3: Calcular la corriente"

#: Other_Calculators/views/resistor_calculator.py:619
msgid "Formula: I = V / R"
msgstr "Fórmula: I = V / R"

#: Other_Calculators/views/resistor_calculator.py:623
msgid "Step 4: Calculate power"
msgstr "Paso 4: Calcular la potencia"

#: Other_Calculators/views/resistor_calculator.py:624
msgid "Formula: P = V² / R"
msgstr "Fórmula: P = V² / R"

#: Other_Calculators/views/resistor_calculator.py:661
msgid "Series Resistance Calculation"
msgstr "Cálculo de resistencia en serie"

#: Other_Calculators/views/resistor_calculator.py:710
msgid "Parallel Resistance Calculation"
msgstr "Cálculo de resistencia paralela"

#: Other_Calculators/views/roman_numeral_converter.py:100
msgid "Decimal number is required."
msgstr "Se requiere un número decimal."

#: Other_Calculators/views/roman_numeral_converter.py:108
