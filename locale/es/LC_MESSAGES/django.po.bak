#: Math_Calculators/templates/math_calculators/average_calculator.html:12
msgid "Average Calculator - Calculate Mean, Median, Mode"
msgstr "Calculadora de promedio: calcular media, mediana y moda"

#: Math_Calculators/templates/math_calculators/average_calculator.html:5
#: Math_Calculators/templates/math_calculators/average_calculator.html:76
msgid ""
"Free average calculator to calculate arithmetic mean, median, mode, "
"geometric mean, and harmonic mean. Find average of numbers with step-by-step"
" solutions. Perfect for statistics and math homework."
msgstr ""
"Calculadora de promedios gratuita para calcular la media aritmética, la "
"mediana, la moda, la media geométrica y la media armónica. Encuentre el "
"promedio de números con soluciones paso a paso. Perfecto para tareas de "
"estadística y matemáticas."

#: Math_Calculators/templates/math_calculators/average_calculator.html:6
msgid ""
"average calculator, calculate average, mean calculator, median calculator, "
"mode calculator, arithmetic mean calculator, geometric mean calculator, "
"harmonic mean calculator, how to calculate average, average finder, mean "
"median mode calculator, statistics calculator, average of numbers, find "
"average"
msgstr ""
"calculadora de promedio, calcular el promedio, calculadora de media, "
"calculadora de mediana, calculadora de modo, calculadora de media "
"aritmética, calculadora de media geométrica, calculadora de media armónica, "
"cómo calcular el promedio, buscador de promedio, calculadora de modo de "
"mediana media, calculadora de estadísticas, promedio de números, encontrar "
"promedio"

#: Math_Calculators/templates/math_calculators/average_calculator.html:9
#: Math_Calculators/templates/math_calculators/average_calculator.html:13
msgid ""
"Free average calculator to calculate arithmetic mean, median, mode, "
"geometric mean, and harmonic mean. Find average of numbers with step-by-step"
" solutions."
msgstr ""
"Calculadora de promedios gratuita para calcular la media aritmética, la "
"mediana, la moda, la media geométrica y la media armónica. Encuentre el "
"promedio de números con soluciones paso a paso."

#: Math_Calculators/templates/math_calculators/average_calculator.html:75
#: Math_Calculators/templates/math_calculators/average_calculator.html:98
#: Math_Calculators/views/index.py:47
msgid "Average Calculator"
msgstr "Calculadora promedio"

#: Math_Calculators/templates/math_calculators/average_calculator.html:81
msgid "Arithmetic mean"
msgstr "Media aritmética"

#: Math_Calculators/templates/math_calculators/average_calculator.html:81
msgid "Geometric mean"
msgstr "media geométrica"

#: Math_Calculators/templates/math_calculators/average_calculator.html:81
msgid "Harmonic mean"
msgstr "media armónica"

#: Math_Calculators/templates/math_calculators/average_calculator.html:81
#: Math_Calculators/templates/math_calculators/mean_median_mode_range_calculator.html:32
#: Math_Calculators/templates/math_calculators/statistics_calculator.html:32
msgid "Median calculation"
msgstr "Cálculo de la mediana"

