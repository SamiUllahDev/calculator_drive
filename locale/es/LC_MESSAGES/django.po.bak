msgid "Example 1: Simple Division"
msgstr "Ejemplo 1: división simple"

#: Math_Calculators/templates/math_calculators/long_division_calculator.html:277
msgid "Example 2: Division with Remainder"
msgstr "Ejemplo 2: División con resto"

