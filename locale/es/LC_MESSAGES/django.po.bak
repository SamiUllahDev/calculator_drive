msgid "Error converting subnet mask: {error}"
msgstr "Error al convertir la máscara de subred: {error}"

#: Other_Calculators/views/ip_subnet_calculator.py:536
#: Other_Calculators/views/ip_subnet_calculator.py:563
#: Other_Calculators/views/ip_subnet_calculator.py:584
#, python-brace-format
msgid "IP Address: {ip}"
msgstr "Dirección IP: {ip}"

#: Other_Calculators/views/ip_subnet_calculator.py:537
#, python-brace-format
msgid "Subnet Mask/CIDR: {mask}"
msgstr "Máscara de subred/CIDR: {mask}"

#: Other_Calculators/views/ip_subnet_calculator.py:538
#, python-brace-format
msgid "CIDR Notation: /{cidr}"
msgstr "Notación CIDR: /{cidr}"

#: Other_Calculators/views/ip_subnet_calculator.py:540
msgid "Step 2: Calculate subnet mask"
msgstr "Paso 2: Calcular la máscara de subred"

#: Other_Calculators/views/ip_subnet_calculator.py:541
#: Other_Calculators/views/ip_subnet_calculator.py:575
#: Other_Calculators/views/ip_subnet_calculator.py:594
#: Other_Calculators/views/ip_subnet_calculator.py:613
#, python-brace-format
msgid "Subnet Mask: {mask}"
msgstr "Máscara de subred: {mask}"

#: Other_Calculators/views/ip_subnet_calculator.py:542
#, python-brace-format
msgid "CIDR: /{cidr} (means {cidr} bits for network)"
msgstr "CIDR: /{cidr} (significa {cidr} bits para la red)"

#: Other_Calculators/views/ip_subnet_calculator.py:544
msgid "Step 3: Calculate network address"
msgstr "Paso 3: Calcular la dirección de red"

#: Other_Calculators/views/ip_subnet_calculator.py:545
msgid "Network Address = IP Address AND Subnet Mask"
msgstr "Dirección de red = Dirección IP Y máscara de subred"

#: Other_Calculators/views/ip_subnet_calculator.py:546
#, python-brace-format
msgid "Network Address: {net}"
msgstr "Dirección de red: {net}"

#: Other_Calculators/views/ip_subnet_calculator.py:548
msgid "Step 4: Calculate broadcast address"
msgstr "Paso 4: Calcular la dirección de transmisión"

#: Other_Calculators/views/ip_subnet_calculator.py:549
#, python-brace-format
msgid "Broadcast Address: {broadcast}"
msgstr "Dirección de transmisión: {broadcast}"

#: Other_Calculators/views/ip_subnet_calculator.py:551
msgid "Step 5: Calculate host information"
msgstr "Paso 5: Calcular la información del host"

#: Other_Calculators/views/ip_subnet_calculator.py:552
#, python-brace-format
msgid "Total Hosts = 2^(32 - {cidr}) = {total}"
msgstr "Total de hosts = 2^(32 - {cidr}) = {total}"

#: Other_Calculators/views/ip_subnet_calculator.py:553
#, python-brace-format
msgid "Usable Hosts = Total Hosts - 2 = {usable}"
msgstr "Hosts utilizables = Total de hosts - 2 = {usable}"

#: Other_Calculators/views/ip_subnet_calculator.py:555
#, python-brace-format
msgid "First Usable Host: {first}"
msgstr "Primer host utilizable: {first}"

#: Other_Calculators/views/ip_subnet_calculator.py:556
#, python-brace-format
msgid "Last Usable Host: {last}"
msgstr "Último host utilizable: {last}"

#: Other_Calculators/views/ip_subnet_calculator.py:564
#, python-brace-format
msgid "Hosts Needed: {hosts}"
msgstr "Anfitriones necesarios: {hosts}"

#: Other_Calculators/views/ip_subnet_calculator.py:566
msgid "Step 2: Calculate required total hosts"
msgstr "Paso 2: Calcular el total de hosts necesarios"

#: Other_Calculators/views/ip_subnet_calculator.py:567
msgid "Required Hosts = Hosts Needed + 2 (network + broadcast)"
msgstr "Hosts requeridos = Hosts necesarios + 2 (red + transmisión)"

#: Other_Calculators/views/ip_subnet_calculator.py:568
#, python-brace-format
msgid "Required Hosts = {needed} + 2 = {required}"
msgstr "Hosts requeridos = {needed} + 2 = {required}"

#: Other_Calculators/views/ip_subnet_calculator.py:570
msgid "Step 3: Calculate minimum CIDR"
msgstr "Paso 3: Calcular el CIDR mínimo"

#: Other_Calculators/views/ip_subnet_calculator.py:571
#, python-brace-format
msgid "We need: 2^(32 - CIDR) >= {required}"
msgstr "Necesitamos: 2^(32 - CIDR) >= {required}"

#: Other_Calculators/views/ip_subnet_calculator.py:572
#, python-brace-format
msgid "CIDR = 32 - log2({required}) = {cidr}"
msgstr "CIDR = 32 - log2({required}) = {cidr}"

#: Other_Calculators/views/ip_subnet_calculator.py:574
msgid "Step 4: Calculate subnet information"
msgstr "Paso 4: Calcular la información de la subred"

#: Other_Calculators/views/ip_subnet_calculator.py:576
#, python-brace-format
msgid "Total Hosts: {total}"
msgstr "Total de anfitriones: {total}"

#: Other_Calculators/views/ip_subnet_calculator.py:577
#, python-brace-format
msgid "Usable Hosts: {usable}"
msgstr "Hosts utilizables: {usable}"

#: Other_Calculators/views/ip_subnet_calculator.py:585
#, python-brace-format
msgid "Subnets Needed: {subnets}"
msgstr "Subredes necesarias: {subnets}"

#: Other_Calculators/views/ip_subnet_calculator.py:586
#, python-brace-format
msgid "Original CIDR: /{cidr}"
msgstr "CIDR original: /{cidr}"

#: Other_Calculators/views/ip_subnet_calculator.py:588
msgid "Step 2: Calculate required CIDR"
msgstr "Paso 2: Calcular el CIDR requerido"

#: Other_Calculators/views/ip_subnet_calculator.py:589
#, python-brace-format
msgid "We need: 2^(New CIDR - Original CIDR) >= {needed}"
msgstr "Necesitamos: 2^(Nuevo CIDR - CIDR original) >= {needed}"

#: Other_Calculators/views/ip_subnet_calculator.py:590
#, python-brace-format
msgid "New CIDR = Original CIDR + log2({needed})"
msgstr "Nuevo CIDR = CIDR original + log2({needed})"

#: Other_Calculators/views/ip_subnet_calculator.py:591
#, python-brace-format
msgid "New CIDR = {orig} + {log} = {new}"
msgstr "Nuevo CIDR = {orig} + {log} = {new}"

#: Other_Calculators/views/ip_subnet_calculator.py:593
msgid "Step 3: Calculate subnet information"
msgstr "Paso 3: Calcular la información de la subred"

#: Other_Calculators/views/ip_subnet_calculator.py:595
#, python-brace-format
msgid "Actual Subnets Created: {actual}"
msgstr "Subredes reales creadas: {actual}"

#: Other_Calculators/views/ip_subnet_calculator.py:596
#, python-brace-format
msgid "Hosts per Subnet: {hosts}"
msgstr "Hosts por subred: {hosts}"

#: Other_Calculators/views/ip_subnet_calculator.py:597
#, python-brace-format
msgid "Usable Hosts per Subnet: {usable}"
msgstr "Hosts utilizables por subred: {usable}"

#: Other_Calculators/views/ip_subnet_calculator.py:604
#, python-brace-format
msgid "Subnet Mask: {value} ({format})"
msgstr "Máscara de subred: {value} ({format})"

#: Other_Calculators/views/ip_subnet_calculator.py:607
msgid "Step 2: Convert to CIDR"
msgstr "Paso 2: convertir a CIDR"

#: Other_Calculators/views/ip_subnet_calculator.py:608
msgid "Count the number of leading 1s in the binary representation"
msgstr "Cuente el número de unos iniciales en la representación binaria"

#: Other_Calculators/views/ip_subnet_calculator.py:609
#, python-brace-format
msgid "CIDR: /{cidr}"
msgstr "CIDR: /{cidr}"

#: Other_Calculators/views/ip_subnet_calculator.py:612
msgid "Step 3: Convert CIDR to dotted decimal"
msgstr "Paso 3: convertir CIDR a decimal con puntos"

#: Other_Calculators/views/ip_subnet_calculator.py:616
#, python-brace-format
msgid "CIDR: /{result}"
msgstr "CIDR: /{result}"

#: Other_Calculators/views/ip_subnet_calculator.py:626
msgid "Reserved (Network + Broadcast)"
msgstr "Reservado (Red + Transmisión)"

#: Other_Calculators/views/ip_subnet_calculator.py:650
msgid "Host Distribution"
msgstr "Distribución de host"

#: Other_Calculators/views/ip_subnet_calculator.py:667
#: Other_Calculators/views/ip_subnet_calculator.py:699
msgid "Hosts"
msgstr "Anfitriones"

#: Other_Calculators/views/ip_subnet_calculator.py:691
msgid "Subnet from Hosts"
msgstr "Subred de hosts"

#: Other_Calculators/views/ip_subnet_calculator.py:741
msgid "Subnet from Subnets"
msgstr "Subred de subredes"

