#: Other_Calculators/views/btu_calculator.py:629
#, python-brace-format
msgid ""
"  Adjusted Base BTU = {base:.2f} × {ins_mult} × {clim_mult} = {adjusted:.2f}"
" BTU"
msgstr ""
"BTU base ajustada = {base:.2f} × {ins_mult} × {clim_mult} = {ajustado:.2f} "
"BTU"

#: Other_Calculators/views/btu_calculator.py:635
msgid "Step 5: Add Additional Loads"
msgstr "Paso 5: agregue cargas adicionales"

#: Other_Calculators/views/btu_calculator.py:636
#, python-brace-format
msgid "  Window Load: {windows} windows × 1000 BTU = {window_btu:.2f} BTU"
msgstr "Carga de ventana: {windows} windows × 1000 BTU = {window_btu:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:639
#, python-brace-format
msgid "  Occupant Load: {occupants} people × 400 BTU = {occupant_btu:.2f} BTU"
msgstr ""
"Carga de ocupantes: {occupants} personas × 400 BTU = {ocupantes_btu:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:642
#, python-brace-format
msgid "  Appliance Load: {watts} W × 3.412 = {appliance_btu:.2f} BTU"
msgstr ""
"Carga del electrodoméstico: {watts} W × 3,412 = {appliance_btu:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:647
msgid "Step 6: Calculate Total Cooling BTU"
msgstr "Paso 6: Calcule el BTU de enfriamiento total"

#: Other_Calculators/views/btu_calculator.py:648
msgid "  Total BTU = Adjusted Base + Windows + Occupants + Appliances"
msgstr "BTU total = Base ajustada + Ventanas + Ocupantes + Electrodomésticos"

#: Other_Calculators/views/btu_calculator.py:649
#, python-brace-format
msgid ""
"  Total BTU = {adjusted:.2f} + {win:.2f} + {occ:.2f} + {app:.2f} = "
"{total:.2f} BTU"
msgstr ""
"BTU total = {ajustado:.2f} + {ganar:.2f} + {occ:.2f} + {app:.2f} = "
"{total:.2f} BTU"

#: Other_Calculators/views/btu_calculator.py:671
msgid "Energy Units (Normalized)"
msgstr "Unidades de energía (normalizadas)"

#: Other_Calculators/views/btu_calculator.py:724
msgid "Required BTU"
msgstr "BTU requeridos"

#: Other_Calculators/views/btu_calculator.py:765
msgid "Base Load"
msgstr "Carga base"

#: Other_Calculators/views/btu_calculator.py:766
msgid "Windows"
msgstr "ventanas"

#: Other_Calculators/views/btu_calculator.py:767
msgid "Occupants"
msgstr "Ocupantes"

#: Other_Calculators/views/btu_calculator.py:768
msgid "Appliances"
msgstr "Accesorios"

#: Other_Calculators/views/concrete_calculator.py:60
msgid "Volume calculations for multiple shapes"
msgstr "Cálculos de volumen para múltiples formas."

#: Other_Calculators/views/concrete_calculator.py:62
msgid "Unit conversions (cubic feet, yards, meters)"
msgstr "Conversiones de unidades (pies cúbicos, yardas, metros)"

#: Other_Calculators/views/concrete_calculator.py:63
msgid "Multiple concrete mix ratios"
msgstr "Múltiples proporciones de mezcla de concreto"

#: Other_Calculators/views/concrete_calculator.py:542
#: Other_Calculators/views/concrete_calculator.py:585
#: Other_Calculators/views/concrete_calculator.py:635
#: Other_Calculators/views/concrete_calculator.py:685
#: Other_Calculators/views/concrete_calculator.py:728
msgid "Step 1: Enter Dimensions"
msgstr "Paso 1: Ingrese las dimensiones"

#: Other_Calculators/views/concrete_calculator.py:545
#: Other_Calculators/views/concrete_calculator.py:587
#: Other_Calculators/views/concrete_calculator.py:731
#, python-brace-format
msgid "  Thickness: {thickness} {unit}"
msgstr "Espesor: {thickness} {unit}"

#: Other_Calculators/views/concrete_calculator.py:552
#: Other_Calculators/views/concrete_calculator.py:593
#: Other_Calculators/views/concrete_calculator.py:738
#, python-brace-format
msgid "  Thickness: {m} m × 3.28084 = {ft:.2f} ft"
msgstr "Espesor: {m} m × 3,28084 = {ft:.2f} pies"

#: Other_Calculators/views/concrete_calculator.py:555
#: Other_Calculators/views/concrete_calculator.py:698
#: Other_Calculators/views/concrete_calculator.py:741
msgid "Step 3: Calculate Volume"
msgstr "Paso 3: calcular el volumen"

#: Other_Calculators/views/concrete_calculator.py:556
msgid "  Volume = Length × Width × Thickness"
msgstr "Volumen = Largo × Ancho × Espesor"

#: Other_Calculators/views/concrete_calculator.py:557
#, python-brace-format
msgid ""
"  Volume = {length:.2f} × {width:.2f} × {thickness:.2f} = {volume:.2f} cu ft"
msgstr ""
"Volumen = {largo:.2f} × {ancho:.2f} × {espesor:.2f} = {volumen:.2f} pies "
"cúbicos"

#: Other_Calculators/views/concrete_calculator.py:562
#: Other_Calculators/views/concrete_calculator.py:705
#: Other_Calculators/views/concrete_calculator.py:748
msgid "Step 4: Convert to Other Units"
msgstr "Paso 4: convertir a otras unidades"

#: Other_Calculators/views/concrete_calculator.py:563
#: Other_Calculators/views/concrete_calculator.py:613
#: Other_Calculators/views/concrete_calculator.py:663
#: Other_Calculators/views/concrete_calculator.py:706
#: Other_Calculators/views/concrete_calculator.py:749
#, python-brace-format
msgid "  Cubic Yards: {cuyd:.2f} cu yd"
msgstr "Yardas cúbicas: {cuyd:.2f} yd cúbicas"

#: Other_Calculators/views/concrete_calculator.py:564
#: Other_Calculators/views/concrete_calculator.py:614
#: Other_Calculators/views/concrete_calculator.py:664
#: Other_Calculators/views/concrete_calculator.py:707
#: Other_Calculators/views/concrete_calculator.py:750
#, python-brace-format
msgid "  Cubic Meters: {cum:.2f} m³"
msgstr "Metros cúbicos: {cum:.2f} m³"

#: Other_Calculators/views/concrete_calculator.py:567
#: Other_Calculators/views/concrete_calculator.py:710
#: Other_Calculators/views/concrete_calculator.py:753
#, python-brace-format
msgid "Step 5: Calculate Materials (Mix Ratio: {ratio})"
msgstr "Paso 5: Calcular los materiales (proporción de mezcla: {ratio})"

#: Other_Calculators/views/concrete_calculator.py:568
#: Other_Calculators/views/concrete_calculator.py:618
#: Other_Calculators/views/concrete_calculator.py:668
#: Other_Calculators/views/concrete_calculator.py:711
#: Other_Calculators/views/concrete_calculator.py:754
#, python-brace-format
msgid "  Cement: {bags} bags ({lbs:.2f} lbs)"
msgstr "Cemento: {bags} bolsas ({lbs:.2f} lbs)"

#: Other_Calculators/views/concrete_calculator.py:571
#: Other_Calculators/views/concrete_calculator.py:621
#: Other_Calculators/views/concrete_calculator.py:671
#: Other_Calculators/views/concrete_calculator.py:714
#: Other_Calculators/views/concrete_calculator.py:757
#, python-brace-format
msgid "  Sand: {lbs:.2f} lbs ({tons:.3f} tons)"
msgstr "Arena: {lbs:.2f} lbs ({tons:.3f} toneladas)"

#: Other_Calculators/views/concrete_calculator.py:574
#: Other_Calculators/views/concrete_calculator.py:624
#: Other_Calculators/views/concrete_calculator.py:674
#: Other_Calculators/views/concrete_calculator.py:717
#: Other_Calculators/views/concrete_calculator.py:760
#, python-brace-format
msgid "  Aggregate: {lbs:.2f} lbs ({tons:.3f} tons)"
msgstr "Agregado: {lbs:.2f} lbs ({tons:.3f} toneladas)"

#: Other_Calculators/views/concrete_calculator.py:586
#: Other_Calculators/views/concrete_calculator.py:636
#, python-brace-format
msgid "  Diameter: {diameter} {unit}"
msgstr "Diámetro: {diameter} {unit}"

#: Other_Calculators/views/concrete_calculator.py:592
#: Other_Calculators/views/concrete_calculator.py:642
#, python-brace-format
msgid "  Diameter: {m} m × 3.28084 = {ft:.2f} ft"
msgstr "Diámetro: {m} m × 3,28084 = {ft:.2f} pies"

#: Other_Calculators/views/concrete_calculator.py:596
#: Other_Calculators/views/concrete_calculator.py:646
msgid "Step 3: Calculate Radius and Area"
msgstr "Paso 3: calcular el radio y el área"

#: Other_Calculators/views/concrete_calculator.py:597
#: Other_Calculators/views/concrete_calculator.py:647
#, python-brace-format
msgid "  Radius = Diameter ÷ 2 = {diameter:.2f} ÷ 2 = {radius:.2f} ft"
msgstr "Radio = Diámetro ÷ 2 = {diámetro:.2f} ÷ 2 = {radio:.2f} pies"

#: Other_Calculators/views/concrete_calculator.py:600
#: Other_Calculators/views/concrete_calculator.py:650
#, python-brace-format
msgid "  Area = π × r² = π × {radius:.2f}² = {area:.2f} sq ft"
msgstr "Área = π × r² = π × {radio:.2f}² = {área:.2f} pies cuadrados"

#: Other_Calculators/views/concrete_calculator.py:606
msgid "  Volume = Area × Thickness"
msgstr "Volumen = Área × Espesor"

#: Other_Calculators/views/concrete_calculator.py:607
#, python-brace-format
msgid "  Volume = {area:.2f} × {thickness:.2f} = {volume:.2f} cu ft"
msgstr "Volumen = {área:.2f} × {espesor:.2f} = {volumen:.2f} pies cúbicos"

#: Other_Calculators/views/concrete_calculator.py:612
#: Other_Calculators/views/concrete_calculator.py:662
msgid "Step 5: Convert to Other Units"
msgstr "Paso 5: convertir a otras unidades"

#: Other_Calculators/views/concrete_calculator.py:617
#: Other_Calculators/views/concrete_calculator.py:667
#, python-brace-format
msgid "Step 6: Calculate Materials (Mix Ratio: {ratio})"
msgstr "Paso 6: Calcular los materiales (proporción de mezcla: {ratio})"

#: Other_Calculators/views/concrete_calculator.py:656
msgid "  Volume = Area × Height"
msgstr "Volumen = Área × Altura"

#: Other_Calculators/views/concrete_calculator.py:657
#, python-brace-format
msgid "  Volume = {area:.2f} × {height:.2f} = {volume:.2f} cu ft"
msgstr "Volumen = {área:.2f} × {altura:.2f} = {volumen:.2f} pies cúbicos"

#: Other_Calculators/views/concrete_calculator.py:688
#, python-brace-format
msgid "  Depth: {depth} {unit}"
msgstr "Profundidad: {depth} {unit}"

#: Other_Calculators/views/concrete_calculator.py:695
#, python-brace-format
msgid "  Depth: {m} m × 3.28084 = {ft:.2f} ft"
msgstr "Profundidad: {m} m × 3,28084 = {ft:.2f} pies"

#: Other_Calculators/views/concrete_calculator.py:699
msgid "  Volume = Length × Width × Depth"
msgstr "Volumen = Largo × Ancho × Profundidad"

#: Other_Calculators/views/concrete_calculator.py:700
#, python-brace-format
msgid ""
"  Volume = {length:.2f} × {width:.2f} × {depth:.2f} = {volume:.2f} cu ft"
msgstr ""
"Volumen = {largo:.2f} × {ancho:.2f} × {profundidad:.2f} = {volumen:.2f} pies"
" cúbicos"

#: Other_Calculators/views/concrete_calculator.py:742
msgid "  Volume = Length × Height × Thickness"
msgstr "Volumen = Largo × Alto × Espesor"

#: Other_Calculators/views/concrete_calculator.py:743
#, python-brace-format
msgid ""
"  Volume = {length:.2f} × {height:.2f} × {thickness:.2f} = {volume:.2f} cu "
"ft"
msgstr ""
"Volumen = {longitud:.2f} × {altura:.2f} × {espesor:.2f} = {volumen:.2f} pies"
" cúbicos"

#: Other_Calculators/views/concrete_calculator.py:775
msgid "Step 2: Convert to Cubic Feet"
msgstr "Paso 2: convertir a pies cúbicos"

#: Other_Calculators/views/concrete_calculator.py:777
#, python-brace-format
msgid "  Cubic Feet = {cuyd} cu yd ÷ {factor} = {cuft:.2f} cu ft"
msgstr "Pies cúbicos = {cuyd} cu yd ÷ {factor} = {cuft:.2f} cu ft"

#: Other_Calculators/views/concrete_calculator.py:781
#, python-brace-format
msgid "  Cubic Feet = {cum} m³ ÷ {factor} = {cuft:.2f} cu ft"
msgstr "Pies cúbicos = {cum} m³ ÷ {factor} = {cuft:.2f} pies cúbicos"

#: Other_Calculators/views/concrete_calculator.py:789
#: Other_Calculators/views/concrete_calculator.py:794
#, python-brace-format
msgid "  {unit} = {cuft} cu ft × {factor} = {converted:.6f} {unit}"
msgstr "  {unit} = {cuft} cu ft × {factor} = {converted:.6f} {unit}"

#: Other_Calculators/views/concrete_calculator.py:800
#, python-brace-format
msgid "  {cuft:.2f} cu ft"
msgstr "{cuft:.2f} pies cúbicos"

