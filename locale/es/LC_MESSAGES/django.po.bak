msgstr "Kilogramos = {lb} libras × 0,453592 = {kg} kg"

#: Other_Calculators/views/mass_calculator.py:536
msgid "Kilograms = Ounces × 0.0283495"
msgstr "Kilogramos = Onzas × 0,0283495"

#: Other_Calculators/views/mass_calculator.py:537
#, python-brace-format
msgid "Kilograms = {oz} oz × 0.0283495 = {kg} kg"
msgstr "Kilogramos = {oz} oz × 0,0283495 = {kg} kg"

#: Other_Calculators/views/mass_calculator.py:539
msgid "Kilograms = Tons × 1000"
msgstr "Kilogramos = Toneladas × 1000"

#: Other_Calculators/views/mass_calculator.py:540
#, python-brace-format
msgid "Kilograms = {tons} tons × 1000 = {kg} kg"
msgstr "Kilogramos = {tons} toneladas × 1000 = {kg} kg"

#: Other_Calculators/views/mass_calculator.py:542
msgid "Kilograms = Stone × 6.35029"
msgstr "Kilogramos = Piedra × 6,35029"

#: Other_Calculators/views/mass_calculator.py:543
#, python-brace-format
msgid "Kilograms = {stone} stone × 6.35029 = {kg} kg"
msgstr "Kilogramos = {stone} piedra × 6,35029 = {kg} kg"

#: Other_Calculators/views/mass_calculator.py:545
#, python-brace-format
msgid "Kilograms = {value} {unit} × conversion factor = {kg} kg"
msgstr "Kilogramos = {value} {unit} × factor de conversión = {kg} kg"

