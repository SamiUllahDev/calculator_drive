msgstr "Área de cobertura = {result} pies²"

#: Other_Calculators/views/gravel_calculator.py:1045
#, python-brace-format
msgid "Volume: {value} {unit}"
msgstr "Volumen: {value} {unit}"

#: Other_Calculators/views/gravel_calculator.py:1048
msgid "Step 2: Convert to cubic feet"
msgstr "Paso 2: convertir a pies cúbicos"

#: Other_Calculators/views/gravel_calculator.py:1050
msgid "Cubic Feet = Cubic Yards × 27"
msgstr "Pies cúbicos = Yardas cúbicas × 27"

#: Other_Calculators/views/gravel_calculator.py:1051
#, python-brace-format
msgid "Cubic Feet = {val} yd³ × 27 = {cf} ft³"
msgstr "Pies cúbicos = {val} yd³ × 27 = {cf} pies³"

#: Other_Calculators/views/gravel_calculator.py:1053
msgid "Cubic Feet = Cubic Meters × 35.3147"
msgstr "Pies cúbicos = Metros cúbicos × 35,3147"

#: Other_Calculators/views/gravel_calculator.py:1054
#, python-brace-format
msgid "Cubic Feet = {val} m³ × 35.3147 = {cf} ft³"
msgstr "Pies cúbicos = {val} m³ × 35,3147 = {cf} pies³"

#: Other_Calculators/views/gravel_calculator.py:1057
#, python-brace-format
msgid "Step 3: Convert from cubic feet to {unit}"
msgstr "Paso 3: Convertir de pies cúbicos a {unit}"

#: Other_Calculators/views/gravel_calculator.py:1060
#, python-brace-format
msgid "Cubic Yards = {cf} ft³ / 27 = {result} yd³"
msgstr "Yardas cúbicas = {cf} pies³ / 27 = {result} yd³"

#: Other_Calculators/views/gravel_calculator.py:1063
#, python-brace-format
msgid "Cubic Meters = {cf} ft³ / 35.3147 = {result} m³"
msgstr "Metros cúbicos = {cf} pies³ / 35,3147 = {result} m³"

#: Other_Calculators/views/gravel_calculator.py:1073
#, python-brace-format
msgid "Weight: {value} {unit}"
msgstr "Peso: {value} {unit}"

#: Other_Calculators/views/gravel_calculator.py:1076
msgid "Step 2: Convert to pounds"
msgstr "Paso 2: convertir a libras"

#: Other_Calculators/views/gravel_calculator.py:1078
msgid "Pounds = Tons × 2000"
msgstr "Libras = Toneladas × 2000"

#: Other_Calculators/views/gravel_calculator.py:1079
#, python-brace-format
msgid "Pounds = {val} tons × 2000 = {lbs} lbs"
msgstr "Libras = {val} toneladas × 2000 = {lbs} lbs"

#: Other_Calculators/views/gravel_calculator.py:1081
msgid "Pounds = Kilograms × 2.20462"
msgstr "Libras = Kilogramos × 2,20462"

#: Other_Calculators/views/gravel_calculator.py:1082
#, python-brace-format
msgid "Pounds = {val} kg × 2.20462 = {lbs} lbs"
msgstr "Libras = {val} kg × 2,20462 = {lbs} lbs"

#: Other_Calculators/views/gravel_calculator.py:1085
#, python-brace-format
msgid "Step 3: Convert from pounds to {unit}"
msgstr "Paso 3: Convertir de libras a {unit}"

#: Other_Calculators/views/gravel_calculator.py:1088
#, python-brace-format
msgid "Tons = {lbs} lbs / 2000 = {result} tons"
msgstr "Toneladas = {lbs} lbs / 2000 = {result} toneladas"

#: Other_Calculators/views/gravel_calculator.py:1091
#, python-brace-format
msgid "Kilograms = {lbs} lbs / 2.20462 = {result} kg"
msgstr "Kilogramos = {lbs} lbs / 2,20462 = {result} kg"

#: Other_Calculators/views/gravel_calculator.py:1104
msgid "Length (ft)"
msgstr "Longitud (pies)"

#: Other_Calculators/views/gravel_calculator.py:1104
msgid "Width (ft)"
msgstr "Ancho (pies)"

#: Other_Calculators/views/gravel_calculator.py:1106
#: Other_Calculators/views/gravel_calculator.py:1158
#: Other_Calculators/views/gravel_calculator.py:1208
msgid "Dimensions"
msgstr "Dimensiones"

#: Other_Calculators/views/gravel_calculator.py:1132
msgid "Rectangular Gravel Volume Calculation"
msgstr "Cálculo del volumen de grava rectangular"

#: Other_Calculators/views/gravel_calculator.py:1156
msgid "Diameter (ft)"
msgstr "Diámetro (pies)"

#: Other_Calculators/views/gravel_calculator.py:1182
msgid "Circular Gravel Volume Calculation"
msgstr "Cálculo del volumen de grava circular"

#: Other_Calculators/views/gravel_calculator.py:1206
msgid "Base (ft)"
msgstr "Base (pies)"

#: Other_Calculators/views/gravel_calculator.py:1206
#: Other_Calculators/views/height_calculator.py:656
msgid "Height (ft)"
msgstr "Altura (pies)"

#: Other_Calculators/views/gravel_calculator.py:1234
msgid "Triangular Gravel Volume Calculation"
msgstr "Cálculo del volumen de grava triangular"

#: Other_Calculators/views/gravel_calculator.py:1284
msgid "Gravel Weight Calculation"
msgstr "Cálculo del peso de la grava"

#: Other_Calculators/views/gravel_calculator.py:1308
msgid "Price/Unit"
msgstr "Precio/Unidad"

#: Other_Calculators/views/gravel_calculator.py:1334
msgid "Gravel Cost Calculation"
msgstr "Cálculo del costo de grava"

#: Other_Calculators/views/gravel_calculator.py:1358
msgid "Coverage Area (ft²)"
msgstr "Área de cobertura (pies²)"

#: Other_Calculators/views/gravel_calculator.py:1384
msgid "Gravel Coverage Calculation"
msgstr "Cálculo de cobertura de grava"

#: Other_Calculators/views/heat_index_calculator.py:126
msgid "Heat index is only valid for temperatures above 80°F (27°C)."
msgstr ""
"El índice de calor solo es válido para temperaturas superiores a 80°F "
"(27°C)."

#: Other_Calculators/views/heat_index_calculator.py:138
msgid "Heat index is only valid for relative humidity above 40%."
msgstr ""
"El índice de calor solo es válido para una humedad relativa superior al 40%."

#: Other_Calculators/views/heat_index_calculator.py:227
#, python-brace-format
msgid "Error calculating heat index: {error}"
msgstr "Error al calcular el índice de calor: {error}"

#: Other_Calculators/views/heat_index_calculator.py:236
#: Other_Calculators/views/heat_index_calculator.py:447
msgid "Heat index is required."
msgstr "Se requiere índice de calor."

#: Other_Calculators/views/heat_index_calculator.py:273
#: Other_Calculators/views/heat_index_calculator.py:492
msgid "Heat index must be at least 80°F (27°C)."
msgstr "El índice de calor debe ser de al menos 80 °F (27 °C)."

#: Other_Calculators/views/heat_index_calculator.py:285
#, python-format
msgid "Relative humidity must be at least 40% for heat index calculations."
msgstr ""
"La humedad relativa debe ser de al menos el 40 % para los cálculos del "
"índice de calor."

#: Other_Calculators/views/heat_index_calculator.py:438
#, python-brace-format
msgid "Error calculating temperature: {error}"
msgstr "Error al calcular la temperatura: {error}"

#: Other_Calculators/views/heat_index_calculator.py:486
msgid "Temperature must be at least 80°F (27°C) for heat index calculations."
msgstr ""
"La temperatura debe ser de al menos 80 °F (27 °C) para los cálculos del "
"índice de calor."

#: Other_Calculators/views/heat_index_calculator.py:633
#, python-brace-format
msgid "Error calculating humidity: {error}"
msgstr "Error al calcular la humedad: {error}"

#: Other_Calculators/views/heat_index_calculator.py:714
#: Other_Calculators/views/heat_index_calculator.py:770
#: Other_Calculators/views/wind_chill_calculator.py:391
#: Other_Calculators/views/wind_chill_calculator.py:452
#, python-brace-format
msgid "Temperature: {temp}°{unit}"
msgstr "Temperatura: {temp}°{unit}"

#: Other_Calculators/views/heat_index_calculator.py:715
#: Other_Calculators/views/heat_index_calculator.py:745
#, python-brace-format
msgid "Relative Humidity: {hum}%"
msgstr "Humedad relativa: {hum}%"

#: Other_Calculators/views/heat_index_calculator.py:718
msgid "Step 2: Convert temperature to Fahrenheit"
msgstr "Paso 2: convertir la temperatura a Fahrenheit"

#: Other_Calculators/views/heat_index_calculator.py:719
#: Other_Calculators/views/heat_index_calculator.py:749
#: Other_Calculators/views/heat_index_calculator.py:800
msgid "Formula: °F = (°C × 9/5) + 32"
msgstr "Fórmula: °F = (°C × 9/5) + 32"

#: Other_Calculators/views/heat_index_calculator.py:720
#, python-brace-format
msgid "°F = ({temp} × 9/5) + 32 = {f}°F"
msgstr "°F = ({temp} × 9/5) + 32 = {f}°F"

#: Other_Calculators/views/heat_index_calculator.py:722
msgid "Step 3: Apply the Rothfusz equation"
msgstr "Paso 3: aplicar la ecuación de Rothfusz"

#: Other_Calculators/views/heat_index_calculator.py:723
msgid "Heat Index Formula:"
msgstr "Fórmula del índice de calor:"

#: Other_Calculators/views/heat_index_calculator.py:724
#: Other_Calculators/views/heat_index_calculator.py:754
#: Other_Calculators/views/heat_index_calculator.py:779
msgid "HI = -42.379 + 2.04901523×T + 10.14333127×RH - 0.22475541×T×RH"
msgstr "HI = -42,379 + 2,04901523×T + 10,14333127×RH - 0,22475541×T×RH"

#: Other_Calculators/views/heat_index_calculator.py:725
#: Other_Calculators/views/heat_index_calculator.py:755
#: Other_Calculators/views/heat_index_calculator.py:780
msgid "     - 6.83783×10⁻³×T² - 5.481717×10⁻²×RH² + 1.22874×10⁻³×T²×RH"
msgstr "- 6,83783×10⁻³×T² - 5,481717×10⁻²×RH² + 1,22874×10⁻³×T²×RH"

#: Other_Calculators/views/heat_index_calculator.py:726
#: Other_Calculators/views/heat_index_calculator.py:756
#: Other_Calculators/views/heat_index_calculator.py:781
msgid "     + 8.5282×10⁻⁴×T×RH² - 1.99×10⁻⁶×T²×RH²"
msgstr "+ 8,5282×10⁻⁴×T×RH² - 1,99×10⁻⁶×T²×RH²"

#: Other_Calculators/views/heat_index_calculator.py:727
#, python-brace-format
msgid "Where T = {temp}°F, RH = {hum}%"
msgstr "Donde T = {temp}°F, RH = {hum}%"

#: Other_Calculators/views/heat_index_calculator.py:729
msgid "Step 4: Apply adjustments (if applicable)"
msgstr "Paso 4: Aplicar ajustes (si corresponde)"

#: Other_Calculators/views/heat_index_calculator.py:731
msgid "Adjustment for RH < 13%: Subtract correction factor"
msgstr "Ajuste para HR < 13%: Restar el factor de corrección"

#: Other_Calculators/views/heat_index_calculator.py:733
msgid "Adjustment for RH > 85%: Add correction factor"
msgstr "Ajuste para HR > 85%: Agregar factor de corrección"

#: Other_Calculators/views/heat_index_calculator.py:735
msgid "Step 5: Final result"
msgstr "Paso 5: resultado final"

#: Other_Calculators/views/heat_index_calculator.py:736
#, python-brace-format
msgid "Heat Index = {hi}°F"
msgstr "Índice de calor = {hi}°F"

#: Other_Calculators/views/heat_index_calculator.py:737
#, python-brace-format
msgid "Category: {cat} ({risk})"
msgstr "Categoría: {cat} ({risk})"

#: Other_Calculators/views/heat_index_calculator.py:744
#: Other_Calculators/views/heat_index_calculator.py:769
#, python-brace-format
msgid "Heat Index: {hi}°{unit}"
msgstr "Índice de calor: {hi}°{unit}"

#: Other_Calculators/views/heat_index_calculator.py:748
msgid "Step 2: Convert heat index to Fahrenheit"
msgstr "Paso 2: convertir el índice de calor a Fahrenheit"

#: Other_Calculators/views/heat_index_calculator.py:750
#, python-brace-format
msgid "°F = ({hi} × 9/5) + 32 = {f}°F"
msgstr "°F = ({hi} × 9/5) + 32 = {f}°F"

#: Other_Calculators/views/heat_index_calculator.py:752
msgid "Step 3: Solve for temperature using iterative method"
msgstr "Paso 3: Resuelva la temperatura usando el método iterativo"

#: Other_Calculators/views/heat_index_calculator.py:753
msgid "Using the Rothfusz equation, we solve for T where:"
msgstr "Usando la ecuación de Rothfusz, resolvemos para T donde:"

#: Other_Calculators/views/heat_index_calculator.py:757
#, python-brace-format
msgid "With HI = {hi}°F, RH = {hum}%"
msgstr "Con HI = {hi}°F, HR = {hum}%"

#: Other_Calculators/views/heat_index_calculator.py:759
#: Other_Calculators/views/heat_index_calculator.py:784
msgid "Step 4: Final result"
msgstr "Paso 4: resultado final"

#: Other_Calculators/views/heat_index_calculator.py:760
#, python-brace-format
msgid "Temperature = {temp}°F"
msgstr "Temperatura = {temp}°F"

#: Other_Calculators/views/heat_index_calculator.py:773
msgid "Step 2: Convert to Fahrenheit"
msgstr "Paso 2: convertir a Fahrenheit"

#: Other_Calculators/views/heat_index_calculator.py:774
#, python-brace-format
msgid "Temperature: {temp}°C = {f}°F"
msgstr "Temperatura: {temp}°C = {f}°F"

#: Other_Calculators/views/heat_index_calculator.py:775
#, python-brace-format
msgid "Heat Index: {hi}°C = {f}°F"
msgstr "Índice de calor: {hi}°C = {f}°F"

#: Other_Calculators/views/heat_index_calculator.py:777
msgid "Step 3: Solve for relative humidity using iterative method"
msgstr "Paso 3: Resuelva la humedad relativa utilizando el método iterativo"

#: Other_Calculators/views/heat_index_calculator.py:778
msgid "Using the Rothfusz equation, we solve for RH where:"
msgstr "Usando la ecuación de Rothfusz, resolvemos para RH donde:"

#: Other_Calculators/views/heat_index_calculator.py:782
#, python-brace-format
msgid "With HI = {hi}°F, T = {temp}°F"
msgstr "Con HI = {hi}°F, T = {temp}°F"

#: Other_Calculators/views/heat_index_calculator.py:785
#, python-brace-format
msgid "Relative Humidity = {hum}%"
msgstr "Humedad relativa = {hum}%"

#: Other_Calculators/views/heat_index_calculator.py:792
#, python-brace-format
msgid "Temperature: {value}°{unit}"
msgstr "Temperatura: {value}°{unit}"

#: Other_Calculators/views/heat_index_calculator.py:795
msgid "Step 2: Convert Fahrenheit to Celsius"
msgstr "Paso 2: convertir grados Fahrenheit a Celsius"

#: Other_Calculators/views/heat_index_calculator.py:796
msgid "Formula: °C = (°F - 32) × 5/9"
msgstr "Fórmula: °C = (°F - 32) × 5/9"

#: Other_Calculators/views/heat_index_calculator.py:797
#, python-brace-format
msgid "°C = ({f} - 32) × 5/9 = {c}°C"
msgstr "°C = ({f} - 32) × 5/9 = {c}°C"

#: Other_Calculators/views/heat_index_calculator.py:799
msgid "Step 2: Convert Celsius to Fahrenheit"
msgstr "Paso 2: convertir grados Celsius a Fahrenheit"

#: Other_Calculators/views/heat_index_calculator.py:801
#, python-brace-format
msgid "°F = ({c} × 9/5) + 32 = {f}°F"
msgstr "°F = ({c} × 9/5) + 32 = {f}°F"

#: Other_Calculators/views/heat_index_calculator.py:804
#, python-brace-format
msgid "Temperature = {result}°{unit}"
msgstr "Temperatura = {result}°{unit}"

#: Other_Calculators/views/heat_index_calculator.py:814
#: Other_Calculators/views/heat_index_calculator.py:864
#: Other_Calculators/views/heat_index_calculator.py:914
msgid "Temperature (°F)"
msgstr "Temperatura (°F)"

#: Other_Calculators/views/heat_index_calculator.py:814
#: Other_Calculators/views/heat_index_calculator.py:864
#: Other_Calculators/views/heat_index_calculator.py:914
msgid "Relative Humidity (%)"
msgstr "Humedad relativa (%)"

#: Other_Calculators/views/heat_index_calculator.py:840
msgid "Heat Index Calculation"
msgstr "Cálculo del índice de calor"

#: Other_Calculators/views/heat_index_calculator.py:940
msgid "Relative Humidity from Heat Index"
msgstr "Humedad relativa del índice de calor"

#: Other_Calculators/views/height_calculator.py:88
msgid "Height value is required."
msgstr "Se requiere valor de altura."

#: Other_Calculators/views/height_calculator.py:109
msgid "Invalid feet/inches values. Feet must be ≥ 0, inches must be 0-11."
msgstr ""
"Valores de pies/pulgadas no válidos. Los pies deben ser ≥ 0, las pulgadas "
"deben ser 0-11."

#: Other_Calculators/views/height_calculator.py:117
#: Other_Calculators/views/height_calculator.py:124
#: Other_Calculators/views/height_calculator.py:131
msgid "Height must be non-negative."
msgstr "La altura no debe ser negativa."

#: Other_Calculators/views/height_calculator.py:137
msgid "Invalid from unit."
msgstr "No válido de la unidad."

#: Other_Calculators/views/height_calculator.py:144
#: Other_Calculators/views/height_calculator.py:427
msgid "Height must be between 50 cm (1.64 ft) and 300 cm (9.84 ft)."
msgstr "La altura debe estar entre 50 cm (1,64 pies) y 300 cm (9,84 pies)."

#: Other_Calculators/views/height_calculator.py:162
msgid "Invalid to unit."
msgstr "No válido para la unidad."

#: Other_Calculators/views/height_calculator.py:203
#, python-brace-format
msgid "Error converting height: {error}"
msgstr "Error al convertir la altura: {error}"

#: Other_Calculators/views/height_calculator.py:212
msgid "Father's height is required."
msgstr "Se requiere la altura del padre."

#: Other_Calculators/views/height_calculator.py:218
msgid "Mother's height is required."
msgstr "Se requiere la altura de la madre."

#: Other_Calculators/views/height_calculator.py:238
msgid "Invalid height unit."
msgstr "Unidad de altura no válida."

#: Other_Calculators/views/height_calculator.py:255
msgid "Parent heights must be between 50 cm (1.64 ft) and 300 cm (9.84 ft)."
msgstr ""
"La altura de los padres debe estar entre 50 cm (1,64 pies) y 300 cm (9,84 "
"pies)."

#: Other_Calculators/views/height_calculator.py:316
#, python-brace-format
msgid "Error predicting height: {error}"
msgstr "Error al predecir la altura: {error}"

#: Other_Calculators/views/height_calculator.py:325
msgid "First height is required."
msgstr "Se requiere la primera altura."

#: Other_Calculators/views/height_calculator.py:331
msgid "Second height is required."
msgstr "Se requiere una segunda altura."

#: Other_Calculators/views/height_calculator.py:353
msgid "Heights must be between 50 cm (1.64 ft) and 300 cm (9.84 ft)."
msgstr "Las alturas deben estar entre 50 cm (1,64 pies) y 300 cm (9,84 pies)."

#: Other_Calculators/views/height_calculator.py:396
#, python-brace-format
msgid "Error comparing heights: {error}"
msgstr "Error al comparar alturas: {error}"

#: Other_Calculators/views/height_calculator.py:433
msgid "Age must be between 0 and 120 years."
msgstr "La edad debe estar entre 0 y 120 años."

#: Other_Calculators/views/height_calculator.py:497
#, python-brace-format
msgid "Error calculating percentile: {error}"
msgstr "Error al calcular el percentil: {error}"

#: Other_Calculators/views/height_calculator.py:538
#, python-brace-format
msgid "Height: {feet} ft {inches} in"
msgstr "Altura: {feet} pies {inches} pulgadas"

#: Other_Calculators/views/height_calculator.py:542
msgid "Step 2: Convert to centimeters (base unit)"
msgstr "Paso 2: Convertir a centímetros (unidad base)"

#: Other_Calculators/views/height_calculator.py:545
#, python-brace-format
msgid "Total inches = {feet} ft × 12 + {inches} in = {total} in"
msgstr ""
"Pulgadas totales = {feet} pies × 12 + {inches} pulgadas = {total} pulgadas"

#: Other_Calculators/views/height_calculator.py:546
#: Other_Calculators/views/height_calculator.py:548
#, python-brace-format
msgid "Centimeters = {inches} in × 2.54 = {cm} cm"
msgstr "Centímetros = {inches} en × 2,54 = {cm} cm"

#: Other_Calculators/views/height_calculator.py:550
#, python-brace-format
msgid "Height in centimeters: {cm} cm"
msgstr "Altura en centímetros: {cm} cm"

#: Other_Calculators/views/height_calculator.py:552
#, python-brace-format
msgid "Centimeters = {m} m × 100 = {cm} cm"
msgstr "Centímetros = {m} m × 100 = {cm} cm"

#: Other_Calculators/views/height_calculator.py:554
#: Other_Calculators/views/mileage_calculator.py:815
#: Other_Calculators/views/molarity_calculator.py:843
msgid "Step 3: Convert to desired unit"
msgstr "Paso 3: convertir a la unidad deseada"

#: Other_Calculators/views/height_calculator.py:559
#, python-brace-format
msgid "Inches = {cm} cm × (1/2.54) = {inches} in"
msgstr "Pulgadas = {cm} cm × (1/2,54) = {inches} pulgadas"

#: Other_Calculators/views/height_calculator.py:560
#, python-brace-format
msgid "Feet = {inches} in / 12 = {feet} ft"
msgstr "Pies = {inches} pulgadas / 12 = {feet} pies"

#: Other_Calculators/views/height_calculator.py:561
#, python-brace-format
msgid "Remaining inches = {inches} in"
msgstr "Pulgadas restantes = {inches} pulgadas"

#: Other_Calculators/views/height_calculator.py:562
#, python-brace-format
msgid "Result: {feet} ft {inches} in"
msgstr "Resultado: {feet} pies {inches} pulgadas"

#: Other_Calculators/views/height_calculator.py:564
#, python-brace-format
msgid "Inches = {cm} cm × (1/2.54) = {result} in"
msgstr "Pulgadas = {cm} cm × (1/2,54) = {result} pulgadas"

#: Other_Calculators/views/height_calculator.py:566
#, python-brace-format
msgid "Result: {result} cm"
msgstr "Resultado: {result} cm"

#: Other_Calculators/views/height_calculator.py:568
#, python-brace-format
msgid "Meters = {cm} cm / 100 = {result} m"
msgstr "Metros = {cm} cm / 100 = {result} m"

#: Other_Calculators/views/height_calculator.py:575
#, python-brace-format
msgid "Father's height: {height} cm"
msgstr "Altura del padre: {height} cm"

#: Other_Calculators/views/height_calculator.py:576
#, python-brace-format
msgid "Mother's height: {height} cm"
msgstr "Altura de la madre: {height} cm"

#: Other_Calculators/views/height_calculator.py:577
#, python-brace-format
msgid "Child's gender: {gender}"
msgstr "Género del niño: {gender}"

#: Other_Calculators/views/height_calculator.py:579
msgid "Step 2: Apply the mid-parental height formula"
msgstr "Paso 2: aplique la fórmula de altura media de los padres"

#: Other_Calculators/views/height_calculator.py:581
msgid "Formula for boys: (Father's height + Mother's height + 13 cm) / 2"
msgstr ""
"Fórmula para niños: (Altura del padre + Altura de la madre + 13 cm) / 2"

#: Other_Calculators/views/height_calculator.py:582
#, python-brace-format
msgid "Predicted height = ({father} + {mother} + 13) / 2"
msgstr "Altura prevista = ({father} + {mother} + 13) / 2"

#: Other_Calculators/views/height_calculator.py:584
msgid "Formula for girls: (Father's height + Mother's height - 13 cm) / 2"
msgstr ""
"Fórmula para niñas: (altura del padre + altura de la madre - 13 cm) / 2"

#: Other_Calculators/views/height_calculator.py:585
#, python-brace-format
msgid "Predicted height = ({father} + {mother} - 13) / 2"
msgstr "Altura prevista = ({father} + {mother} - 13) / 2"

#: Other_Calculators/views/height_calculator.py:586
#, python-brace-format
msgid "Predicted height = {height} cm"
msgstr "Altura prevista = {height} cm"

#: Other_Calculators/views/height_calculator.py:588
msgid "Step 3: Calculate prediction range"
msgstr "Paso 3: Calcular el rango de predicción"

#: Other_Calculators/views/height_calculator.py:589
msgid "Range: ±8.5 cm from predicted height"
msgstr "Rango: ±8,5 cm desde la altura prevista"

#: Other_Calculators/views/height_calculator.py:590
#, python-brace-format
msgid "Low range: {low} cm"
msgstr "Rango bajo: {low} cm"

#: Other_Calculators/views/height_calculator.py:591
#, python-brace-format
msgid "High range: {high} cm"
msgstr "Rango alto: {high} cm"

#: Other_Calculators/views/height_calculator.py:595
#, python-brace-format
msgid "Predicted height: {feet} ft {inches} in"
msgstr "Altura prevista: {feet} pies {inches} pulgadas"

#: Other_Calculators/views/height_calculator.py:596
#, python-brace-format
msgid "Range: {low_ft} ft {low_in} in to {high_ft} ft {high_in} in"
msgstr ""
"Rango: {low_ft} pies {low_in} pulgadas a {high_ft} pies {high_in} pulgadas"

#: Other_Calculators/views/height_calculator.py:601
#, python-brace-format
msgid "Predicted height: {result} {unit}"
msgstr "Altura prevista: {result} {unit}"

#: Other_Calculators/views/height_calculator.py:602
#, python-brace-format
msgid "Range: {low} to {high} {unit}"
msgstr "Rango: {low} a {high} {unit}"

#: Other_Calculators/views/height_calculator.py:608
msgid "Step 1: Identify the given heights"
msgstr "Paso 1: identificar las alturas dadas"

#: Other_Calculators/views/height_calculator.py:609
#, python-brace-format
msgid "Height 1: {height} cm"
msgstr "Altura 1: {height} cm"

#: Other_Calculators/views/height_calculator.py:610
#, python-brace-format
msgid "Height 2: {height} cm"
msgstr "Altura 2: {height} cm"

#: Other_Calculators/views/height_calculator.py:612
#: Other_Calculators/views/time_zone_calculator.py:350
msgid "Step 2: Calculate difference"
msgstr "Paso 2: Calcular la diferencia"

#: Other_Calculators/views/height_calculator.py:613
msgid "Difference = Height 1 - Height 2"
msgstr "Diferencia = Altura 1 - Altura 2"

#: Other_Calculators/views/height_calculator.py:614
#, python-brace-format
msgid "Difference = {h1} - {h2} = {diff} cm"
msgstr "Diferencia = {h1} - {h2} = {diff} cm"

#: Other_Calculators/views/height_calculator.py:616
msgid "Step 3: Calculate percentage difference"
msgstr "Paso 3: Calcular la diferencia porcentual"

#: Other_Calculators/views/height_calculator.py:617
msgid "Percentage = (Difference / Height 2) × 100"
msgstr "Porcentaje = (Diferencia / Altura 2) × 100"

#: Other_Calculators/views/height_calculator.py:618
#, python-brace-format
msgid "Percentage = ({diff} / {h2}) × 100 = {percent}%"
msgstr "Porcentaje = ({diff} / {h2}) × 100 = {percent}%"

#: Other_Calculators/views/height_calculator.py:620
#, python-brace-format
msgid "Height 1 is {diff} cm ({percent}%) taller than Height 2"
msgstr "La altura 1 es {diff} cm ({percent}%) más alta que la altura 2"

#: Other_Calculators/views/height_calculator.py:622
#, python-brace-format
msgid "Height 1 is {diff} cm ({percent}%) shorter than Height 2"
msgstr "La altura 1 es {diff} cm ({percent}%) más corta que la altura 2"

#: Other_Calculators/views/height_calculator.py:624
msgid "Both heights are equal"
msgstr "Ambas alturas son iguales."

#: Other_Calculators/views/height_calculator.py:631
#, python-brace-format
msgid "Height: {height} cm"
msgstr "Altura: {height} cm"

#: Other_Calculators/views/height_calculator.py:632
#, python-brace-format
msgid "Age: {age} years"
msgstr "Edad: {age} años"

#: Other_Calculators/views/height_calculator.py:633
#: Other_Calculators/views/shoe_size_conversion.py:252
#, python-brace-format
msgid "Gender: {gender}"
msgstr "Género: {gender}"

#: Other_Calculators/views/height_calculator.py:635
msgid "Step 2: Determine average height for age and gender"
msgstr "Paso 2: Determinar la altura promedio para edad y sexo"

#: Other_Calculators/views/height_calculator.py:636
#, python-brace-format
msgid "Average height for {gender} at age {age}: {avg} cm"
msgstr "Altura promedio de {gender} a la edad {age}: {avg} cm"

#: Other_Calculators/views/height_calculator.py:636
#: Other_Calculators/views/height_calculator.py:645
msgid "males"
msgstr "machos"

#: Other_Calculators/views/height_calculator.py:636
#: Other_Calculators/views/height_calculator.py:645
msgid "females"
msgstr "hembras"

#: Other_Calculators/views/height_calculator.py:637
#, python-brace-format
msgid "Standard deviation: {std} cm"
msgstr "Desviación estándar: {std} cm"

#: Other_Calculators/views/height_calculator.py:639
msgid "Step 3: Calculate z-score"
msgstr "Paso 3: calcular la puntuación z"

#: Other_Calculators/views/height_calculator.py:640
msgid "Z-score = (Height - Average) / Standard Deviation"
msgstr "Puntuación Z = (Altura - Promedio) / Desviación estándar"

#: Other_Calculators/views/height_calculator.py:641
#, python-brace-format
msgid "Z-score = ({height} - {avg}) / {std} = {z}"
msgstr "Puntuación Z = ({height} - {avg}) / {std} = {z}"

#: Other_Calculators/views/height_calculator.py:643
msgid "Step 4: Determine percentile"
msgstr "Paso 4: determinar el percentil"

#: Other_Calculators/views/height_calculator.py:644
#, python-brace-format
msgid "Percentile: {percent}%"
msgstr "Percentil: {percent}%"

#: Other_Calculators/views/height_calculator.py:645
#, python-format, python-brace-format
msgid ""
"This means the height is greater than {percent}% of {gender} of the same age"
msgstr ""
"Esto significa que la altura es mayor que el {percent}% de {gender} de la "
"misma edad."

#: Other_Calculators/views/height_calculator.py:659
msgid "Height (in)"
msgstr "Altura (pulg.)"

#: Other_Calculators/views/height_calculator.py:662
#: Other_Calculators/views/mulch_calculator.py:1066
msgid "Height (m)"
msgstr "Altura (m)"

#: Other_Calculators/views/height_calculator.py:692
msgid "Height Conversion"
msgstr "Conversión de altura"

#: Other_Calculators/views/height_calculator.py:716
msgid "Father"
msgstr "Padre"

#: Other_Calculators/views/height_calculator.py:716
msgid "Mother"
msgstr "Madre"

#: Other_Calculators/views/height_calculator.py:716
msgid "Predicted"
msgstr "Previsto"

#: Other_Calculators/views/height_calculator.py:716
msgid "Range Low"
msgstr "Rango bajo"

#: Other_Calculators/views/height_calculator.py:716
msgid "Range High"
msgstr "Rango alto"

#: Other_Calculators/views/height_calculator.py:746
msgid "Height Prediction"
msgstr "Predicción de altura"

#: Other_Calculators/views/height_calculator.py:794
msgid "Height Comparison"
msgstr "Comparación de altura"

#: Other_Calculators/views/height_calculator.py:818
msgid "Average Height"
msgstr "Altura media"

#: Other_Calculators/views/height_calculator.py:818
msgid "+1 SD"
msgstr "+1 DE"

#: Other_Calculators/views/height_calculator.py:818
msgid "-1 SD"
msgstr "-1 DE"

#: Other_Calculators/views/horsepower_calculator.py:136
msgid "RPM must be less than 50,000."
msgstr "Las RPM deben ser inferiores a 50.000."

#: Other_Calculators/views/horsepower_calculator.py:224
#: Other_Calculators/views/horsepower_calculator.py:313
msgid "Horsepower must be greater than zero."
msgstr "Los caballos de fuerza deben ser mayores que cero."

#: Other_Calculators/views/horsepower_calculator.py:341
msgid ""
"Calculated RPM exceeds reasonable limits (>50,000). Please check your "
"inputs."
msgstr ""
"Las RPM calculadas exceden los límites razonables (>50 000). Por favor "
"revise sus entradas."

#: Other_Calculators/views/horsepower_calculator.py:450
msgid "Watts is required."
msgstr "Se requieren vatios."

#: Other_Calculators/views/horsepower_calculator.py:464
msgid "Watts must be non-negative."
msgstr "Los vatios no deben ser negativos."

#: Other_Calculators/views/horsepower_calculator.py:501
msgid "Kilowatts is required."
msgstr "Se requieren kilovatios."

#: Other_Calculators/views/horsepower_calculator.py:515
msgid "Kilowatts must be non-negative."
msgstr "Los kilovatios no deben ser negativos."

#: Other_Calculators/views/horsepower_calculator.py:555
#: Other_Calculators/views/horsepower_calculator.py:598
msgid "Step 2: Convert torque to foot-pounds"
msgstr "Paso 2: convertir el torque a libras-pie"

#: Other_Calculators/views/horsepower_calculator.py:556
#: Other_Calculators/views/horsepower_calculator.py:599
msgid "Formula: ft-lb = N⋅m × 0.737562"
msgstr "Fórmula: pies-libra = N⋅m × 0,737562"

#: Other_Calculators/views/horsepower_calculator.py:557
#: Other_Calculators/views/horsepower_calculator.py:600
#, python-brace-format
msgid "Torque = {nm} N⋅m × 0.737562 = {ftlb} ft-lb"
msgstr "Torque = {nm} N⋅m × 0,737562 = {ftlb} ft-lb"

#: Other_Calculators/views/horsepower_calculator.py:561
#, python-brace-format
msgid "HP = ({torque} ft-lb × {rpm}) / 5252"
msgstr "HP = ({torque} pies-libra × {rpm}) / 5252"

#: Other_Calculators/views/horsepower_calculator.py:562
#, python-brace-format
msgid "HP = {hp}"
msgstr "HP = {hp}"

#: Other_Calculators/views/horsepower_calculator.py:565
#, python-brace-format
msgid "Kilowatts = {hp} HP × 0.7457 = {kw} kW"
msgstr "Kilovatios = {hp} HP × 0,7457 = {kw} kW"

#: Other_Calculators/views/horsepower_calculator.py:566
#, python-brace-format
msgid "Watts = {hp} HP × 745.7 = {watts} W"
msgstr "Vatios = {hp} HP × 745,7 = {watts} W"

#: Other_Calculators/views/horsepower_calculator.py:573
#: Other_Calculators/views/horsepower_calculator.py:594
#, python-brace-format
msgid "Horsepower: {hp} HP"
msgstr "Caballos de fuerza: {hp} HP"

#: Other_Calculators/views/horsepower_calculator.py:576
msgid "Step 2: Apply the torque formula"
msgstr "Paso 2: aplique la fórmula de torsión"

#: Other_Calculators/views/horsepower_calculator.py:579
#: Other_Calculators/views/horsepower_calculator.py:587
#, python-brace-format
msgid "Torque = {torque} ft-lb"
msgstr "Torque = {torque} pies-libra"

#: Other_Calculators/views/horsepower_calculator.py:582
msgid "Step 3: Convert to Newton-meters"
msgstr "Paso 3: Convertir a Newton-metros"

#: Other_Calculators/views/horsepower_calculator.py:583
msgid "Formula: N⋅m = ft-lb × 1.35582"
msgstr "Fórmula: N⋅m = pies-libra × 1,35582"

#: Other_Calculators/views/horsepower_calculator.py:584
#, python-brace-format
msgid "Torque = {ftlb} ft-lb × 1.35582 = {nm} N⋅m"
msgstr "Torque = {ftlb} ft-lb × 1,35582 = {nm} N⋅m"

#: Other_Calculators/views/horsepower_calculator.py:604
#, python-brace-format
msgid "RPM = ({hp} HP × 5252) / {torque} ft-lb"
msgstr "RPM = ({hp} HP × 5252) / {torque} ft-lb"

#: Other_Calculators/views/horsepower_calculator.py:616
msgid "Step 2: Convert to horsepower"
msgstr "Paso 2: convertir a caballos de fuerza"

#: Other_Calculators/views/horsepower_calculator.py:618
msgid "HP = kW × 1.341"
msgstr "CV = kilovatios × 1,341"

#: Other_Calculators/views/horsepower_calculator.py:619
#: Other_Calculators/views/horsepower_calculator.py:659
#, python-brace-format
msgid "HP = {kw} kW × 1.341 = {hp} HP"
msgstr "CV = {kw} kW × 1,341 = {hp} CV"

#: Other_Calculators/views/horsepower_calculator.py:621
msgid "HP = W / 745.7"
msgstr "CV = W/745,7"

#: Other_Calculators/views/horsepower_calculator.py:622
#, python-brace-format
msgid "HP = {w} W / 745.7 = {hp} HP"
msgstr "HP = {w} W / 745,7 = {hp} HP"

#: Other_Calculators/views/horsepower_calculator.py:625
#, python-brace-format
msgid "Step 3: Convert from horsepower to {unit}"
msgstr "Paso 3: convertir de caballos de fuerza a {unit}"

#: Other_Calculators/views/horsepower_calculator.py:627
msgid "kW = HP × 0.7457"
msgstr "kW = CV × 0,7457"

#: Other_Calculators/views/horsepower_calculator.py:628
#: Other_Calculators/views/horsepower_calculator.py:648
#, python-brace-format
msgid "kW = {hp} HP × 0.7457 = {kw} kW"
msgstr "kW = {hp} CV × 0,7457 = {kw} kW"

#: Other_Calculators/views/horsepower_calculator.py:630
msgid "W = HP × 745.7"
msgstr "Ancho = CV × 745,7"

#: Other_Calculators/views/horsepower_calculator.py:631
#, python-brace-format
msgid "W = {hp} HP × 745.7 = {w} W"
msgstr "W = {hp} HP × 745,7 = {w} W"

#: Other_Calculators/views/horsepower_calculator.py:641
#, python-brace-format
msgid "Power: {watts} W"
msgstr "Potencia: {watts} W"

#: Other_Calculators/views/horsepower_calculator.py:643
#: Other_Calculators/views/horsepower_calculator.py:657
msgid "Step 2: Apply the conversion formula"
msgstr "Paso 2: aplica la fórmula de conversión"

#: Other_Calculators/views/horsepower_calculator.py:644
msgid "Formula: HP = Watts / 745.7"
msgstr "Fórmula: HP = Vatios / 745,7"

#: Other_Calculators/views/horsepower_calculator.py:645
#, python-brace-format
msgid "HP = {watts} W / 745.7 = {hp} HP"
msgstr "HP = {watts} W / 745,7 = {hp} HP"

#: Other_Calculators/views/horsepower_calculator.py:647
msgid "Step 3: Convert to kilowatts"
msgstr "Paso 3: convertir a kilovatios"

#: Other_Calculators/views/horsepower_calculator.py:655
#, python-brace-format
msgid "Power: {kw} kW"
msgstr "Potencia: {kw}kW"

#: Other_Calculators/views/horsepower_calculator.py:658
msgid "Formula: HP = kW × 1.341"
msgstr "Fórmula: CV = kW × 1,341"

#: Other_Calculators/views/horsepower_calculator.py:661
msgid "Step 3: Convert to watts"
msgstr "Paso 3: convertir a vatios"

#: Other_Calculators/views/horsepower_calculator.py:662
#, python-brace-format
msgid "W = {hp} HP × 745.7 = {watts} W"
msgstr "W = {hp} HP × 745,7 = {watts} W"

#: Other_Calculators/views/horsepower_calculator.py:672
#: Other_Calculators/views/horsepower_calculator.py:722
#: Other_Calculators/views/horsepower_calculator.py:772
msgid "Torque (ft-lb)"
msgstr "Torsión (pie-libra)"

#: Other_Calculators/views/horsepower_calculator.py:698
msgid "Horsepower Calculation"
msgstr "Cálculo de caballos de fuerza"

#: Other_Calculators/views/horsepower_calculator.py:748
msgid "Torque Calculation"
msgstr "Cálculo de par"

#: Other_Calculators/views/horsepower_calculator.py:798
msgid "RPM Calculation"
msgstr "Cálculo de RPM"

#: Other_Calculators/views/hours_calculator.py:142
#: Other_Calculators/views/hours_calculator.py:488
#: Other_Calculators/views/time_calculator.py:320
#: Other_Calculators/views/time_duration_calculator.py:145
#: Other_Calculators/views/time_duration_calculator.py:348
msgid "Start time is required."
msgstr "Se requiere hora de inicio."

#: Other_Calculators/views/hours_calculator.py:148
#: Other_Calculators/views/hours_calculator.py:494
#: Other_Calculators/views/time_calculator.py:326
#: Other_Calculators/views/time_duration_calculator.py:151
msgid "End time is required."
msgstr "Se requiere hora de finalización."

#: Other_Calculators/views/hours_calculator.py:182
msgid "End time must be after start time."
msgstr "La hora de finalización debe ser posterior a la hora de inicio."

#: Other_Calculators/views/hours_calculator.py:188
msgid "Time difference exceeds 48 hours. Please check your inputs."
msgstr ""
"La diferencia horaria supera las 48 horas. Por favor revise sus entradas."

#: Other_Calculators/views/hours_calculator.py:221
#: Other_Calculators/views/time_calculator.py:174
#, python-brace-format
msgid "Error calculating time difference: {error}"
msgstr "Error al calcular la diferencia horaria: {error}"

#: Other_Calculators/views/hours_calculator.py:230
#: Other_Calculators/views/speed_calculator.py:125
#: Other_Calculators/views/speed_calculator.py:206
#: Other_Calculators/views/time_calculator.py:183
#: Other_Calculators/views/time_calculator.py:269
#: Other_Calculators/views/time_duration_calculator.py:211
#: Other_Calculators/views/time_zone_calculator.py:136
msgid "Time is required."
msgstr "Se requiere tiempo."

#: Other_Calculators/views/hours_calculator.py:236
msgid "Hours to add/subtract is required."
msgstr "Se requieren horas para sumar/restar."

#: Other_Calculators/views/hours_calculator.py:247
msgid "Invalid hours value. Please enter a numeric value."
msgstr "Valor de horas no válido. Por favor ingrese un valor numérico."

#: Other_Calculators/views/hours_calculator.py:296
#, python-brace-format
msgid "Error adding/subtracting hours: {error}"
msgstr "Error al sumar/restar horas: {error}"

#: Other_Calculators/views/hours_calculator.py:305
msgid "Time value is required."
msgstr "Se requiere valor de tiempo."

#: Other_Calculators/views/hours_calculator.py:329
#: Other_Calculators/views/time_calculator.py:287
msgid "Time must be non-negative."
msgstr "El tiempo no debe ser negativo."

#: Other_Calculators/views/hours_calculator.py:383
msgid "Time periods are required as a list."
msgstr "Los períodos de tiempo se requieren como una lista."

#: Other_Calculators/views/hours_calculator.py:391
msgid "At least one time period is required."
msgstr "Se requiere al menos un período de tiempo."

#: Other_Calculators/views/hours_calculator.py:397
msgid "Maximum 50 time periods allowed."
msgstr "Máximo 50 períodos de tiempo permitidos."

#: Other_Calculators/views/hours_calculator.py:407
msgid "Invalid time period data format."
msgstr "Formato de datos de período de tiempo no válido."

#: Other_Calculators/views/hours_calculator.py:423
#, python-brace-format
msgid "Invalid time format in period {num}: {error}"
msgstr "Formato de hora no válido en el período {num}: {error}"

#: Other_Calculators/views/hours_calculator.py:440
#, python-brace-format
msgid "Invalid time period {num}: end time must be after start time."
msgstr ""
"Período de tiempo no válido {num}: la hora de finalización debe ser "
"posterior a la hora de inicio."

#: Other_Calculators/views/hours_calculator.py:479
#, python-brace-format
msgid "Error calculating total hours: {error}"
msgstr "Error al calcular el total de horas: {error}"

#: Other_Calculators/views/hours_calculator.py:514
msgid "Break time must be non-negative."
msgstr "El tiempo de descanso no debe ser negativo."

#: Other_Calculators/views/hours_calculator.py:537
#: Other_Calculators/views/time_card_calculator.py:150
msgid "Break time cannot exceed total time."
msgstr "El tiempo de descanso no puede exceder el tiempo total."

#: Other_Calculators/views/hours_calculator.py:569
#, python-brace-format
msgid "Error calculating hours worked: {error}"
msgstr "Error al calcular las horas trabajadas: {error}"

#: Other_Calculators/views/hours_calculator.py:576
#: Other_Calculators/views/time_calculator.py:383
#: Other_Calculators/views/time_calculator.py:450
#: Other_Calculators/views/time_duration_calculator.py:424
msgid "Step 1: Identify the given times"
msgstr "Paso 1: Identificar los tiempos dados"

#: Other_Calculators/views/hours_calculator.py:577
#: Other_Calculators/views/hours_calculator.py:680
#: Other_Calculators/views/time_duration_calculator.py:425
#: Other_Calculators/views/time_duration_calculator.py:497
#, python-brace-format
msgid "Start Time: {time}"
msgstr "Hora de inicio: {time}"

#: Other_Calculators/views/hours_calculator.py:578
#: Other_Calculators/views/hours_calculator.py:681
#: Other_Calculators/views/time_duration_calculator.py:426
#, python-brace-format
msgid "End Time: {time}"
msgstr "Hora de finalización: {time}"

#: Other_Calculators/views/hours_calculator.py:580
#: Other_Calculators/views/hours_calculator.py:683
msgid "Note: End time is on the next day"
msgstr "Nota: La hora de finalización es el día siguiente."

#: Other_Calculators/views/hours_calculator.py:582
msgid "Step 2: Convert to decimal hours"
msgstr "Paso 2: convertir a horas decimales"

#: Other_Calculators/views/hours_calculator.py:583
#, python-brace-format
msgid "Start Time: {hours} hours"
msgstr "Hora de inicio: {hours} horas"

#: Other_Calculators/views/hours_calculator.py:584
#, python-brace-format
msgid "End Time: {hours} hours"
msgstr "Hora de finalización: {hours} horas"

#: Other_Calculators/views/hours_calculator.py:586
#: Other_Calculators/views/time_calculator.py:391
msgid "Step 3: Calculate difference"
msgstr "Paso 3: Calcular la diferencia"

#: Other_Calculators/views/hours_calculator.py:587
msgid "Difference = End Time - Start Time"
msgstr "Diferencia = Hora de finalización - Hora de inicio"

#: Other_Calculators/views/hours_calculator.py:588
#, python-brace-format
msgid "Difference = {end} - {start} = {diff} hours"
msgstr "Diferencia = {end} - {start} = {diff} horas"

#: Other_Calculators/views/hours_calculator.py:591
#: Other_Calculators/views/hours_calculator.py:670
#, python-brace-format
msgid "Time Format: {h:02d}:{m:02d}:{s:02d}"
msgstr "Formato de hora: {h:02d}:{m:02d}:{s:02d}"

#: Other_Calculators/views/hours_calculator.py:592
#: Other_Calculators/views/hours_calculator.py:671
#, python-brace-format
msgid "Minutes: {min} minutes"
msgstr "Minutos: {min} minutos"

#: Other_Calculators/views/hours_calculator.py:593
#: Other_Calculators/views/hours_calculator.py:672
#, python-brace-format
msgid "Seconds: {sec} seconds"
msgstr "Segundos: {sec} segundos"

#: Other_Calculators/views/hours_calculator.py:594
#: Other_Calculators/views/hours_calculator.py:673
#, python-brace-format
msgid "Days: {days} days"
msgstr "Días: {days} días"

#: Other_Calculators/views/hours_calculator.py:601
#: Other_Calculators/views/time_calculator.py:409
#: Other_Calculators/views/time_duration_calculator.py:455
#: Other_Calculators/views/time_zone_calculator.py:322
#, python-brace-format
msgid "Time: {time}"
msgstr "Hora: {time}"

#: Other_Calculators/views/hours_calculator.py:602
#, python-brace-format
msgid "Hours to {op}: {hours}"
msgstr "Horas hasta {op}: {hours}"

#: Other_Calculators/views/hours_calculator.py:604
msgid "Step 2: Convert time to decimal hours"
msgstr "Paso 2: convertir el tiempo a horas decimales"

#: Other_Calculators/views/hours_calculator.py:605
#, python-brace-format
msgid "Time = {hours} hours"
msgstr "Tiempo = {hours} horas"

#: Other_Calculators/views/hours_calculator.py:607
#, python-brace-format
msgid "Step 3: {op} hours"
msgstr "Paso 3: {op} horas"

#: Other_Calculators/views/hours_calculator.py:609
#, python-brace-format
msgid "Result = {time} + {hours} = {result} hours"
msgstr "Resultado = {time} + {hours} = {result} horas"

#: Other_Calculators/views/hours_calculator.py:611
#, python-brace-format
msgid "Result = {time} - {hours} = {result} hours"
msgstr "Resultado = {time} - {hours} = {result} horas"

#: Other_Calculators/views/hours_calculator.py:613
msgid "Step 4: Convert to time format"
msgstr "Paso 4: convertir al formato de hora"

