msgstr "Tipo de entrada no válido. Por favor ingrese un número entero válido."

#: Other_Calculators/views/roman_numeral_converter.py:115
msgid "Decimal number must be at least 1."
msgstr "El número decimal debe ser al menos 1."

#: Other_Calculators/views/roman_numeral_converter.py:121
msgid "Decimal number cannot exceed 3999 (standard Roman numeral limit)."
msgstr ""
"El número decimal no puede exceder 3999 (límite estándar de números "
"romanos)."

#: Other_Calculators/views/roman_numeral_converter.py:146
#, python-brace-format
msgid "Error converting to Roman numeral: {error}"
msgstr "Error al convertir a número romano: {error}"

#: Other_Calculators/views/roman_numeral_converter.py:155
msgid "Roman numeral is required."
msgstr "Se requiere número romano."

#: Other_Calculators/views/roman_numeral_converter.py:163
msgid "Roman numeral cannot be empty."
msgstr "El número romano no puede estar vacío."

#: Other_Calculators/views/roman_numeral_converter.py:170
msgid "Invalid Roman numeral format."
msgstr "Formato de números romanos no válido."

#: Other_Calculators/views/roman_numeral_converter.py:180
msgid "Invalid Roman numeral."
msgstr "Número romano no válido."

#: Other_Calculators/views/roman_numeral_converter.py:197
#, python-brace-format
msgid "Error converting to decimal: {error}"
msgstr "Error al convertir a decimal: {error}"

#: Other_Calculators/views/roman_numeral_converter.py:203
msgid "Step 1: Start with the decimal number"
msgstr "Paso 1: comienza con el número decimal"

#: Other_Calculators/views/roman_numeral_converter.py:204
#, python-brace-format
msgid "Decimal: {decimal}"
msgstr "decimal: {decimal}"

#: Other_Calculators/views/roman_numeral_converter.py:206
msgid "Step 2: Break down into Roman numeral components"
msgstr "Paso 2: dividir en componentes de números romanos"

#: Other_Calculators/views/roman_numeral_converter.py:218
#, python-brace-format
msgid "{count} × {value} = {symbol} × {count} = {symbols}"
msgstr "{count} × {value} = {symbol} × {count} = {symbols}"

#: Other_Calculators/views/roman_numeral_converter.py:226
msgid "Step 3: Combine all components"
msgstr "Paso 3: combine todos los componentes"

#: Other_Calculators/views/roman_numeral_converter.py:227
#, python-brace-format
msgid "Roman Numeral: {roman}"
msgstr "Número romano: {roman}"

#: Other_Calculators/views/roman_numeral_converter.py:234
msgid "Step 1: Start with the Roman numeral"
msgstr "Paso 1: comienza con el número romano"

#: Other_Calculators/views/roman_numeral_converter.py:235
#, python-brace-format
msgid "Roman: {roman}"
msgstr "romano: {roman}"

#: Other_Calculators/views/roman_numeral_converter.py:237
msgid "Step 2: Process each symbol from left to right"
msgstr "Paso 2: procesa cada símbolo de izquierda a derecha"

#: Other_Calculators/views/roman_numeral_converter.py:252
#, python-brace-format
msgid "{symbol} = {value} (subtractive notation)"
msgstr "{symbol} = {value} (notación sustractiva)"

#: Other_Calculators/views/roman_numeral_converter.py:262
#, python-brace-format
msgid "{symbol} = {value}"
msgstr "{symbol} = {value}"

#: Other_Calculators/views/roman_numeral_converter.py:268
msgid "Step 3: Sum all values"
msgstr "Paso 3: Sumar todos los valores"

#: Other_Calculators/views/roman_numeral_converter.py:270
#, python-brace-format
msgid "Decimal = {sum}"
msgstr "Decimal = {sum}"

#: Other_Calculators/views/roman_numeral_converter.py:271
#, python-brace-format
msgid "Decimal = {decimal}"
msgstr "decimal = {decimal}"

#: Other_Calculators/views/roman_numeral_converter.py:356
msgid "Decimal to Roman Numeral Conversion"
msgstr "Conversión de números decimales a romanos"

#: Other_Calculators/views/roman_numeral_converter.py:427
msgid "Roman Numeral to Decimal Conversion"
msgstr "Conversión de números romanos a decimales"

