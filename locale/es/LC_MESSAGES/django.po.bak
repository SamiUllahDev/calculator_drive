msgstr "Se requiere precio por mosaico."

#: Other_Calculators/views/tile_calculator.py:397
#: Other_Calculators/views/tile_calculator.py:459
#, python-brace-format
msgid "Area: {area} {unit}"
msgstr "Área: {area} {unit}"

#: Other_Calculators/views/tile_calculator.py:398
#: Other_Calculators/views/tile_calculator.py:431
#, python-brace-format
msgid "Tile Length: {length} {unit}"
msgstr "Longitud del mosaico: {length} {unit}"

#: Other_Calculators/views/tile_calculator.py:399
#: Other_Calculators/views/tile_calculator.py:432
#, python-brace-format
msgid "Tile Width: {width} {unit}"
msgstr "Ancho del mosaico: {width} {unit}"

#: Other_Calculators/views/tile_calculator.py:403
#, python-brace-format
msgid "Area: {area} ft² = {area_in} in²"
msgstr "Área: {area} pies² = {area_in} pulgadas²"

#: Other_Calculators/views/tile_calculator.py:404
#: Other_Calculators/views/tile_calculator.py:435
#, python-brace-format
msgid "Tile Length: {length} in"
msgstr "Longitud del mosaico: {length} pulgadas"

#: Other_Calculators/views/tile_calculator.py:405
#: Other_Calculators/views/tile_calculator.py:436
#, python-brace-format
msgid "Tile Width: {width} in"
msgstr "Ancho del mosaico: {width} pulgadas"

#: Other_Calculators/views/tile_calculator.py:407
#: Other_Calculators/views/tile_calculator.py:438
msgid "Step 3: Calculate tile area"
msgstr "Paso 3: calcular el área del mosaico"

#: Other_Calculators/views/tile_calculator.py:408
#: Other_Calculators/views/tile_calculator.py:439
msgid "Tile Area = Length × Width"
msgstr "Área del mosaico = largo × ancho"

#: Other_Calculators/views/tile_calculator.py:409
#: Other_Calculators/views/tile_calculator.py:440
#, python-brace-format
msgid "Tile Area = {length} × {width} = {area} in²"
msgstr "Área del mosaico = {length} × {width} = {area} pulgadas²"

#: Other_Calculators/views/tile_calculator.py:411
msgid "Step 4: Calculate tiles needed"
msgstr "Paso 4: Calcular los mosaicos necesarios"

#: Other_Calculators/views/tile_calculator.py:412
msgid "Tiles Needed = Area / Tile Area"
msgstr "Mosaicos necesarios = Área / Área de mosaicos"

#: Other_Calculators/views/tile_calculator.py:413
#, python-brace-format
msgid "Tiles Needed = {area} / {tile_area} = {tiles} tiles"
msgstr "Mosaicos necesarios = {area} / {tile_area} = {tiles} mosaicos"

#: Other_Calculators/views/tile_calculator.py:415
msgid "Step 5: Add waste factor"
msgstr "Paso 5: agregar factor de desperdicio"

#: Other_Calculators/views/tile_calculator.py:416
msgid "Tiles with Waste = Tiles Needed × (1 + Waste Factor / 100)"
msgstr ""
"Baldosas con desperdicio = Baldosas necesarias × (1 + Factor de desperdicio "
"/ 100)"

#: Other_Calculators/views/tile_calculator.py:417
#, python-brace-format
msgid "Tiles with Waste = {tiles} × (1 + {waste} / 100) = {tiles_waste} tiles"
msgstr ""
"Mosaicos con Residuos = {tiles} × (1 + {waste} / 100) = {tiles_waste} "
"mosaicos"

#: Other_Calculators/views/tile_calculator.py:419
msgid "Step 6: Round up to whole tiles"
msgstr "Paso 6: redondear hasta mosaicos enteros"

#: Other_Calculators/views/tile_calculator.py:420
#, python-brace-format
msgid "Tiles to Buy = {tiles} tiles"
msgstr "Mosaicos para comprar = {tiles} mosaicos"

#: Other_Calculators/views/tile_calculator.py:422
msgid "Step 7: Calculate grout needed"
msgstr "Paso 7: Calcule la lechada necesaria"

#: Other_Calculators/views/tile_calculator.py:423
#, python-brace-format
msgid "Grout Needed ≈ {grout} lbs (approximately 1 lb per 10 ft²)"
msgstr ""
"Lechada necesaria ≈ {grout} libras (aproximadamente 1 libra por 10 pies²)"

#: Other_Calculators/views/tile_calculator.py:430
#, python-brace-format
msgid "Number of Tiles: {num}"
msgstr "Número de mosaicos: {num}"

#: Other_Calculators/views/tile_calculator.py:434
msgid "Step 2: Convert to base units (inches)"
msgstr "Paso 2: convertir a unidades base (pulgadas)"

#: Other_Calculators/views/tile_calculator.py:442
msgid "Step 4: Calculate total coverage"
msgstr "Paso 4: Calcular la cobertura total"

#: Other_Calculators/views/tile_calculator.py:443
msgid "Total Coverage = Tile Area × Number of Tiles"
msgstr "Cobertura total = Área de mosaicos × Número de mosaicos"

#: Other_Calculators/views/tile_calculator.py:444
#, python-brace-format
msgid "Total Coverage = {area} × {num} = {total} in²"
msgstr "Cobertura total = {area} × {num} = {total} pulgadas²"

#: Other_Calculators/views/tile_calculator.py:445
#, python-brace-format
msgid "Total Coverage = {area} ft²"
msgstr "Cobertura total = {area} pies²"

#: Other_Calculators/views/tile_calculator.py:449
#, python-brace-format
msgid "Coverage = {result} {unit}"
msgstr "Cobertura = {result} {unit}"

#: Other_Calculators/views/tile_calculator.py:452
#, python-brace-format
msgid "Coverage = {result} ft²"
msgstr "Cobertura = {result} pies²"

#: Other_Calculators/views/tile_calculator.py:460
#, python-brace-format
msgid "Tile Size: {length} × {width} {unit}"
msgstr "Tamaño del mosaico: {length} × {width} {unit}"

#: Other_Calculators/views/tile_calculator.py:461
#, python-brace-format
msgid "Price per Tile: {price} {currency}"
msgstr "Precio por mosaico: {price} {currency}"

#: Other_Calculators/views/tile_calculator.py:464
msgid "Step 2: Calculate tiles needed (with waste)"
msgstr "Paso 2: Calcular las losetas necesarias (con desperdicio)"

#: Other_Calculators/views/tile_calculator.py:465
#, python-brace-format
msgid "Tiles to Buy: {tiles} tiles"
msgstr "Azulejos para comprar: {tiles} mosaicos"

#: Other_Calculators/views/tile_calculator.py:467
msgid "Step 3: Calculate tile cost"
msgstr "Paso 3: Calcular el costo de las baldosas"

#: Other_Calculators/views/tile_calculator.py:468
msgid "Tile Cost = Tiles × Price per Tile"
msgstr "Costo de mosaico = mosaicos × precio por mosaico"

#: Other_Calculators/views/tile_calculator.py:469
#, python-brace-format
msgid "Tile Cost = {tiles} × {price} = {cost} {currency}"
msgstr "Costo de mosaico = {tiles} × {price} = {cost} {currency}"

#: Other_Calculators/views/tile_calculator.py:471
msgid "Step 4: Calculate grout cost"
msgstr "Paso 4: Calcule el costo de la lechada"

#: Other_Calculators/views/tile_calculator.py:472
#, python-brace-format
msgid "Grout Needed ≈ {grout} lbs"
msgstr "Lechada necesaria ≈ {grout} lbs"

#: Other_Calculators/views/tile_calculator.py:473
#, python-brace-format
msgid "Grout Cost = {grout} × {price} = {cost} {currency}"
msgstr "Costo de la lechada = {grout} × {price} = {cost} {currency}"

#: Other_Calculators/views/tile_calculator.py:475
msgid "Step 5: Calculate total cost"
msgstr "Paso 5: Calcular el costo total"

#: Other_Calculators/views/tile_calculator.py:476
msgid "Total Cost = Tile Cost + Grout Cost + Labor Cost"
msgstr ""
"Costo total = Costo de losetas + Costo de lechada + Costo de mano de obra"

#: Other_Calculators/views/tile_calculator.py:477
#, python-brace-format
msgid "Total Cost = {tile} + {grout} + {labor} = {total} {currency}"
msgstr "Total Cost = {tile} + {grout} + {labor} = {total} {currency}"

