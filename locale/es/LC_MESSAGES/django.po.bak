"File extension “%(extension)s” is not allowed. Allowed extensions are: "
"%(allowed_extensions)s."
msgstr ""
"La extensión de archivo “%(extensión)s” no está permitida. Las extensiones "
"permitidas son: %(allowed_extensions)s."

#: venv/lib/python3.12/site-packages/django/core/validators.py:659
msgid "Null characters are not allowed."
msgstr "No se permiten caracteres nulos."

#: venv/lib/python3.12/site-packages/django/db/models/base.py:1633
#, python-format
msgid "%(model_name)s with this %(field_labels)s already exists."
msgstr "%(model_name)s con este %(field_labels)s ya existe."

#: venv/lib/python3.12/site-packages/django/db/models/constraints.py:20
#, python-format
msgid "Constraint “%(name)s” is violated."
msgstr "Se infringe la restricción “%(nombre)s”."

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:134
#, python-format
msgid "Value %(value)r is not a valid choice."
msgstr "El valor %(valor)r no es una opción válida."

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:135
msgid "This field cannot be null."
msgstr "Este campo no puede ser nulo."

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:136
msgid "This field cannot be blank."
msgstr "Este campo no puede estar en blanco."

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:137
#, python-format
msgid "%(model_name)s with this %(field_label)s already exists."
msgstr "%(model_name)s con este %(field_label)s ya existe."

#. Translators: The 'lookup_type' is one of 'date', 'year' or
#. 'month'. Eg: "Title must be unique for pub_date year"
#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:141
#, python-format
msgid ""
"%(field_label)s must be unique for %(date_field_label)s %(lookup_type)s."
msgstr ""
"%(field_label)s debe ser único para %(date_field_label)s %(lookup_type)s."

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:180
#, python-format
msgid "Field of type: %(field_type)s"
msgstr "Campo de tipo: %(field_type)s"

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:1161
#, python-format
msgid "“%(value)s” value must be either True or False."
msgstr "El valor de “%(valor)s” debe ser Verdadero o Falso."

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:1162
#, python-format
msgid "“%(value)s” value must be either True, False, or None."
msgstr "El valor de “%(valor)s” debe ser Verdadero, Falso o Ninguno."

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:1164
msgid "Boolean (Either True or False)"
msgstr "Booleano (verdadero o falso)"

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:1214
#, python-format
msgid "String (up to %(max_length)s)"
msgstr "Cadena (hasta %(max_length)s)"

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:1216
msgid "String (unlimited)"
msgstr "Cadena (ilimitada)"

#: venv/lib/python3.12/site-packages/django/db/models/fields/__init__.py:1325
msgid "Comma-separated integers"
msgstr "Enteros separados por comas"

