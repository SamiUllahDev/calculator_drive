#: Other_Calculators/views/bandwidth_calculator.py:335
#: Other_Calculators/views/bandwidth_calculator.py:376
#: Other_Calculators/views/bandwidth_calculator.py:417
msgid "Step 1: Identify the Given Values"
msgstr "Paso 1: identificar los valores dados"

#: Other_Calculators/views/bandwidth_calculator.py:336
#: Other_Calculators/views/bandwidth_calculator.py:377
#, python-brace-format
msgid "  File Size: {size} {unit}"
msgstr "Tamaño del archivo: {size} {unit}"

#: Other_Calculators/views/bandwidth_calculator.py:337
#: Other_Calculators/views/bandwidth_calculator.py:418
#, python-brace-format
msgid "  Bandwidth: {bandwidth} {unit}"
msgstr "  Bandwidth: {bandwidth} {unit}"

#: Other_Calculators/views/bandwidth_calculator.py:340
msgid "Step 2: Convert to Common Units (Bits)"
msgstr "Paso 2: convertir a unidades comunes (bits)"

#: Other_Calculators/views/bandwidth_calculator.py:341
#: Other_Calculators/views/bandwidth_calculator.py:382
msgid "  File Size in Bits = {size} {unit} × {factor} = {bits:,} bits"
msgstr "Tamaño del archivo en bits = {size} {unit} × {factor} = {bits:,} bits"

#: Other_Calculators/views/bandwidth_calculator.py:346
#: Other_Calculators/views/bandwidth_calculator.py:423
msgid "  Bandwidth in bps = {bandwidth} {unit} × {factor} = {bps:,} bps"
msgstr "  Bandwidth in bps = {bandwidth} {unit} × {factor} = {bps:,} bps"

#: Other_Calculators/views/bandwidth_calculator.py:353
msgid "Step 3: Calculate Transfer Time"
msgstr "Paso 3: Calcular el tiempo de transferencia"

#: Other_Calculators/views/bandwidth_calculator.py:354
msgid "  Time = File Size ÷ Bandwidth"
msgstr "Tiempo = Tamaño de archivo ÷ Ancho de banda"

#: Other_Calculators/views/bandwidth_calculator.py:355
msgid "  Time = {bits:,} bits ÷ {bps:,} bps = {seconds:.2f} seconds"
msgstr "Tiempo = {bits:,} bits ÷ {bps:,} bps = {segundos:.2f} segundos"

#: Other_Calculators/views/bandwidth_calculator.py:360
msgid "Step 4: Convert to Various Time Units"
msgstr "Paso 4: convertir a varias unidades de tiempo"

#: Other_Calculators/views/bandwidth_calculator.py:361
#, python-brace-format
msgid "  Seconds: {seconds:.2f}"
msgstr "Segundos: {segundos:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:362
#, python-brace-format
msgid "  Minutes: {minutes:.2f}"
msgstr "Minutos: {minutos:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:363
#, python-brace-format
msgid "  Hours: {hours:.2f}"
msgstr "Horas: {horas:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:364
#, python-brace-format
msgid "  Days: {days:.2f}"
msgstr "Días: {días:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:368
#, python-brace-format
msgid "  Transfer Time: {formatted}"
msgstr "Tiempo de transferencia: {formatted}"

#: Other_Calculators/views/bandwidth_calculator.py:378
#: Other_Calculators/views/bandwidth_calculator.py:419
#, python-brace-format
msgid "  Time: {time} {unit}"
msgstr "Hora: {time} {unit}"

#: Other_Calculators/views/bandwidth_calculator.py:381
#: Other_Calculators/views/bandwidth_calculator.py:422
msgid "Step 2: Convert to Common Units"
msgstr "Paso 2: convertir a unidades comunes"

#: Other_Calculators/views/bandwidth_calculator.py:387
#: Other_Calculators/views/bandwidth_calculator.py:428
#, python-brace-format
msgid "  Time in Seconds = {time} {unit} × {factor} = {seconds:.2f} seconds"
msgstr ""
"Tiempo en segundos = {time} {unit} × {factor} = {segundos:.2f} segundos"

#: Other_Calculators/views/bandwidth_calculator.py:394
msgid "Step 3: Calculate Required Bandwidth"
msgstr "Paso 3: Calcule el ancho de banda requerido"

#: Other_Calculators/views/bandwidth_calculator.py:395
msgid "  Bandwidth = File Size ÷ Time"
msgstr "Ancho de banda = Tamaño de archivo ÷ Tiempo"

#: Other_Calculators/views/bandwidth_calculator.py:396
msgid "  Bandwidth = {bits:,} bits ÷ {seconds:.2f} seconds = {bps:.2f} bps"
msgstr ""
"Ancho de banda = {bits:,} bits ÷ {segundos:.2f} segundos = {bps:.2f} bps"

#: Other_Calculators/views/bandwidth_calculator.py:401
msgid "Step 4: Convert to Various Bandwidth Units"
msgstr "Paso 4: Convierta a varias unidades de ancho de banda"

#: Other_Calculators/views/bandwidth_calculator.py:402
#, python-brace-format
msgid "  bps: {bps:.2f}"
msgstr "bps: {bps:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:403
#, python-brace-format
msgid "  Kbps: {kbps:.2f}"
msgstr "Kbps: {kbps:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:404
#, python-brace-format
msgid "  Mbps: {mbps:.2f}"
msgstr "Mbps: {mbps:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:405
#, python-brace-format
msgid "  Gbps: {gbps:.2f}"
msgstr "Gbps: {gbps:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:409
#, python-brace-format
msgid "  Required Bandwidth: {formatted}"
msgstr "Ancho de banda requerido: {formatted}"

#: Other_Calculators/views/bandwidth_calculator.py:435
msgid "Step 3: Calculate File Size"
msgstr "Paso 3: Calcular el tamaño del archivo"

#: Other_Calculators/views/bandwidth_calculator.py:436
msgid "  File Size = Bandwidth × Time"
msgstr "Tamaño del archivo = Ancho de banda × Tiempo"

#: Other_Calculators/views/bandwidth_calculator.py:437
msgid "  File Size = {bps:,} bps × {seconds:.2f} seconds = {bits:,} bits"
msgstr ""
"Tamaño del archivo = {bps:,} bps × {segundos:.2f} segundos = {bits:,} bits"

#: Other_Calculators/views/bandwidth_calculator.py:442
msgid "Step 4: Convert to Various File Size Units"
msgstr "Paso 4: Convertir a varias unidades de tamaño de archivo"

#: Other_Calculators/views/bandwidth_calculator.py:443
#, python-brace-format
msgid "  Bits: {bits:.2f}"
msgstr "Bits: {bits:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:444
#, python-brace-format
msgid "  Bytes: {bytes:.2f}"
msgstr "Bytes: {bytes:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:445
#, python-brace-format
msgid "  KB: {kb:.2f}"
msgstr "KB: {acerca de:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:446
#, python-brace-format
msgid "  MB: {mb:.2f}"
msgstr "MB: {mb:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:447
#, python-brace-format
msgid "  GB: {gb:.2f}"
msgstr "GB: {gb:.2f}"

#: Other_Calculators/views/bandwidth_calculator.py:451
#, python-brace-format
msgid "  File Size: {formatted}"
msgstr "Tamaño del archivo: {formatted}"

#: Other_Calculators/views/bandwidth_calculator.py:553
msgid "Please provide at least one file."
msgstr "Proporcione al menos un archivo."

#: Other_Calculators/views/bandwidth_calculator.py:556
msgid "Bandwidth must be greater than zero."
msgstr "El ancho de banda debe ser mayor que cero."

#: Other_Calculators/views/bandwidth_calculator.py:566
#: venv/lib/python3.12/site-packages/django/db/models/fields/files.py:244
msgid "File"
msgstr "Archivo"

#: Other_Calculators/views/bandwidth_calculator.py:606
#: Other_Calculators/views/bandwidth_calculator.py:651
msgid "File size must be greater than zero."
msgstr "El tamaño del archivo debe ser mayor que cero."

#: Other_Calculators/views/bra_size_calculator.py:79
msgid ""
"Multiple sizing systems (US, UK, EU, FR, AU, PK, CA, IN, NZ, IT, ES, DE, JP,"
" CN, BR, MX, ZA)"
msgstr ""
"Múltiples sistemas de dimensionamiento (EE. UU., Reino Unido, UE, FR, AU, "
"PK, CA, IN, NZ, IT, ES, DE, JP, CN, BR, MX, ZA)"

#: Other_Calculators/views/bra_size_calculator.py:119
msgid "Measurements must be greater than zero."
msgstr "Las medidas deben ser mayores que cero."

#: Other_Calculators/views/bra_size_calculator.py:122
msgid "Bust measurement must be greater than underbust measurement."
msgstr "La medida del busto debe ser mayor que la medida debajo del busto."

#: Other_Calculators/views/bra_size_calculator.py:134
msgid "Underbust measurement must be between 20 and 60 inches (51-152 cm)."
msgstr ""
"La medida debajo del busto debe estar entre 20 y 60 pulgadas (51-152 cm)."

#: Other_Calculators/views/bra_size_calculator.py:137
msgid "Bust measurement must be between 25 and 70 inches (64-178 cm)."
msgstr "La medida del busto debe estar entre 25 y 70 pulgadas (64-178 cm)."

#: Other_Calculators/views/bra_size_calculator.py:144
#, python-brace-format
msgid ""
"Calculated band size ({band}) is outside valid range (28-50). Please check "
"your measurements."
msgstr ""
"El tamaño de banda calculado ({band}) está fuera del rango válido (28-50). "
"Por favor revisa tus medidas."

#: Other_Calculators/views/bra_size_calculator.py:206
msgid "Invalid size format. Please use format like \"34C\" or \"34 C\"."
msgstr "Formato de tamaño no válido. Utilice un formato como \"34C\" o \"34 C\"."

#: Other_Calculators/views/bra_size_calculator.py:214
#: Other_Calculators/views/bra_size_calculator.py:290
msgid "FR band size must be between 75 and 115."
msgstr "El tamaño de la banda FR debe estar entre 75 y 115."

#: Other_Calculators/views/bra_size_calculator.py:217
#: Other_Calculators/views/bra_size_calculator.py:293
msgid "Band size must be between 28 and 50."
msgstr "El tamaño de la banda debe estar entre 28 y 50."

#: Other_Calculators/views/bra_size_calculator.py:224
msgid "Invalid cup size for the selected system."
msgstr "Tamaño de copa no válido para el sistema seleccionado."

#: Other_Calculators/views/bra_size_calculator.py:229
msgid "Cup size not available in target system."
msgstr "Tamaño de copa no disponible en el sistema objetivo."

#: Other_Calculators/views/bra_size_calculator.py:240
msgid "Converted band size is outside valid range."
msgstr "El tamaño de banda convertido está fuera del rango válido."

#: Other_Calculators/views/bra_size_calculator.py:245
msgid "Converted band size is outside valid FR range."
msgstr "El tamaño de banda convertido está fuera del rango FR válido."

#: Other_Calculators/views/bra_size_calculator.py:276
msgid "Invalid size format."
msgstr "Formato de tamaño no válido."

#: Other_Calculators/views/bra_size_calculator.py:285
msgid "Invalid cup size."
msgstr "Talla de copa no válida."

#: Other_Calculators/views/bra_size_calculator.py:390
msgid "Step 1: Take Measurements"
msgstr "Paso 1: tomar medidas"

#: Other_Calculators/views/bra_size_calculator.py:391
#, python-brace-format
msgid "  Underbust: {measurement} {unit}"
msgstr "Bajo pecho: {measurement} {unit}"

#: Other_Calculators/views/bra_size_calculator.py:392
#, python-brace-format
msgid "  Bust (at fullest point): {measurement} {unit}"
msgstr "Busto (en su punto máximo): {measurement} {unit}"

#: Other_Calculators/views/bra_size_calculator.py:396
msgid "Step 2: Convert to Inches (if needed)"
msgstr "Paso 2: convertir a pulgadas (si es necesario)"

#: Other_Calculators/views/bra_size_calculator.py:397
#, python-brace-format
msgid "  Underbust in inches = {cm} cm ÷ 2.54 = {inches:.2f} inches"
msgstr ""
"Debajo del busto en pulgadas = {cm} cm ÷ 2,54 = {pulgadas:.2f} pulgadas"

#: Other_Calculators/views/bra_size_calculator.py:400
#, python-brace-format
msgid "  Bust in inches = {cm} cm ÷ 2.54 = {inches:.2f} inches"
msgstr "Busto en pulgadas = {cm} cm ÷ 2,54 = {pulgadas:.2f} pulgadas"

#: Other_Calculators/views/bra_size_calculator.py:405
msgid "Step 3: Calculate Band Size"
msgstr "Paso 3: Calcular el tamaño de la banda"

#: Other_Calculators/views/bra_size_calculator.py:406
#, python-brace-format
msgid ""
"  Band Size = Round underbust ({inches:.2f} inches) to nearest even number"
msgstr ""
"Tamaño de la banda = Bajo busto redondo ({inches:.2f} pulgadas) al número "
"par más cercano"

#: Other_Calculators/views/bra_size_calculator.py:407
#, python-brace-format
msgid "  Band Size = {band}"
msgstr "Tamaño de banda = {band}"

#: Other_Calculators/views/bra_size_calculator.py:410
msgid "Step 4: Calculate Cup Size"
msgstr "Paso 4: Calcular el tamaño de la copa"

#: Other_Calculators/views/bra_size_calculator.py:411
msgid "  Cup Difference = Bust - Band Size"
msgstr "Diferencia de copa = busto - tamaño de banda"

#: Other_Calculators/views/bra_size_calculator.py:412
#, python-brace-format
msgid "  Cup Difference = {bust:.2f} - {band} = {diff:.2f} inches"
msgstr "Diferencia de copa = {busto:.2f} - {band} = {diff:.2f} pulgadas"

#: Other_Calculators/views/bra_size_calculator.py:415
#, python-brace-format
msgid "  Cup Size = {cup} (based on {diff:.2f} inch difference)"
msgstr ""
"Tamaño de copa = {cup} (basado en la diferencia de {diff:.2f} pulgadas)"

#: Other_Calculators/views/bra_size_calculator.py:421
#, python-brace-format
msgid "  Bra Size ({system}): {band}{cup}"
msgstr "Talla de sujetador ({system}): {band}{cup}"

#: Other_Calculators/views/bra_size_calculator.py:471
msgid "Band Size"
msgstr "Tamaño de la banda"

#: Other_Calculators/views/bra_size_calculator.py:517
msgid "Cup Index"
msgstr "Índice de copa"

#: Other_Calculators/views/bra_size_calculator.py:550
msgid "Step 1: Parse Original Size"
msgstr "Paso 1: analizar el tamaño original"

#: Other_Calculators/views/bra_size_calculator.py:551
#: Other_Calculators/views/bra_size_calculator.py:589
#, python-brace-format
msgid "  Original Size: {band}{cup} ({system})"
msgstr "Tamaño original: {band}{cup} ({system})"

#: Other_Calculators/views/bra_size_calculator.py:552
#, python-brace-format
msgid "  Band: {band}"
msgstr "Banda: {band}"

#: Other_Calculators/views/bra_size_calculator.py:553
#, python-brace-format
msgid "  Cup: {cup}"
msgstr "Copa: {cup}"

#: Other_Calculators/views/bra_size_calculator.py:556
msgid "Step 2: Find Cup Index"
msgstr "Paso 2: Encuentra el índice de copas"

#: Other_Calculators/views/bra_size_calculator.py:559
#, python-brace-format
msgid "  Cup '{cup}' is at index {index} in {system} system"
msgstr "La copa '{cup}' está en el índice {index} en el sistema {system}"

#: Other_Calculators/views/bra_size_calculator.py:562
msgid "Step 3: Convert Band Size"
msgstr "Paso 3: convertir el tamaño de la banda"

#: Other_Calculators/views/bra_size_calculator.py:564
#, python-brace-format
msgid "  Converting from FR (cm-based) to {system}"
msgstr "Conversión de FR (basado en cm) a {system}"

#: Other_Calculators/views/bra_size_calculator.py:565
#, python-brace-format
msgid "  Converted Band = {band} - 15 = {converted}"
msgstr "Banda convertida = {band} - 15 = {converted}"

#: Other_Calculators/views/bra_size_calculator.py:567
#, python-brace-format
msgid "  Converting to FR (cm-based) from {system}"
msgstr "Conversión a FR (basado en cm) desde {system}"

#: Other_Calculators/views/bra_size_calculator.py:568
#, python-brace-format
msgid "  Converted Band = {band} + 15 = {converted}"
msgstr "Banda Convertida = {band} + 15 = {converted}"

#: Other_Calculators/views/bra_size_calculator.py:570
#, python-brace-format
msgid "  Band size remains the same: {band}"
msgstr "El tamaño de la banda sigue siendo el mismo: {band}"

#: Other_Calculators/views/bra_size_calculator.py:573
msgid "Step 4: Convert Cup Size"
msgstr "Paso 4: convertir el tamaño de la copa"

#: Other_Calculators/views/bra_size_calculator.py:575
#, python-brace-format
msgid "  Using cup index {index} in {system} system"
msgstr "Usando el índice de copa {index} en el sistema {system}"

#: Other_Calculators/views/bra_size_calculator.py:576
#, python-brace-format
msgid "  Converted Cup = {cup}"
msgstr "Copa Convertida = {cup}"

#: Other_Calculators/views/bra_size_calculator.py:580
#, python-brace-format
msgid "  Converted Size ({system}): {band}{cup}"
msgstr "Tamaño convertido ({system}): {band}{cup}"

#: Other_Calculators/views/bra_size_calculator.py:588
msgid "Step 1: Original Size"
msgstr "Paso 1: Tamaño original"

#: Other_Calculators/views/bra_size_calculator.py:592
msgid "Step 2: Understanding Sister Sizes"
msgstr "Paso 2: comprender los tamaños de las hermanas"

#: Other_Calculators/views/bra_size_calculator.py:593
msgid ""
"  Sister sizes have the same cup volume but different band and cup "
"combinations"
msgstr ""
"Los tamaños hermanos tienen el mismo volumen de copa pero diferentes "
"combinaciones de banda y copa."

#: Other_Calculators/views/bra_size_calculator.py:594
msgid "  When band size increases, cup size decreases (and vice versa)"
msgstr ""
"Cuando el tamaño de la banda aumenta, el tamaño de la copa disminuye (y "
"viceversa)"

#: Other_Calculators/views/bra_size_calculator.py:597
msgid "Step 3: Calculate Sister Sizes"
msgstr "Paso 3: Calcular los tamaños de las hermanas"

#: Other_Calculators/views/bra_size_calculator.py:605
#, python-brace-format
msgid ""
"  {band}{cup}: Band {original} {direction} {offset} = {new_band}, Cup "
"{original_cup} {cup_direction} {offset} = {new_cup}"
msgstr ""
"{band}{cup}: Banda {original} {direction} {offset} = {new_band}, Copa "
"{original_cup} {cup_direction} {offset} = {new_cup}"

#: Other_Calculators/views/bra_size_calculator.py:612
msgid "Step 4: Sister Sizes Found"
msgstr "Paso 4: Se encontraron tamaños de hermanas"

#: Other_Calculators/views/bra_size_calculator.py:614
#, python-brace-format
msgid "  Found {count} sister sizes:"
msgstr "Se encontraron {count} tamaños de hermanas:"

#: Other_Calculators/views/bra_size_calculator.py:616
#, python-brace-format
msgid "    {size}"
msgstr "{size}"

#: Other_Calculators/views/bra_size_calculator.py:618
msgid "  No valid sister sizes found within the valid range"
msgstr "No se encontraron tallas hermanas válidas dentro del rango válido"

