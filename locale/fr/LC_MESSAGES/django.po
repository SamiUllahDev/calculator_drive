msgstr "Calculateur des besoins quotidiens en graisses"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:5
msgid ""
"Calculate your daily fat intake needs based on total calories and macro "
"percentages. Get personalized fat recommendations for your diet."
msgstr ""
"Calculez vos besoins quotidiens en matières grasses en fonction des calories"
" totales et des macro-pourcentages. Obtenez des recommandations "
"personnalisées en matière de matières grasses pour votre alimentation."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:10
msgid ""
"fat intake calculator, fat calculator, daily fat, fat intake, healthy fats"
msgstr ""
"calculateur d'apport en graisses, calculateur de graisses, graisse "
"quotidienne, apport en graisses, graisses saines"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:15
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:24
