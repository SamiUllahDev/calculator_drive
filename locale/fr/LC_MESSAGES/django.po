#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:175
msgid ""
"Enter your total calories and fat percentage to see your daily fat breakdown"
" with meal distribution and food sources."
msgstr ""
"Entrez votre total de calories et votre pourcentage de graisse pour voir "
"votre répartition quotidienne des graisses avec la répartition des repas et "
"les sources de nourriture."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:185
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:408
msgid "Daily Fat Intake"
msgstr "Apport quotidien en graisses"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:196
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/ideal_weight_calculator.html:221
