#: Other_Calculators/views/dew_point_calculator.py:731
#, python-brace-format
msgid "Term 1: (A×Td)/(B+Td) = ({a}×{td})/({b}+{td}) = {term1}"
msgstr "Suku 1: (A×Td)/(B+Td) = ({a}×{td})/({b}+{td}) = {term1}"

#: Other_Calculators/views/dew_point_calculator.py:734
