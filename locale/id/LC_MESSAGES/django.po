msgid "RH = 100 × exp({diff}) = {rh}%"
msgstr "RH = 100 × exp({diff}) = {rh}%"

#: Other_Calculators/views/dew_point_calculator.py:749
msgid "Step 2: Convert dew point to Celsius"
