msgstr ""
"calcolatore dell'aumento di peso in gravidanza, monitoraggio del peso in "
"gravidanza, gravidanza BMI, gravidanza con aumento di peso sano"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:15
msgid ""
"Calculate recommended pregnancy weight gain based on your pre-pregnancy BMI."
msgstr ""
"Calcola l'aumento di peso raccomandato in gravidanza in base al tuo indice "
"di massa corporea pre-gravidanza."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:24
msgid "Calculate recommended pregnancy weight gain based on BMI"
msgstr "Calcola l'aumento di peso raccomandato in gravidanza in base al BMI"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:51
msgid ""
"Calculate recommended pregnancy weight gain based on your pre-pregnancy BMI "
"and track your progress throughout pregnancy."
msgstr ""
"Calcola l'aumento di peso raccomandato in gravidanza in base al tuo indice "
"di massa corporea pre-gravidanza e monitora i tuoi progressi durante la "
"gravidanza."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_weight_gain_calculator.html:65
