#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/calories_burned_calculator.html:352
msgid "Low-impact exercise suitable for all fitness levels."
msgstr "Esercizio a basso impatto adatto a tutti i livelli di fitness."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/calories_burned_calculator.html:357
msgid ""
"MET values: Leisure (6.0), Moderate (8.0), Vigorous (10.0), Butterfly (13.8)"
msgstr ""
