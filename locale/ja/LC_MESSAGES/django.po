msgstr "Kbps: キロビット/秒 (1,000 bps)"

#: Other_Calculators/templates/other_calculators/bandwidth_calculator.html:679
msgid "Mbps: Megabits per second (1,000,000 bps)"
msgstr "Mbps: メガビット/秒 (1,000,000 bps)"

#: Other_Calculators/templates/other_calculators/bandwidth_calculator.html:680
