msgid "Wind chill only applies when temperature is 50°F (10°C) or below."
msgstr "체감온도는 온도가 10°C(50°F) 이하인 경우에만 적용됩니다."

#: Other_Calculators/views/wind_chill_calculator.py:383
#, python-brace-format
msgid "Error calculating wind speed: {error}"
msgstr "풍속 계산 오류: {error}"

#: Other_Calculators/views/wind_chill_calculator.py:392
#: Other_Calculators/views/wind_chill_calculator.py:424
#, python-brace-format
msgid "Wind Speed: {speed} {unit}"
msgstr "풍속: {speed} {unit}"

#: Other_Calculators/views/wind_chill_calculator.py:394
#: Other_Calculators/views/wind_chill_calculator.py:426
#: Other_Calculators/views/wind_chill_calculator.py:454
msgid "Step 2: Convert to standard units"
msgstr "2단계: 표준 단위로 변환"

#: Other_Calculators/views/wind_chill_calculator.py:396
#, python-brace-format
msgid "Temperature in Fahrenheit = ({temp} × 9/5) + 32 = {f}°F"
msgstr "화씨 온도 = ({temp} × 9/5) + 32 = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:398
#: Other_Calculators/views/wind_chill_calculator.py:457
#, python-brace-format
msgid "Temperature in Fahrenheit = {f}°F"
msgstr "화씨 온도 = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:400
#: Other_Calculators/views/wind_chill_calculator.py:430
#, python-brace-format
msgid "Wind Speed in mph = {speed} {unit} = {mph} mph"
msgstr "풍속(mph) = {speed} {unit} = {mph}mph"

#: Other_Calculators/views/wind_chill_calculator.py:402
#, python-brace-format
msgid "Wind Speed in mph = {mph} mph"
msgstr "풍속(mph) = {mph}mph"

#: Other_Calculators/views/wind_chill_calculator.py:404
msgid "Step 3: Apply Wind Chill Index formula"
msgstr "3단계: 체감온도 지수 공식 적용"

#: Other_Calculators/views/wind_chill_calculator.py:405
msgid "Wind Chill = 35.74 + 0.6215×T - 35.75×V^0.16 + 0.4275×T×V^0.16"
msgstr "체감온도 = 35.74 + 0.6215×T - 35.75×V^0.16 + 0.4275×T×V^0.16"

#: Other_Calculators/views/wind_chill_calculator.py:406
msgid "Where T = temperature in °F, V = wind speed in mph"
msgstr "여기서 T = 온도(°F), V = 풍속(mph)"

#: Other_Calculators/views/wind_chill_calculator.py:408
#: Other_Calculators/views/wind_chill_calculator.py:436
#, python-brace-format
msgid "V^0.16 = {v_power}"
msgstr "V^0.16 = {v_power}"

#: Other_Calculators/views/wind_chill_calculator.py:409
#, python-brace-format
msgid ""
"Wind Chill = 35.74 + 0.6215×{temp} - 35.75×{v_power} + "
"0.4275×{temp}×{v_power}"
msgstr ""
"체감온도 = 35.74 + 0.6215×{temp} - 35.75×{v_power} + 0.4275×{temp}×{v_power}"

#: Other_Calculators/views/wind_chill_calculator.py:410
#, python-brace-format
msgid "Wind Chill = {wc}°F"
msgstr "체감온도 = {wc}°F"

