msgstr "Langkah 3: Kira CIDR minimum"

#: Other_Calculators/views/ip_subnet_calculator.py:571
#, python-brace-format
msgid "We need: 2^(32 - CIDR) >= {required}"
msgstr "Kami memerlukan: 2^(32 - CIDR) >= {diperlukan}"

#: Other_Calculators/views/ip_subnet_calculator.py:572
#, python-brace-format
msgid "CIDR = 32 - log2({required}) = {cidr}"
msgstr "CIDR = 32 - log2({diperlukan}) = {cidr}"

