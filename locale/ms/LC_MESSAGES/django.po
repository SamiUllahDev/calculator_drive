msgstr ""
"Nisbah Pergelangan Tangan Kepada Ketinggian = (Lilit Pergelangan Tangan / "
"Tinggi) × 100"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:340
msgid "Small Frame:"
msgstr "Bingkai Kecil:"

