msgstr "Kami memerlukan: 2^(CIDR Baharu - CIDR Asal) >= {diperlukan}"

#: Other_Calculators/views/ip_subnet_calculator.py:590
#, python-brace-format
msgid "New CIDR = Original CIDR + log2({needed})"
msgstr "CIDR Baharu = CIDR Asal + log2({diperlukan})"

