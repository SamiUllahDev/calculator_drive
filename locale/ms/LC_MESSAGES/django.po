msgstr ""
"Bayar hutang sebelum membeli untuk meningkatkan DTI anda dan mendapatkan "
"kadar yang lebih baik."

#: Financial_Calculators/templates/financial_calculators/house_affordability_calculator.html:359
msgid "Keep 3-6 months of expenses in reserves after closing."
msgstr "Simpan 3-6 bulan perbelanjaan dalam rizab selepas ditutup."

