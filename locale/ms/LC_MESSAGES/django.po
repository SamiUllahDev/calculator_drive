msgstr "Penilaian BMI"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/overweight_calculator.html:15
msgid "Calculate BMI and determine if you are overweight."
msgstr "Kira BMI dan tentukan sama ada anda berlebihan berat badan."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/overweight_calculator.html:24
