msgstr "Jumlah Pinjaman Asal"

#: Financial_Calculators/templates/financial_calculators/mortgage_payoff_calculator.html:114
msgid "Original Loan Term"
msgstr "Tempoh Pinjaman Asal"

#: Financial_Calculators/templates/financial_calculators/mortgage_payoff_calculator.html:135
