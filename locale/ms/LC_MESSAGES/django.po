msgstr "Kalkulator Keperluan Karbohidrat Harian"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:5
msgid ""
"Calculate your daily carbohydrate needs based on total calories and macro "
"percentages. Get personalized carb recommendations for your diet."
msgstr ""
"Kira keperluan karbohidrat harian anda berdasarkan jumlah kalori dan "
"peratusan makro. Dapatkan cadangan karbohidrat yang diperibadikan untuk diet"
" anda."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:10
msgid ""
"carbohydrate calculator, carb calculator, daily carbs, carb intake, macro "
"calculator"
msgstr ""
"kalkulator karbohidrat, kalkulator karbohidrat, karbohidrat harian, "
"pengambilan karbohidrat, kalkulator makro"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:15
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:24
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:59
msgid ""
"Calculate your daily carbohydrate needs based on total calories and macro "
