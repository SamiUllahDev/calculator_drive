#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/anorexic_bmi_calculator.html:368
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:344
msgid "Click 'Calculate BMI' to see your results"
msgstr "Klik 'Kira BMI' untuk melihat keputusan anda"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/anorexic_bmi_calculator.html:369
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:345
