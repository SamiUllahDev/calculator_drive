#: Other_Calculators/views/wind_chill_calculator.py:426
#: Other_Calculators/views/wind_chill_calculator.py:454
msgid "Step 2: Convert to standard units"
msgstr "Langkah 2: Tukar kepada unit piawai"

#: Other_Calculators/views/wind_chill_calculator.py:396
#, python-brace-format
msgid "Temperature in Fahrenheit = ({temp} × 9/5) + 32 = {f}°F"
msgstr "Suhu dalam Fahrenheit = ({temp} × 9/5) + 32 = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:398
#: Other_Calculators/views/wind_chill_calculator.py:457
#, python-brace-format
msgid "Temperature in Fahrenheit = {f}°F"
msgstr "Suhu dalam Fahrenheit = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:400
#: Other_Calculators/views/wind_chill_calculator.py:430
#, python-brace-format
msgid "Wind Speed in mph = {speed} {unit} = {mph} mph"
msgstr "Kelajuan Angin dalam mph = {kelajuan} {unit} = {mph} mph"

#: Other_Calculators/views/wind_chill_calculator.py:402
#, python-brace-format
msgid "Wind Speed in mph = {mph} mph"
msgstr "Kelajuan Angin dalam mph = {mph} mph"

#: Other_Calculators/views/wind_chill_calculator.py:404
msgid "Step 3: Apply Wind Chill Index formula"
msgstr "Langkah 3: Gunakan formula Indeks Sejuk Angin"

#: Other_Calculators/views/wind_chill_calculator.py:405
msgid "Wind Chill = 35.74 + 0.6215×T - 35.75×V^0.16 + 0.4275×T×V^0.16"
msgstr "Sejuk Angin = 35.74 + 0.6215×T - 35.75×V^0.16 + 0.4275×T×V^0.16"

#: Other_Calculators/views/wind_chill_calculator.py:406
msgid "Where T = temperature in °F, V = wind speed in mph"
msgstr "Di mana T = suhu dalam °F, V = kelajuan angin dalam mph"

#: Other_Calculators/views/wind_chill_calculator.py:408
#: Other_Calculators/views/wind_chill_calculator.py:436
#, python-brace-format
msgid "V^0.16 = {v_power}"
msgstr "V^0.16 = {v_kuasa}"

#: Other_Calculators/views/wind_chill_calculator.py:409
#, python-brace-format
msgid ""
"Wind Chill = 35.74 + 0.6215×{temp} - 35.75×{v_power} + "
"0.4275×{temp}×{v_power}"
msgstr ""
"Sejuk Angin = 35.74 + 0.6215×{temp} - 35.75×{v_power} + "
"0.4275×{temp}×{v_power}"

#: Other_Calculators/views/wind_chill_calculator.py:410
#, python-brace-format
msgid "Wind Chill = {wc}°F"
msgstr "Sejuk Angin = {wc}°F"

#: Other_Calculators/views/wind_chill_calculator.py:412
#: Other_Calculators/views/wind_chill_calculator.py:440
#: Other_Calculators/views/wind_chill_calculator.py:464
msgid "Step 4: Convert to requested unit"
msgstr "Langkah 4: Tukar kepada unit yang diminta"

#: Other_Calculators/views/wind_chill_calculator.py:414
#, python-brace-format
msgid "Wind Chill in Celsius = ({f} - 32) × 5/9 = {c}°C"
msgstr "Sejuk Angin dalam Celsius = ({f} - 32) × 5/9 = {c}°C"

#: Other_Calculators/views/wind_chill_calculator.py:416
#, python-brace-format
msgid "Wind Chill = {result}°F"
msgstr "Sejuk Angin = {hasil}°F"

#: Other_Calculators/views/wind_chill_calculator.py:423
#: Other_Calculators/views/wind_chill_calculator.py:451
#, python-brace-format
msgid "Wind Chill: {wc}°{unit}"
msgstr "Sejuk Angin: {wc}°{unit}"

#: Other_Calculators/views/wind_chill_calculator.py:428
#, python-brace-format
msgid "Wind Chill in Fahrenheit = ({wc} × 9/5) + 32 = {f}°F"
msgstr "Angin Sejuk dalam Fahrenheit = ({wc} × 9/5) + 32 = {f}°F"

#: Other_Calculators/views/wind_chill_calculator.py:432
msgid "Step 3: Solve for temperature"
msgstr "Langkah 3: Selesaikan untuk suhu"

#: Other_Calculators/views/wind_chill_calculator.py:433
#: Other_Calculators/views/wind_chill_calculator.py:460
msgid "From: WC = 35.74 + 0.6215×T - 35.75×V^0.16 + 0.4275×T×V^0.16"
msgstr "Daripada: WC = 35.74 + 0.6215×T - 35.75×V^0.16 + 0.4275×T×V^0.16"

#: Other_Calculators/views/wind_chill_calculator.py:434
msgid "Solving for T:"
msgstr "Penyelesaian untuk T:"

#: Other_Calculators/views/wind_chill_calculator.py:435
msgid "T = (WC - 35.74 + 35.75×V^0.16) / (0.6215 + 0.4275×V^0.16)"
msgstr "T = (WC - 35.74 + 35.75×V^0.16) / (0.6215 + 0.4275×V^0.16)"

#: Other_Calculators/views/wind_chill_calculator.py:437
#, python-brace-format
msgid "T = ({wc} - 35.74 + 35.75×{v_power}) / (0.6215 + 0.4275×{v_power})"
msgstr "T = ({wc} - 35.74 + 35.75×{v_kuasa}) / (0.6215 + 0.4275×{v_kuasa})"

#: Other_Calculators/views/wind_chill_calculator.py:438
#, python-brace-format
msgid "T = {temp}°F"
msgstr "T = {suhu}°F"

#: Other_Calculators/views/wind_chill_calculator.py:442
#, python-brace-format
msgid "Temperature in Celsius = ({f} - 32) × 5/9 = {c}°C"
msgstr "Suhu dalam Celsius = ({f} - 32) × 5/9 = {c}°C"

#: Other_Calculators/views/wind_chill_calculator.py:444
#, python-brace-format
msgid "Temperature = {result}°F"
msgstr "Suhu = {hasil}°F"

#: Other_Calculators/views/wind_chill_calculator.py:456
#, python-brace-format
msgid "Wind Chill in Fahrenheit = {f}°F"
msgstr "Angin Sejuk dalam Fahrenheit = {f}°F"

