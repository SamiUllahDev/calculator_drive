msgstr "Analyseproviders (om te begrijpen hoe gebruikers omgaan met de site)"

#: core/templates/core/cookie_policy.html:164
msgid "Advertising networks (to deliver relevant advertisements)"
msgstr "Advertentienetwerken (om relevante advertenties te leveren)"

