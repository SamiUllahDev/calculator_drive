msgstr "Jednostka wagi"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:100
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:110
#: Other_Calculators/templates/other_calculators/density_calculator.html:95
#: Other_Calculators/templates/other_calculators/density_calculator.html:169
#: Other_Calculators/templates/other_calculators/density_calculator.html:200
msgid "kg"
msgstr "kg"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:104
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bmi_calculator.html:121
