#: Other_Calculators/templates/other_calculators/bra_size_calculator.html:538
msgid "Calculate Bra Size"
msgstr "Oblicz rozmiar biustonosza"

#: Other_Calculators/templates/other_calculators/bra_size_calculator.html:264
#: Other_Calculators/templates/other_calculators/bra_size_calculator.html:544
#: Other_Calculators/templates/other_calculators/bra_size_calculator.html:945
msgid "Size Conversion"
