#, python-brace-format
msgid "Max Voltage Drop = ({drop}% / 100) × {voltage} = {volts} V"
msgstr "Maksymalny spadek napięcia = ({drop}% / 100) × {napięcie} = {wolty} V"

#: Other_Calculators/views/voltage_drop_calculator.py:463
#, python-brace-format
msgid "Max Voltage Drop = {volts} V"
msgstr "Maksymalny spadek napięcia = {wolt} V"

