#: Other_Calculators/views/dew_point_calculator.py:758
msgid "Formula: T = (B × α) / (A - α)"
msgstr "Wzór: T = (B × α) / (A - α)"

#: Other_Calculators/views/dew_point_calculator.py:756
msgid "Where: α = (A×Td)/(B+Td) - ln(RH/100)"
msgstr "Gdzie: α = (A×Td)/(B+Td) - ln(RH/100)"

