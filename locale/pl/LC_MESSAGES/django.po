#: Other_Calculators/templates/other_calculators/gdp_calculator.html:433
msgid "GDP deflator of 100 means no inflation; above 100 indicates inflation."
msgstr ""
"Deflator PKB wynoszący 100 oznacza brak inflacji; powyżej 100 oznacza "
