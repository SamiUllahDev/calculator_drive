#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:4
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:14
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:189
msgid "Blood Alcohol Content"
msgstr "Zawartość alkoholu we krwi"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:5
msgid ""
"Calculate blood alcohol content (BAC) based on drinks consumed, weight, "
"gender, and time. Estimate when you'll be safe to drive."
msgstr ""
"Oblicz zawartość alkoholu we krwi (BAC) na podstawie spożytych napojów, "
"wagi, płci i czasu. Oszacuj, kiedy będziesz mógł bezpiecznie prowadzić."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:10
msgid ""
"bac calculator, blood alcohol content, alcohol calculator, drunk driving, "
"widmark formula"
msgstr ""
"kalkulator bac, zawartość alkoholu we krwi, kalkulator alkoholu, jazda pod "
"wpływem alkoholu, wzór widmarka"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:15
msgid ""
"Calculate your estimated blood alcohol content using the Widmark formula. "
"Know when it's safe to drive."
msgstr ""
"Oblicz szacunkową zawartość alkoholu we krwi, korzystając ze wzoru Widmarka."
" Dowiedz się, kiedy można bezpiecznie prowadzić."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:24
msgid ""
"Calculate blood alcohol content (BAC) based on drinks consumed, weight, "
"gender, and time."
msgstr ""
"Oblicz zawartość alkoholu we krwi (BAC) na podstawie spożytych napojów, "
"wagi, płci i czasu."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:56
msgid "Blood Alcohol Content Calculator"
msgstr "Kalkulator zawartości alkoholu we krwi"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:59
msgid ""
"Calculate your estimated blood alcohol content (BAC) using the Widmark "
"formula. Know when it's safe to drive."
msgstr ""
"Oblicz szacunkową zawartość alkoholu we krwi (BAC) za pomocą wzoru Widmarka."
" Dowiedz się, kiedy można bezpiecznie prowadzić."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:96
#: Other_Calculators/templates/other_calculators/mulch_calculator.html:339
#: Other_Calculators/templates/other_calculators/weight_calculator.html:132
