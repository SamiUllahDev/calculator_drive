#, python-brace-format
msgid "Term 1: (A×Td)/(B+Td) = ({a}×{td})/({b}+{td}) = {term1}"
msgstr "Wyrażenie 1: (A×Td)/(B+Td) = ({a}×{td})/({b}+{td}) = {term1}"

#: Other_Calculators/views/dew_point_calculator.py:734
#, python-brace-format
msgid "Term 2: (A×T)/(B+T) = ({a}×{t})/({b}+{t}) = {term2}"
msgstr "Wyrażenie 2: (A×T)/(B+T) = ({a}×{t})/({b}+{t}) = {term2}"

#: Other_Calculators/views/dew_point_calculator.py:738
#, python-brace-format
msgid "Difference: {term1} - {term2} = {diff}"
msgstr "Różnica: {term1} - {term2} = {różnica}"

#: Other_Calculators/views/dew_point_calculator.py:739
#, python-brace-format
msgid "RH = 100 × exp({diff}) = {rh}%"
msgstr "RH = 100 × exp({diff}) = {rh}%"

