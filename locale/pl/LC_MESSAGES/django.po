msgid "Calculate target heart rate zones for training"
msgstr "Oblicz docelowe strefy tętna dla treningu"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:51
msgid ""
"Calculate your target heart rate zones for different training intensities. "
"Includes Karvonen method and standard formulas for optimal training."
msgstr ""
"Oblicz docelowe strefy tętna dla różnych intensywności treningu. Obejmuje "
"metodę Karvonena i standardowe formuły dla optymalnego treningu."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:77
msgid "Range: 10-100 years"
msgstr "Zasięg: 10-100 lat"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:82
msgid "Resting Heart Rate"
msgstr "Tętno spoczynkowe"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:89
msgid "Range: 30-120 bpm (measure when fully rested)"
msgstr "Zakres: 30-120 uderzeń na minutę (mierz w stanie pełnego odpoczynku)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:97
msgid "Standard (220 - age)"
msgstr "Standard (220 - wiek)"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:98
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:320
