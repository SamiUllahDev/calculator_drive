msgid "Body Fat Categories"
msgstr "Kategorie tkanki tłuszczowej"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:305
msgid "Your Body Fat vs Ideal Range"
msgstr "Twoja zawartość tkanki tłuszczowej w porównaniu z zakresem idealnym"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_fat_calculator.html:317
