#: Other_Calculators/views/wind_chill_calculator.py:437
#, python-brace-format
msgid "T = ({wc} - 35.74 + 35.75×{v_power}) / (0.6215 + 0.4275×{v_power})"
msgstr "T = ({wc} - 35,74 + 35,75×{v_power}) / (0,6215 + 0,4275×{v_power})"

