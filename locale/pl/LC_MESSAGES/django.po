msgstr "Metoda Karvonena uwzględnia tętno spoczynkowe"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:144
msgid ""
"Enter your age and resting heart rate to see your target heart rate zones "
"for different training intensities."
msgstr ""
"Wprowadź swój wiek i tętno spoczynkowe, aby zobaczyć docelowe strefy tętna "
"dla różnych intensywności treningu."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:154
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:358
msgid "Maximum Heart Rate"
msgstr "Maksymalne tętno"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:156
msgid "Heart Rate Reserve"
msgstr "Rezerwa tętna"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:159
msgid "Resting HR"
msgstr "Odpoczynkowe tętno"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:173
msgid "Tanaka"
msgstr "Tanaka"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/target_heart_rate_calculator.html:178
