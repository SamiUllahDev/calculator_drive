msgstr "Computadores e equipamentos geram calor"

#: Other_Calculators/templates/other_calculators/btu_calculator.html:675
msgid "Insulation Quality and Climate Zones"
msgstr "Qualidade de Isolamento e Zonas Climáticas"

#: Other_Calculators/templates/other_calculators/btu_calculator.html:678
