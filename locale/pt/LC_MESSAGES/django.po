msgstr "Para distância geográfica, insira latitude e longitude em graus"

#: Math_Calculators/templates/math_calculators/distance_calculator.html:466
msgid ""
"For Minkowski distance, enter comma-separated coordinates and the p value"
msgstr ""
"Para a distância de Minkowski, insira as coordenadas separadas por vírgula e"
" o valor p"

