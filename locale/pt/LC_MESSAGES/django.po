msgstr "Desfrute de vantagens atléticas naturais"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:453
msgid "Endomorph Tips"
msgstr "Dicas para endomorfos"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_type_calculator.html:455
msgid "Focus on regular cardio exercise"
msgstr "Concentre-se em exercícios cardiovasculares regulares"

