msgstr "Nova York: (40,7128°N, 74,0060°W), Londres: (51,5074°N, 0,1278°W)"

#: Math_Calculators/templates/math_calculators/distance_calculator.html:515
msgid "Distance: ~5,585 km"
msgstr "Distância: ~5.585 km"

#: Math_Calculators/templates/math_calculators/distance_calculator.html:528
msgid ""
"For geographic distance, latitude must be between -90° and 90°, longitude "
"between -180° and 180°."
msgstr ""
"Para distância geográfica, a latitude deve estar entre -90° e 90°, a "
"longitude entre -180° e 180°."

#: Math_Calculators/templates/math_calculators/distance_calculator.html:534
msgid ""
"For Minkowski distance, both points must have the same number of dimensions."
msgstr ""
"Para a distância de Minkowski, ambos os pontos devem ter o mesmo número de "
"dimensões."

#: Math_Calculators/templates/math_calculators/distance_calculator.html:540
msgid ""
"Euclidean distance is always less than or equal to Manhattan distance for "
"the same points."
msgstr ""
"A distância euclidiana é sempre menor ou igual à distância de Manhattan para"
" os mesmos pontos."

