msgstr "Lånebelopp i dollar"

#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:133
msgid "Loan term"
msgstr "Lånetid"

#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:152
msgid "Extra monthly payment amount"
msgstr "Extra månadsbetalningsbelopp"

#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:182
msgid "Total Payment"
msgstr "Total betalning"

#: Financial_Calculators/templates/financial_calculators/loan_calculator.html:198
#: Financial_Calculators/templates/financial_calculators/mortgage_amortization_calculator.html:261
