msgstr "Rättvis kredit (650–699): 15–20 %% APR"

#: Financial_Calculators/templates/financial_calculators/personal_loan_calculator.html:343
#, python-format
msgid "Poor credit (below 650): 20-36%% APR"
msgstr "Dålig kredit (under 650): 20-36 %% APR"

