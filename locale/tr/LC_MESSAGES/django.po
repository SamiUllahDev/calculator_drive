#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:289
msgid "Chronic Kidney Disease Stages"
msgstr "Kronik Böbrek Hastalığı Aşamaları"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/gfr_calculator.html:295
