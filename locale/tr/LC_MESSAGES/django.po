msgstr "Peşinat yüzdesi"

#: Financial_Calculators/templates/financial_calculators/mortgage_calculator.html:169
msgid "Include Taxes & Costs"
msgstr "Vergileri ve Maliyetleri Dahil Et"

#: Financial_Calculators/templates/financial_calculators/mortgage_calculator.html:178
