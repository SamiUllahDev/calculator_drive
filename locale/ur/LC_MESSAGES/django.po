msgid "New York: (40.7128°N, 74.0060°W), London: (51.5074°N, 0.1278°W)"
msgstr ""
"نیو یارک: (40.7128 ° N ، 74.0060 ° W) ، لندن: (51.5074 ° N ، 0.1278 ° W)"

#: Math_Calculators/templates/math_calculators/distance_calculator.html:515
