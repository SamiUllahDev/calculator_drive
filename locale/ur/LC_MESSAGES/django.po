msgid "Pregnancy Progress"
msgstr "حمل کی پیشرفت"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/conception_calculator.html:234
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/conception_calculator.html:735
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/due_date_calculator.html:234
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/due_date_calculator.html:791
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_calculator.html:301
