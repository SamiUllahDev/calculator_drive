#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:380
#, python-format
msgid "Athletic: 6-14%%"
msgstr "ایتھلیٹک: 6-14 ٪٪"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/lean_body_mass_calculator.html:382
