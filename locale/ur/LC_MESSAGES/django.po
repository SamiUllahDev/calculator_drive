msgid "Current Trimester"
msgstr "موجودہ سہ ماہی"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/conception_calculator.html:248
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/due_date_calculator.html:248
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/pregnancy_conception_calculator.html:424
msgid "Pregnancy Timeline"
msgstr "حمل کی ٹائم لائن"

