#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/macro_calculator.html:205
msgid "Total Daily Calories"
msgstr "کل روزانہ کیلوری"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/carbohydrate_calculator.html:87
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/fat_intake_calculator.html:87
