#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:59
msgid ""
"Calculate body surface area (BSA) using multiple proven formulas including "
"Du Bois, Mosteller, Haycock, and Gehan & George."
msgstr ""
"جسم کی سطح کے رقبے (بی ایس اے) کا حساب لگائیں جس میں ڈو بوئس ، موسٹیلر ، "
"ہائکک ، اور گیہان اینڈ جارج سمیت متعدد ثابت شدہ فارمولوں کا استعمال کیا "
"جائے۔"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:102
msgid "Range: 50-250 cm"
msgstr "حد: 50-250 سینٹی میٹر"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:113
msgid "Range: 1-500 kg"
msgstr "حد: 1-500 کلوگرام"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:121
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:505
msgid "Calculate BSA"
msgstr "بی ایس اے کا حساب لگائیں"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:151
msgid ""
"Enter your height and weight to calculate your Body Surface Area (BSA) using"
" multiple proven formulas."
msgstr ""
"متعدد ثابت شدہ فارمولوں کا استعمال کرتے ہوئے اپنے جسم کی سطح کے رقبے (BSA) "
"کا حساب لگانے کے لئے اپنی اونچائی اور وزن درج کریں۔"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:161
msgid "Average Body Surface Area"
msgstr "اوسطا جسم کی سطح کا رقبہ"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:163
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/ideal_weight_calculator.html:184
msgid "Based on 4 formulas"
msgstr "4 فارمولوں پر مبنی"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:171
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:569
msgid "Du Bois"
msgstr "ڈو بوائس"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:177
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:570
msgid "Mosteller"
msgstr "موسٹیلر"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:183
