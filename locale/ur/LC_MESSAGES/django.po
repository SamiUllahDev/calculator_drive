msgid "lbs"
msgstr "lbs"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:114
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/calories_burned_calculator.html:376
msgid "Enter your body weight"
msgstr "اپنے جسمانی وزن میں داخل ہوں"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:119
msgid "Number of Drinks"
msgstr "مشروبات کی تعداد"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/bac_calculator.html:122
msgid "Standard drinks consumed"
msgstr "معیاری مشروبات کھا گئے"

