msgstr ""
"Chuyển đổi dữ liệu sử dụng cơ sở nhị phân (1024) cho byte, kilobyte, "
"megabyte, v.v."

#: Other_Calculators/templates/other_calculators/conversion_calculator.html:291
msgid "Negative values are only allowed for temperature conversions."
