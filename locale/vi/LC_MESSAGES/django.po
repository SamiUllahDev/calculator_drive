#: venv/lib/python3.12/site-packages/django/views/csrf.py:29
msgid "Forbidden"
msgstr "Cấm"

#: venv/lib/python3.12/site-packages/django/views/csrf.py:30
msgid "CSRF verification failed. Request aborted."
msgstr "Xác minh CSRF không thành công. Yêu cầu bị hủy bỏ."

#: venv/lib/python3.12/site-packages/django/views/csrf.py:34
msgid ""
"You are seeing this message because this HTTPS site requires a “Referer "
"header” to be sent by your web browser, but none was sent. This header is "
"required for security reasons, to ensure that your browser is not being "
"hijacked by third parties."
msgstr ""
"Bạn thấy thông báo này vì trang web HTTPS này yêu cầu phải gửi “Tiêu đề "
"người giới thiệu” bởi trình duyệt web của bạn nhưng không có gì được gửi. "
"Tiêu đề này là bắt buộc vì lý do bảo mật, để đảm bảo rằng trình duyệt của "
"bạn không bị bên thứ ba chiếm quyền điều khiển."

#: venv/lib/python3.12/site-packages/django/views/csrf.py:40
msgid ""
"If you have configured your browser to disable “Referer” headers, please re-"
"enable them, at least for this site, or for HTTPS connections, or for “same-"
"origin” requests."
msgstr ""
"Nếu bạn đã định cấu hình trình duyệt của mình để tắt tiêu đề “Người giới "
"thiệu”, vui lòng bật lại chúng, ít nhất là cho trang web này hoặc cho các "
"kết nối HTTPS hoặc cho các yêu cầu “cùng nguồn gốc”."

#: venv/lib/python3.12/site-packages/django/views/csrf.py:45
msgid ""
"If you are using the <meta name=\"referrer\" content=\"no-referrer\"> tag or"
" including the “Referrer-Policy: no-referrer” header, please remove them. "
"The CSRF protection requires the “Referer” header to do strict referer "
"checking. If you’re concerned about privacy, use alternatives like <a "
"rel=\"noreferrer\" …> for links to third-party sites."
msgstr ""
"Nếu bạn đang sử dụng thẻ <meta name=\"referrer\" content=\"no-referrer\"> "
"hoặc bao gồm tiêu đề “Referrer-Policy: no-referrer”, vui lòng xóa chúng. "
"Việc bảo vệ CSRF yêu cầu tiêu đề \"Người giới thiệu\" để thực hiện kiểm tra "
"người giới thiệu một cách nghiêm ngặt. Nếu bạn lo ngại về quyền riêng tư, "
"hãy sử dụng các lựa chọn thay thế như <a rel=\"noreferrer\" …> cho các liên "
"kết đến trang web của bên thứ ba."

#: venv/lib/python3.12/site-packages/django/views/csrf.py:54
msgid ""
"You are seeing this message because this site requires a CSRF cookie when "
"submitting forms. This cookie is required for security reasons, to ensure "
"that your browser is not being hijacked by third parties."
msgstr ""
"Bạn thấy thông báo này vì trang web này yêu cầu cookie CSRF khi gửi biểu "
"mẫu. Cookie này là bắt buộc vì lý do bảo mật, để đảm bảo rằng trình duyệt "
"của bạn không bị bên thứ ba chiếm quyền điều khiển."

#: venv/lib/python3.12/site-packages/django/views/csrf.py:60
msgid ""
"If you have configured your browser to disable cookies, please re-enable "
"them, at least for this site, or for “same-origin” requests."
msgstr ""
"Nếu bạn đã định cấu hình trình duyệt của mình để tắt cookie, vui lòng bật "
"lại chúng, ít nhất là đối với trang web này hoặc đối với các yêu cầu “cùng "
"nguồn gốc”."

#: venv/lib/python3.12/site-packages/django/views/csrf.py:66
msgid "More information is available with DEBUG=True."
msgstr "Thông tin thêm có sẵn với DEBUG=True."

