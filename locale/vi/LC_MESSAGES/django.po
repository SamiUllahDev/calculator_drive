msgstr ""
"Tính diện tích bề mặt cơ thể (BSA) bằng nhiều công thức đã được chứng minh."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:59
msgid ""
"Calculate body surface area (BSA) using multiple proven formulas including "
"Du Bois, Mosteller, Haycock, and Gehan & George."
msgstr ""
"Tính diện tích bề mặt cơ thể (BSA) bằng nhiều công thức đã được chứng minh "
"bao gồm Du Bois, Mosteller, Haycock và Gehan & George."

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:102
msgid "Range: 50-250 cm"
msgstr "Phạm vi: 50-250 cm"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:113
