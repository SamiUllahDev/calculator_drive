msgstr "Máy tính lương hưu - Tính trợ cấp hưu trí"

#: Financial_Calculators/templates/financial_calculators/pension_calculator.html:7
msgid ""
"Calculate your pension benefits for defined benefit plans. Compare lump sum "
"vs annuity options and evaluate service credit purchases."
