msgstr "Tính toán bê tông"

#: Other_Calculators/templates/other_calculators/concrete_calculator.html:510
msgid "Concrete Volume Required"
msgstr "Khối lượng bê tông yêu cầu"

#: Other_Calculators/templates/other_calculators/concrete_calculator.html:518
