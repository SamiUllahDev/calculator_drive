#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:4
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:280
msgid "US Army Body Fat Standards"
msgstr "Tiêu chuẩn mỡ cơ thể của quân đội Hoa Kỳ"

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:5
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:27
msgid ""
"Calculate body fat percentage using US Army measurement standards. Check if "
"you meet Army body fat requirements."
msgstr ""
