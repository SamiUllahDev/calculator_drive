msgid ""
"Enter your gross monthly income (before taxes). Add any additional monthly "
"income if needed."
msgstr ""

#: Financial_Calculators/templates/financial_calculators/rent_calculator.html:259
msgid ""
"Enter your monthly debt payments: car, student loans, credit cards, other."
msgstr ""

#: Financial_Calculators/templates/financial_calculators/rent_calculator.html:260
#, python-format
msgid "Choose a rent budget rule (e.g. 30%%) and estimated utilities."
msgstr ""

#: Financial_Calculators/templates/financial_calculators/rent_calculator.html:261
msgid ""
"Click Calculate to see recommended rent, breakdown chart, and rent by "
"guideline."
msgstr ""

#: Financial_Calculators/templates/financial_calculators/rent_calculator.html:262
msgid ""
"Use the table and charts to compare conservative vs maximum rent levels."
msgstr ""

