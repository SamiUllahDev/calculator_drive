#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:399
msgid "US Army Body Fat Formula"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:402
msgid "For Males:"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/army_body_fat_calculator.html:403
#, python-format
msgid ""
"Body Fat %% = 86.010 × log10(waist - neck) - 70.041 × log10(height) + 36.76"
