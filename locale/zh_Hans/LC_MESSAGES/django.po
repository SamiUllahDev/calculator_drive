msgstr ""

#: Other_Calculators/templates/other_calculators/horsepower_calculator.html:210
msgid "• 200 HP at 6000 RPM → (200 × 5252) / 6000 = 175.07 ft-lb"
msgstr ""

#: Other_Calculators/templates/other_calculators/horsepower_calculator.html:211
msgid "• 150 HP = 111.86 kW = 111,855 W"
