#: Financial_Calculators/templates/financial_calculators/rmd_calculator.html:315
msgid "Formulas & SECURE Act 2.0"
msgstr ""

#: Financial_Calculators/templates/financial_calculators/rmd_calculator.html:316
msgid ""
"RMD = Prior year-end balance ÷ life expectancy factor (IRS Uniform Lifetime "
"Table). SECURE Act 2.0: Born 1950 or earlier start at 72; 1951–1959 at 73; "
"1960+ at 75. Deadline: December 31 each year (first RMD can delay to April 1 "
"of next year, but then two RMDs that year)."
msgstr ""

#: Financial_Calculators/templates/financial_calculators/rmd_calculator.html:317
#, python-format
