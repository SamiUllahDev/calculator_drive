#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:181
msgid "Full Circle (360°)"
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:181
msgid ""
"Maximum flare and twirl. Uses most fabric. Great for dance skirts and formal "
"wear."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:182
msgid "¾ Circle (270°)"
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:182
msgid ""
"Beautiful drape with less bulk. Requires one seam. Nice compromise between "
"fullness and practicality."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:183
msgid "Half Circle (180°)"
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:183
msgid ""
"Moderate flare, very wearable. Uses about half the fabric of a full circle. "
"Perfect for everyday."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:184
msgid "¼ Circle / A-Line (90°)"
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:184
msgid ""
"Minimal flare, classic A-line. Most fabric-efficient and easy to sew. Needs "
"two panels."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:188
msgid "Sewing Tips"
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:190
msgid "Always cut on the bias (diagonal grain) for the best drape."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:191
msgid ""
"Let the skirt hang for 24 hours before hemming — bias-cut fabric stretches."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:192
msgid ""
"Use a narrow hem (rolled or baby hem) for the smoothest finish on curved "
"edges."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:193
msgid "Add 1-2 inches to length if using stretchy fabric."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:194
msgid ""
"Add a separate straight-grain waistband rather than folding the circle "
"fabric."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:200
msgid ""
"Seam allowance is added to the waist circumference before calculating the "
"radius."
msgstr ""

#: Other_Calculators/templates/other_calculators/circle_skirt_calculator.html:201
