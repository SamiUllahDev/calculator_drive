#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:300
msgid "Additive Rule"
msgstr ""

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:301
msgid ""
"When a smaller or equal symbol follows a larger one, add the values. "
"Example: VI = 5 + 1 = 6"
msgstr ""

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:304
msgid "Subtractive Rule"
msgstr ""

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:305
msgid ""
"When a smaller symbol precedes a larger one, subtract the smaller. Example: "
"IV = 5 - 1 = 4. Only I, X, and C can be subtracted."
msgstr ""

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:308
msgid "Repetition Rule"
msgstr ""

#: Other_Calculators/templates/other_calculators/roman_numeral_converter.html:309
msgid ""
"I, X, C, and M can be repeated up to 3 times consecutively. V, L, and D are "
"never repeated. Example: III = 3, but IIII is invalid."
msgstr ""

