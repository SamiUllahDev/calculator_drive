msgid "Click 'Calculate Ovulation' to see your predicted ovulation date"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/ovulation_calculator.html:311
msgid "Review your fertile window (the best days for conception)"
msgstr ""

