#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:254
msgid "What is Body Surface Area (BSA)?"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:256
msgid ""
"Body Surface Area (BSA) is the total surface area of the human body. It's "
"measured in square meters (m²) and is used in various medical applications, "
"particularly for calculating drug dosages, determining cardiac index, and "
"assessing metabolic rate."
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:259
msgid ""
"BSA provides a more accurate measure than body weight alone for many medical "
"calculations, as it accounts for both height and weight, giving a better "
"representation of body size."
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:265
msgid "BSA Calculation Formulas"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:268
msgid "Du Bois Formula (1916)"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:270
msgid ""
"One of the oldest and most widely used formulas. Considered the gold "
"standard."
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:273
msgid "BSA = 0.007184 × weight^0.425 × height^0.725"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:276
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:300
#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:312
msgid "Where weight is in kg and height is in cm"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:280
msgid "Mosteller Formula (1987)"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:282
msgid ""
"Simplified formula, easy to remember and calculate. Commonly used in "
"clinical practice."
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:285
msgid "BSA = √((height × weight) / 3600)"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:288
msgid "Where height is in cm and weight is in kg"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:292
msgid "Haycock Formula (1978)"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:294
msgid ""
"Developed specifically for pediatric populations but also accurate for "
"adults."
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:297
msgid "BSA = 0.024265 × weight^0.5378 × height^0.3964"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:304
msgid "Gehan & George Formula (1970)"
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:306
msgid ""
"Another commonly used formula, particularly in oncology and chemotherapy "
"dosing."
msgstr ""

#: Fitness_and_Health_Calculators/templates/fitness_and_health_calculators/body_surface_area_calculator.html:309
msgid "BSA = 0.0235 × weight^0.51456 × height^0.42246"
